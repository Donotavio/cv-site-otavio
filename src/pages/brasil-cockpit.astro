    border-top: 1px solid var(--line);
    margin: 0;
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    .ck-cat--chart .ck-cat__cards { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<!-- ════════════════════════════════════════════════════════════
     SCRIPT 1 — motion do conteúdo estático (mesmo padrão do radar)
     ════════════════════════════════════════════════════════════ -->
<script>
  import { revealUp }     from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  // astro:page-load (não DOMContentLoaded): dispara no 1º load E após cada
  // navegação SPA do <ClientRouter />. O guard #ck-hero garante que só roda
  // nesta página (o listener no document persiste entre navegações).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('ck-hero')) return;
    const heroCard = document.querySelector('.hero-card');
    if (heroCard && motionOk) revealUp([heroCard], heroCard, 0);

    // Para cada seção: head + line + items estáticos
    const sections = ['painel', 'briefing', 'detalhe', 'leitura', 'pipeline', 'meta-stack', 'metodologia'];
    sections.forEach((id) => {
      const sec = document.getElementById(id);
      if (!sec) return;
      const head = sec.querySelector('.section-head');
      const line = sec.querySelector('.section-line');
      if (line) hairlineDraw(line, sec);
      if (motionOk && head) revealUp([head], sec, 0);
    });

    // Itens estáticos por seção (não hidratados — recebem stagger)
    const leitura = document.getElementById('leitura');
    if (leitura && motionOk) {
      const callouts = leitura.querySelectorAll('.ck-callout');
      if (callouts.length) revealUp(callouts, leitura, STAGGER.normal);
    }

    const pipeline = document.getElementById('pipeline');
    if (pipeline && motionOk) {
      const cards = pipeline.querySelectorAll('.arch-card');
      const auto = pipeline.querySelector('.arch-automation');
      if (cards.length) revealUp(cards, pipeline, STAGGER.tight);
      if (auto) revealUp([auto], pipeline, 0);
    }

    const meta = document.getElementById('meta-stack');
    if (meta && motionOk) {
      const items = meta.querySelectorAll('.radar-meta-item');
      if (items.length) revealUp(items, meta, STAGGER.tight);
    }

    const method = document.getElementById('metodologia');
    if (method && motionOk) {
      const items = method.querySelectorAll('.radar-methodology-item');
      if (items.length) revealUp(items, method, STAGGER.normal);
    }
  });
</script>

<!-- ════════════════════════════════════════════════════════════
     SCRIPT 2 — fetch runtime dos dados + render (charts vanilla SVG)
     ════════════════════════════════════════════════════════════ -->
<script>
  /**
   * cockpit.json + historico.json → hero, status strip, IPCA band chart,
   * briefing (bento), detalhe por categoria (com mini-charts) e callouts.
   * Um par de fetches (AbortController + 8s timeout), reaproveitado por
   * todas as renderizações — mesmo padrão de data-stack-radar-br.astro.
   * Falha graciosa: estado "dados indisponíveis", nunca crash.
   */
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { revealUp } from '../scripts/motion/reveal-up';
  import { countUp } from '../scripts/motion/count-up';
  import { DURATIONS, EASINGS, STAGGER, motionOk } from '../scripts/motion/constants';

  // ScrollTrigger já é registrado pelos módulos de motion, mas registrar aqui
  // também torna este script autônomo e autodocumentado (idempotente).
  gsap.registerPlugin(ScrollTrigger);

  type CkStatus = 'verde' | 'amarelo' | 'vermelho' | 'neutro';
  type CkTrend  = 'alta' | 'baixa' | 'estavel';

  interface CkKpi {
    kpi_id: string;
    label: string;
    unit: string;
    category: string;
    frequency: string;
    description: string;
    data_referencia: string;
    valor_atual: number;
    valor_anterior: number;
    delta_abs: number;
    delta_pct: number;
    status: CkStatus | string;
    trend: CkTrend | string;
    meta: number | null;
    banda: number | null;
    direction: string | null;
    threshold_trend: number | null;
  }
  interface CkPayload {
    gerado_em: string;
    categorias: Record<string, string>;
    category_order: string[];
    kpis: CkKpi[];
  }
  interface HistPoint { data_referencia: string; valor: number; }
  interface HistPayload {
    gerado_em: string;
    janela_anos: number;
    series: Record<string, HistPoint[]>;
  }

  const STATUS_LABELS: Record<string, string> = {
    verde: 'Verde', amarelo: 'Amarelo', vermelho: 'Vermelho', neutro: 'Neutro',
  };
  const STATUS_ORDER: CkStatus[] = ['verde', 'amarelo', 'vermelho', 'neutro'];

  // ── Formatação pt-BR ───────────────────────────────────────
  function numFmt(opts: Intl.NumberFormatOptions, v: number): string {
    return new Intl.NumberFormat('pt-BR', opts).format(v);
  }

  /** Formata o número conforme a unidade (PTAX usa 4 casas; pts, 0). */
  function formatValue(valor: number, unit: string): string {
    if (unit === 'pts') return numFmt({ maximumFractionDigits: 0 }, valor);
    if (unit === 'R$')  return numFmt({ minimumFractionDigits: 4, maximumFractionDigits: 4 }, valor);
    if (unit.startsWith('US$')) return numFmt({ minimumFractionDigits: 2, maximumFractionDigits: 2 }, valor);
    return numFmt({ minimumFractionDigits: 2, maximumFractionDigits: 2 }, valor);
  }

  /** Decompõe valor+unidade em (símbolo pré, número, sufixo) para layout. */
  function decomposeValueUnit(valor: number, unit: string): { pre: string; num: string; post: string } {
    const n = formatValue(valor, unit);
    if (unit === 'R$') return { pre: 'R$', num: n, post: '' };
    if (unit === 'US$ bi') return { pre: 'US$', num: n, post: 'bi' };
    if (unit.startsWith('US$')) return { pre: 'US$', num: n, post: unit.slice(3).trim() };
    return { pre: '', num: n, post: unit };
  }

  /** Delta: seta da tendência + valor percentual assinado. */
  function formatDelta(deltaPct: number, trend: string): string {
    const arrow = trend === 'alta' ? '▲' : trend === 'baixa' ? '▼' : '→';
    const sign = deltaPct > 0 ? '+' : '';
    const val = numFmt({ minimumFractionDigits: 2, maximumFractionDigits: 2 }, deltaPct);
    return `${arrow} ${sign}${val}%`;
  }

  /** Formata mês/ano curto pt-BR (ago/2021). */
  function formatMonthShort(iso: string): string {
    const d = new Date(iso + '-01');
    if (Number.isNaN(d.getTime())) return iso;
    return new Intl.DateTimeFormat('pt-BR', { month: 'short', year: 'numeric' })
      .format(d).replace('.', '');
  }

  function formatGeradoEm(iso: string): string {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    const date = new Intl.DateTimeFormat('pt-BR', {
      day: '2-digit', month: 'short', year: 'numeric',
    }).format(d);
    const time = new Intl.DateTimeFormat('pt-BR', {
      hour: '2-digit', minute: '2-digit', hour12: false,
      timeZone: 'America/Sao_Paulo',
    }).format(d);
    return `${date} · ${time} BRT`;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  /** Sufixo de unidade legível para labels de gráfico (% → %, % PIB → % PIB). */
  function unitSuffix(unit: string): string {
    if (unit === '%') return '%';
    if (unit === '% PIB') return '% PIB';
    if (unit === '% a.a.') return '%';
    return '';
  }

  // ══════════════════════════════════════════════════════════
  // SPARKLINE — SVG vanilla, sem eixos. ~120×36 (default) ou wide (banner).
  // ══════════════════════════════════════════════════════════
  const SPARK_W = 120, SPARK_H = 36, SPARK_PAD = 4;

  /** Reduz a série a ≤maxN pontos (stride) — séries diárias têm 504 pts. */
  function downsample(pts: number[], maxN = 48): number[] {
    if (pts.length <= maxN) return pts;
    const stride = pts.length / maxN;
    const out: number[] = [];
    for (let i = 0; i < maxN; i++) out.push(pts[Math.floor(i * stride)]);
    out.push(pts[pts.length - 1]);
    return out;
  }

  /** SVG markup de um sparkline, sem eixos. Stroke = --ck-*-ink por status. */
  function sparkline(points: number[], status: string, wide = false): string {
    const W = wide ? 480 : SPARK_W;
    const H = wide ? 72 : SPARK_H;
    const PAD = wide ? 6 : SPARK_PAD;
    const pts = downsample(points.filter((p) => Number.isFinite(p)), wide ? 96 : 48);
    if (pts.length < 2) {
      return `<span class="ck-spark ck-spark--ph" aria-hidden="true">—</span>`;
    }
    const min = Math.min(...pts);
    const max = Math.max(...pts);
    const range = max - min || 1;
    const n = pts.length;
    const stepX = (W - PAD * 2) / (n - 1);
    const usableH = H - PAD * 2;
    const coords = pts.map((v, i) => {
      const x = PAD + i * stepX;
      const y = PAD + (1 - (v - min) / range) * usableH;
      return `${x.toFixed(2)},${y.toFixed(2)}`;
    });
    return `<svg class="ck-spark" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" preserveAspectRatio="none" role="img" aria-hidden="true">
      <polyline class="ck-spark__line ck-spark__line--${escapeHtml(status)}" points="${coords.join(' ')}" />
    </svg>`;
  }

  // ══════════════════════════════════════════════════════════
  // NICE TICKS — algoritmo de "nice numbers" para eixos limpos.
  // ══════════════════════════════════════════════════════════
  function niceNum(range: number, round: boolean): number {
    const exp = Math.floor(Math.log10(range));
    const frac = range / Math.pow(10, exp);
    let nf: number;
    if (round) {
      if (frac < 1.5) nf = 1; else if (frac < 3) nf = 2; else if (frac < 7) nf = 5; else nf = 10;
    } else {
      if (frac <= 1) nf = 1; else if (frac <= 2) nf = 2; else if (frac <= 5) nf = 5; else nf = 10;
    }
    return nf * Math.pow(10, exp);
  }

  /** Retorna { ticks[], niceMax } com ~n intervalos arredondados (Heckbert). */
  function niceTicks(min: number, max: number, n = 5): { ticks: number[]; niceMax: number } {
    if (max <= min) max = min + 1;
    const rawRange = max - min;
    // step direto do range bruto (não arredonda o range antes) → ticks mais
    // justos: IPCA vira 0-12 (step 2) em vez de 0-15 (step 5).
    const step = niceNum(rawRange / (n - 1), true);
    const niceMax = Math.ceil(max / step) * step;
    const ticks: number[] = [];
    for (let v = 0; v <= niceMax + step * 0.5; v += step) ticks.push(Math.round(v * 100) / 100);
    return { ticks, niceMax };
  }

  // ══════════════════════════════════════════════════════════
  // bandChart — GRÁFICO DE BANDA DE META (vanilla SVG inline).
  // Reutilizado por §1 (IPCA, ~720×280) e §3 (dívida bruta, ~360×140).
  //
  // Zonas de status empilhadas no eixo Y:
  //   baixo_melhor: verde [0,meta] · amarelo [meta,teto] · vermelho [teto,ymax]
  //   alto_melhor: vermelho [0,teto] · amarelo [teto,meta] · verde [meta,ymax]
  // onde teto = meta ± banda (limite onde começa o vermelho).
  //
  // Linhas tracejadas de meta + teto com label mono à direita.
  // Grade temporal: linhas verticais de ano. Série como <polyline> stroke --ink.
  // Marcador do valor atual = <circle> fill --ck-{status}-ink + label tabular.
  // ══════════════════════════════════════════════════════════
  interface BandChartOpts {
    series: HistPoint[];
    meta: number;
    banda: number;
    direction: string;
    status: string;
    unit: string;
    size?: 'lg' | 'mini';
    ariaLabel: string;
  }

  function bandChart(opts: BandChartOpts): string {
    const { series, meta, banda, direction, status, unit, ariaLabel } = opts;
    const mini = opts.size === 'mini';
    if (!series || series.length < 2) {
      return `<p class="ck-error mono-label">série indisponível</p>`;
    }

    const isLow = direction === 'baixo_melhor';
    const teto = isLow ? meta + banda : meta - banda; // limite vermelho
    const suf = unitSuffix(unit);

    // Geometria
    const W = mini ? 360 : 720;
    const H = mini ? 160 : 300;
    const PAD = mini
      ? { l: 38, r: 14, t: 12, b: 26 }
      : { l: 52, r: 44, t: 20, b: 40 };
    const plotW = W - PAD.l - PAD.r;
    const plotH = H - PAD.t - PAD.b;

    // Escala Y com nice ticks
    const vals = series.map((p) => p.valor).filter((v) => Number.isFinite(v));
    const seriesMax = Math.max(...vals);
    const thrHi = isLow ? teto : meta;
    const rawMax = Math.max(seriesMax, thrHi) * 1.1;
    const { ticks, niceMax } = niceTicks(0, rawMax, mini ? 4 : 5);
    const yMax = niceMax;
    const yMin = 0;
    const yRange = yMax - yMin || 1;

    const xAt = (i: number) => PAD.l + (i / (series.length - 1)) * plotW;
    const yAt = (v: number) => PAD.t + (1 - (v - yMin) / yRange) * plotH;

    const fmtTick = (v: number) => {
      const dec = yMax > 20 ? 0 : (v % 1 === 0 ? 0 : 1);
      return numFmt({ minimumFractionDigits: dec, maximumFractionDigits: dec }, v) + suf;
    };

    // Zonas de status (rects preenchidos)
    const zoneRect = (lo: number, hi: number, fill: string) =>
      `<rect class="ck-band-zone" x="${PAD.l}" y="${yAt(hi).toFixed(2)}" width="${plotW}" height="${(yAt(lo) - yAt(hi)).toFixed(2)}" fill="${fill}" />`;

    let zones: string;
    if (isLow) {
      zones =
        zoneRect(0, meta, 'var(--ck-verde-dim)') +
        zoneRect(meta, teto, 'var(--ck-amarelo-dim)') +
        zoneRect(teto, yMax, 'var(--ck-vermelho-dim)');
    } else {
      zones =
        zoneRect(0, teto, 'var(--ck-vermelho-dim)') +
        zoneRect(teto, meta, 'var(--ck-amarelo-dim)') +
        zoneRect(meta, yMax, 'var(--ck-verde-dim)');
    }

    // Thresholds tracejados + labels à direita
    const thr = (val: number, label: string, lineVar: string) => {
      const yy = yAt(val);
      return `<line class="ck-band-thr" x1="${PAD.l}" y1="${yy.toFixed(2)}" x2="${W - PAD.r}" y2="${yy.toFixed(2)}" stroke="var(${lineVar})" />` +
        `<text class="ck-band-thrlabel" x="${W - PAD.r + 4}" y="${(yy + 3).toFixed(2)}" text-anchor="start">${label}</text>`;
    };
    const metaLabel = `meta ${numFmt({ minimumFractionDigits: 1, maximumFractionDigits: 1 }, meta)}${suf}`;
    const tetoLabel = `teto ${numFmt({ minimumFractionDigits: 1, maximumFractionDigits: 1 }, teto)}${suf}`;
    const thresholds =
      thr(meta, metaLabel, '--ck-amarelo-line') +
      thr(teto, tetoLabel, '--ck-vermelho-line');

    // Grade temporal: linhas de ano + labels
    const yearMarks: { i: number; yr: string }[] = [];
    let lastYear = '';
    series.forEach((p, i) => {
      const yr = (p.data_referencia || '').slice(0, 4);
      if (yr && yr !== lastYear) {
        yearMarks.push({ i, yr });
        lastYear = yr;
      }
    });
    // Evita label duplicado no extremo direito se o ano muda no último ponto
    const yearLines = yearMarks.map(({ i, yr }) => {
      const xx = xAt(i);
      return `<line class="ck-band-yearline" x1="${xx.toFixed(2)}" y1="${PAD.t}" x2="${xx.toFixed(2)}" y2="${H - PAD.b}" />` +
        `<text class="ck-band-yearlabel" x="${xx.toFixed(2)}" y="${H - PAD.b + 14}" text-anchor="middle">${escapeHtml(yr)}</text>`;
    }).join('');

    // Ticks Y
    const tickEls = ticks.map((v) => {
      const yy = yAt(v);
      return `<line class="ck-band-tickline" x1="${PAD.l - 4}" y1="${yy.toFixed(2)}" x2="${PAD.l}" y2="${yy.toFixed(2)}" />` +
        `<text class="ck-band-ticklabel" x="${PAD.l - 6}" y="${(yy + 3).toFixed(2)}" text-anchor="end">${fmtTick(v)}</text>`;
    }).join('');

    // Série histórica
    const ptsStr = series.map((p, i) => `${xAt(i).toFixed(2)},${yAt(p.valor).toFixed(2)}`).join(' ');
    const line = `<polyline class="ck-band-line" points="${ptsStr}" />`;

    // Marcador do valor atual
    const last = series[series.length - 1];
    const cx = xAt(series.length - 1);
    const cy = yAt(last.valor);
    const valStr = numFmt({ minimumFractionDigits: 2, maximumFractionDigits: 2 }, last.valor) + suf;
    const marker =
      `<circle class="ck-band-marker" cx="${cx.toFixed(2)}" cy="${cy.toFixed(2)}" r="4" fill="var(--ck-${escapeHtml(status)}-ink)" />` +
      `<text class="ck-band-markerval" x="${(cx - 8).toFixed(2)}" y="${(cy - 10).toFixed(2)}" text-anchor="end" fill="var(--ck-${escapeHtml(status)}-ink)">${valStr}</text>`;

    return `<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" role="img" aria-label="${escapeHtml(ariaLabel)}">
      ${zones}${thresholds}${yearLines}${tickEls}${line}${marker}
    </svg>`;
  }

  // ══════════════════════════════════════════════════════════
  // trendChart — 2 séries sobrepostas + linha de zero (vanilla SVG).
  // Usado em §3 (Setor externo: exportações × importações).
  // ══════════════════════════════════════════════════════════
  interface TrendChartOpts {
    a: HistPoint[];        // série primária (exportações) — stroke --ink
    b: HistPoint[];        // série secundária (importações) — stroke --ink-soft
    aLabel: string;
    bLabel: string;
    unit: string;
    ariaLabel: string;
  }

  function trendChart(opts: TrendChartOpts): string {
    const { a, b, aLabel, bLabel, ariaLabel } = opts;
    if (!a || !b || a.length < 2 || b.length < 2) {
      return `<p class="ck-error mono-label">série indisponível</p>`;
    }
    const W = 360, H = 160;
    const PAD = { l: 38, r: 14, t: 24, b: 26 };
    const plotW = W - PAD.l - PAD.r;
    const plotH = H - PAD.t - PAD.b;

    // Alinha séries pelo mesmo comprimento (mesma janela temporal)
    const n = Math.min(a.length, b.length);
    const aS = a.slice(a.length - n);
    const bS = b.slice(b.length - n);

    const allVals = [...aS.map((p) => p.valor), ...bS.map((p) => p.valor)].filter(Number.isFinite);
    const seriesMax = Math.max(...allVals, 0);
    const { ticks, niceMax } = niceTicks(0, seriesMax * 1.1, 4);
    const yMax = niceMax;
    const suf = unitSuffix(opts.unit);

    const xAt = (i: number) => PAD.l + (i / (n - 1)) * plotW;
    const yAt = (v: number) => PAD.t + (1 - v / yMax) * plotH;
    const fmtTick = (v: number) => numFmt({ maximumFractionDigits: 0 }, v) + suf;

    // Grade temporal (anos)
    const yearMarks: { i: number; yr: string }[] = [];
    let lastYear = '';
    aS.forEach((p, i) => {
      const yr = (p.data_referencia || '').slice(0, 4);
      if (yr && yr !== lastYear) { yearMarks.push({ i, yr }); lastYear = yr; }
    });
    const yearLines = yearMarks.map(({ i, yr }) => {
      const xx = xAt(i);
      return `<line class="ck-band-yearline" x1="${xx.toFixed(2)}" y1="${PAD.t}" x2="${xx.toFixed(2)}" y2="${H - PAD.b}" />` +
        `<text class="ck-band-yearlabel" x="${xx.toFixed(2)}" y="${H - PAD.b + 14}" text-anchor="middle">${escapeHtml(yr)}</text>`;
    }).join('');

    // Ticks Y
    const tickEls = ticks.map((v) => {
      const yy = yAt(v);
      return `<line class="ck-band-tickline" x1="${PAD.l - 4}" y1="${yy.toFixed(2)}" x2="${PAD.l}" y2="${yy.toFixed(2)}" />` +
        `<text class="ck-band-ticklabel" x="${PAD.l - 6}" y="${(yy + 3).toFixed(2)}" text-anchor="end">${fmtTick(v)}</text>`;
    }).join('');

    // Linha de zero (baseline de referência)
    const zeroLine = `<line class="ck-trend-zeroline" x1="${PAD.l}" y1="${yAt(0).toFixed(2)}" x2="${W - PAD.r}" y2="${yAt(0).toFixed(2)}" />`;

    // Séries
    const aPts = aS.map((p, i) => `${xAt(i).toFixed(2)},${yAt(p.valor).toFixed(2)}`).join(' ');
    const bPts = bS.map((p, i) => `${xAt(i).toFixed(2)},${yAt(p.valor).toFixed(2)}`).join(' ');
    const aLine = `<polyline class="ck-trend-line" points="${aPts}" stroke="var(--ink)" />`;
    const bLine = `<polyline class="ck-trend-line" points="${bPts}" stroke="var(--ink-soft)" stroke-dasharray="3 3" />`;

    // Legenda inline (topo)
    const legend =
      `<text class="ck-trend-axislabel" x="${PAD.l}" y="12"><tspan fill="var(--ink)">━</tspan> ${escapeHtml(aLabel)}</text>` +
      `<text class="ck-trend-axislabel" x="${W / 2}" y="12"><tspan fill="var(--ink-soft)">┄</tspan> ${escapeHtml(bLabel)}</text>`;

    return `<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" role="img" aria-label="${escapeHtml(ariaLabel)}">
      ${yearLines}${tickEls}${zeroLine}${bLine}${aLine}${legend}
    </svg>`;
  }

  // ══════════════════════════════════════════════════════════
  // SIGNATURE — o band chart "se desenha" ao entrar no viewport.
  // O único momento coreografado da página (web-motion.md: one
  // signature device). Sequência (≤ DURATIONS.entrance / 1.4s):
  //   1. zonas de status fade in staggered — DOM order já é
  //      verde→amarelo→vermelho (= bottom→top no baixo_melhor)
  //   2. thresholds tracejados + labels fade
  //   3. <polyline> IPCA desenha via stroke-dashoffset (sem DrawSVG)
  //   4. <circle> do valor atual escala por último (scale 0→1)
  //
  // Coordenação com hidratação: o SVG é montado por bandChart() via
  // innerHTML em renderIpcaChart(); revealBandChart() é chamado logo
  // após, então todos os alvos já existem no DOM.
  //
  // Acessibilidade: reduced-motion → retorna antes de esconder nada;
  // o chart segue totalmente visível como renderizado por bandChart().
  // Apenas transform/opacity animados (web-motion.md guardrails).
  // ══════════════════════════════════════════════════════════
  function revealBandChart(svg: SVGSVGElement): void {
    if (!motionOk) return;

    const zones = svg.querySelectorAll<SVGElement>('.ck-band-zone');
    const thresholds = svg.querySelectorAll<SVGElement>('.ck-band-thr, .ck-band-thrlabel');
    const polyline = svg.querySelector<SVGGeometryElement>('.ck-band-line');
    const marker = svg.querySelector<SVGCircleElement>('.ck-band-marker');
    const markerVal = svg.querySelector<SVGTextElement>('.ck-band-markerval');

    // Estados iniciais escondidos — só quando motion está on. Reduced-motion
    // mantém o SVG inteiro visível (já renderizado por bandChart).
    gsap.set(zones, { opacity: 0 });
    gsap.set(thresholds, { opacity: 0 });
    if (polyline) {
      const len = polyline.getTotalLength();
      gsap.set(polyline, { strokeDasharray: len, strokeDashoffset: len });
    }
    if (marker) gsap.set(marker, { scale: 0, transformOrigin: 'center' });
    if (markerVal) gsap.set(markerVal, { opacity: 0 });

    const run = () => {
      const tl = gsap.timeline();
      // 1) zonas fade in staggered (DOM order = verde→amarelo→vermelho)
      tl.to(zones, {
        opacity: 1,
        duration: DURATIONS.fast,
        ease: EASINGS.out,
        stagger: STAGGER.tight,
      });
      // 2) thresholds tracejados + labels fade
      tl.to(thresholds, {
        opacity: 1,
        duration: DURATIONS.fast,
        ease: EASINGS.out,
      }, 0.2);
      // 3) polyline IPCA desenha (dash trick); clearProps garante estado final limpo
      if (polyline) tl.to(polyline, {
        strokeDashoffset: 0,
        duration: DURATIONS.slow,
        ease: EASINGS.out,
        onComplete: () => gsap.set(polyline, { clearProps: 'strokeDasharray,strokeDashoffset' }),
      }, 0.15);
      // 4) marcador do valor atual escala por último (back.out não está no
      //    vocabulário → expo.out, mesmo easing premium do resto da página)
      if (marker) tl.to(marker, {
        scale: 1,
        duration: DURATIONS.fast,
        ease: EASINGS.out,
      }, 0.9);
      if (markerVal) tl.to(markerVal, {
        opacity: 1,
        duration: DURATIONS.fast,
        ease: EASINGS.out,
      }, 0.9);
    };

    // Já-visível no load → dispara já (mesma lógica de count-up.ts /
    // meter-sweep.ts: ScrollTrigger não dispara confiavelmente para
    // elementos que já passaram do start no carregamento).
    const rect = svg.getBoundingClientRect();
    const alreadyVisible = rect.top < window.innerHeight * 0.8 && rect.bottom > 0;

    if (alreadyVisible) {
      run();
      return;
    }

    ScrollTrigger.create({
      trigger: svg,
      start: 'top 80%',
      once: true,
      onEnter: run,
    });
  }

  // ══════════════════════════════════════════════════════════
  // CARD MARKUP
  // ══════════════════════════════════════════════════════════

  /** StatusCard compacto (detalhe por categoria + briefing secundário). */
  function statusCard(kpi: CkKpi, hist: HistPayload | null, size: 'lg' | 'md'): string {
    const status = String(kpi.status ?? 'neutro');
    const statusLabel = STATUS_LABELS[status] ?? escapeHtml(status);
    const series = hist?.series?.[kpi.kpi_id] ?? [];
    const pts = series.map((p) => p.valor);
    const spark = sparkline(pts, status);
    const { pre, num, post } = decomposeValueUnit(kpi.valor_atual, kpi.unit);
    const delta = formatDelta(kpi.delta_pct, String(kpi.trend ?? 'estavel'));
    const sizeCls = size === 'lg' ? ' ck-card--lg' : '';

    const metaBits: string[] = [];
    if (kpi.meta != null && kpi.banda != null) {
      const metaStr = formatValue(kpi.meta, kpi.unit);
      metaBits.push(`<span class="ck-card__meta-bit">meta ${metaStr} ± ${formatValue(kpi.banda, kpi.unit)}</span>`);
    }
    metaBits.push(`<span class="ck-card__meta-bit">ref. ${escapeHtml(kpi.data_referencia)}</span>`);

    return `<article class="ck-card${sizeCls}" role="listitem" data-status="${escapeHtml(status)}" data-kpi-id="${escapeHtml(kpi.kpi_id)}">
      <div class="ck-card__top">
        <span class="ck-status ck-status--${escapeHtml(status)}">${statusLabel}</span>
        <span class="ck-card__label">${escapeHtml(kpi.label)}</span>
      </div>
      <div class="ck-card__value">
        ${pre ? `<span class="ck-card__cur">${escapeHtml(pre)}</span>` : ''}
        <span class="ck-card__num">${escapeHtml(num)}</span>
        ${post ? `<span class="ck-card__unit">${escapeHtml(post)}</span>` : ''}
      </div>
      <span class="ck-card__delta">${escapeHtml(delta)}</span>
      ${spark}
      <div class="ck-card__meta">${metaBits.join('')}</div>
    </article>`;
  }

  /** IPCA banner (briefing dominante): display-2 + status chip + wide sparkline. */
  function briefingBanner(kpi: CkKpi, hist: HistPayload | null): string {
    const status = String(kpi.status ?? 'neutro');
    const statusLabel = STATUS_LABELS[status] ?? escapeHtml(status);
    const series = hist?.series?.[kpi.kpi_id] ?? [];
    const pts = series.map((p) => p.valor);
    const spark = sparkline(pts, status, true);
    const { pre, num, post } = decomposeValueUnit(kpi.valor_atual, kpi.unit);
    const delta = formatDelta(kpi.delta_pct, String(kpi.trend ?? 'estavel'));

    const metaBits: string[] = [];
    if (kpi.meta != null && kpi.banda != null) {
      metaBits.push(`meta ${formatValue(kpi.meta, kpi.unit)} ± ${formatValue(kpi.banda, kpi.unit)}`);
    }
    metaBits.push(`ref. ${escapeHtml(kpi.data_referencia)}`);

    return `<article class="ck-banner" role="listitem" data-status="${escapeHtml(status)}" data-kpi-id="${escapeHtml(kpi.kpi_id)}">
      <div class="ck-banner__top">
        <span class="ck-status ck-status--${escapeHtml(status)}">${statusLabel}</span>
        <span class="ck-card__label">${escapeHtml(kpi.label)}</span>
      </div>
      <div class="ck-banner__body">
        <div class="ck-banner__main">
          <span class="ck-banner__value">
            ${pre ? `<span class="ck-banner__cur">${escapeHtml(pre)}</span>` : ''}
            <span class="ck-banner__num">${escapeHtml(num)}</span>
            ${post ? `<span class="ck-banner__unit">${escapeHtml(post)}</span>` : ''}
          </span>
          <span class="ck-banner__delta">${escapeHtml(delta)}</span>
          <span class="ck-banner__meta">${metaBits.join(' · ')}</span>
        </div>
        <div class="ck-banner__spark">${spark}</div>
      </div>
    </article>`;
  }

  // ══════════════════════════════════════════════════════════
  // RENDER — hero
  // ══════════════════════════════════════════════════════════
  function renderHero(data: CkPayload): void {
    const geradoEl = document.getElementById('ck-hero-gerado');
    if (geradoEl) geradoEl.textContent = formatGeradoEm(data.gerado_em);

    const summaryEl = document.getElementById('ck-hero-summary');
    if (!summaryEl) return;

    const counts: Record<string, number> = { verde: 0, amarelo: 0, vermelho: 0, neutro: 0 };
    data.kpis.forEach((k) => {
      const s = String(k.status ?? 'neutro');
      if (s in counts) counts[s] += 1;
    });
    const total = data.kpis.length;
    const sumFmt = (n: number) => numFmt({ maximumFractionDigits: 0 }, n);

    summaryEl.innerHTML = `
      <span>${sumFmt(total)} indicadores</span>
      <span aria-hidden="true">·</span>
      <span style="color: var(--ck-verde-ink)">${sumFmt(counts.verde)} verde</span>
      <span aria-hidden="true">·</span>
      <span style="color: var(--ck-amarelo-ink)">${sumFmt(counts.amarelo)} amarelo</span>
      <span aria-hidden="true">·</span>
      <span style="color: var(--ck-vermelho-ink)">${sumFmt(counts.vermelho)} vermelho</span>
      <span aria-hidden="true">·</span>
      <span style="color: var(--ck-neutro-ink)">${sumFmt(counts.neutro)} neutro</span>`;
  }

  // ══════════════════════════════════════════════════════════
  // RENDER — status strip (§1 header) + IPCA band chart
  // ══════════════════════════════════════════════════════════
  function renderStatusStrip(data: CkPayload): void {
    const counts: Record<string, number> = { verde: 0, amarelo: 0, vermelho: 0, neutro: 0 };
    data.kpis.forEach((k) => {
      const s = String(k.status ?? 'neutro');
      if (s in counts) counts[s] += 1;
    });

    const section = document.getElementById('painel');

    STATUS_ORDER.forEach((st) => {
      const chip = document.querySelector<HTMLLIElement>(`.ck-strip-chip[data-status="${st}"]`);
      if (!chip) return;
      // countUp só escreve o número; o prefixo "Verde · " fica como texto.
      // countUp trata reduced-motion (escreve o valor final na hora).
      chip.innerHTML = `${STATUS_LABELS[st]} · <span class="ck-strip-count" data-count-to="${counts[st]}" data-count-decimals="0">0</span>`;
      const countEl = chip.querySelector<HTMLElement>('.ck-strip-count');
      if (countEl) countUp(countEl, section ?? chip);
    });
  }

  function renderIpcaChart(data: CkPayload, hist: HistPayload | null): void {
    const wrap = document.getElementById('ck-ipca-chart');
    if (!wrap) return;
    const ipca = data.kpis.find((k) => k.kpi_id === 'ipca_12m');
    const series = hist?.series?.['ipca_12m'] ?? [];
    if (!ipca || !series.length || ipca.meta == null || ipca.banda == null) {
      wrap.innerHTML = '<p class="ck-error mono-label">série IPCA indisponível</p>';
      return;
    }

    const status = String(ipca.status ?? 'neutro');
    const first = series[0];
    const last = series[series.length - 1];
    const aria = `IPCA acumulado em 12 meses de ${formatMonthShort(first.data_referencia)} a ${formatMonthShort(last.data_referencia)}; ${formatValue(last.valor, ipca.unit)} em ${formatMonthShort(last.data_referencia)}, acima do teto de ${numFmt({ minimumFractionDigits: 1, maximumFractionDigits: 1 }, (ipca.meta as number) + (ipca.banda as number))}% — status ${status}.`;

    wrap.innerHTML = `<div class="ck-chart-wrap">${bandChart({
      series,
      meta: ipca.meta as number,
      banda: ipca.banda as number,
      direction: String(ipca.direction ?? 'baixo_melhor'),
      status,
      unit: ipca.unit,
      size: 'lg',
      ariaLabel: aria,
    })}</div>`;

    // SIGNATURE: o chart "se desenha" — chamado só após o SVG estar no DOM
    // (innerHTML acima), coordenando motion com a hidratação.
    const svg = wrap.querySelector<SVGSVGElement>('svg');
    if (svg) revealBandChart(svg);
  }

  // ══════════════════════════════════════════════════════════
  // RENDER — briefing (bento: IPCA banner + 3 secundários)
  // ══════════════════════════════════════════════════════════
  const BRIEFING_SECONDARY = ['selic', 'desocupacao', 'cambio_usd'];

  function renderBriefing(data: CkPayload, hist: HistPayload | null): void {
    const grid = document.getElementById('ck-briefing-grid');
    if (!grid) return;
    const byId = new Map(data.kpis.map((k) => [k.kpi_id, k]));

    const ipca = byId.get('ipca_12m');
    if (!ipca) {
      grid.innerHTML = '<p class="ck-error mono-label" style="grid-column: 1 / -1">dados do briefing indisponíveis</p>';
      return;
    }

    const banner = briefingBanner(ipca, hist);
    const secondaryKpis = BRIEFING_SECONDARY
      .map((id) => byId.get(id))
      .filter((k): k is CkKpi => Boolean(k));
    const secondary = secondaryKpis.map((k) => statusCard(k, hist, 'lg'));

    grid.innerHTML = banner + secondary.join('');

    // Big values contam de 0 (banner + 3 secundários). Decimais casam com a
    // formatação de unidade (R$ PTAX usa 4; pts, 0; demais, 2) para o valor
    // final do countUp ser idêntico ao renderizado. countUp cuida do
    // reduced-motion (escreve o valor final sem animar).
    const section = document.getElementById('briefing');
    const briefingKpis = [ipca, ...secondaryKpis];
    const nums = grid.querySelectorAll<HTMLElement>('.ck-banner__num, .ck-card__num');
    nums.forEach((numEl, i) => {
      const kpi = briefingKpis[i];
      if (!kpi) return;
      numEl.dataset.countTo = String(kpi.valor_atual);
      numEl.dataset.countDecimals =
        kpi.unit === 'R$' ? '4' : kpi.unit === 'pts' ? '0' : '2';
      countUp(numEl, section ?? numEl);
    });

    if (motionOk && section) {
      revealUp(grid.querySelectorAll('.ck-banner, .ck-card'), section, STAGGER.normal);
    }
  }

  // ══════════════════════════════════════════════════════════
  // RENDER — detalhe por categoria (12 KPIs em 6 grupos; 2 com mini-chart)
  // ══════════════════════════════════════════════════════════
  /** KPIs que viram chart (não ganham card próprio — estão no gráfico). */
  const CHARTED_KPIS = new Set(['exportacoes_fob', 'importacoes_fob', 'divida_bruta']);

  function renderDetalhe(data: CkPayload, hist: HistPayload | null): void {
    const root = document.getElementById('ck-detalhe');
    if (!root) return;
    const order = data.category_order ?? [];
    const labels = data.categorias ?? {};

    const groups = order.map((cat) => {
      const kpis = data.kpis.filter((k) => k.category === cat);
      if (!kpis.length) return '';
      const label = labels[cat] ?? escapeHtml(cat);
      const count = numFmt({ maximumFractionDigits: 0 }, kpis.length);

      // Setor externo → trendChart (exportações × importações) + companion cards
      if (cat === 'externo') {
        const exp = hist?.series?.['exportacoes_fob'] ?? [];
        const imp = hist?.series?.['importacoes_fob'] ?? [];
        const chartable = exp.length > 1 && imp.length > 1;
        const companionKpis = kpis.filter((k) => !CHARTED_KPIS.has(k.kpi_id));
        const cards = companionKpis.map((k) => statusCard(k, hist, 'md')).join('');
        const chartBlock = chartable
          ? `<div class="ck-cat__chart">
              <span class="mono-label ck-cat__chart-label">exportações × importações · US$ bi FOB</span>
              <div class="ck-chart-wrap ck-chart-wrap--mini">${trendChart({
                a: exp, b: imp,
                aLabel: 'Exportações', bLabel: 'Importações',
                unit: 'US$ bi',
                ariaLabel: 'Exportações e importações mensais (US$ bi FOB) — exportações acima de importações indicam superávit comercial.',
              })}</div>
            </div>`
          : '';
        return `<div class="ck-cat ck-cat--chart" data-cat="${escapeHtml(cat)}">
          <div class="ck-cat__head">
            <h3 class="ck-cat__title">${escapeHtml(label)}</h3>
            <span class="ck-cat__count">${count} ${kpis.length === 1 ? 'indicador' : 'indicadores'}</span>
          </div>
          ${chartBlock}
          <div class="ck-cat__cards" role="list" aria-label="${escapeHtml(label)}">${cards}</div>
        </div>`;
      }

      // Fiscal → bandChart (dívida bruta) + companion (resultado primário)
      if (cat === 'fiscal') {
        const divida = data.kpis.find((k) => k.kpi_id === 'divida_bruta');
        const primario = data.kpis.find((k) => k.kpi_id === 'resultado_primario');
        const dSeries = hist?.series?.['divida_bruta'] ?? [];
        const chartable = divida && dSeries.length > 1 && divida.meta != null && divida.banda != null;
        const companionKpis = kpis.filter((k) => !CHARTED_KPIS.has(k.kpi_id));
        const cards = companionKpis.map((k) => statusCard(k, hist, 'md')).join('');
        // Readout mono compacto: pequeno texto qualitativo derivado do
        // valor (não do status, que é Só verde/amarelo) — preenche o void
        // abaixo do companion card "órfão" (1 card só no rail direito).
        const readout = primario
          ? (() => {
              const v = primario.valor_atual;
              const qualit = Math.abs(v) < 0.5 ? 'equilíbrio'
                : v >= 0 ? 'superávit primário'
                : 'déficit primário';
              return `<p class="ck-cat__readout mono-label">primário ${formatValue(v, primario.unit)} PIB · ${qualit}</p>`;
            })()
          : '';
        const chartBlock = (chartable && divida)
          ? `<div class="ck-cat__chart">
              <span class="mono-label ck-cat__chart-label">dívida bruta do governo geral · % do PIB</span>
              <div class="ck-chart-wrap ck-chart-wrap--mini">${bandChart({
                series: dSeries,
                meta: (divida as CkKpi).meta as number,
                banda: (divida as CkKpi).banda as number,
                direction: String((divida as CkKpi).direction ?? 'baixo_melhor'),
                status: String((divida as CkKpi).status ?? 'neutro'),
                unit: (divida as CkKpi).unit,
                size: 'mini',
                ariaLabel: `Dívida bruta do governo geral (% do PIB); ${formatValue((divida as CkKpi).valor_atual, (divida as CkKpi).unit)} no último ponto, meta ${formatValue((divida as CkKpi).meta as number, (divida as CkKpi).unit)} ± ${formatValue((divida as CkKpi).banda as number, (divida as CkKpi).unit)}.`,
              })}</div>
            </div>`
          : '';
        return `<div class="ck-cat ck-cat--chart" data-cat="${escapeHtml(cat)}">
          <div class="ck-cat__head">
            <h3 class="ck-cat__title">${escapeHtml(label)}</h3>
            <span class="ck-cat__count">${count} ${kpis.length === 1 ? 'indicador' : 'indicadores'}</span>
          </div>
          ${chartBlock}
          <div class="ck-cat__cards" role="list" aria-label="${escapeHtml(label)}">${cards}${readout}</div>
        </div>`;
      }

      // Demais categorias → lista compacta de cards.
      // count-aware: 1 KPI → single col (32rem); 2 → pair (52rem); 3+ → grid 3 col.
      const cards = kpis.map((k) => statusCard(k, hist, 'md')).join('');
      const gridMod = kpis.length === 1 ? ' ck-grid--single'
        : kpis.length === 2 ? ' ck-grid--pair' : '';
      return `<div class="ck-cat" data-cat="${escapeHtml(cat)}">
        <div class="ck-cat__head">
          <h3 class="ck-cat__title">${escapeHtml(label)}</h3>
          <span class="ck-cat__count">${count} ${kpis.length === 1 ? 'indicador' : 'indicadores'}</span>
        </div>
        <div class="ck-grid${gridMod}" role="list" aria-label="${escapeHtml(label)}">${cards}</div>
      </div>`;
    }).filter(Boolean);

    if (!groups.length) {
      root.innerHTML = '<p class="ck-error mono-label">dados por categoria indisponíveis</p>';
      const statusEl = document.getElementById('ck-detalhe-status');
      if (statusEl) statusEl.textContent = 'Detalhe por categoria indisponível.';
      return;
    }
    root.innerHTML = groups.join('');
    // Live region dedicada (sr-only, sibling de #ck-detalhe): anuncia apenas
    // um resumo curto, não a swap inteira do grid — SR não fica "narrando"
    // todos os cards. Node externo sobrevive ao innerHTML acima.
    const statusEl = document.getElementById('ck-detalhe-status');
    if (statusEl) statusEl.textContent = `Detalhe carregado: ${groups.length} categorias, ${data.kpis.length} indicadores.`;

    if (motionOk) {
      const section = document.getElementById('detalhe');
      const cats = root.querySelectorAll('.ck-cat');
      if (section && cats.length) revealUp(cats, section, STAGGER.normal);
    }
  }

  // ══════════════════════════════════════════════════════════
  // RENDER — callouts (§4: juro real + contas públicas), valores derivados
  // ══════════════════════════════════════════════════════════
  function renderCallouts(data: CkPayload): void {
    const byId = new Map(data.kpis.map((k) => [k.kpi_id, k]));
    const selic = byId.get('selic');
    const ipca = byId.get('ipca_12m');
    const primario = byId.get('resultado_primario');
    const divida = byId.get('divida_bruta');

    const setText = (selector: string, text: string) => {
      document.querySelectorAll(selector).forEach((el) => { el.textContent = text; });
    };

    if (selic) setText('[data-ck-kpi="selic"]', formatValue(selic.valor_atual, selic.unit) + (selic.unit === '% a.a.' ? '' : ''));
    if (ipca)  setText('[data-ck-kpi="ipca_12m"]', formatValue(ipca.valor_atual, ipca.unit) + '%');

    // Juro real ≈ Selic − IPCA (aproximação ex-ante simples)
    if (selic && ipca) {
      const real = selic.valor_atual - ipca.valor_atual;
      const realStr = numFmt({ minimumFractionDigits: 1, maximumFractionDigits: 1 }, real) + '%';
      setText('[data-ck-real]', realStr);
    }

    if (primario) setText('[data-ck-kpi="resultado_primario"]', formatValue(primario.valor_atual, primario.unit) + '%');
    if (divida)   setText('[data-ck-kpi="divida_bruta"]', formatValue(divida.valor_atual, divida.unit));
  }

  // ══════════════════════════════════════════════════════════
  // ORQUESTRAÇÃO — fetch cockpit + historico
  // ══════════════════════════════════════════════════════════
  async function loadCockpit(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    const get = async (path: string): Promise<Response> =>
      fetch(path, { cache: 'no-cache', signal: controller.signal });

    try {
      const [ckRes, histRes] = await Promise.all([
        get(`${base}assets/data/cockpit.json`),
        get(`${base}assets/data/historico.json`),
      ]);
      clearTimeout(timeoutId);
      if (!ckRes.ok) throw new Error('cockpit fetch failed');

      const data: CkPayload = await ckRes.json();
      // historico é opcional — sparklines/charts só somem se ele falhar
      let hist: HistPayload | null = null;
      if (histRes.ok) {
        try { hist = (await histRes.json()) as HistPayload; } catch { hist = null; }
      }

      renderHero(data);
      renderStatusStrip(data);
      renderIpcaChart(data, hist);
      renderBriefing(data, hist);
      renderDetalhe(data, hist);
      renderCallouts(data);
      // #detalhe ficou bem mais alto após o innerHTML (cards + charts);
      // recalcula os ScrollTriggers das seções abaixo para dispararem na
      // posição correta (leitura, etc.).
      ScrollTrigger.refresh();
    } catch {
      clearTimeout(timeoutId);
      // Estado gracioso: nunca crash
      const geradoEl = document.getElementById('ck-hero-gerado');
      if (geradoEl) geradoEl.textContent = 'indisponível';
      const summaryEl = document.getElementById('ck-hero-summary');
      if (summaryEl) summaryEl.innerHTML = '<span class="ck-error mono-label">dados indisponíveis — tente recarregar</span>';
      const briefingGrid = document.getElementById('ck-briefing-grid');
      if (briefingGrid) briefingGrid.innerHTML = '<p class="ck-error mono-label" style="grid-column: 1 / -1">dados do briefing indisponíveis</p>';
      const detalhe = document.getElementById('ck-detalhe');
      if (detalhe) detalhe.innerHTML = '<p class="ck-error mono-label">dados por categoria indisponíveis</p>';
      const ipcaChart = document.getElementById('ck-ipca-chart');
      if (ipcaChart) ipcaChart.innerHTML = '<p class="ck-error mono-label">série IPCA indisponível</p>';
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('ck-hero')) return;
    loadCockpit();
  });
</script>
