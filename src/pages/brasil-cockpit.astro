    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--paper-card);
    color: var(--ink-soft);
    font-variant-numeric: var(--num-tabular);
  }
  .ck-strip-chip::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    background: var(--ck-neutro);
  }
  .ck-strip-chip[data-status='verde'] {
    color: var(--ck-verde-ink);
    border-color: var(--ck-verde-line);
    background: var(--ck-verde-dim);
  }
  .ck-strip-chip[data-status='verde']::before { background: var(--ck-verde); }
  .ck-strip-chip[data-status='amarelo'] {
    color: var(--ck-amarelo-ink);
    border-color: var(--ck-amarelo-line);
    background: var(--ck-amarelo-dim);
  }
  .ck-strip-chip[data-status='amarelo']::before { background: var(--ck-amarelo); }
  .ck-strip-chip[data-status='vermelho'] {
    color: var(--ck-vermelho-ink);
    border-color: var(--ck-vermelho-line);
    background: var(--ck-vermelho-dim);
  }
  .ck-strip-chip[data-status='vermelho']::before { background: var(--ck-vermelho); }
  .ck-strip-chip[data-status='neutro'] {
    color: var(--ck-neutro-ink);
    border-color: var(--ck-neutro-line);
    background: var(--ck-neutro-dim);
  }
  .ck-strip-chip[data-status='neutro']::before { background: var(--ck-neutro); }

  /* ── Chart wrapper (band + trend) ─────────────────────────── */
  .ck-chart-wrap {
    width: 100%;
    overflow-x: auto;
  }
  .ck-chart-wrap svg {
    display: block;
    width: 100%;
    height: auto;
    min-width: 480px;
  }
  .ck-chart-wrap--mini svg {
    min-width: 280px;
  }

  /* Elementos SVG do bandChart / trendChart — uso de var() via style attr
     não é confiável em todos os renderizadores; classes garantem. */
  .ck-band-zone      { stroke: none; }
  .ck-band-thr       { stroke-width: 1; stroke-dasharray: 4 4; fill: none; }
  .ck-band-thrlabel,
  .ck-band-yearlabel,
  .ck-band-ticklabel {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-faint);
  }
  .ck-band-thrlabel { fill: var(--ink-soft); }
  .ck-band-yearline { stroke: var(--line); stroke-width: 1; }
  .ck-band-tickline { stroke: var(--line-strong); stroke-width: 1; }
  .ck-band-line {
    fill: none;
    stroke: var(--ink);
    stroke-width: 1.5;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }
  .ck-band-marker      { stroke: var(--paper-card); stroke-width: 1.5; }
  .ck-band-markerval   {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    font-variant-numeric: var(--num-tabular);
  }

  .ck-trend-line {
    fill: none;
    stroke-width: 1.5;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }
  .ck-trend-zeroline { stroke: var(--line-strong); stroke-width: 1; }
