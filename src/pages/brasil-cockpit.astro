  /* Grid compacto (categorias sem chart).
     Modificadores count-aware para não deixar cells vazias: 1 KPI →
     1 coluna estreita; 2 KPIs → par centralizado; 3+ → 3 colunas default. */
  .ck-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-inline: auto;
  }
  @media (min-width: 640px) {
    .ck-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1024px) {
    .ck-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  /* Single-KPI cats (juros, emprego, financeiro): 1 coluna, largura travada
     para não esticar o card solitário em monitores largos. */
  .ck-grid--single {
    grid-template-columns: 1fr;
    max-width: 32rem;
  }
  /* Pair cats (precos): 2 colunas centralizadas, sem a terceira cell vazia. */
  .ck-grid--pair {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 52rem;
  }

  /* Categoria com mini-chart: head full-width no topo, [chart | cards] em
     baixo. .ck-cat--chart é um grid de 2 cols (≥1024px); se .ck-cat__head
     ficar como item direto sem span, ela ocupa só col 1, chart vai p/ col 2
     e as cards wrap p/ row 2 — alinhamento destruído (bug original).
     Gap = space-4 (não space-5): a head agora tem border-block-end, e o
     row-gap soma com a padding-block-end da head — space-4 mantém o ritmo
     "rule → 16px → content" igual às cats sem chart. */
  .ck-cat--chart {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .ck-cat--chart { grid-template-columns: 1.25fr 1fr; }
  }
  /* Head atravessa todas as cols: row 1 = head cheio,
     row 2 = [chart | cards] lado a lado. Auto-placement põe chart em
     (2,1) e cards em (2,2). margin-block-end: 0 porque o row-gap do grid
     (var(--space-4)) já separa head do conteúdo — sem isso, somava
     space-3 (padding da head) + space-4 (margin) + space-4 (gap) vs
     space-3 (padding) + space-4 (gap) nas cats sem chart. */
  .ck-cat--chart > .ck-cat__head {
    grid-column: 1 / -1;
    margin-block-end: 0;
  }
  .ck-cat__chart {
    position: relative;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-self: center; /* chart ~240px contra rail de cards ~660px: centraliza
                            o chart na row para dividir o void acima/abaixo em
                            vez de deixá-lo top-pinned ("montado" vs "flutuando").
                            Parent mantém align-items: start. */
  }
  .ck-cat__chart-label {
    color: var(--ink-faint);
  }
  .ck-cat__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-content: start; /* companion cards bunch no topo do rail direito,
                              sem esticar mesmo se o chart for alto */
  }
  /* Readout mono de uma linha (companion card "órfão", ex.: resultado
     primário ao lado do chart de dívida). Mesma anatomia do .ck-callout__stat
     (§4): texto ink-soft, num tabular, divisor --line em cima. Sem hex.
     grid-column: 1 / -1 garante que ele sempre caia abaixo do companion,
     nunca ao lado (em tablet .ck-cat__cards vira 2 cols). */
  .ck-cat__readout {
