  .wc-bracket-side__matches { display: flex; flex-direction: column; justify-content: space-around; gap: var(--space-2); flex: 1; }
  .wc-bracket-tree__center { display: flex; flex-direction: column; gap: var(--space-3); align-self: center; padding: 0 var(--space-2); }
