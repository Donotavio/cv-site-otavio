  @media (prefers-reduced-motion: reduce) { .wc-skeleton { animation: none; } }
  .wc-skeleton-card { display: block; padding: 0; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--paper-card); overflow: hidden; min-height: 88px; }
  .wc-skeleton-card > .wc-skeleton { border-radius: 0; }

  /* ════════════════ Filtro "minha seleção" + highlight/dim ════════════════ */
  .wc-team-filter { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-5); background: var(--paper-soft); border-bottom: 1px solid var(--line); }
  @media (min-width: 640px)  { .wc-team-filter { padding-inline: var(--space-8); } }
  @media (min-width: 1024px) { .wc-team-filter { padding-inline: var(--space-12); } }
  .wc-team-filter__label { color: var(--ink-faint); flex-shrink: 0; }
  .wc-team-filter__chips { display: flex; flex-wrap: wrap; gap: var(--space-2); min-width: 0; }
  .wc-team-chip { display: inline-flex; align-items: center; gap: var(--space-1); padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-full); cursor: pointer; transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast); }
  .wc-team-chip:hover { border-color: var(--wc-field-line); color: var(--wc-field-ink); }
