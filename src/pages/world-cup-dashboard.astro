  @media (prefers-reduced-motion: reduce) {
    :global(.wc-jumpnav__bullet), :global(.wc-jumpnav__label), :global(.wc-jumpnav-fab), :global(.wc-jumpnav-fab__icon span), :global(.wc-jumpnav-backdrop) { transition: none !important; }
  }
