---
/**
 * world-cup-dashboard.astro — Dashboard da Copa do Mundo 2026 (Fase 1 · esqueleto)
 * ================================================================================
 * Prova de ponta-a-ponta da migração do painel estático `public/world-cup-dashboard/`
 * para dentro do Astro, seguindo o MESMO padrão das páginas-irmãs
 * (pix-observatory / data-stack-radar-br / brasil-cockpit / eleicoes-2026).
 *
 * Escopo desta fase — TRÊS seções, validando o ciclo completo antes de portar as
 * outras 16 do painel legado:
 *   0. Hero + KPIs (#wc-hero)      — count-up compartilhado (src/scripts/motion/count-up)
 *   1. [01] Artilharia (#artilheiros) — tabela top-10 (dado artilheiros.json)
 *   2. [02] Estatísticas (#estatisticas) — UM doughnut via a nova lib SVG
 *      (src/scripts/worldcup/charts → doughnutChart), gols 1º vs 2º tempo.
 *
 * Paleta: família World Cup APENAS — `--wc-field*` / `--wc-gold*` / `--wc-live*`
 * (+ rampa neutra ink/paper/line). NUNCA o navy/cyan do portfólio. Zero hex hardcoded.
 *
 * Dados: fetch em runtime de `${base}assets/data/worldcup/<file>.json` (zero LLM).
 * i18n: data-i18n-key estático (as chaves são autoradas à parte; degradam para o
 * texto pt-BR embutido enquanto não existirem nos dicionários).
 * Motion: padrões nomeados `resolve` (herói) + `reveal-up` (seções), guardados por
 * motionOk (respeita prefers-reduced-motion). Charts self-handle reduced-motion.
 * SPA: todo bootstrap em `astro:page-load` (o site usa <ClientRouter/>).
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectRecommendations from '../components/ProjectRecommendations.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Dashboard da Copa do Mundo 2026 — Otávio Ribeiro"
  description="Painel de dados da Copa do Mundo FIFA 2026: 48 seleções, 104 jogos. Pipeline Python coleta partidas, artilharia e estatísticas; gráficos SVG hand-rolled, zero LLM em runtime."
>
  <Header />

  <main id="main-content">

    <!-- ═══════════════════════════ HERO + KPIs ═══════════════════════════ -->
    <section id="wc-hero" class="section wc-hero" aria-labelledby="wc-hero-title">
      <div class="container">

        <div class="wc-hero__card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="wc-hero__head">
            <span class="mono-label">FIFA World Cup 2026 · Canada/Mexico/USA</span>
            <span class="wc-freshness" id="wc-freshness" data-freshness hidden aria-live="polite"></span>
          </header>

          <h1 id="wc-hero-title" class="wc-hero__display" data-i18n-key="portfolio.world_cup.hero_title">
            A Copa em dados, ao vivo.
          </h1>

          <p class="wc-hero__lead" data-i18n-key="portfolio.world_cup.hero_lead">
            Dashboard sobre a Copa do Mundo FIFA 2026 — 48 seleções, 104 jogos.
            Pipeline Python coleta partidas, artilharia e estatísticas a cada hora.
            Gráficos SVG desenhados à mão, tudo no navegador, a partir de JSONs públicos.
          </p>

          <div class="wc-hero__actions">
            <a href="#noticias" class="btn-primary" data-i18n-key="portfolio.world_cup.hero_cta_news">Ver notícias ao vivo</a>
            <a href="#craque" class="btn-secondary" data-i18n-key="portfolio.world_cup.hero_cta_game">Jogar: quem é o craque?</a>
          </div>
        </div>

        <!-- KPI Bento — 4 KPIs -->
        <div class="wc-kpi-bento" role="list" aria-label="Métricas gerais da Copa">
          <div class="wc-kpi wc-kpi--hero crop" role="listitem" aria-label="Total de jogos">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-kpi__head">
              <span class="mono-label" aria-hidden="true">01</span>
              <span class="wc-kpi__spark" aria-hidden="true">⚽</span>
            </header>
            <span class="wc-kpi__value wc-kpi__value--hero" id="kpi-total-matches"
                  data-count-to="0" aria-label="Total de jogos">—</span>
            <span class="wc-kpi__label">Jogos disputados</span>
          </div>

          <div class="wc-kpi crop" role="listitem" aria-label="Total de gols">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-kpi__head"><span class="mono-label" aria-hidden="true">02</span></header>
            <span class="wc-kpi__value" id="kpi-total-goals"
                  data-count-to="0" aria-label="Total de gols marcados">—</span>
            <span class="wc-kpi__label">Gols marcados</span>
          </div>

          <div class="wc-kpi crop" role="listitem" aria-label="Média de gols por partida">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-kpi__head"><span class="mono-label" aria-hidden="true">03</span></header>
            <span class="wc-kpi__value" id="kpi-avg-goals"
                  data-count-to="0" data-count-decimals="2" aria-label="Média de gols por partida">—</span>
            <span class="wc-kpi__label">Média de gols / jogo</span>
          </div>

          <div class="wc-kpi wc-kpi--gold crop" role="listitem" aria-label="Artilheiro atual">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-kpi__head">
              <span class="mono-label" aria-hidden="true">04</span>
              <span class="wc-kpi__badge">Chuteira de Ouro</span>
            </header>
            <span class="wc-kpi__value wc-kpi__value--scorer" id="kpi-top-scorer">—</span>
            <span class="wc-kpi__label" id="kpi-top-scorer-team">Artilheiro</span>
          </div>
        </div>

        <!-- Barra de progresso do torneio (cap1) — DEPOIS dos KPIs: revela tarde
             (fetch) sem empurrar o herói/LCP → evita CLS. -->
        <div class="wc-progress" id="wc-tournament-progress" hidden
             role="region" data-i18n-aria="portfolio.world_cup.progress_aria" aria-label="Progresso do torneio">
          <div class="wc-progress__head">
            <span class="wc-progress__phase mono-label" id="wc-progress-phase">—</span>
            <span class="wc-progress__pct" id="wc-progress-pct">0%</span>
          </div>
          <div class="wc-progress__bar"
               role="progressbar"
               aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
               data-i18n-aria="portfolio.world_cup.progress_bar_aria" aria-label="Porcentagem do torneio concluída"
               id="wc-progress-bar">
            <div class="wc-progress__fill" id="wc-progress-fill" style="width:0%"></div>
          </div>
          <div class="wc-progress__meta">
            <span id="wc-progress-remaining">—</span>
            <span class="wc-progress__sep" aria-hidden="true">·</span>
            <span id="wc-progress-next">—</span>
          </div>
        </div>

      </div>
    </section>

    <!-- Filtro "minha seleção" (cap1) — depois do herói: revela tarde (fetch)
         sem empurrar o herói/LCP → evita CLS above-the-fold. -->
    <div class="wc-team-filter" id="wc-team-filter" hidden role="region"
         data-i18n-aria="portfolio.world_cup.filter_aria" aria-label="Filtrar por seleção">
      <span class="mono-label wc-team-filter__label" data-i18n-key="portfolio.world_cup.filter_label">minha seleção</span>
      <div class="wc-team-filter__chips" id="wc-team-filter-chips"></div>
    </div>

    <!-- ═══════════════════════════ [01] NOTÍCIAS AO VIVO ═══════════════════════════ -->
    <section id="noticias" class="section wc-news-section" aria-labelledby="wc-news-title">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="mono-label">01</span>
          <h2 id="wc-news-title" class="wc-display" data-i18n-key="portfolio.world_cup.noticias_title">Notícias ao vivo</h2>
          <p class="wc-lead" data-i18n-key="portfolio.world_cup.noticias_lead">
            Feed agregado de Google News (PT/EN) sobre a Copa do Mundo 2026.
            Atualizado a cada hora pelo pipeline.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" data-reveal />

        <div class="wc-news-headline">
          <span class="wc-live-dot" aria-hidden="true"></span>
          <span class="mono-label wc-live-text" data-i18n-key="portfolio.world_cup.noticias_live">AO VIVO · RSS</span>
          <span class="wc-news-source mono-label" id="wc-news-source" hidden></span>
        </div>

        <ol class="wc-news-list" id="wc-news-list" role="list" aria-live="polite"
            data-i18n-aria="portfolio.world_cup.noticias_list_aria" aria-label="Últimas notícias da Copa do Mundo">
          <li class="wc-loading mono-label">carregando notícias…</li>
        </ol>
      </div>
    </section>

    <!-- ═══════════════════════════ [02] ARTILHARIA ═══════════════════════════ -->
    <section id="artilheiros" class="section wc-scorers-section" aria-labelledby="wc-scorers-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">02</span>
          <h2 id="wc-scorers-title" class="wc-display" data-i18n-key="portfolio.world_cup.artilharia_title">Artilharia</h2>
          <p class="wc-lead" data-i18n-key="portfolio.world_cup.artilharia_lead">
            Top 10 artilheiros da Copa. O líder leva a Chuteira de Ouro.
            Gols de pênalti aparecem na última coluna.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="wc-scorers-wrap crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <table class="wc-scorers-table" aria-labelledby="wc-scorers-title">
            <thead>
              <tr>
                <th scope="col" class="wc-scorers-table__rank">#</th>
                <th scope="col" class="wc-scorers-table__player">Jogador</th>
                <th scope="col" class="wc-scorers-table__team">Sel.</th>
                <th scope="col" class="wc-scorers-table__goals">Gols</th>
                <th scope="col" class="wc-scorers-table__pen">Pen.</th>
              </tr>
            </thead>
            <tbody id="wc-scorers-body">
              <tr><td colspan="5"><p class="wc-loading mono-label">carregando artilharia…</p></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ [02] ESTATÍSTICAS ═══════════════════════════ -->
    <section id="estatisticas" class="section wc-stats-section" aria-labelledby="wc-stats-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">03</span>
          <h2 id="wc-stats-title" class="wc-display" data-i18n-key="portfolio.world_cup.estatisticas_title">Estatísticas</h2>
          <p class="wc-lead" data-i18n-key="portfolio.world_cup.estatisticas_lead">
            Os números do torneio até agora — e a divisão dos gols entre o
            primeiro e o segundo tempo (com a prorrogação).
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="wc-stats-grid">
          <!-- Bento de números-chave -->
          <div class="wc-stat-bento" role="list" aria-label="Recordes e totais">
            <div class="wc-stat-card crop" role="listitem" aria-labelledby="wc-stat-avg-l">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="mono-label" id="wc-stat-avg-l">média / partida</span>
              <span class="wc-stat-card__value" id="wc-stat-avg">—</span>
              <span class="wc-stat-card__sub" id="wc-stat-avg-sub"></span>
            </div>
            <div class="wc-stat-card crop" role="listitem" aria-labelledby="wc-stat-bigwin-l">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="mono-label" id="wc-stat-bigwin-l">maior goleada</span>
              <span class="wc-stat-card__value wc-stat-card__value--sm" id="wc-stat-bigwin">—</span>
              <span class="wc-stat-card__sub" id="wc-stat-bigwin-sub"></span>
            </div>
            <div class="wc-stat-card crop" role="listitem" aria-labelledby="wc-stat-pen-l">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="mono-label" id="wc-stat-pen-l">pênaltis convertidos</span>
              <span class="wc-stat-card__value" id="wc-stat-pen">—</span>
              <span class="wc-stat-card__sub">gols de pênalti</span>
            </div>
            <div class="wc-stat-card crop" role="listitem" aria-labelledby="wc-stat-og-l">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="mono-label" id="wc-stat-og-l">gols contra</span>
              <span class="wc-stat-card__value" id="wc-stat-og">—</span>
              <span class="wc-stat-card__sub">own goals</span>
            </div>
          </div>

          <!-- Doughnut: gols 1º vs 2º tempo (nova lib SVG) -->
          <figure class="wc-stat-card wc-stat-card--chart crop" aria-labelledby="wc-halves-l">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="mono-label" id="wc-halves-l">gols por tempo</span>
            <div class="wc-halves-chart" id="wc-chart-halves">
              <p class="wc-loading mono-label">carregando gráfico…</p>
            </div>
          </figure>

          <!-- Estatísticas-extra (cap1): gols por minuto + eficiência + jogo com mais gols -->
          <figure class="wc-stat-card wc-stat-card--chart crop" aria-labelledby="wc-stat-min-l">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-stat-card__head">
              <span class="mono-label" id="wc-stat-min-l" data-i18n-key="portfolio.world_cup.stat_minutes_label">gols por faixa de minuto</span>
              <span class="mono-label wc-stat-card__hint" aria-hidden="true" data-i18n-key="portfolio.world_cup.stat_minutes_hint">0–134 min</span>
            </header>
            <div class="wc-stat-card__chart" id="wc-chart-minutes">
              <p class="wc-loading mono-label">carregando gráfico…</p>
            </div>
          </figure>

          <figure class="wc-stat-card wc-stat-card--chart crop" aria-labelledby="wc-stat-eff-l">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-stat-card__head">
              <span class="mono-label" id="wc-stat-eff-l" data-i18n-key="portfolio.world_cup.stat_eff_label">ranking de eficiência · saldo por jogo</span>
              <span class="mono-label wc-stat-card__hint" aria-hidden="true" data-i18n-key="portfolio.world_cup.stat_eff_hint">top 8</span>
            </header>
            <div class="wc-stat-card__chart" id="wc-chart-efficiency">
              <p class="wc-loading mono-label">carregando gráfico…</p>
            </div>
          </figure>

          <div class="wc-stat-card crop" aria-labelledby="wc-stat-hi-l">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="mono-label" id="wc-stat-hi-l" data-i18n-key="portfolio.world_cup.stat_hi_label">jogo com mais gols</span>
            <span class="wc-stat-card__value wc-stat-card__value--sm" id="wc-stat-hi">—</span>
            <span class="wc-stat-card__sub" id="wc-stat-hi-sub"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ [04] FIFA · ESTATÍSTICAS DE SELEÇÃO ═══════════════════ -->
    <section id="fifa-team-stats" class="section wc-fifa-section" aria-labelledby="fifa-team-title">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="mono-label">04</span>
          <h2 id="fifa-team-title" class="wc-display" data-i18n-key="portfolio.world_cup.fifa_team_title">Estatísticas de seleção · dado FIFA</h2>
          <p class="wc-lead" data-i18n-key="portfolio.world_cup.fifa_team_lead">
            As 48 seleções da Copa 2026 pelo dado oficial da FIFA: xG, posse, pressão, distância percorrida e mais de 20 métricas por jogo. Escolha a métrica e veja o ranking; o bento destaca quem lidera cada dimensão do jogo.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" data-reveal />

        <span class="mono-label wc-cl-tagline" id="fifa-team-meta" data-i18n-key="portfolio.world_cup.fifa_team_source">dado oficial FIFA</span>

        <p class="wc-error mono-label" id="fifa-team-error" hidden data-i18n-key="portfolio.world_cup.fifa_team_error">Estatísticas FIFA de seleção indisponíveis.</p>

        <!-- Bento de destaques cruzados -->
        <div class="wc-insights-grid" id="fifa-team-bento" aria-label="Destaques FIFA das seleções"
             data-i18n-aria="portfolio.world_cup.fifa_team_bento_aria">
          <div class="wc-skeleton-card"><span class="wc-skeleton" style="height:140px"></span></div>
          <div class="wc-skeleton-card"><span class="wc-skeleton" style="height:140px"></span></div>
          <div class="wc-skeleton-card"><span class="wc-skeleton" style="height:140px"></span></div>
        </div>

        <!-- Ranking por métrica selecionável -->
        <div class="wc-c22-block card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <header class="wc-c22-block__head">
            <h3 class="wc-c22-block__title" data-i18n-key="portfolio.world_cup.fifa_team_ranking_title">Ranking de seleções</h3>
            <div class="wc-match-select-wrap">
              <label for="fifa-metric-select" class="mono-label" data-i18n-key="portfolio.world_cup.select_metric">métrica</label>
              <select id="fifa-metric-select" class="wc-cl-select"></select>
            </div>
          </header>
          <div class="wc-c22-block__chart" id="fifa-team-chart" role="img"
               aria-label="Ranking das 48 seleções da Copa 2026 pela métrica FIFA selecionada."
               data-i18n-aria="portfolio.world_cup.fifa_team_chart_aria">
            <p class="wc-loading mono-label">carregando gráfico…</p>
          </div>
          <p class="wc-cl-note mono-label" id="fifa-team-note" data-i18n-key="portfolio.world_cup.fifa_team_note">Top 16 seleções pela métrica selecionada — Copa 2026 (dado oficial FIFA).</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ [05] FIFA · POWER RANKING DE JOGADORES ═══════════════ -->
    <section id="fifa-power-ranking" class="section wc-fifa-section wc-fifa-section--alt" aria-labelledby="fifa-power-title">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="mono-label">05</span>
          <h2 id="fifa-power-title" class="wc-display" data-i18n-key="portfolio.world_cup.fifa_power_title">Power Ranking de jogadores</h2>
          <p class="wc-lead" data-i18n-key="portfolio.world_cup.fifa_power_lead">
            O ranking oficial da FIFA por jogador, em três eixos — ataque, defesa e criatividade — com a nota e a variação de posição na rodada. Escolha o eixo; ao lado, o top-5 de goleiros por defesa.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" data-reveal />

        <span class="mono-label wc-cl-tagline" id="fifa-power-meta" data-i18n-key="portfolio.world_cup.fifa_team_source">dado oficial FIFA</span>

        <p class="wc-error mono-label" id="fifa-power-error" hidden data-i18n-key="portfolio.world_cup.fifa_power_error">Power Ranking FIFA indisponível.</p>

        <div class="wc-c22-two-col">
          <!-- Jogadores de linha por eixo -->
          <div class="wc-c22-block card crop">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="wc-c22-block__head">
              <h3 class="wc-c22-block__title" data-i18n-key="portfolio.world_cup.fifa_power_outfield_title">Jogadores de linha · top 15</h3>
              <div class="wc-match-select-wrap">
                <label for="fifa-power-select" class="mono-label" data-i18n-key="portfolio.world_cup.fifa_select_axis">eixo</label>
                <select id="fifa-power-select" class="wc-cl-select"></select>
              </div>
            </header>
            <div class="wc-scorers-wrap crop">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <table class="wc-scorers-table" aria-label="Power ranking FIFA de jogadores de linha pelo eixo selecionado"
                     data-i18n-aria="portfolio.world_cup.fifa_power_outfield_aria">
                <thead>
                  <tr>
                    <th scope="col" class="wc-scorers-table__rank" data-i18n-key="portfolio.world_cup.col_rank">#</th>
                    <th scope="col" class="wc-scorers-table__player" data-i18n-key="portfolio.world_cup.col_player">Jogador</th>
                    <th scope="col" class="wc-scorers-table__goals" data-i18n-key="portfolio.world_cup.fifa_power_col_score">Nota</th>
                    <th scope="col" class="wc-scorers-table__pen" data-i18n-key="portfolio.world_cup.fifa_power_col_change">Var.</th>
                  </tr>
                </thead>
                <tbody id="fifa-power-body">
                  <tr><td colspan="4"><p class="wc-loading mono-label">carregando ranking…</p></td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Goleiros top-5 por defesa -->
          <div class="wc-c22-block card crop">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <h3 class="wc-c22-block__title" data-i18n-key="portfolio.world_cup.fifa_power_gk_title">Goleiros · top 5 por defesa</h3>
            <div class="wc-scorers-wrap crop">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
