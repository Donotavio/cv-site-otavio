  .wc-match__score--pending { font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); text-transform: uppercase; }
  .wc-match__today-badge { display: inline-block; margin-left: var(--space-2); padding: 1px var(--space-2); font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wide); color: var(--wc-live-ink); background: var(--paper-card); border: 1px solid var(--wc-live-line); border-radius: var(--radius-sm); text-transform: uppercase; vertical-align: middle; }
  .wc-match__meta { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-top: var(--space-2); padding-top: var(--space-2); border-top: 1px dashed var(--line); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); flex-wrap: wrap; }
  .wc-match__round { text-transform: uppercase; }
  .wc-match__time { font-variant-numeric: var(--num-tabular); }

  /* ════════════════ Skeleton shimmer (placeholders 2022/histórico) ════════════════ */
  .wc-skeleton { display: block; width: 100%; height: 100%; background: linear-gradient(90deg, var(--paper-soft) 25%, var(--paper-card) 50%, var(--paper-soft) 75%); background-size: 200% 100%; animation: wc-shimmer 1.5s infinite; border-radius: var(--radius-sm); }
