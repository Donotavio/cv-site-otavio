  .wc-match { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: var(--space-3); padding: var(--space-4); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); transition: border-color var(--transition-fast); }
  .wc-match:hover { border-color: var(--line-strong); }
