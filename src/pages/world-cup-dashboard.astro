  }
  .wc-groups-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px)  { .wc-groups-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); } }
  @media (min-width: 1024px) { .wc-groups-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1440px) { .wc-groups-grid { grid-template-columns: repeat(4, 1fr); } }
  .wc-group-card { background: var(--paper-card); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); transition: border-color var(--transition-fast); }
  .wc-group-card:hover { border-color: var(--line-strong); }
  .wc-group-card__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); padding-bottom: var(--space-2); margin-bottom: var(--space-1); border-bottom: 1px solid var(--line); }
  .wc-group-card__head .mono-label { color: var(--wc-field-ink); }
  .wc-group-card__head .mono-label::before, .wc-group-card__head .mono-label::after { color: var(--wc-field-ink); }
  .wc-group-rows { display: flex; flex-direction: column; }
  .wc-group-row { display: grid; grid-template-columns: 22px 1fr auto auto auto auto; align-items: center; gap: var(--space-2); padding: var(--space-2) 0; font-family: var(--font-mono); font-size: var(--text-sm); font-variant-numeric: var(--num-tabular); color: var(--ink-soft); border-bottom: 1px dashed var(--line); transition: background var(--transition-fast); }
  .wc-group-row:last-child { border-bottom: none; }
  .wc-group-row__flag { font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; font-size: var(--text-base); line-height: 1; }
  .wc-group-row__name { font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 500; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }
  .wc-group-row__pts { font-weight: 700; color: var(--ink); text-align: right; min-width: 1.75ch; }
  .wc-group-row__played, .wc-group-row__gca, .wc-group-row__diff { text-align: right; min-width: 4ch; color: var(--ink-soft); }
  .wc-group-row__diff.is-positive { color: var(--wc-field-ink); }
  .wc-group-row__diff.is-negative { color: var(--wc-live-ink); }
  .wc-group-row.is-qualified { background: var(--wc-field-dim); box-shadow: inset 3px 0 0 var(--wc-field); border-radius: var(--radius-sm); }
  .wc-group-row__badge { display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; white-space: nowrap; width: 16px; height: 16px; font-family: var(--font-mono); font-size: 10px; font-weight: 700; line-height: 1; color: var(--wc-field-ink); background: var(--paper-card); border: 1px solid var(--wc-field-line); border-radius: 50%; }
  .wc-group-row__name-block { display: flex; align-items: center; gap: var(--space-2); min-width: 0; }

  /* ════════════════ [05] Bracket do mata-mata ════════════════ */
  .wc-bracket-section { background: var(--paper); }
  .wc-bracket-tree { display: grid; grid-template-columns: 1fr minmax(180px, auto) 1fr; gap: var(--space-6); align-items: stretch; padding: var(--space-3) 0; }
  .wc-bracket-tree__side { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
  .wc-bracket-tree__head { text-align: center; padding: var(--space-2); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-sm); font-size: var(--text-xs); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-soft); font-weight: 600; }
  .wc-bracket-tree__cols { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-3); align-items: stretch; }
