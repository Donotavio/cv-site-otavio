  .wc-pitch__row--mf { grid-template-columns: repeat(3, 1fr); }
  .wc-pitch__row--fw { grid-template-columns: repeat(3, 1fr); }
  .wc-player-token { display: flex; flex-direction: column; align-items: center; gap: 4px; width: 100%; max-width: 96px; }
  .wc-player-token__circle { width: 56px; height: 56px; border-radius: var(--radius-full); background: var(--paper-card); border: 1px solid var(--wc-field-line); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--ink); letter-spacing: var(--tracking-wide); box-shadow: var(--shadow-sm); text-align: center; padding: 4px; }
  .wc-player-token__initials { line-height: 1; }
  .wc-player-token__name { font-family: var(--font-sans); font-size: 10px; font-weight: 500; color: var(--ink); text-align: center; line-height: 1.1; max-width: 88px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wc-player-token__stat { font-family: var(--font-mono); font-size: 9px; color: var(--ink-soft); letter-spacing: var(--tracking-wide); text-align: center; line-height: 1.1; }
  .wc-player-token--gk .wc-player-token__stat { color: var(--wc-field-ink); }
  .wc-player-token--topscorer .wc-player-token__circle { box-shadow: 0 0 0 2px var(--wc-gold), var(--shadow-sm); }
  .wc-player-token--topscorer .wc-player-token__stat { color: var(--wc-gold-ink); }
  .wc-top-gks { width: 100%; max-width: 640px; display: flex; flex-direction: column; gap: var(--space-3); }
  .wc-top-gks__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); padding-bottom: var(--space-2); border-bottom: 1px solid var(--line); }
  .wc-top-gks__list { display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: flex-start; justify-content: center; }
  .wc-top-gk { display: flex; flex-direction: column; align-items: center; gap: var(--space-1); width: 80px; text-align: center; }
  .wc-top-gk__avatar { width: 32px; height: 32px; border-radius: var(--radius-full); background: var(--paper-card); border: 1px solid var(--wc-field-line); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; font-weight: 500; color: var(--ink); }
  .wc-top-gk__flag { font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; font-size: var(--text-base); line-height: 1; }
  .wc-top-gk--best .wc-top-gk__avatar { box-shadow: 0 0 0 2px var(--wc-gold); }
  .wc-top-gk__name { font-family: var(--font-sans); font-size: 10px; font-weight: 500; color: var(--ink); line-height: 1.1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%; }
  .wc-top-gk__stat { font-family: var(--font-mono); font-size: 9px; color: var(--ink-faint); letter-spacing: var(--tracking-wide); }

  /* ════════════════ [12] Insights (bento) ════════════════ */
  .wc-insights-section { background: var(--paper); }
  .wc-insights-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px)  { .wc-insights-grid { grid-template-columns: repeat(6, 1fr); gap: var(--space-5); } }
  @media (min-width: 1024px) { .wc-insights-grid { grid-template-columns: repeat(12, 1fr); } }
  .wc-insight-card { background: var(--paper-card); border: 1px solid var(--line); border-top: 2px solid var(--ink); border-radius: 0 0 var(--radius-md) var(--radius-md); padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  .wc-insight-card--field { border-top-color: var(--wc-field); }
  .wc-insight-card--gold  { border-top-color: var(--wc-gold); }
  .wc-insight-card--ink   { border-top-color: var(--ink); }
  .wc-insight-card--live  { border-top-color: var(--wc-live); }
  .wc-insight-card__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); }
  /* Heading da categoria (h3) — visual do mono-label, sem estilo default de h3. */
  .wc-insight-card__cat { margin: 0; font-weight: inherit; font-size: inherit; }
  .wc-insight-card__title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 400; color: var(--ink); line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); margin: 0; }
  .wc-insight-card__body { font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink-soft); line-height: var(--leading-normal); }
  .wc-insight-card__key { font-family: var(--font-mono); font-weight: 700; font-variant-numeric: var(--num-tabular); }
  .wc-insight-card--field .wc-insight-card__key { color: var(--wc-field-ink); }
  .wc-insight-card--gold  .wc-insight-card__key { color: var(--wc-gold-ink); }
  .wc-insight-card--ink   .wc-insight-card__key { color: var(--ink); }
  .wc-insight-card--live  .wc-insight-card__key { color: var(--wc-live-ink); }
  @media (min-width: 640px) { .wc-insight-card--hero { grid-column: span 6; } .wc-insight-card--md { grid-column: span 3; } }
  @media (min-width: 1024px) { .wc-insight-card--hero { grid-column: span 6; } .wc-insight-card--md { grid-column: span 3; } }

  /* ════════════════ [13] Bolão local ════════════════ */
  .wc-bolao-section { background: var(--paper-soft); }
  .wc-bolao-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 1024px) { .wc-bolao-grid { grid-template-columns: 2fr 1fr; } }
  .wc-bolao-list { display: flex; flex-direction: column; gap: var(--space-3); margin: 0; padding: 0; list-style: none; }
  .wc-bolao-item { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: var(--space-3); padding: var(--space-4); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .wc-bolao-item.is-today { border-color: var(--wc-live-line); background: var(--wc-live-dim); }
  .wc-bolao-item.is-finished { background: var(--paper-soft); border-color: var(--line); }
  .wc-bolao-team { display: flex; flex-direction: column; align-items: center; gap: var(--space-1); text-align: center; min-width: 0; }
  .wc-bolao-team__flag { font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; font-size: var(--text-xl); line-height: 1; }
  .wc-bolao-team__name { font-family: var(--font-sans); font-size: var(--text-xs); font-weight: 500; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
  .wc-bolao-team__name--placeholder { color: var(--ink-faint); font-style: italic; font-weight: 400; }
  .wc-bolao-mid { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
  .wc-bolao-inputs { display: flex; align-items: center; gap: var(--space-2); }
  .wc-bolao-input { width: 44px; height: 36px; text-align: center; font-family: var(--font-mono); font-size: var(--text-base); font-weight: 500; color: var(--ink); background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius-sm); font-variant-numeric: var(--num-tabular); transition: border-color var(--transition-fast); }
  .wc-bolao-input:focus { outline: 2px solid var(--wc-field-ink); outline-offset: 1px; border-color: var(--wc-field-ink); }
  .wc-bolao-input:disabled { background: var(--paper-soft); color: var(--ink-faint); cursor: not-allowed; }
  .wc-bolao-input-sep { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink-faint); }
  .wc-bolao-submit { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--paper); background: var(--ink); border: 1px solid var(--ink); border-radius: var(--radius-sm); cursor: pointer; transition: background var(--transition-fast), transform var(--transition-fast); }
  .wc-bolao-submit:hover:not(:disabled) { background: var(--wc-field-ink); border-color: var(--wc-field-ink); transform: translateY(-1px); }
  .wc-bolao-submit:disabled { background: var(--paper-soft); color: var(--ink-faint); border-color: var(--line); cursor: not-allowed; }
  .wc-bolao-result { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); text-align: center; min-height: 1em; }
  .wc-bolao-result--exact { color: var(--wc-field-ink); font-weight: 700; }
  .wc-bolao-result--winner { color: var(--wc-gold-ink); font-weight: 700; }
  .wc-bolao-meta { grid-column: 1 / -1; display: flex; justify-content: space-between; gap: var(--space-3); margin-top: var(--space-2); padding-top: var(--space-2); border-top: 1px dashed var(--line); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); flex-wrap: wrap; }
  .wc-bolao-score { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); height: fit-content; }
  .wc-bolao-score__value { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--wc-field-ink); line-height: 0.95; font-variant-numeric: var(--num-tabular); }
  .wc-bolao-score__label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); text-transform: uppercase; }
  .wc-bolao-score__list { display: flex; flex-direction: column; gap: var(--space-2); margin: var(--space-2) 0; padding: 0; list-style: none; }
  .wc-bolao-score__row { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: var(--space-3); padding: var(--space-2) var(--space-3); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); }
  .wc-bolao-score__pts { font-weight: 700; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .wc-bolao-score__pts--exact { color: var(--wc-field-ink); }
  .wc-bolao-score__pts--winner { color: var(--wc-gold-ink); }
  .wc-bolao-reset { align-self: flex-start; margin-top: var(--space-2); }

  /* ════════════════ [14] Quem é o craque? ════════════════ */
  .wc-game-section { background: var(--paper-soft); }
  .wc-game__duel { display: grid; grid-template-columns: 1fr; gap: var(--space-5); margin-bottom: var(--space-6); }
  @media (min-width: 768px) { .wc-game__duel { grid-template-columns: 1fr 1fr; } }
  .wc-game__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .wc-player-card { position: relative; display: flex; flex-direction: column; gap: var(--space-4); padding: var(--space-6); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); text-align: left; cursor: pointer; width: 100%; font: inherit; color: inherit; transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast); }
  .wc-player-card:hover { border-color: var(--wc-field-line); transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .wc-player-card:focus-visible { outline: 2px solid var(--wc-field-ink); outline-offset: 3px; }
  .wc-player-card:active { transform: translateY(-1px); }
  .wc-player-card__flag { font-size: clamp(3rem, 8vw, 4.5rem); line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; }
  .wc-player-card__name { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 400; color: var(--ink); line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); }
  .wc-player-card__meta { display: flex; flex-direction: column; gap: var(--space-1); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); letter-spacing: var(--tracking-wide); }
  .wc-player-card__stat { display: flex; align-items: baseline; gap: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--line); margin-top: auto; }
  .wc-player-card__goals { font-family: var(--font-display); font-size: var(--text-3xl); color: var(--wc-field-ink); line-height: 1; font-variant-numeric: var(--num-tabular); }
  .wc-player-card__goals-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); text-transform: uppercase; }
  .wc-player-card__cta { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--wc-field-ink); opacity: 0; transition: opacity var(--transition-fast); }
  .wc-player-card:hover .wc-player-card__cta, .wc-player-card:focus-visible .wc-player-card__cta { opacity: 1; }
  .wc-game__duel.is-voting .wc-player-card { pointer-events: none; animation: wc-fade-out 0.25s ease forwards; }
  .wc-game__duel.is-entering .wc-player-card { animation: wc-fade-in 0.35s ease; }
  @keyframes wc-fade-out { to { opacity: 0; transform: translateY(-8px); } }
  @keyframes wc-fade-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .wc-game__duel.is-voting .wc-player-card, .wc-game__duel.is-entering .wc-player-card { animation: none; } }
  .wc-game__empty { grid-column: 1 / -1; padding: var(--space-8); text-align: center; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink-faint); }
  .wc-ranking-list { display: flex; flex-direction: column; gap: var(--space-2); margin: 0; padding: 0; list-style: none; }
  .wc-ranking-row { display: grid; grid-template-columns: 28px 1fr auto auto; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-sm); }
  .wc-ranking-row__rank { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); text-align: right; font-variant-numeric: var(--num-tabular); }
  .wc-ranking-row__name { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink); min-width: 0; }
  .wc-ranking-row__name-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wc-ranking-row__team { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); }
  .wc-ranking-row__winrate { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--wc-field-ink); font-variant-numeric: var(--num-tabular); min-width: 56px; text-align: right; }

  /* ════════════════ [08/09/10] Deep-stats compare + selects ════════════════ */
  .wc-shotmap-section { background: var(--paper); }
  .wc-passnet-section { background: var(--paper-soft); }
  .wc-flow-section    { background: var(--paper); }
  .wc-shotmap-tagline { color: var(--ink-faint); }
  .wc-match-select-wrap { display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-2); }
  .wc-match-select-wrap > .mono-label { margin-right: var(--space-2); color: var(--ink-faint); }
  .wc-match-select { flex: 1 1 auto; min-width: 0; max-width: 100%; font-family: var(--font-mono); font-size: var(--text-sm); padding: 8px 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--paper-card); color: var(--ink); cursor: pointer; appearance: none; -webkit-appearance: none; background-image: linear-gradient(45deg, transparent 50%, var(--ink-soft) 50%), linear-gradient(135deg, var(--ink-soft) 50%, transparent 50%); background-position: calc(100% - 16px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px); background-size: 4px 4px, 4px 4px; background-repeat: no-repeat; padding-right: 28px; }
  .wc-match-select:hover { border-color: var(--line-strong); }
  .wc-match-select:focus-visible { outline: 2px solid var(--wc-field-ink); outline-offset: 2px; }
  .wc-stat-compare { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  .wc-stat-compare[hidden] { display: none; }
  @media (min-width: 768px) { .wc-stat-compare { padding: var(--space-6); } }
  .wc-stat-compare__head { display: flex; justify-content: space-between; align-items: center; gap: var(--space-3); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); margin-bottom: var(--space-2); flex-wrap: wrap; }
  .wc-stat-compare__team { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-display); font-size: var(--text-lg); color: var(--ink); line-height: var(--leading-tight); min-width: 0; }
  .wc-stat-compare__team--right { flex-direction: row-reverse; text-align: right; }
  .wc-stat-compare__team .wc-flag { font-size: var(--text-xl); line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; flex-shrink: 0; }
  .wc-stat-compare__team-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-variant-numeric: var(--num-tabular); }
  .wc-stat-rows { display: flex; flex-direction: column; gap: 0; }
  .wc-stat-row { display: grid; grid-template-columns: minmax(56px, auto) 1fr minmax(56px, auto); align-items: center; gap: var(--space-3); padding: var(--space-2) 0; }
  .wc-stat-row__home, .wc-stat-row__away { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; text-align: center; font-variant-numeric: var(--num-tabular); min-width: 56px; }
  .wc-stat-row__home { color: var(--wc-field-ink); text-align: right; }
  .wc-stat-row__away { color: var(--wc-gold-ink); text-align: left; }
  .wc-stat-row__bar { display: flex; height: 6px; border-radius: 3px; overflow: hidden; background: var(--line); }
  .wc-stat-row__bar-home, .wc-stat-row__bar-away { display: block; height: 100%; width: 0; transition: width 700ms cubic-bezier(0.16, 1, 0.3, 1); }
  .wc-stat-row__bar-home { background: var(--wc-field-ink); }
  .wc-stat-row__bar-away { background: var(--wc-gold-ink); }
  .wc-stat-row__label { grid-column: 1 / -1; text-align: center; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); margin-top: -2px; margin-bottom: var(--space-2); letter-spacing: var(--tracking-wide); }
  .wc-stat-subhead { color: var(--ink-faint); margin: var(--space-4) 0 var(--space-2); padding-top: var(--space-3); border-top: 1px solid var(--line); }
  .wc-stat-compare__source { align-self: flex-end; margin-top: var(--space-2); color: var(--ink-faint); }
  @media (prefers-reduced-motion: reduce) { .wc-stat-row__bar-home, .wc-stat-row__bar-away { transition: none !important; } }

  /* ════════════════ [15] Clássicos 2022 ════════════════ */
  .wc-classics-section { background: var(--paper); }
  .wc-cl-tagline { display: block; color: var(--ink-faint); margin-bottom: var(--space-4); }
  .wc-cl-select { flex: 1 1 auto; min-width: 0; max-width: 100%; font-family: var(--font-mono); font-size: var(--text-sm); padding: 8px 28px 8px 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--paper-card); color: var(--ink); cursor: pointer; appearance: none; -webkit-appearance: none; background-image: linear-gradient(45deg, transparent 50%, var(--ink-soft) 50%), linear-gradient(135deg, var(--ink-soft) 50%, transparent 50%); background-position: calc(100% - 16px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px); background-size: 4px 4px, 4px 4px; background-repeat: no-repeat; }
  .wc-cl-select:hover { border-color: var(--line-strong); }
  .wc-cl-select:focus-visible { outline: 2px solid var(--wc-field-ink); outline-offset: 2px; }
  .wc-cl-meta { display: block; color: var(--ink-faint); margin-bottom: var(--space-5); }
  .wc-cl-block { padding: var(--space-5); margin-bottom: var(--space-5); }
  @media (min-width: 768px) { .wc-cl-block { padding: var(--space-6); } }
  .wc-cl-block__title { font-family: var(--font-mono); font-size: var(--text-base); font-weight: 600; color: var(--ink); margin: 0 0 var(--space-4); display: flex; align-items: baseline; gap: var(--space-2); }
  .wc-cl-block__unit { font-size: var(--text-xs); font-weight: 400; color: var(--ink-faint); letter-spacing: var(--tracking-wide); text-transform: none; }
  .wc-cl-table { width: 100%; border-collapse: collapse; margin-bottom: var(--space-4); font-family: var(--font-mono); }
  .wc-cl-table thead th { font-size: var(--text-xs); font-weight: 500; color: var(--ink-faint); letter-spacing: var(--tracking-wide); text-align: right; padding: 0 0 var(--space-2) var(--space-3); border-bottom: 1px solid var(--line); }
  .wc-cl-table__corner { border-bottom: 1px solid var(--line); }
  .wc-cl-table__team { text-align: left; font-weight: 500; color: var(--ink); padding: var(--space-2) var(--space-3) var(--space-2) 0; white-space: nowrap; }
  .wc-cl-table__team .wc-flag { margin-right: var(--space-2); }
  .wc-cl-table__num { text-align: right; font-variant-numeric: var(--num-tabular); color: var(--ink-soft); padding: var(--space-2) 0 var(--space-2) var(--space-3); min-width: 64px; }
  .wc-cl-table tbody tr + tr td, .wc-cl-table tbody tr + tr th { border-top: 1px solid var(--line); }
  .wc-cl-table__row--lead .wc-cl-table__team, .wc-cl-table__row--lead .wc-cl-table__num:first-of-type { color: var(--wc-gold-ink); font-weight: 600; }
  .wc-cl-block__chart { margin-top: var(--space-2); }
  .wc-cl-note { display: block; margin-top: var(--space-4); color: var(--ink-faint); line-height: 1.5; }
  .wc-cl-note strong { color: var(--ink-soft); }

  /* ════════════════ [16-18] Copa 2022 — panorama / comparativo / história ════════════════ */
  .wc-c22-section { background: var(--paper); }
  .wc-c22-section--alt { background: var(--paper-soft); }
  .wc-c22-block { padding: var(--space-5); margin-top: var(--space-6); }
  .wc-c22-block__head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: var(--space-3); margin-bottom: var(--space-4); }
  .wc-c22-block__title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 400; letter-spacing: var(--tracking-tight); color: var(--ink); margin: 0 0 var(--space-4); }
  .wc-c22-block__head .wc-c22-block__title { margin-bottom: 0; }
  .wc-c22-block__title .wc-cl-block__unit { display: block; font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--ink-faint); margin-top: var(--space-1); }
  .wc-c22-block__chart { position: relative; width: 100%; }
  .wc-c22-bignumbers { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-bottom: var(--space-6); }
  @media (min-width: 560px) { .wc-c22-bignumbers { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .wc-c22-bignumbers { grid-template-columns: repeat(3, 1fr); } .wc-c22-bignumbers > .wc-stat-card--wide { grid-column: span 1; } }
  .wc-c22-two-col { display: grid; grid-template-columns: 1fr; gap: var(--space-5); margin-top: var(--space-6); }
  @media (min-width: 900px) { .wc-c22-two-col { grid-template-columns: 1fr 1fr; align-items: start; } }
  .wc-c22-context { margin-bottom: var(--space-6); }
  .wc-c22-context__head { display: block; color: var(--ink-faint); margin-bottom: var(--space-4); }
  .wc-c22-context__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 560px) { .wc-c22-context__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .wc-c22-context__grid { grid-template-columns: repeat(3, 1fr); } }
  .wc-c22-context-card { padding: var(--space-4); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); display: flex; flex-direction: column; gap: var(--space-2); }
  .wc-c22-context-card__title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 400; line-height: 1.15; color: var(--ink); margin: var(--space-1) 0 0; }
  .wc-c22-context-card__body { font-size: var(--text-sm); line-height: 1.5; color: var(--ink-soft); margin: 0; }
  .wc-c22-context-card__src { margin-top: auto; color: var(--wc-field-ink); text-decoration: none; align-self: flex-start; }
  .wc-c22-context-card__src:hover { text-decoration: underline; }

  /* Big-numbers históricos: os .wc-stat-card são injetados; escopados sob o
     host p/ não colidir com o .wc-stat-card estático do bento de [03]. */
  #c22-hist-bignumbers .wc-stat-card { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  #c22-hist-bignumbers .wc-stat-card__value { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--wc-field-ink); line-height: 0.95; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  #c22-hist-bignumbers .wc-stat-card__sub { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); }

  /* Linhas injetadas nas tabelas 2022/histórico — espelha #wc-scorers-body ── */
  #c22-scorers-body td, #c22-hist-scorers td, #c22-hist-appearances td { padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--line); color: var(--ink); vertical-align: middle; }
  #c22-scorers-body tr:last-child td, #c22-hist-scorers tr:last-child td, #c22-hist-appearances tr:last-child td { border-bottom: none; }
  #c22-scorers-body tr, #c22-hist-scorers tr, #c22-hist-appearances tr { transition: background var(--transition-fast); }
  #c22-scorers-body tr:hover, #c22-hist-scorers tr:hover, #c22-hist-appearances tr:hover { background: var(--paper-soft); }
  #c22-scorers-body .wc-scorers-table__rank-cell, #c22-hist-scorers .wc-scorers-table__rank-cell, #c22-hist-appearances .wc-scorers-table__rank-cell { font-family: var(--font-mono); font-weight: 500; text-align: right; color: var(--ink-faint); }
  #c22-scorers-body .wc-scorers-table__player-cell, #c22-hist-scorers .wc-scorers-table__player-cell, #c22-hist-appearances .wc-scorers-table__player-cell { display: flex; align-items: center; gap: var(--space-3); }
  #c22-scorers-body .wc-scorers-table__name, #c22-hist-scorers .wc-scorers-table__name, #c22-hist-appearances .wc-scorers-table__name { font-weight: 500; color: var(--ink); }
  #c22-scorers-body .wc-scorers-table__name-block, #c22-hist-scorers .wc-scorers-table__name-block, #c22-hist-appearances .wc-scorers-table__name-block { display: flex; flex-direction: column; gap: 2px; }
  #c22-scorers-body .wc-scorers-table__sub, #c22-hist-scorers .wc-scorers-table__sub, #c22-hist-appearances .wc-scorers-table__sub { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); }
  #c22-scorers-body .wc-scorers-table__goals-cell, #c22-hist-scorers .wc-scorers-table__goals-cell, #c22-hist-appearances .wc-scorers-table__goals-cell { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 500; text-align: right; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  #c22-scorers-body .wc-scorers-table__pen-cell, #c22-hist-scorers .wc-scorers-table__pen-cell, #c22-hist-appearances .wc-scorers-table__pen-cell { font-family: var(--font-mono); font-size: var(--text-xs); text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); }
  #c22-scorers-body tr.wc-scorers-table__row--gold td, #c22-hist-scorers tr.wc-scorers-table__row--gold td, #c22-hist-appearances tr.wc-scorers-table__row--gold td { background: var(--wc-gold-dim); border-bottom-color: var(--wc-gold-line); }
  #c22-scorers-body tr.wc-scorers-table__row--gold .wc-scorers-table__rank-cell, #c22-hist-scorers tr.wc-scorers-table__row--gold .wc-scorers-table__rank-cell, #c22-hist-appearances tr.wc-scorers-table__row--gold .wc-scorers-table__rank-cell { color: var(--wc-gold-ink); font-weight: 500; }
  .wc-scorers-table__gold-badge { display: inline-block; margin-left: var(--space-2); padding: 1px var(--space-2); font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wide); color: var(--wc-gold-ink); background: var(--paper-card); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-sm); text-transform: uppercase; vertical-align: middle; }
</style>

<script>
  // Dashboard da Copa 2026 — hidrata Hero+KPIs, Artilharia e Estatísticas a
  // partir de assets/data/worldcup/*.json. Fetch runtime (base do body, no-cache,
  // AbortController, fail-soft). SPA-safe: bootstrap em astro:page-load.
  import { countUpAll } from '../scripts/motion/count-up';
  import { doughnutChart, readToken } from '../scripts/worldcup/charts';
  import * as cap1 from '../scripts/worldcup/_frag/cap1';
  import { renderClassics, renderPanorama, renderComparativo, renderHistoria } from '../scripts/worldcup/_frag/cap23';
  import { renderFifaTeamStats, renderFifaPowerRanking, renderFifaCompare } from '../scripts/worldcup/_frag/fifa';

  interface Team { name?: string; code?: string; flag?: string }
  interface Scorer { name: string; team?: Team; goals: number; penalties?: number }
  interface PartidasPayload { total?: number }
  interface ArtilheirosPayload { scorers?: Scorer[]; updated_at?: string }
  interface EstatisticasPayload {
    total_goals?: number;
    avg_goals_per_match?: number;
    goals_first_half?: number;
    goals_second_half?: number;
    goals_extra_time?: number;
    penalties_scored?: number;
    own_goals?: number;
    biggest_win?: { match?: string; diff?: number } | null;
  }

  const el = (id: string): HTMLElement | null => document.getElementById(id);
  const esc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

  function safe(label: string, fn: () => void): void {
    try { fn(); } catch (e) { console.error(`[world-cup] render "${label}" falhou:`, e); }
  }

  async function fetchJSON<T>(base: string, file: string, ms = 8000): Promise<T | null> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), ms);
    try {
      const res = await fetch(`${base}assets/data/worldcup/${file}`, { cache: 'no-cache', signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) return null;
      return (await res.json()) as T;
    } catch { clearTimeout(timeoutId); return null; }
  }

  // ── Hero + KPIs ──────────────────────────────────────────────
  function renderHeroKPIs(partidas: PartidasPayload | null, artil: ArtilheirosPayload | null, stats: EstatisticasPayload | null): void {
    const matches = partidas?.total ?? 0;
    const goals = stats?.total_goals ?? 0;
    const avg = stats?.avg_goals_per_match ?? 0;

    const mEl = el('kpi-total-matches'); if (mEl) mEl.dataset.countTo = String(matches);
    const gEl = el('kpi-total-goals'); if (gEl) gEl.dataset.countTo = String(goals);
    const aEl = el('kpi-avg-goals'); if (aEl) { aEl.dataset.countTo = String(avg); aEl.dataset.countDecimals = '2'; }

    const sEl = el('kpi-top-scorer'), stEl = el('kpi-top-scorer-team');
    const top = artil?.scorers?.[0];
    if (sEl && stEl) {
      if (top) {
        sEl.textContent = top.name;
        const parts: string[] = [];
        if (top.team?.flag) parts.push(top.team.flag);
        if (top.team?.code) parts.push(top.team.code);
        parts.push(`${top.goals} gols`);
        stEl.textContent = parts.join(' · ');
      } else {
        sEl.textContent = '—';
        stEl.textContent = 'artilheiro indisponível';
      }
    }
    // count-up compartilhado lê [data-count-to] (respeita prefers-reduced-motion).
    countUpAll(document.getElementById('wc-hero') ?? document);
  }

  // ── [01] Artilharia (top-10) ─────────────────────────────────
  function renderScorers(artil: ArtilheirosPayload | null): void {
    const body = el('wc-scorers-body'); if (!body) return;
    const scorers = artil?.scorers;
    if (!Array.isArray(scorers) || !scorers.length) {
      body.innerHTML = '<tr><td colspan="5" class="wc-error mono-label">artilharia indisponível — tente recarregar</td></tr>';
      return;
    }
    body.innerHTML = scorers.slice(0, 10).map((s, i) => {
      const rank = i + 1;
      const isGold = rank === 1;
      const flag = s.team?.flag ? esc(s.team.flag) : '';
      const teamCode = s.team?.code ? esc(s.team.code) : '';
      const teamName = s.team?.name ? esc(s.team.name) : '';
      const pen = s.penalties ?? 0;
      const flagCell = flag
        ? `<span class="wc-flag" aria-hidden="true">${flag}</span>`
        : `<span class="wc-flag wc-flag--empty" aria-hidden="true">—</span>`;
      const goldBadge = isGold ? ' <span class="wc-scorers-table__gold-badge" aria-label="Chuteira de Ouro">🏆 Ouro</span>' : '';
      return `
        <tr class="${isGold ? 'wc-scorers-table__row--gold' : ''}">
          <td class="wc-scorers-table__rank-cell">${rank}${goldBadge}</td>
          <td>
            <div class="wc-scorers-table__player-cell">
              ${flagCell}
              <span class="wc-scorers-table__name-block">
                <span class="wc-scorers-table__name">${esc(s.name)}</span>
                <span class="wc-scorers-table__sub">${teamName}</span>
              </span>
            </div>
          </td>
          <td><span class="mono-label" style="letter-spacing:var(--tracking-wide)">${teamCode}</span></td>
          <td class="wc-scorers-table__goals-cell">${s.goals}</td>
          <td class="wc-scorers-table__pen-cell">${pen}</td>
        </tr>`;
    }).join('');
  }

  // ── [02] Estatísticas — números-chave + doughnut 1º vs 2º tempo ──
  function renderStats(stats: EstatisticasPayload | null): void {
    const setTxt = (id: string, v: string): void => { const n = el(id); if (n) n.textContent = v; };
    if (!stats) {
      ['wc-stat-avg', 'wc-stat-bigwin', 'wc-stat-pen', 'wc-stat-og'].forEach((id) => setTxt(id, '—'));
      const box = el('wc-chart-halves'); if (box) box.innerHTML = '<p class="wc-error mono-label">dados indisponíveis — tente recarregar</p>';
      return;
    }

    setTxt('wc-stat-avg', (stats.avg_goals_per_match ?? 0).toFixed(2).replace('.', ','));
    setTxt('wc-stat-avg-sub', `${stats.total_goals ?? 0} gols no total`);
    setTxt('wc-stat-bigwin', stats.biggest_win?.match ?? '—');
    setTxt('wc-stat-bigwin-sub', stats.biggest_win?.diff != null ? `saldo de ${stats.biggest_win.diff}` : '');
    setTxt('wc-stat-pen', String(stats.penalties_scored ?? 0));
    setTxt('wc-stat-og', String(stats.own_goals ?? 0));

    const box = el('wc-chart-halves'); if (!box) return;
    const h1 = stats.goals_first_half ?? 0;
    const h2 = (stats.goals_second_half ?? 0) + (stats.goals_extra_time ?? 0);
    doughnutChart(box, {
      ariaLabel: 'Distribuição de gols por tempo: primeiro tempo versus segundo tempo mais prorrogação',
      segments: [
        { label: '1º tempo', value: h1, color: readToken('--wc-field-ink', '#0B6B2E') },
        { label: '2º tempo + prorrogação', value: h2, color: readToken('--wc-gold-ink', '#8A5A06') },
      ],
      valueFmt: (v) => `${v} gols`,
      centerLabel: String(h1 + h2),
      centerSub: 'gols',
      legend: true,
    });
  }

  async function loadWorldCup(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    cap1.resetCap1State(); // higiene de estado em re-entrada SPA

    const [
      partidas, artil, stats,
      noticias, simulacao, grupos, selecao, insights, jogadores, deep,
      classics, panorama, comparativo, idade, historia, contexto,
      fifaTeam, fifaPower,
    ] = await Promise.all([
      fetchJSON<cap1.PartidasPayload>(base, 'partidas.json'),
      fetchJSON<ArtilheirosPayload>(base, 'artilheiros.json'),
      fetchJSON<cap1.EstatisticasPayload>(base, 'estatisticas.json'),
      fetchJSON<cap1.NoticiasPayload>(base, 'noticias.json'),
      fetchJSON<cap1.SimulacaoPayload>(base, 'simulacao.json'),
      fetchJSON<cap1.GruposPayload>(base, 'grupos.json'),
      fetchJSON<cap1.SelecaoPayload>(base, 'selecao_copa.json'),
      fetchJSON<cap1.InsightsPayload>(base, 'insights.json'),
      fetchJSON<cap1.JogadoresPayload>(base, 'jogadores.json'),
      fetchJSON<cap1.DeepStatsPayload>(base, 'deepstats.json'),
      fetchJSON<any>(base, 'classics_2022.json'),
      fetchJSON<any>(base, 'copa2022_panorama.json'),
      fetchJSON<any>(base, 'comparativo_copas.json'),
      fetchJSON<any>(base, 'idade_copas.json'),
      fetchJSON<any>(base, 'historia_copas.json'),
      fetchJSON<any>(base, 'contexto_copas.json'),
      fetchJSON<any>(base, 'fifa_team_stats.json'),
      fetchJSON<any>(base, 'fifa_power_ranking.json'),
    ]);

    // ── Herói + KPIs + freshness/progress (esqueleto + cap1) ──
    safe('hero-kpis', () => renderHeroKPIs(partidas, artil, stats));
    safe('freshness', () => cap1.renderFreshness([partidas, artil, stats, noticias, simulacao, grupos, selecao, insights, jogadores, deep]));
    safe('progress', () => cap1.renderTournamentProgress(stats));

    // ── Capítulo 1 · A Copa 2026 ao vivo ──
    safe('news', () => cap1.renderNews(noticias));
    safe('scorers', () => renderScorers(artil));
    safe('stats', () => renderStats(stats));
    safe('stats-extra', () => cap1.renderStatsExtra(stats));

    // ── FIFA (dado oficial) ── entre Estatísticas [03] e Grupos [07] ──
    safe('fifa-team', () => renderFifaTeamStats(fifaTeam));
    safe('fifa-power', () => renderFifaPowerRanking(fifaPower));
    safe('fifa-compare', () => renderFifaCompare(fifaTeam));

    safe('groups', () => cap1.renderGroups(grupos));
    safe('bracket', () => cap1.renderBracket(partidas));
    safe('probs', () => cap1.renderProbabilities(simulacao));
    safe('matches', () => cap1.renderMatches(partidas));
    safe('deepstats', () => cap1.setupDeepStats(deep));
    safe('selection', () => cap1.renderSelection(selecao));
    safe('insights', () => cap1.renderInsights(insights));
    safe('bolao', () => cap1.renderBolao(partidas));
    safe('game', () => cap1.setupGame(jogadores));
    safe('team-filter', () => cap1.setupTeamFilter()); // DEPOIS de renderMatches

    // ── Capítulo 2 + 3 · 2022 / histórico (cap23) ──
    safe('classics', () => renderClassics(classics));
    safe('panorama', () => renderPanorama(panorama));
    safe('comparativo', () => renderComparativo(comparativo, idade));
    safe('historia', () => renderHistoria(historia, contexto));
  }

  // astro:page-load (não DOMContentLoaded): 1º load + toda navegação SPA.
  // Guard #wc-hero evita fetch em outras páginas (o listener persiste no document).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('wc-hero')) return;
    loadWorldCup();
  });
</script>

<script>
  // Motion — padrões nomeados (GSAP + ScrollTrigger), guardados por motionOk
  // (respeita prefers-reduced-motion): `resolve` no herói, `reveal-up` por seção.
  import { revealUp } from '../scripts/motion/reveal-up';
  import { resolveHero } from '../scripts/motion/resolve';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  function animateWorldCup(): void {
    if (!motionOk) return;
    if (!document.getElementById('wc-hero')) return;
    const heroCard = document.querySelector('#wc-hero .wc-hero__card') as HTMLElement | null;
    if (heroCard) resolveHero(heroCard);
    document.querySelectorAll<HTMLElement>('main section[id]').forEach((sec) => {
      if (sec.id === 'wc-hero') return; // herói já animado pelo resolve
      const head = sec.querySelector('.section-head') as HTMLElement | null;
      if (head) revealUp([head], sec, 0);
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.wc-kpi, .wc-scorers-wrap, .wc-stat-card, .wc-cl-block, .wc-c22-block, .wc-insight-card, .wc-c22-context-card, .wc-group-card, .wc-prob-row, .wc-news-item, .wc-match, .wc-bolao-item, .wc-player-card, .wc-stat-compare'));
      if (cards.length) revealUp(cards, sec, STAGGER.tight);
    });
  }
  document.addEventListener('astro:page-load', animateWorldCup);
</script>

<script>
  // Jump-nav — rail de pontos (desktop) + FAB/bottom-sheet (mobile). Lê as seções
  // desta página; auto-numera. Active via IntersectionObserver. Portado do
  // world-cup-dashboard/jumpnav.js (renomeado el-→wc-).
  const NAV = [
    { id: 'wc-hero',            fb: 'Início' },
    { id: 'noticias',           fb: 'Notícias' },
    { id: 'artilheiros',        fb: 'Artilharia' },
    { id: 'estatisticas',       fb: 'Estatísticas' },
    { id: 'fifa-team-stats',    fb: 'Estatísticas FIFA' },
    { id: 'fifa-power-ranking', fb: 'Power Ranking' },
    { id: 'fifa-compare',       fb: 'Comparador' },
    { id: 'grupos',             fb: 'Grupos' },
    { id: 'mata-mata',          fb: 'Mata-mata' },
    { id: 'monte-carlo',        fb: 'Monte Carlo' },
    { id: 'partidas',           fb: 'Partidas' },
    { id: 'shot-map',           fb: 'Finalizações' },
    { id: 'pass-network',       fb: 'Posse e Passes' },
    { id: 'momentum',           fb: 'Trajetória' },
    { id: 'selecao-copa',       fb: 'Seleção da Copa' },
    { id: 'insights',           fb: 'Insights' },
    { id: 'bolao',              fb: 'Bolão' },
    { id: 'craque',             fb: 'Quem é o craque?' },
    { id: 'wc-classics',        fb: 'Clássicos 2022' },
    { id: 'copa2022-panorama',  fb: 'Panorama 2022' },
    { id: 'comparativo-copas',  fb: '2022 × 2026' },
    { id: 'historia-copas',     fb: 'História' },
  ];
  const jesc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
  const jReduce = (): boolean => matchMedia('(prefers-reduced-motion: reduce)').matches;
  const jMobile = (): boolean => matchMedia('(max-width: 1023px)').matches;
  let backdrop: HTMLElement | null = null;

  function jRenderList(): void {
    const list = document.getElementById('wc-jumpnav-list'); if (!list) return;
    const items = NAV.filter((n) => document.getElementById(n.id));
    list.innerHTML = items.map((n, i) => `
      <li class="wc-jumpnav__item">
        <a href="#${n.id}" class="wc-jumpnav__link" data-target="${n.id}" aria-current="false">
          <span class="wc-jumpnav__label">${jesc(n.fb)}</span>
          <span class="wc-jumpnav__bullet" aria-hidden="true"></span>
          <span class="wc-jumpnav__num">${String(i + 1).padStart(2, '0')}</span>
        </a>
      </li>`).join('');
  }
  function jSetActive(id: string): void {
    document.querySelectorAll('.wc-jumpnav__link').forEach((l) => {
      const on = (l as HTMLElement).dataset.target === id;
      if (l.getAttribute('aria-current') !== String(on)) l.setAttribute('aria-current', String(on));
    });
  }
  function jEnsureBackdrop(): HTMLElement {
    if (backdrop) return backdrop;
    backdrop = document.createElement('div');
    backdrop.className = 'wc-jumpnav-backdrop';
    backdrop.setAttribute('aria-hidden', 'true');
    backdrop.addEventListener('click', jCloseSheet);
    document.body.appendChild(backdrop);
    return backdrop;
  }
  function jOpenSheet(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => jEnsureBackdrop().classList.add('is-visible'));
    document.body.style.overflow = 'hidden';
  }
  function jCloseSheet(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    fab.setAttribute('aria-expanded', 'false');
    backdrop?.classList.remove('is-visible');
    setTimeout(() => { if (fab.getAttribute('aria-expanded') === 'false') (nav as HTMLElement).hidden = true; }, 250);
    document.body.style.overflow = '';
  }
  function initJumpnav(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    if (!document.getElementById('wc-hero')) return;
    jRenderList();
    document.getElementById('wc-jumpnav-list')!.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.wc-jumpnav__link') as HTMLElement | null;
      if (!link) return;
      e.preventDefault();
      const id = link.dataset.target!; const target = document.getElementById(id); if (!target) return;
      const go = () => { target.scrollIntoView({ behavior: jReduce() ? 'auto' : 'smooth', block: 'start' }); history.replaceState(null, '', '#' + id); };
      if (jMobile() && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); setTimeout(go, jReduce() ? 0 : 260); } else go();
      jSetActive(id);
    });
    fab.addEventListener('click', () => (fab.getAttribute('aria-expanded') === 'true' ? jCloseSheet() : jOpenSheet()));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); fab.focus(); } });
    matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) { (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'false'); backdrop?.classList.remove('is-visible'); document.body.style.overflow = ''; }
      else { fab.setAttribute('aria-expanded', 'false'); (nav as HTMLElement).hidden = true; }
    });
    const els = NAV.map((n) => document.getElementById(n.id)).filter(Boolean) as HTMLElement[];
    if (els[0]) jSetActive(els[0].id);
    const obs = new IntersectionObserver((ents) => {
      const vis = ents.filter((x) => x.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (vis[0]) jSetActive(vis[0].target.id);
    }, { rootMargin: '-30% 0px -50% 0px', threshold: [0, 0.1, 0.3, 0.5, 1] });
    els.forEach((element) => obs.observe(element));
    if (jMobile()) { (fab as HTMLElement).hidden = false; (nav as HTMLElement).hidden = true; }
    else { (nav as HTMLElement).hidden = false; (fab as HTMLElement).hidden = true; }
  }
  document.addEventListener('astro:page-load', initJumpnav);
</script>
