  .wc-team-chip__clear:hover { background: var(--wc-live-dim); }
  .wc-match.is-highlighted { border-color: var(--wc-field-line); box-shadow: inset 3px 0 0 var(--wc-field); }
  .wc-news-link.is-highlighted { border-color: var(--wc-field-line); box-shadow: inset 3px 0 0 var(--wc-field); }
  .is-dimmed { opacity: 0.32; }
  @media (prefers-reduced-motion: reduce) { .is-dimmed, .wc-match.is-highlighted, .wc-news-link.is-highlighted { transition: none; } }

  /* ════════════════ [04] Grupos ════════════════ */
  .wc-groups-section { background: var(--paper-soft); }
  /* Calha à direita p/ a dock fixa do jumpnav (só onde ela aparece, ≥1024px):
     evita que a 4ª coluna de grupos / a coluna B do bracket fiquem sob o rail. */
  @media (min-width: 1024px) {
    .wc-groups-section .container,
