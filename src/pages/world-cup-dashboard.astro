  .wc-bracket-mobile summary { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); padding: var(--space-3) var(--space-4); cursor: pointer; list-style: none; background: var(--paper-soft); border-bottom: 1px solid transparent; transition: background var(--transition-fast); }
  .wc-bracket-mobile summary::-webkit-details-marker { display: none; }
  .wc-bracket-mobile summary:hover { background: var(--paper-card); }
  .wc-bracket-mobile details[open] summary { border-bottom-color: var(--line); }
  .wc-bracket-mobile summary .mono-label { color: var(--wc-gold-ink); }
  .wc-bracket-mobile summary .mono-label::before, .wc-bracket-mobile summary .mono-label::after { color: var(--wc-gold-ink); }
  .wc-bracket-mobile__round { display: flex; flex-direction: column; gap: var(--space-2); }
  .wc-bracket-mobile__round-head { color: var(--ink-faint); }
  .wc-bracket-mobile__body { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-3); }
  @media (min-width: 1024px) { .wc-bracket-mobile { display: none; } }

  /* ════════════════ [11] Seleção da Copa ════════════════ */
  .wc-selection-section { background: var(--paper-soft); }
  .wc-selection-wrap { display: flex; flex-direction: column; gap: var(--space-6); align-items: center; }
  .wc-pitch { position: relative; width: 100%; max-width: 480px; aspect-ratio: 3 / 4; background: var(--paper-soft); background-image: repeating-linear-gradient(180deg, transparent 0 40px, var(--wc-field-dim) 40px 80px); border: 1px solid var(--wc-field-line); border-radius: var(--radius-md); display: grid; grid-template-rows: 1fr repeat(4, 1fr); padding: var(--space-3); gap: var(--space-2); overflow: hidden; }
  .wc-pitch::before { content: ''; position: absolute; top: var(--space-3); left: 50%; transform: translateX(-50%); width: 40%; height: 24px; border: 1px solid var(--wc-field-line); border-bottom: none; border-radius: 4px 4px 0 0; pointer-events: none; }
  .wc-pitch__row { display: grid; gap: var(--space-3); align-items: center; justify-items: center; }
