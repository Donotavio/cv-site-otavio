  @keyframes wc-trophy-pulse { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }
  @media (prefers-reduced-motion: reduce) { .wc-bracket-tree__trophy { animation: none; } }
  @media (max-width: 1023px) { .wc-bracket-tree { display: none; } }
  @media (min-width: 1024px) and (max-width: 1439px) { .wc-bracket-tree { overflow-x: auto; min-width: 0; } .wc-bracket-tree__cols { min-width: 540px; } }
  .wc-bracket-match { position: relative; display: flex; flex-direction: column; gap: 2px; min-height: 48px; padding: var(--space-2) var(--space-3); background: var(--paper-card); border: 1px solid var(--line); border-left: 3px solid transparent; border-radius: var(--radius-sm); font-family: var(--font-sans); transition: border-color var(--transition-fast), background var(--transition-fast); }
  .wc-bracket-match:hover { border-color: var(--line-strong); }
  .wc-bracket-match--empty { background: transparent; border: 1px dashed var(--line); min-height: 48px; visibility: hidden; }
  .wc-bracket-match__row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); font-size: var(--text-xs); min-width: 0; }
  .wc-bracket-match__team { display: flex; align-items: center; gap: var(--space-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .wc-bracket-match__flag { font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; font-size: var(--text-sm); line-height: 1; flex-shrink: 0; }
  .wc-bracket-match__name { font-size: var(--text-xs); font-weight: 500; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .wc-bracket-match__name--winner { color: var(--ink); font-weight: 700; }
  .wc-bracket-match__name--loser { color: var(--ink-faint); }
  .wc-bracket-match__name--placeholder { color: var(--ink-faint); font-style: italic; font-weight: 400; }
  .wc-bracket-match__score { font-family: var(--font-mono); font-size: var(--text-xs); font-variant-numeric: var(--num-tabular); font-weight: 500; flex-shrink: 0; }
  .wc-bracket-match__score--winner { color: var(--ink); font-weight: 700; }
  .wc-bracket-match__score--loser { color: var(--ink-faint); }
  .wc-bracket-match__score--pending { font-size: 10px; color: var(--ink-faint); letter-spacing: var(--tracking-wide); }
  .wc-bracket-match.is-today { box-shadow: inset 3px 0 0 var(--wc-live); background: var(--wc-live-dim); }
  .wc-bracket-match__today-tag { display: inline-flex; align-items: center; gap: 4px; margin-top: 2px; font-family: var(--font-mono); font-size: 9px; letter-spacing: var(--tracking-wide); color: var(--wc-live-ink); text-transform: uppercase; }
  .wc-bracket-match__today-tag::before { content: ''; width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--wc-live); }
  .wc-bracket-match.is-final-done { background: var(--wc-gold-dim); border-color: var(--wc-gold-line); }
  .wc-bracket-mobile { display: flex; flex-direction: column; gap: var(--space-4); }
