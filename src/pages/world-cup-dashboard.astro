    vertical-align: middle;
  }
  #fifa-power-body :global(tr:last-child td), #fifa-gk-body :global(tr:last-child td) { border-bottom: none; }
  #fifa-power-body :global(tr), #fifa-gk-body :global(tr) { transition: background var(--transition-fast); }
  #fifa-power-body :global(tr:hover), #fifa-gk-body :global(tr:hover) { background: var(--paper-soft); }
  #fifa-power-body :global(.wc-scorers-table__rank-cell), #fifa-gk-body :global(.wc-scorers-table__rank-cell) { font-family: var(--font-mono); font-weight: 500; text-align: right; color: var(--ink-faint); }
  #fifa-power-body :global(.wc-scorers-table__player-cell), #fifa-gk-body :global(.wc-scorers-table__player-cell) { display: flex; align-items: center; gap: var(--space-3); }
  #fifa-power-body :global(.wc-scorers-table__name), #fifa-gk-body :global(.wc-scorers-table__name) { font-weight: 500; color: var(--ink); }
  #fifa-power-body :global(.wc-scorers-table__name-block), #fifa-gk-body :global(.wc-scorers-table__name-block) { display: flex; flex-direction: column; gap: 2px; }
  #fifa-power-body :global(.wc-scorers-table__sub), #fifa-gk-body :global(.wc-scorers-table__sub) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); letter-spacing: var(--tracking-wide); }
  #fifa-power-body :global(.wc-flag), #fifa-gk-body :global(.wc-flag) { font-size: var(--text-xl); line-height: 1; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif; }
  #fifa-power-body :global(.wc-scorers-table__goals-cell), #fifa-gk-body :global(.wc-scorers-table__goals-cell) { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 500; text-align: right; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  #fifa-power-body :global(.wc-scorers-table__pen-cell) { font-family: var(--font-mono); font-size: var(--text-xs); text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); }
  #fifa-power-body :global(tr.wc-scorers-table__row--gold td), #fifa-gk-body :global(tr.wc-scorers-table__row--gold td) { background: var(--wc-gold-dim); border-bottom-color: var(--wc-gold-line); }
  #fifa-power-body :global(tr.wc-scorers-table__row--gold .wc-scorers-table__rank-cell), #fifa-gk-body :global(tr.wc-scorers-table__row--gold .wc-scorers-table__rank-cell) { color: var(--wc-gold-ink); font-weight: 500; }
  #fifa-power-body :global(.wc-scorers-table__gold-badge) {
    display: inline-block;
    margin-left: var(--space-2);
    padding: 1px var(--space-2);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    color: var(--wc-gold-ink);
    background: var(--paper-card);
    border: 1px solid var(--wc-gold-line);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    vertical-align: middle;
  }

  /* ── Divisor de capítulo (NÃO é section[id] → jumpnav ignora) ── */
  .wc-chapter { max-width: var(--container-max, 1200px); margin: 0 auto; padding: var(--space-10) var(--space-6) var(--space-4); display: flex; flex-direction: column; gap: var(--space-3); }
  @media (min-width: 640px)  { .wc-chapter { padding-inline: var(--space-8); } }
  @media (min-width: 1024px) { .wc-chapter { padding-inline: var(--space-12); } }
  .wc-chapter .mono-label { color: var(--wc-gold-ink); }
  .wc-chapter hr { border: 0; border-top: 1px solid var(--wc-gold-line); margin: 0; }

  /* ── Estatísticas ── */
  .wc-stats-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); margin-top: var(--space-8); }
  @media (min-width: 1024px) { .wc-stats-grid { grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr); align-items: start; } }
  .wc-stat-bento { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  .wc-stat-card {
    position: relative;
    background: var(--paper-card);
