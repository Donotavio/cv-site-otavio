    :global(.wc-jumpnav__link) { width: 100%; padding: var(--space-3) var(--space-2); font-size: var(--text-sm); }
    :global(.wc-jumpnav__label) { opacity: 1; transform: none; box-shadow: none; background: transparent; padding: 0; flex: 1; text-align: left; }
    :global(.wc-jumpnav__num) { display: inline-block; font-family: var(--font-mono); color: var(--jn-ink); margin-right: var(--space-3); }
    :global(.wc-jumpnav__bullet) { display: none; }
    :global(.wc-jumpnav__link[aria-current="true"]) { background: var(--wc-gold-dim); color: var(--jn-ink-active); border-radius: var(--radius-sm); }
