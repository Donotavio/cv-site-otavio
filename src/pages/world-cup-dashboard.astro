<script>
  // Dashboard da Copa 2026 — hidrata Hero+KPIs, Artilharia e Estatísticas a
  // partir de assets/data/worldcup/*.json. Fetch runtime (base do body, no-cache,
  // AbortController, fail-soft). SPA-safe: bootstrap em astro:page-load.
  import { countUpAll } from '../scripts/motion/count-up';
  import { doughnutChart, readToken } from '../scripts/worldcup/charts';

  interface Team { name?: string; code?: string; flag?: string }
  interface Scorer { name: string; team?: Team; goals: number; penalties?: number }
  interface PartidasPayload { total?: number }
  interface ArtilheirosPayload { scorers?: Scorer[] }
  interface EstatisticasPayload {
    total_goals?: number;
    avg_goals_per_match?: number;
    goals_first_half?: number;
    goals_second_half?: number;
    goals_extra_time?: number;
    penalties_scored?: number;
    own_goals?: number;
    biggest_win?: { match?: string; diff?: number } | null;
  }

  const el = (id: string): HTMLElement | null => document.getElementById(id);
  const esc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

  function safe(label: string, fn: () => void): void {
    try { fn(); } catch (e) { console.error(`[world-cup] render "${label}" falhou:`, e); }
  }

  async function fetchJSON<T>(base: string, file: string, ms = 8000): Promise<T | null> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), ms);
    try {
      const res = await fetch(`${base}assets/data/worldcup/${file}`, { cache: 'no-cache', signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) return null;
      return (await res.json()) as T;
    } catch { clearTimeout(timeoutId); return null; }
  }

  // ── Hero + KPIs ──────────────────────────────────────────────
  function renderHeroKPIs(partidas: PartidasPayload | null, artil: ArtilheirosPayload | null, stats: EstatisticasPayload | null): void {
    const matches = partidas?.total ?? 0;
    const goals = stats?.total_goals ?? 0;
    const avg = stats?.avg_goals_per_match ?? 0;

    const mEl = el('kpi-total-matches'); if (mEl) mEl.dataset.countTo = String(matches);
    const gEl = el('kpi-total-goals'); if (gEl) gEl.dataset.countTo = String(goals);
    const aEl = el('kpi-avg-goals'); if (aEl) { aEl.dataset.countTo = String(avg); aEl.dataset.countDecimals = '2'; }

    const sEl = el('kpi-top-scorer'), stEl = el('kpi-top-scorer-team');
    const top = artil?.scorers?.[0];
    if (sEl && stEl) {
      if (top) {
        sEl.textContent = top.name;
        const parts: string[] = [];
        if (top.team?.flag) parts.push(top.team.flag);
        if (top.team?.code) parts.push(top.team.code);
        parts.push(`${top.goals} gols`);
        stEl.textContent = parts.join(' · ');
      } else {
        sEl.textContent = '—';
        stEl.textContent = 'artilheiro indisponível';
      }
    }
    // count-up compartilhado lê [data-count-to] (respeita prefers-reduced-motion).
    countUpAll(document.getElementById('wc-hero') ?? document);
  }

  // ── [01] Artilharia (top-10) ─────────────────────────────────
  function renderScorers(artil: ArtilheirosPayload | null): void {
    const body = el('wc-scorers-body'); if (!body) return;
    const scorers = artil?.scorers;
    if (!Array.isArray(scorers) || !scorers.length) {
      body.innerHTML = '<tr><td colspan="5" class="wc-error mono-label">artilharia indisponível — tente recarregar</td></tr>';
      return;
    }
    body.innerHTML = scorers.slice(0, 10).map((s, i) => {
      const rank = i + 1;
      const isGold = rank === 1;
      const flag = s.team?.flag ? esc(s.team.flag) : '';
      const teamCode = s.team?.code ? esc(s.team.code) : '';
      const teamName = s.team?.name ? esc(s.team.name) : '';
      const pen = s.penalties ?? 0;
      const flagCell = flag
        ? `<span class="wc-flag" aria-hidden="true">${flag}</span>`
        : `<span class="wc-flag wc-flag--empty" aria-hidden="true">—</span>`;
      const goldBadge = isGold ? ' <span class="wc-scorers-table__gold-badge" aria-label="Chuteira de Ouro">🏆 Ouro</span>' : '';
      return `
        <tr class="${isGold ? 'wc-scorers-table__row--gold' : ''}">
          <td class="wc-scorers-table__rank-cell">${rank}${goldBadge}</td>
          <td>
            <div class="wc-scorers-table__player-cell">
              ${flagCell}
              <span class="wc-scorers-table__name-block">
                <span class="wc-scorers-table__name">${esc(s.name)}</span>
                <span class="wc-scorers-table__sub">${teamName}</span>
              </span>
            </div>
          </td>
          <td><span class="mono-label" style="letter-spacing:var(--tracking-wide)">${teamCode}</span></td>
          <td class="wc-scorers-table__goals-cell">${s.goals}</td>
          <td class="wc-scorers-table__pen-cell">${pen}</td>
        </tr>`;
    }).join('');
  }

  // ── [02] Estatísticas — números-chave + doughnut 1º vs 2º tempo ──
  function renderStats(stats: EstatisticasPayload | null): void {
    const setTxt = (id: string, v: string): void => { const n = el(id); if (n) n.textContent = v; };
    if (!stats) {
      ['wc-stat-avg', 'wc-stat-bigwin', 'wc-stat-pen', 'wc-stat-og'].forEach((id) => setTxt(id, '—'));
      const box = el('wc-chart-halves'); if (box) box.innerHTML = '<p class="wc-error mono-label">dados indisponíveis — tente recarregar</p>';
      return;
    }

    setTxt('wc-stat-avg', (stats.avg_goals_per_match ?? 0).toFixed(2).replace('.', ','));
    setTxt('wc-stat-avg-sub', `${stats.total_goals ?? 0} gols no total`);
    setTxt('wc-stat-bigwin', stats.biggest_win?.match ?? '—');
    setTxt('wc-stat-bigwin-sub', stats.biggest_win?.diff != null ? `saldo de ${stats.biggest_win.diff}` : '');
    setTxt('wc-stat-pen', String(stats.penalties_scored ?? 0));
    setTxt('wc-stat-og', String(stats.own_goals ?? 0));

    const box = el('wc-chart-halves'); if (!box) return;
    const h1 = stats.goals_first_half ?? 0;
    const h2 = (stats.goals_second_half ?? 0) + (stats.goals_extra_time ?? 0);
    doughnutChart(box, {
      ariaLabel: 'Distribuição de gols por tempo: primeiro tempo versus segundo tempo mais prorrogação',
      segments: [
        { label: '1º tempo', value: h1, color: readToken('--wc-field-ink', '#0B6B2E') },
        { label: '2º tempo + prorrogação', value: h2, color: readToken('--wc-gold-ink', '#8A5A06') },
      ],
      valueFmt: (v) => `${v} gols`,
      centerLabel: String(h1 + h2),
      centerSub: 'gols',
      legend: true,
    });
  }

  async function loadWorldCup(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const [partidas, artil, stats] = await Promise.all([
      fetchJSON<PartidasPayload>(base, 'partidas.json'),
      fetchJSON<ArtilheirosPayload>(base, 'artilheiros.json'),
      fetchJSON<EstatisticasPayload>(base, 'estatisticas.json'),
    ]);
    safe('hero-kpis', () => renderHeroKPIs(partidas, artil, stats));
    safe('scorers', () => renderScorers(artil));
    safe('stats', () => renderStats(stats));
  }

  // astro:page-load (não DOMContentLoaded): 1º load + toda navegação SPA.
  // Guard #wc-hero evita fetch em outras páginas (o listener persiste no document).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('wc-hero')) return;
    loadWorldCup();
  });
</script>

<script>
  // Motion — padrões nomeados (GSAP + ScrollTrigger), guardados por motionOk
  // (respeita prefers-reduced-motion): `resolve` no herói, `reveal-up` por seção.
  import { revealUp } from '../scripts/motion/reveal-up';
  import { resolveHero } from '../scripts/motion/resolve';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  function animateWorldCup(): void {
    if (!motionOk) return;
    if (!document.getElementById('wc-hero')) return;
    const heroCard = document.querySelector('#wc-hero .wc-hero__card') as HTMLElement | null;
    if (heroCard) resolveHero(heroCard);
    document.querySelectorAll<HTMLElement>('main section[id]').forEach((sec) => {
      if (sec.id === 'wc-hero') return; // herói já animado pelo resolve
      const head = sec.querySelector('.section-head') as HTMLElement | null;
      if (head) revealUp([head], sec, 0);
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.wc-kpi, .wc-scorers-wrap, .wc-stat-card'));
      if (cards.length) revealUp(cards, sec, STAGGER.tight);
    });
  }
  document.addEventListener('astro:page-load', animateWorldCup);
</script>

<script>
  // Jump-nav — rail de pontos (desktop) + FAB/bottom-sheet (mobile). Lê as seções
  // desta página; auto-numera. Active via IntersectionObserver. Portado do
  // world-cup-dashboard/jumpnav.js (renomeado el-→wc-).
  const NAV = [
    { id: 'wc-hero',       fb: 'Início' },
    { id: 'artilheiros',   fb: 'Artilharia' },
    { id: 'estatisticas',  fb: 'Estatísticas' },
  ];
  const jesc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
  const jReduce = (): boolean => matchMedia('(prefers-reduced-motion: reduce)').matches;
  const jMobile = (): boolean => matchMedia('(max-width: 1023px)').matches;
  let backdrop: HTMLElement | null = null;

  function jRenderList(): void {
    const list = document.getElementById('wc-jumpnav-list'); if (!list) return;
    const items = NAV.filter((n) => document.getElementById(n.id));
    list.innerHTML = items.map((n, i) => `
      <li class="wc-jumpnav__item">
        <a href="#${n.id}" class="wc-jumpnav__link" data-target="${n.id}" aria-current="false">
          <span class="wc-jumpnav__label">${jesc(n.fb)}</span>
          <span class="wc-jumpnav__bullet" aria-hidden="true"></span>
          <span class="wc-jumpnav__num">${String(i + 1).padStart(2, '0')}</span>
        </a>
      </li>`).join('');
  }
  function jSetActive(id: string): void {
    document.querySelectorAll('.wc-jumpnav__link').forEach((l) => {
      const on = (l as HTMLElement).dataset.target === id;
      if (l.getAttribute('aria-current') !== String(on)) l.setAttribute('aria-current', String(on));
    });
  }
  function jEnsureBackdrop(): HTMLElement {
    if (backdrop) return backdrop;
    backdrop = document.createElement('div');
    backdrop.className = 'wc-jumpnav-backdrop';
    backdrop.setAttribute('aria-hidden', 'true');
    backdrop.addEventListener('click', jCloseSheet);
    document.body.appendChild(backdrop);
    return backdrop;
  }
  function jOpenSheet(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => jEnsureBackdrop().classList.add('is-visible'));
    document.body.style.overflow = 'hidden';
  }
  function jCloseSheet(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    fab.setAttribute('aria-expanded', 'false');
    backdrop?.classList.remove('is-visible');
    setTimeout(() => { if (fab.getAttribute('aria-expanded') === 'false') (nav as HTMLElement).hidden = true; }, 250);
    document.body.style.overflow = '';
  }
  function initJumpnav(): void {
    const nav = document.getElementById('wc-jumpnav'), fab = document.getElementById('wc-jumpnav-fab');
    if (!nav || !fab) return;
    if (!document.getElementById('wc-hero')) return;
    jRenderList();
    document.getElementById('wc-jumpnav-list')!.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.wc-jumpnav__link') as HTMLElement | null;
      if (!link) return;
      e.preventDefault();
      const id = link.dataset.target!; const target = document.getElementById(id); if (!target) return;
      const go = () => { target.scrollIntoView({ behavior: jReduce() ? 'auto' : 'smooth', block: 'start' }); history.replaceState(null, '', '#' + id); };
      if (jMobile() && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); setTimeout(go, jReduce() ? 0 : 260); } else go();
      jSetActive(id);
    });
    fab.addEventListener('click', () => (fab.getAttribute('aria-expanded') === 'true' ? jCloseSheet() : jOpenSheet()));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); fab.focus(); } });
    matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) { (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'false'); backdrop?.classList.remove('is-visible'); document.body.style.overflow = ''; }
      else { fab.setAttribute('aria-expanded', 'false'); (nav as HTMLElement).hidden = true; }
    });
    const els = NAV.map((n) => document.getElementById(n.id)).filter(Boolean) as HTMLElement[];
    if (els[0]) jSetActive(els[0].id);
    const obs = new IntersectionObserver((ents) => {
      const vis = ents.filter((x) => x.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (vis[0]) jSetActive(vis[0].target.id);
    }, { rootMargin: '-30% 0px -50% 0px', threshold: [0, 0.1, 0.3, 0.5, 1] });
    els.forEach((element) => obs.observe(element));
    if (jMobile()) { (fab as HTMLElement).hidden = false; (nav as HTMLElement).hidden = true; }
    else { (nav as HTMLElement).hidden = false; (fab as HTMLElement).hidden = true; }
  }
  document.addEventListener('astro:page-load', initJumpnav);
</script>
