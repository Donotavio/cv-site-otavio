  @media (prefers-reduced-motion: reduce) { .wc-mc-info-btn { transition: none; } .wc-mc-info-btn:active { transform: none; } .wc-mc-modal__body > * { animation: none; } }

  /* ════════════════ [07] Partidas ════════════════ */
  .wc-matches-section { background: var(--paper); }
