    align-items: center;
  }

  /* Governança de cor da página: .btn-primary/.btn-secondary (globais)
     hover em --accent azul por padrão — nesta página o único acento é
     verde, então sobrescrevemos o hover aqui (escopo automático do Astro
     restringe isso só a este arquivo, não afeta o site principal). */
  .hero-actions .btn-primary:hover {
    background: var(--pix-green-ink);
    border-color: var(--pix-green-ink);
  }
  .hero-actions .btn-secondary:hover {
    border-color: var(--pix-green-ink);
    color: var(--pix-green-ink);
  }

  /* Tags "accent" (azul, global) usadas nos insight cards — mesma
     governança: verde substitui azul dentro desta página. O escopo
     automático do Astro restringe esta regra só aos elementos renderizados
     por este arquivo (não afeta .tag--accent no site principal). */
  .tag--accent {
    color: var(--pix-green-ink);
    border-color: var(--pix-green-line);
    background: var(--pix-green-dim);
  }

  /* ── KPI Dashboard section ───────────────────────────────── */
  .pix-dashboard {
    background: var(--paper-soft);
  }

  .pix-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .pix-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  /* ── Bento ───────────────────────────────────────────────── */
  .pix-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-block-end: var(--space-12);
  }

  @media (min-width: 640px) {
    .pix-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
    .pix-metric--hero {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .pix-bento {
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(150px, auto);
      gap: var(--space-5);
    }
    /* dominante: 7 col × 2 rows */
    .pix-metric--hero {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }
    /* sec cards stack right */
    .pix-metric--sec:nth-child(2) {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }
    .pix-metric--sec:nth-child(3) {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }
    /* wide metric full row */
    .pix-metric--wide {
      grid-column: 1 / 13;
      grid-row: 3 / 4;
    }
    /* pipeline strip full row */
    .pix-pipeline-strip {
      grid-column: 1 / 13;
    }
  }

  /* ── Metric card ─────────────────────────────────────────── */
  .pix-metric {
    position: relative;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-3);
    transition: border-color var(--transition-normal);
  }

  .pix-metric:hover {
    border-color: var(--line-strong);
  }

  .pix-metric--hero {
    padding: var(--space-8);
    justify-content: space-between;
  }

  .pix-metric--wide {
    flex-direction: column;
  }

  @media (min-width: 640px) {
    .pix-metric--wide {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .pix-metric__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .pix-metric__index {
    color: var(--ink-faint);
  }

  .pix-metric__spark {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--pix-green-ink);
    letter-spacing: 0.08em;
    line-height: 1;
    opacity: 0.85;
  }

  .pix-metric__spark--sm {
    font-size: var(--text-sm);
  }

  .pix-metric__value {
    /* pix-green (não --accent azul) — governança de cor da página: verde é
       o único acento de dado/KPI aqui, azul fica reservado à navegação
       global do site. --text-3xl é "large text" (≥24px) — 3.1:1 passa AA. */
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--pix-green);
    line-height: 0.95;
    letter-spacing: var(--tracking-tight);
  }

  .pix-metric__value--hero {
    font-size: var(--display-1);
    line-height: 0.9;
  }

  /* dominant KPI in pix-green */
  .pix-metric__value--green {
    color: var(--pix-green);
  }

  .pix-metric__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
  }

  /* ── Métricas secundárias (sm) ──────────────────────────── */
  .pix-metric--sm {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: border-color var(--transition-normal);
  }

  .pix-metric--sm:hover {
    border-color: var(--pix-green-line);
  }

  @media (min-width: 1024px) {
    /* segunda linha de 4 cards pequenos após a linha principal */
    .pix-metric--sm:nth-child(5) { grid-column: 1 / 4; }
    .pix-metric--sm:nth-child(6) { grid-column: 4 / 7; }
    .pix-metric--sm:nth-child(7) { grid-column: 7 / 10; }
    .pix-metric--sm:nth-child(8) { grid-column: 10 / 13; }
  }

  /* ── Gráfico ASCII de crescimento ────────────────────────── */
  .pix-growth-chart {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-block-start: var(--space-6);
  }

  .pix-growth-chart__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .pix-growth-chart__unit {
    color: var(--pix-green-ink);
  }

  .pix-growth-chart__body {
    overflow-x: auto;
    padding-block: var(--space-2);
  }

  .pix-growth-chart__bars {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--pix-green-ink);
    margin: 0;
    white-space: pre;
  }

  .pix-growth-chart__legend {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block-start: var(--space-4);
    border-top: 1px solid var(--line);
  }

  .pix-growth-chart__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wide);
  }

  .pix-growth-chart__milestones {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Widget de notícias ──────────────────────────────────── */
  .pix-news {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-block-start: var(--space-6);
  }

  .pix-news__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-block-end: var(--space-4);
    border-bottom: 1px solid var(--line);
  }

  .pix-news__title-wrap {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .pix-news__feed {
    color: var(--ink-faint);
  }

  .pix-news__live-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--pix-green);
    flex-shrink: 0;
    animation: news-pulse 2s ease-in-out infinite;
  }

  @keyframes news-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.35; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pix-news__live-dot { animation: none; }
  }

  /* Lista: grid de 2 colunas no desktop, 1 no mobile.
     (Os itens/filhos desta lista são injetados via innerHTML em runtime —
     ver bloco <style is:global> ao final do arquivo: CSS scoped do Astro
     não se aplica a nós DOM criados no client, só aos renderizados no SSG.) */
  .pix-news__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: news;
  }

  @media (min-width: 768px) {
    .pix-news__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  /* ── Pipeline strip card ─────────────────────────────────── */
  .pix-pipeline-strip {
    position: relative;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .pix-pipeline-strip__label {
    margin: 0;
    color: var(--ink-faint);
  }

  .pix-pipeline-strip__flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .pix-pipeline-strip__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pix-pipeline-strip__badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    font-size: var(--text-xs);
  }

  .pix-pipeline-strip__badge--bronze {
    color: var(--medallion-bronze-ink);
    border-color: var(--medallion-bronze-line);
    background: var(--medallion-bronze-dim);
  }

  .pix-pipeline-strip__badge--silver {
    color: var(--medallion-silver-ink);
    border-color: var(--medallion-silver-line);
    background: var(--medallion-silver-dim);
  }

  .pix-pipeline-strip__badge--gold {
    color: var(--medallion-gold-ink);
    border-color: var(--medallion-gold-line);
    background: var(--medallion-gold-dim);
  }

  .pix-pipeline-strip__badge--gh {
    color: var(--pix-green-ink);
    border-color: var(--pix-green-line);
    background: var(--pix-green-dim);
  }

  .pix-pipeline-strip__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .pix-pipeline-strip__arrow {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--ink-faint);
    flex-shrink: 0;
    align-self: center;
  }

  /* ── Architecture section ────────────────────────────────── */
  .pix-architecture {
    background: var(--paper);
  }

  .arch-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-block-end: var(--space-8);
  }

  @media (min-width: 640px) {
    .arch-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .arch-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .arch-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .arch-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .arch-card__badge {
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .arch-card__badge--bronze { color: var(--medallion-bronze-ink); }
  .arch-card__badge--silver { color: var(--medallion-silver-ink); }
  .arch-card__badge--gold   { color: var(--medallion-gold-ink);   }

  .arch-card__layer {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wider);
  }

  .arch-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .arch-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    flex: 1;
    margin: 0;
  }

  .arch-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Automation card ─────────────────────────────────────── */
  .arch-automation {
    position: relative;
  }

  .arch-automation__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .arch-automation__inner {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-12);
    }
    .arch-automation__left {
      flex: 1;
    }
    .arch-automation__right {
      flex-shrink: 0;
      width: 280px;
    }
  }

  .arch-automation__badge {
    display: inline-block;
    margin-block-end: var(--space-3);
    color: var(--pix-green-ink);
  }

  .arch-automation__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-4);
  }

  .arch-automation__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    margin: 0;
  }

  .arch-automation__code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    letter-spacing: var(--tracking-normal);
    background: var(--paper-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin: 0;
    overflow-x: auto;
    white-space: pre;
  }

  /* ── Insights section ────────────────────────────────────── */
  .pix-insights {
    background: var(--paper-soft);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .insights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .insights-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .insight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .insight-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .insight-card__num {
    color: var(--ink-faint);
  }

  .insight-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .insight-card__body {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    flex: 1;
    margin: 0;
  }

  .insight-card__stat {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block-start: var(--space-2);
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }

  .insight-card__stat-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: var(--tracking-wide);
  }

  .insight-card__stat-value--accent {
    color: var(--pix-green-ink);
  }

  .insight-card__stat-arrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-faint);
  }

  .insight-card__stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Anatomia dos Dados (análise) ─────────────────────────── */
  .pix-analysis {
    background: var(--paper);
  }

  .analysis-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .analysis-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .analysis-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .analysis-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .analysis-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .analysis-card__label {
    color: var(--ink-faint);
  }

  .analysis-card__num {
    color: var(--ink-faint);
  }

  .analysis-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .analysis-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    margin: 0;
    flex: 1;
  }

  .analysis-card__foot {
    font-size: var(--text-xs);
    color: var(--ink-faint);
    padding-top: var(--space-3);
    border-top: 1px solid var(--line);
  }

  /* Gráfico ASCII (sazonalidade / donut) — mesmo idioma visual do
     growth-chart: mono, pix-green-ink (AA), overflow-x seguro. */
  .analysis-chart,
  .analysis-donut {
    overflow-x: auto;
    padding-block: var(--space-1);
  }

  .analysis-chart__bars,
  .analysis-donut__ascii {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: var(--leading-loose);
    color: var(--pix-green-ink);
    margin: 0;
    white-space: pre;
  }

  /* Composição de chaves — notação mono [████··] (padrão Skills.astro) */
  .analysis-meters {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .analysis-meter-row {
    display: grid;
    grid-template-columns: 4.5em 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
  }

  .analysis-meter-row__label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-soft);
  }

  .analysis-meter-row__bar {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--pix-green-ink);
    letter-spacing: 0.02em;
    line-height: 1;
    overflow: hidden;
  }

  .analysis-meter-row__val {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: var(--tracking-wide);
    text-align: right;
  }

  /* ── Ranking de Instituições ──────────────────────────────── */
  .pix-ranking {
    background: var(--paper-soft);
  }

  .ranking-methodology {
    display: block;
    color: var(--ink-faint);
    margin: 0 0 var(--space-8);
    max-width: 70ch;
  }

  .ranking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 900px) {
    .ranking-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ranking-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .ranking-card__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--line);
  }

  .ranking-card__hint {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }

  /* .ranking-list é o container estático — seus <li> (.ranking-row) são
     injetados via innerHTML em runtime, ver <style is:global> ao final. */
  .ranking-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: none; /* rank vem do dado, não de counter() */
  }

  .ranking-footnote {
    display: block;
    color: var(--ink-faint);
    margin: var(--space-8) 0 0;
  }

  /* ── Geografia do PIX (top cidades) ───────────────────────── */
  .pix-geografia {
    background: var(--paper);
  }

  /* Lista de cidades: 1 coluna (nomes de município podem ser longos,
     2 colunas comprimiriam demais o texto — ver .ranking-list padrão
     de 2 colunas usado na seção de instituições). */
  .ranking-list--geo {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Mapa de calor por estado ─────────────────────────────── */
  .geo-map-block {
    position: relative;
    margin-block-end: var(--space-6);
  }

  .geo-map-block__layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 900px) {
    .geo-map-block__layout {
      flex-direction: row;
      align-items: flex-start;
    }
    .geo-map-block__map-col { flex: 0 0 340px; }
    .geo-map-block__detail-col { flex: 1; min-width: 0; }
  }

  .geo-map-block__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-block-end: var(--space-4);
  }

  .geo-map-block__hint {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }

  /* Select acessível — estilizado como um input Blueprint padrão */
  .geo-state-select {
    width: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    background: var(--paper-card);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    margin-block-end: var(--space-4);
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .geo-state-select:hover,
  .geo-state-select:focus {
    border-color: var(--pix-green-line);
  }

  .geo-state-select:focus-visible {
    outline: var(--focus-ring-width) solid var(--pix-green);
    outline-offset: var(--focus-ring-offset);
  }

  /* SVG do mapa */
  .geo-map__svg-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: var(--space-4);
    background: var(--paper-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .geo-map__svg-wrap :global(svg) {
    width: 100%;
    max-width: 280px;
    height: auto;
  }

  /* Estados do mapa — mesmo idioma do heatmap de contribuições do GitHub
     (5 níveis de opacidade de UM acento, sem gradiente contínuo), mas em
     pix-green — coerente com a governança de cor desta página. */
  .geo-map__svg-wrap :global(.br-state) {
    stroke: var(--paper-soft);
    stroke-width: 1.2;
    fill: var(--line);
    cursor: pointer;
    transition: fill var(--transition-fast), opacity var(--transition-fast);
  }

  .geo-map__svg-wrap :global(.br-state[data-lvl='0']) { fill: rgba(0, 166, 81, 0.14); }
  .geo-map__svg-wrap :global(.br-state[data-lvl='1']) { fill: rgba(0, 166, 81, 0.32); }
  .geo-map__svg-wrap :global(.br-state[data-lvl='2']) { fill: rgba(0, 166, 81, 0.52); }
  .geo-map__svg-wrap :global(.br-state[data-lvl='3']) { fill: rgba(0, 166, 81, 0.74); }
  .geo-map__svg-wrap :global(.br-state[data-lvl='4']) { fill: var(--pix-green); }

  .geo-map__svg-wrap :global(.br-state:hover),
  .geo-map__svg-wrap :global(.br-state:focus) {
    opacity: 0.75;
  }

  .geo-map__svg-wrap :global(.br-state.is-selected) {
    stroke: var(--ink);
    stroke-width: 2.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .geo-map__svg-wrap :global(.br-state) { transition: none; }
  }

  /* Legenda */
  .geo-map__legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-block-start: var(--space-4);
  }

  .geo-map__legend-cells {
    display: inline-flex;
    gap: 3px;
  }

  .geo-map__legend-cell {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: var(--line);
  }

  .geo-map__legend-cell[data-lvl='0'] { background: rgba(0, 166, 81, 0.14); }
  .geo-map__legend-cell[data-lvl='1'] { background: rgba(0, 166, 81, 0.32); }
  .geo-map__legend-cell[data-lvl='2'] { background: rgba(0, 166, 81, 0.52); }
  .geo-map__legend-cell[data-lvl='3'] { background: rgba(0, 166, 81, 0.74); }
  .geo-map__legend-cell[data-lvl='4'] { background: var(--pix-green); }

  /* ── Painel de detalhe do estado ──────────────────────────── */
  /* #geo-detail é o container estático — seu conteúdo interno
     (.geo-detail__head, __name, __value, __cities etc.) é injetado via
     innerHTML em runtime, ver <style is:global> ao final do arquivo. */
  .geo-detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-height: 220px;
    padding: var(--space-6);
    background: var(--paper-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  /* ── Segurança & MED ──────────────────────────────────────── */
  .pix-seguranca {
    background: var(--paper-soft);
  }

  /* .seguranca-grid é o container estático — os cards (.seguranca-card,
     .seguranca-explainer) são injetados via innerHTML em runtime. */
  .seguranca-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .seguranca-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .seguranca-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Tech Stack ASCII Logos ──────────────────────────────── */
  .pix-techstack {
    background: var(--paper);
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .stack-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .stack-grid { grid-template-columns: repeat(6, 1fr); }
  }

  .stack-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  /* Quadro ASCII com spotlight igual ao hero */
  .stack-item__portrait {
    position: relative;
    width: 100%;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    cursor: crosshair;
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
    overflow: hidden;
  }

  .stack-item__portrait:hover {
    border-color: var(--pix-green-line);
    box-shadow: var(--shadow-sm);
  }

  /* Foto real — revelada pelo spotlight no hover */
  .stack-item__photo {
    position: absolute;
    inset: 0;
    background-size: 70%;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0;
    -webkit-mask: radial-gradient(circle var(--spot-r, 60px) at var(--mx, 50%) var(--my, 50%), #000 0%, #000 55%, transparent 100%);
    mask: radial-gradient(circle var(--spot-r, 60px) at var(--mx, 50%) var(--my, 50%), #000 0%, #000 55%, transparent 100%);
    transition: opacity var(--transition-normal);
    pointer-events: none;
    border-radius: var(--radius-md);
    background-color: var(--paper-card);
  }

  .stack-item__portrait.is-spotting .stack-item__photo { opacity: 1; }
  .stack-item__portrait.is-revealed .stack-item__photo {
    opacity: 1;
    -webkit-mask: none;
    mask: none;
  }
  .stack-item__portrait.is-revealed .stack-item__ascii { opacity: 0.1; }

  .stack-item__ascii {
    font-family: var(--font-mono);
    font-size: clamp(6px, 1.1vw, 9px);
    line-height: 1.15;
    color: var(--ink-soft);
    margin: 0;
    white-space: pre;
    text-align: center;
    position: relative;
    z-index: 1;
    transition: opacity var(--transition-normal);
  }

  .stack-item__name {
    font-size: var(--text-xs);
    color: var(--ink);
    letter-spacing: var(--tracking-wide);
  }

  .stack-item__role {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    line-height: var(--leading-normal);
  }

</style>

<!-- ════════════════════════════════════════════════════════════
     ESTILOS GLOBAIS — elementos criados via innerHTML/createElement
     ════════════════════════════════════════════════════════════
     O CSS "scoped" do Astro só se aplica a elementos presentes no HTML
     gerado em build/SSG — ele injeta um atributo data-astro-cid-* neles
     e reescreve os seletores para exigir esse atributo. Elementos criados
     no CLIENT (via JS, `.innerHTML = ...` ou `document.createElement`)
     nunca recebem esse atributo, então regras "scoped" nunca os afetam.
     Todas as classes abaixo pertencem a conteúdo montado em runtime pelos
     widgets desta página (notícias, ranking de instituições, geografia,
     detalhe de estado, segurança/MED) — por isso vivem num bloco global.
     ════════════════════════════════════════════════════════════ -->
<style is:global>
