<!-- ════════════════════════════════════════════════════════════
     SCRIPTS — motion + countUp + AI chat
     ════════════════════════════════════════════════════════════ -->
<script>
  import { revealUp }     from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { countUp }      from '../scripts/motion/count-up';
  import { motionOk }     from '../scripts/motion/constants';

  // ── Reveal animations for all sections ───────────────────
  // astro:page-load (não DOMContentLoaded): dispara no 1º load E após cada
  // navegação SPA do <ClientRouter />. O guard #pix-hero garante que só roda
  // nesta página (o listener no document persiste entre navegações).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('pix-hero')) return;

    // Hero
    const heroCard = document.querySelector('.hero-card') as Element;
    if (heroCard && motionOk) revealUp([heroCard], heroCard, 0);

    // KPI bento
    const bentoSection = document.getElementById('dashboard');
    if (bentoSection) {
      const bentoHead = bentoSection.querySelector('.section-head') as Element;
      const bentoLine = bentoSection.querySelector('.section-line') as Element;
      const metricCards = bentoSection.querySelectorAll('.pix-metric, .pix-pipeline-strip');
      if (bentoLine) hairlineDraw(bentoLine, bentoSection);
      if (motionOk && bentoHead) revealUp([bentoHead], bentoSection, 0);
      if (motionOk) revealUp(metricCards, bentoSection, 0.08);
    }

    // Architecture
    const archSection = document.getElementById('pipeline');
    if (archSection) {
      const archHead = archSection.querySelector('.section-head') as Element;
      const archLine = archSection.querySelector('.section-line') as Element;
      const archCards = archSection.querySelectorAll('.arch-card, .arch-automation');
      if (archLine) hairlineDraw(archLine, archSection);
      if (motionOk && archHead) revealUp([archHead], archSection, 0);
      if (motionOk) revealUp(archCards, archSection, 0.1);
    }

    // Insights
    const insightsSection = document.getElementById('insights');
    if (insightsSection) {
      const insightsHead = insightsSection.querySelector('.section-head') as Element;
      const insightsLine = insightsSection.querySelector('.section-line') as Element;
      const insightCards = insightsSection.querySelectorAll('.insight-card');
      if (insightsLine) hairlineDraw(insightsLine, insightsSection);
      if (motionOk && insightsHead) revealUp([insightsHead], insightsSection, 0);
      if (motionOk) revealUp(insightCards, insightsSection, 0.1);
    }

    // Anatomia dos Dados (analysis)
    const analysisSection = document.getElementById('analysis');
    if (analysisSection) {
      const analysisHead = analysisSection.querySelector('.section-head') as Element;
      const analysisLine = analysisSection.querySelector('.section-line') as Element;
      const analysisCards = analysisSection.querySelectorAll('.analysis-card');
      if (analysisLine) hairlineDraw(analysisLine, analysisSection);
      if (motionOk && analysisHead) revealUp([analysisHead], analysisSection, 0);
      if (motionOk) revealUp(analysisCards, analysisSection, 0.1);
    }

    // Ranking de Instituições
    const rankingSection = document.getElementById('ranking');
    if (rankingSection) {
      const rankingHead = rankingSection.querySelector('.section-head') as Element;
      const rankingLine = rankingSection.querySelector('.section-line') as Element;
      const rankingCards = rankingSection.querySelectorAll('.ranking-card');
      if (rankingLine) hairlineDraw(rankingLine, rankingSection);
      if (motionOk && rankingHead) revealUp([rankingHead], rankingSection, 0);
      if (motionOk) revealUp(rankingCards, rankingSection, 0.12);
    }

    // Geografia do PIX
    const geografiaSection = document.getElementById('geografia');
    if (geografiaSection) {
      const geografiaHead = geografiaSection.querySelector('.section-head') as Element;
      const geografiaLine = geografiaSection.querySelector('.section-line') as Element;
      const geografiaMapBlock = geografiaSection.querySelector('.geo-map-block') as Element;
      const geografiaCard = geografiaSection.querySelector('.ranking-card') as Element;
      if (geografiaLine) hairlineDraw(geografiaLine, geografiaSection);
      if (motionOk && geografiaHead) revealUp([geografiaHead], geografiaSection, 0);
      if (motionOk && geografiaMapBlock) revealUp([geografiaMapBlock], geografiaSection, 0.08);
      if (motionOk && geografiaCard) revealUp([geografiaCard], geografiaSection, 0.14);
    }

    // Segurança & MED
    const segurancaSection = document.getElementById('seguranca');
    if (segurancaSection) {
      const segurancaHead = segurancaSection.querySelector('.section-head') as Element;
      const segurancaLine = segurancaSection.querySelector('.section-line') as Element;
      if (segurancaLine) hairlineDraw(segurancaLine, segurancaSection);
      if (motionOk && segurancaHead) revealUp([segurancaHead], segurancaSection, 0);
      // Cards do grid de segurança são injetados via fetch async — reveal
      // aplicado depois que o conteúdo chega (ver renderSeguranca()).
    }

    // Count-up on KPI metrics
    document.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el) => {
      const card = el.closest('.pix-metric') as Element | null;
      countUp(el, card ?? el);
    });

  });
</script>

<script>
  /**
   * Widget de notícias — carrega assets/data/pix_news.json (gerado no pipeline
   * pelo fetch_news.py via GitHub Actions). Feed do Google News RSS sobre PIX.
   * Fallback gracioso: se o fetch falhar, mostra mensagem discreta.
   */
  interface NewsItem {
    title: string;
    source: string;
    url: string;
    published: string;
  }

  const baseUrl: string = (document.body as HTMLElement).dataset.baseurl ?? '';

  function timeAgo(iso: string): string {
    if (!iso) return '';
    const then = new Date(iso).getTime();
    if (Number.isNaN(then)) return '';
    const diffMs = Date.now() - then;
    const days = Math.floor(diffMs / 86_400_000);
    if (days <= 0) return 'hoje';
    if (days === 1) return 'ontem';
    if (days < 7) return `há ${days} dias`;
    const weeks = Math.floor(days / 7);
    if (weeks < 5) return `há ${weeks} sem`;
    const months = Math.floor(days / 30);
    return `há ${months} ${months === 1 ? 'mês' : 'meses'}`;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  async function renderNews(): Promise<void> {
    const list = document.getElementById('pix-news-list');
    const updatedEl = document.querySelector<HTMLElement>('[data-news-updated]');
    if (!list) return;

    // Timeout defensivo — evita "carregando feed…" infinito se a rede travar.
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const res = await fetch(`${baseUrl}assets/data/pix_news.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: { items?: NewsItem[]; updated_at?: string } = await res.json();
      const items = data.items ?? [];

      if (!items.length) {
        list.innerHTML = '<li class="pix-news__error mono-label">sem notícias no momento</li>';
        return;
      }

      list.innerHTML = items
        .map((n) => {
          const when = timeAgo(n.published);
          const source = n.source ? escapeHtml(n.source) : 'Fonte';
          const timeHtml = when
            ? `<span class="pix-news__time"><span aria-hidden="true">◷</span>${when}</span>`
            : '';
          return `
            <li class="pix-news__item" role="listitem">
              <a class="pix-news__link" href="${escapeHtml(n.url)}"
                 target="_blank" rel="noopener noreferrer"
                 aria-label="${escapeHtml(n.title)} — ${source}${when ? ', ' + when : ''}">
                <span class="pix-news__index mono-label" aria-hidden="true"></span>
                <span class="pix-news__content">
                  <span class="pix-news__headline">${escapeHtml(n.title)}</span>
                  <span class="pix-news__meta">
                    <span class="pix-news__source" title="${source}">${source}</span>
                    ${timeHtml}
                  </span>
                </span>
              </a>
            </li>`;
        })
        .join('');

      // Atualiza o rótulo do feed com a data de atualização
      if (updatedEl && data.updated_at) {
        const when = timeAgo(data.updated_at);
        updatedEl.textContent = `Google News · ${when || 'atualizado'}`;
      }
    } catch {
      clearTimeout(timeoutId);
      list.innerHTML =
        '<li class="pix-news__error mono-label">feed indisponível — tente recarregar</li>';
    }
  }

  document.addEventListener('astro:page-load', renderNews);
</script>

<script>
  /**
   * Widget de ranking de instituições — carrega assets/data/pix_ranking.json
   * (gerado pelo pipeline via ingestion/ingest_ranking.py). Dado real do
   * BACEN (DICT/ChavesPix): estoque de chaves PIX por instituição.
   */
  interface RankingHistoricoItem {
    rank: number;
    ispb: string;
    nome: string;
    chaves: number;
  }

  interface RankingRecenteItem {
    rank: number;
    ispb: string;
    nome: string;
    chaves_atual: number;
    chaves_anterior: number;
    crescimento_absoluto: number;
    crescimento_pct: number;
  }

  interface RankingPayload {
    gerado_em?: string;
    snapshot_recente?: string;
    snapshot_comparacao?: string | null;
    historico?: RankingHistoricoItem[];
    recente?: RankingRecenteItem[];
  }

  const rankingBaseUrl: string = (document.body as HTMLElement).dataset.baseurl ?? '';

  /** Formata números grandes de forma compacta (183422436 → "183,4M"). */
  function formatCompact(n: number): string {
    const abs = Math.abs(n);
    if (abs >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.', ',')}M`;
    if (abs >= 1_000) return `${(n / 1_000).toFixed(1).replace('.', ',')}mil`;
    return String(n);
  }

  function rankingEscapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function monthLabel(iso: string | null | undefined): string {
    if (!iso) return '';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return d.toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' });
  }

  function renderHistorico(items: RankingHistoricoItem[]): string {
    return items
      .map((item) => {
        const podium = item.rank <= 3 ? ' ranking-row--podium' : '';
        return `
          <li class="ranking-row${podium}" role="listitem">
            <span class="ranking-row__rank" aria-hidden="true">${item.rank}</span>
            <span class="ranking-row__name" title="${rankingEscapeHtml(item.nome)}">${rankingEscapeHtml(item.nome)}</span>
            <span class="ranking-row__value">
              <span class="ranking-row__value-main">${formatCompact(item.chaves)}</span>
            </span>
          </li>`;
      })
      .join('');
  }

  function renderRecente(items: RankingRecenteItem[]): string {
    return items
      .map((item) => {
        const podium = item.rank <= 3 ? ' ranking-row--podium' : '';
        const isPositive = item.crescimento_absoluto >= 0;
        const deltaClass = isPositive ? '' : ' ranking-row__value-delta--neg';
        const sign = isPositive ? '+' : '';
        return `
          <li class="ranking-row${podium}" role="listitem">
            <span class="ranking-row__rank" aria-hidden="true">${item.rank}</span>
            <span class="ranking-row__name" title="${rankingEscapeHtml(item.nome)}">${rankingEscapeHtml(item.nome)}</span>
            <span class="ranking-row__value">
              <span class="ranking-row__value-main">${sign}${formatCompact(item.crescimento_absoluto)}</span>
              <span class="ranking-row__value-delta${deltaClass}">${sign}${item.crescimento_pct.toFixed(1).replace('.', ',')}%</span>
            </span>
          </li>`;
      })
      .join('');
  }

  async function renderRanking(): Promise<void> {
    const historicoList = document.getElementById('ranking-historico-list');
    const recenteList = document.getElementById('ranking-recente-list');
    const footnote = document.getElementById('ranking-footnote');
    if (!historicoList || !recenteList) return;

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const res = await fetch(`${rankingBaseUrl}assets/data/pix_ranking.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: RankingPayload = await res.json();

      const historico = data.historico ?? [];
      const recente = data.recente ?? [];

      historicoList.innerHTML = historico.length
        ? renderHistorico(historico)
        : '<li class="ranking-error mono-label">sem dados no momento</li>';

      recenteList.innerHTML = recente.length
        ? renderRecente(recente)
        : '<li class="ranking-error mono-label">sem dados de comparação disponíveis</li>';

      if (footnote) {
        const recentLabel = monthLabel(data.snapshot_recente);
        const pastLabel = monthLabel(data.snapshot_comparacao);
        const period = pastLabel && recentLabel ? ` · ${pastLabel} → ${recentLabel}` : '';
        footnote.textContent = `fonte: BACEN Olinda API · Pix_DadosAbertos / ChavesPix${period}`;
      }
    } catch {
      clearTimeout(timeoutId);
      const errorMsg = '<li class="ranking-error mono-label">ranking indisponível — tente recarregar</li>';
      historicoList.innerHTML = errorMsg;
      recenteList.innerHTML = errorMsg;
    }
  }

  document.addEventListener('astro:page-load', renderRanking);
</script>

<script>
  /**
   * KPI de usuários — atualiza o card "Usuários cadastrados (DICT)" com o
   * número mais recente de assets/data/pix_usuarios.json (gerado por
   * ingest_usuarios.py). O valor no HTML é apenas o fallback estático do
   * momento da build; aqui buscamos o dado fresco em runtime.
   */
  interface UsuariosPayload {
    usuarios_total_atual?: number;
    fator_crescimento?: number;
    ultimo_mes?: string;
  }

  function formatUsuariosCompact(n: number): string {
    return `${Math.round(n / 1_000_000)}M+`;
  }

  async function refreshUsuariosKpi(): Promise<void> {
    const valueEl = document.getElementById('kpi-usuarios-value');
    const labelEl = document.getElementById('kpi-usuarios-label');
    const cardEl = document.getElementById('kpi-usuarios-card');
    if (!valueEl) return;

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
      const res = await fetch(`${base}assets/data/pix_usuarios.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: UsuariosPayload = await res.json();

      if (data.usuarios_total_atual) {
        const compact = formatUsuariosCompact(data.usuarios_total_atual);
        // Atualiza o data-count-to para o countUp já disparado recalcular
        // corretamente caso ainda não tenha corrido (senão, ajusta o texto direto).
        valueEl.dataset.countTo = String(Math.round(data.usuarios_total_atual / 1_000_000));
        valueEl.textContent = compact;
        valueEl.setAttribute(
          'aria-label',
          `${data.usuarios_total_atual.toLocaleString('pt-BR')} usuários cadastrados`
        );
      }

      if (labelEl && data.fator_crescimento) {
        labelEl.textContent = `Usuários cadastrados (DICT) · ${data.fator_crescimento.toFixed(2).replace('.', ',')}× desde nov/2020`;
      }

      if (cardEl && data.usuarios_total_atual) {
        cardEl.setAttribute(
          'aria-label',
          `${data.usuarios_total_atual.toLocaleString('pt-BR')} usuários cadastrados no DICT`
        );
      }
    } catch {
      clearTimeout(timeoutId);
      // Falha silenciosa — mantém o fallback estático já renderizado no HTML.
    }
  }

  document.addEventListener('astro:page-load', refreshUsuariosKpi);
</script>

<script>
  /**
   * Widgets "Geografia do PIX" — mapa de calor por estado + ranking de
   * cidades. Ambos consomem o MESMO fetch de assets/data/pix_municipios.json
   * (gerado por ingest_municipios.py) — busca única, compartilhada.
   */
  interface MunicipioItem {
    rank: number;
    municipio: string;
    estado: string;
    regiao: string;
    valor_pago: number;
    valor_recebido: number;
  }

  interface EstadoCidade {
    municipio: string;
    valor_pago: number;
  }

  interface EstadoItem {
    uf: string;
    nome: string;
    valor_pago: number;
    nivel: number; // -1 (sem amostra) a 4 (maior)
    amostra_insuficiente: boolean;
    cidades: EstadoCidade[];
  }

  interface MunicipiosPayload {
    anomes?: string;
    ranking?: MunicipioItem[];
    estados?: EstadoItem[];
  }

  function formatReaisCompact(v: number): string {
    if (Math.abs(v) >= 1_000_000_000) return `R$ ${(v / 1_000_000_000).toFixed(1).replace('.', ',')}bi`;
    if (Math.abs(v) >= 1_000_000) return `R$ ${(v / 1_000_000).toFixed(1).replace('.', ',')}M`;
    return `R$ ${v.toLocaleString('pt-BR')}`;
  }

  function anomesToLabel(anomes: string | undefined): string {
    if (!anomes || anomes.length !== 6) return '';
    const y = anomes.slice(0, 4);
    const m = parseInt(anomes.slice(4, 6), 10);
    const meses = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
    return `${meses[m - 1]}/${y}`;
  }

  function escapeHtmlGeo(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  // ── Fetch único, compartilhado entre ranking e mapa ──────────────
  let municipiosDataPromise: Promise<MunicipiosPayload | null> | null = null;

  function loadMunicipiosData(): Promise<MunicipiosPayload | null> {
    if (municipiosDataPromise) return municipiosDataPromise;

    municipiosDataPromise = (async () => {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 8000);
      try {
        const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
        const res = await fetch(`${base}assets/data/pix_municipios.json`, {
          cache: 'no-cache',
          signal: controller.signal,
        });
        clearTimeout(timeoutId);
        if (!res.ok) throw new Error('fetch failed');
        return (await res.json()) as MunicipiosPayload;
      } catch {
        clearTimeout(timeoutId);
        return null;
      }
    })();

    return municipiosDataPromise;
  }

  // ── Ranking nacional de cidades ───────────────────────────────────
  async function renderGeografiaRanking(): Promise<void> {
    const list = document.getElementById('geografia-list');
    const footnote = document.getElementById('geografia-footnote');
    if (!list) return;

    const data = await loadMunicipiosData();
    if (!data) {
      list.innerHTML = '<li class="ranking-error mono-label">ranking indisponível — tente recarregar</li>';
      return;
    }

    const ranking = data.ranking ?? [];
    if (!ranking.length) {
      list.innerHTML = '<li class="ranking-error mono-label">sem dados no momento</li>';
      return;
    }

    list.innerHTML = ranking
      .map((item) => {
        const podium = item.rank <= 3 ? ' ranking-row--podium' : '';
        const nomeCompleto = `${item.municipio} / ${item.estado}`;
        return `
          <li class="ranking-row${podium}" role="listitem">
            <span class="ranking-row__rank" aria-hidden="true">${item.rank}</span>
            <span class="ranking-row__name" title="${nomeCompleto}">${nomeCompleto}</span>
            <span class="ranking-row__tag" aria-hidden="true">${item.regiao}</span>
            <span class="ranking-row__value">
              <span class="ranking-row__value-main">${formatReaisCompact(item.valor_pago)}</span>
            </span>
          </li>`;
      })
      .join('');

    if (footnote) {
      const label = anomesToLabel(data.anomes);
      footnote.textContent = `fonte: BACEN Olinda API · Pix_DadosAbertos / TransacoesPixPorMunicipio${label ? ' · ' + label : ''}`;
    }
  }

  // ── Mapa de calor + drill-down por estado ─────────────────────────
  function renderDetail(estado: EstadoItem | undefined): void {
    const detail = document.getElementById('geo-detail');
    if (!detail) return;

    if (!estado) {
      detail.innerHTML = '<p class="geo-detail__empty mono-label">nenhum estado selecionado</p>';
      return;
    }

    const citiesHtml = estado.cidades.length
      ? estado.cidades
          .map(
            (c) => `
            <li class="geo-detail__city">
              <span>${escapeHtmlGeo(c.municipio)}</span>
              <span class="geo-detail__city-value">${formatReaisCompact(c.valor_pago)}</span>
            </li>`
          )
          .join('')
      : '<li class="geo-detail__city"><span class="mono-label">nenhuma cidade deste estado está na amostra</span></li>';

    detail.innerHTML = `
      <header class="geo-detail__head">
        <div>
          <h3 class="geo-detail__name">${escapeHtmlGeo(estado.nome)}</h3>
          <span class="geo-detail__uf">${estado.uf}</span>
        </div>
        <span class="geo-detail__value">${estado.amostra_insuficiente ? '—' : formatReaisCompact(estado.valor_pago)}</span>
      </header>
      ${
        estado.amostra_insuficiente
          ? '<p class="geo-detail__note">Nenhuma cidade deste estado apareceu entre as ~1000 maiores do país nesta amostra — não significa volume zero, apenas que não há dados nesta amostra específica.</p>'
          : `<p class="geo-detail__note">Soma das cidades deste estado presentes na amostra nacional das maiores — não é o total exato do estado.</p>`
      }
      <p class="mono-label geo-detail__cities-title">cidades na amostra</p>
      <ul class="geo-detail__cities">${citiesHtml}</ul>
    `;
  }

  async function renderMapa(): Promise<void> {
    const wrap = document.getElementById('geo-map-svg-wrap');
    const select = document.getElementById('geo-state-select') as HTMLSelectElement | null;
    if (!wrap || !select) return;

    const data = await loadMunicipiosData();
    const estados = data?.estados ?? [];

    if (!estados.length) {
      wrap.innerHTML = '<p class="ranking-error mono-label">mapa indisponível — tente recarregar</p>';
      return;
    }

    const estadoPorUf = new Map(estados.map((e) => [e.uf, e]));

    // Popula o select (ordenado por nome, mais previsível para navegação por teclado)
    const ordenados = [...estados].sort((a, b) => a.nome.localeCompare(b.nome, 'pt-BR'));
    for (const e of ordenados) {
      const opt = document.createElement('option');
      opt.value = e.uf;
      opt.textContent = e.amostra_insuficiente ? `${e.nome} (sem amostra)` : e.nome;
      select.appendChild(opt);
    }

    // Carrega o SVG (mesmo padrão de fetch-de-texto usado no ASCII portrait do Hero)
    const svgSrc = wrap.dataset.mapSrc;
    if (!svgSrc) return;

    try {
      const res = await fetch(svgSrc);
      if (!res.ok) throw new Error('svg fetch failed');
      wrap.innerHTML = await res.text();
    } catch {
      wrap.innerHTML = '<p class="ranking-error mono-label">mapa indisponível — tente recarregar</p>';
      return;
    }

    const svg = wrap.querySelector('svg');
    if (!svg) return;

    const paths = Array.from(svg.querySelectorAll<SVGPathElement>('.br-state'));
    for (const path of paths) {
      const uf = path.dataset.uf ?? path.id;
      const estado = estadoPorUf.get(uf);
      path.setAttribute('data-lvl', String(estado?.nivel ?? -1));
      path.setAttribute('tabindex', '-1'); // navegação via <select>, mapa é atalho de mouse
      path.setAttribute('role', 'button');
      if (estado) {
        path.setAttribute('aria-label', `${estado.nome}: ${estado.amostra_insuficiente ? 'sem amostra' : formatReaisCompact(estado.valor_pago)}`);
      }
    }

    function selectUf(uf: string): void {
      for (const path of paths) {
        path.classList.toggle('is-selected', (path.dataset.uf ?? path.id) === uf);
      }
      if (select && select.value !== uf) select.value = uf;
      renderDetail(estadoPorUf.get(uf));
    }

    svg.addEventListener('click', (e) => {
      const target = (e.target as Element).closest<SVGPathElement>('.br-state');
      if (!target) return;
      const uf = target.dataset.uf ?? target.id;
      selectUf(uf);
    });

    select.addEventListener('change', () => {
      if (select.value) selectUf(select.value);
      else {
        for (const path of paths) path.classList.remove('is-selected');
        renderDetail(undefined);
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    renderGeografiaRanking();
    renderMapa();
  });
</script>

<script>
  /**
   * Widget "Segurança & MED" — carrega assets/data/pix_fraudes.json
   * (gerado por ingest_fraudes.py). Único dataset deste projeto onde o
   * BACEN publica uma linha exata por mês — sem amostragem.
   */
  interface FraudesPayload {
    anomes?: string;
    contestacoes?: {
      total: number;
      aceitas: number;
      valor_aceitas: number;
    };
    usuarios_marcados_fraude?: number;
    med?: {
      percentual_devolucao: number;
      devolvido_integral_valor: number;
      devolvido_parcial_valor: number;
    };
    bloqueios_cautelares?: {
      liberados_valor: number;
      devolvidos_valor: number;
    };
  }

  function formatReaisFull(v: number): string {
    if (Math.abs(v) >= 1_000_000_000) return `R$ ${(v / 1_000_000_000).toFixed(2).replace('.', ',')} bi`;
    if (Math.abs(v) >= 1_000_000) return `R$ ${(v / 1_000_000).toFixed(1).replace('.', ',')} M`;
    return `R$ ${v.toLocaleString('pt-BR')}`;
  }

  function formatIntCompact(n: number): string {
    if (Math.abs(n) >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.', ',')}M`;
    if (Math.abs(n) >= 1_000) return `${(n / 1_000).toFixed(1).replace('.', ',')}mil`;
    return String(n);
  }

  function segAnomesToLabel(anomes: string | undefined): string {
    if (!anomes || anomes.length !== 6) return '';
    const y = anomes.slice(0, 4);
    const m = parseInt(anomes.slice(4, 6), 10);
    const meses = [
      'janeiro', 'fevereiro', 'março', 'abril', 'maio', 'junho',
      'julho', 'agosto', 'setembro', 'outubro', 'novembro', 'dezembro',
    ];
    return `${meses[m - 1]} de ${y}`;
  }

  async function renderSeguranca(): Promise<void> {
    const grid = document.getElementById('seguranca-grid');
    const footnote = document.getElementById('seguranca-footnote');
    if (!grid) return;

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
      const res = await fetch(`${base}assets/data/pix_fraudes.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: FraudesPayload = await res.json();

      const contestacoes = data.contestacoes;
      const med = data.med;
      const bloqueios = data.bloqueios_cautelares;
      const mesLabel = segAnomesToLabel(data.anomes);

      if (!contestacoes || !med || !bloqueios) {
        grid.innerHTML = '<p class="ranking-error mono-label">sem dados no momento</p>';
        return;
      }

      grid.innerHTML = `
        <div class="card seguranca-card" role="group" aria-label="Contestações de fraude no mês">
          <span class="mono-label seguranca-card__label">contestações no mês</span>
          <span class="seguranca-card__value">${formatIntCompact(contestacoes.total)}</span>
          <p class="seguranca-card__desc">
            ${formatIntCompact(contestacoes.aceitas)} aceitas como fraude confirmada
            (${formatReaisFull(contestacoes.valor_aceitas)})
          </p>
        </div>

        <div class="card seguranca-card" role="group" aria-label="Valor bloqueado cautelarmente">
          <span class="mono-label seguranca-card__label">bloqueado cautelarmente</span>
          <span class="seguranca-card__value seguranca-card__value--protect">${formatReaisFull(bloqueios.liberados_valor)}</span>
          <p class="seguranca-card__desc">
            valores suspeitos de fraude retidos pelo MED em um único mês
          </p>
        </div>

        <div class="card seguranca-card" role="group" aria-label="Percentual de devolução às vítimas">
          <span class="mono-label seguranca-card__label">devolução às vítimas</span>
          <span class="seguranca-card__value seguranca-card__value--protect">${med.percentual_devolucao.toFixed(1).replace('.', ',')}%</span>
          <p class="seguranca-card__desc">
            dos valores contestados foram devolvidos (integral ou parcialmente)
          </p>
        </div>

        <div class="card seguranca-card" role="group" aria-label="Usuários marcados por fraude">
          <span class="mono-label seguranca-card__label">marcados por fraude</span>
          <span class="seguranca-card__value">${formatIntCompact(data.usuarios_marcados_fraude ?? 0)}</span>
          <p class="seguranca-card__desc">
            usuários com registro de fraude no mês, banidos da rede DICT
          </p>
        </div>

        <div class="seguranca-explainer">
          <h3 class="seguranca-explainer__title">O que é o MED?</h3>
          <p class="seguranca-explainer__body">
            O Mecanismo Especial de Devolução (MED) é o protocolo do BACEN para bloquear
            e devolver valores movidos por fraude no PIX. Quando uma vítima contesta uma
            transação, a instituição recebedora pode bloquear cautelarmente o saldo antes
            que o fraudador o retire — ${mesLabel ? `em ${mesLabel}, isso` : 'isso'} significou
            ${formatReaisFull(bloqueios.liberados_valor)} retidos preventivamente,
            com ${med.percentual_devolucao.toFixed(1).replace('.', ',')}% de devolução efetiva às vítimas.
          </p>
        </div>
      `;

      if (footnote && mesLabel) {
        footnote.textContent = `fonte: BACEN Olinda API · Pix_DadosAbertos / EstatisticasFraudesPix · ${mesLabel}`;
      }
    } catch {
      clearTimeout(timeoutId);
      grid.innerHTML = '<p class="ranking-error mono-label">estatísticas indisponíveis — tente recarregar</p>';
    }
  }

  document.addEventListener('astro:page-load', renderSeguranca);
</script>

