---
/**
 * pix-observatory.astro — PIX Observatory
 * Direção: Blueprint (DESIGN.md)
 *
 * Seções (numeração sequencial dos mono-labels [ 01 ]…[ 08 ]):
 *  0. Header (reuse) + Hero — sem número, abertura da página
 *  1. [01] KPI Bento — métricas do BACEN (Impact.astro pattern) + widget de
 *         notícias + KPI de usuários atualizado em runtime (pix_usuarios.json)
 *  2. [02] Pipeline Architecture — Bronze/Silver/Gold
 *  3. [03] Data Insights — 3 insight cards
 *  4. [04] Anatomia dos Dados — sazonalidade, chaves DICT, canal de pagamento
 *  5. [05] Ranking de Instituições — top chaves DICT + crescimento recente
 *         (dado real via ingest_ranking.py, fetch runtime de pix_ranking.json)
 *  6. [06] Geografia do PIX — top cidades por valor pago (ingest_municipios.py,
 *         fetch runtime de pix_municipios.json)
 *  7. [07] Segurança & MED — estatísticas reais de fraude e devolução
 *         (ingest_fraudes.py, fetch runtime de pix_fraudes.json — único
 *         dataset do projeto sem risco de amostragem: 1 linha exata/mês)
 *  8. [08] Tech Stack — logos ASCII com spotlight
 *  9. Footer (reuse)
 *
 * O agente conversacional NÃO é uma seção — é o componente <PixAgent />,
 * flutuante, renderizado fora do <main> (FAB + painel, acompanha o scroll).
 *
 * Tokens: src/styles/tokens.css (zero hex hardcoded fora de definições)
 * Motion: GSAP revealUp + hairlineDraw + countUp
 * i18n: data-i18n-key attributes em todo texto visível
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectRecommendations from '../components/ProjectRecommendations.astro';
import PixAgent from '../components/PixAgent.astro';

const base = import.meta.env.BASE_URL;

// Notação mono blueprint [████████··] — mesmo padrão de Skills.astro,
// usado na composição de chaves DICT (evita <div style="width:%"> frágil).
const METER_CELLS = 10;
const meter = (pct: number) => {
  const filled = Math.round((pct / 100) * METER_CELLS);
  return '█'.repeat(filled) + '·'.repeat(METER_CELLS - filled);
};

const dictKeyShare = [
  { label: 'Celular', pct: 32 },
  { label: 'CPF',     pct: 27 },
  { label: 'E-mail',  pct: 18 },
  { label: 'EVP',     pct: 16 },
  { label: 'CNPJ',    pct: 7  },
];
---

<BaseLayout
  title="PIX Observatory — Otávio Ribeiro"
  description="Observatório de dados do PIX: pipeline Bronze→Silver→Gold sobre dados do BACEN, métricas em tempo real e agente de chat demonstrativo."
>
  <Header />

  <main id="main-content">

    <!-- ══════════════════════════════════════════════════════
         SECTION 1: PIX HERO
         ══════════════════════════════════════════════════════ -->
    <section id="pix-hero" class="section pix-hero" aria-labelledby="pix-hero-title">
      <div class="container">
        <div class="hero-card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="hero-card__header">
            <span class="mono-label" data-i18n-key="pix.hero.label">PIX Observatory</span>
            <div class="hero-card__spark-wrap" aria-hidden="true">
              <span class="hero-sparkline">▁▂▃▅▆▇▇▆▇█</span>
              <span class="hero-spark-label mono-label">tx/s · live</span>
            </div>
          </header>

          <h1
            id="pix-hero-title"
            class="hero-display"
            data-i18n-key="pix.hero.title"
          >O maior sistema de pagamentos do mundo, em tempo real.</h1>

          <p class="hero-lead" data-i18n-key="pix.hero.lead">
            Pipeline de dados sobre o sistema PIX do Banco Central do Brasil —
            coleta, transforma e expõe métricas de 258 milhões de transações/dia
            com arquitetura medallion Bronze → Silver → Gold.
          </p>

          <div class="hero-actions">
            <a
              href="#dashboard"
              class="btn-primary"
              data-i18n-key="pix.hero.cta_dashboard"
            >Ver Dashboard</a>
            <a
              href="https://github.com/Donotavio/cv-site-otavio/tree/main/ingestion"
              class="btn-secondary"
              target="_blank"
              rel="noopener noreferrer"
              data-i18n-key="pix.hero.cta_code"
            >Código Fonte</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 2: KPI BENTO
         ══════════════════════════════════════════════════════ -->
    <section id="dashboard" class="section pix-dashboard" aria-labelledby="pix-kpi-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">01</span>
          <h2 id="pix-kpi-title" class="pix-display" data-i18n-key="pix.kpi.title">
            Telemetria do PIX
          </h2>
          <p class="pix-lead" data-i18n-key="pix.kpi.subtitle">
            Métricas extraídas da API do BACEN — python-bcb · DuckDB · Parquet.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <!-- Bento assimétrico — mirrors Impact.astro pattern -->
        <div class="pix-bento" role="list" aria-label="Métricas do PIX">

          <!-- Card 1: métrica DOMINANTE -->
          <article
            class="pix-metric pix-metric--hero crop"
            role="listitem"
            data-metric="1"
            aria-label="258 milhões+ de transações por dia no pico de 2025"
          >
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">01</span>
              <span class="pix-metric__spark" aria-hidden="true">▁▂▃▅▆▇▇▆▇█</span>
            </header>
            <span
              class="pix-metric__value pix-metric__value--hero pix-metric__value--green"
              data-count-to="258"
              data-count-suffix="M+"
              data-i18n-key="pix.kpi_1_value"
              aria-label="258 milhões e mais"
            >258M+</span>
            <span class="pix-metric__label" data-i18n-key="pix.kpi_1_label">
              Transações por dia (pico 2025)
            </span>
          </article>

          <!-- Card 2 -->
          <article
            class="pix-metric pix-metric--sec"
            role="listitem"
            data-metric="2"
            aria-label="R$ 4,4 trilhões movimentados em 2024"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">02</span>
            </header>
            <span
              class="pix-metric__value"
              data-i18n-key="pix.kpi_2_value"
            >R$ 4,4 tri</span>
            <span class="pix-metric__label" data-i18n-key="pix.kpi_2_label">
              Movimentado em 2024
            </span>
          </article>

          <!-- Card 3 -->
          <article
            class="pix-metric pix-metric--sec crop"
            role="listitem"
            data-metric="3"
            aria-label="106.000 vezes de crescimento desde novembro de 2020"
          >
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">03</span>
            </header>
            <span
              class="pix-metric__value"
              data-count-to="106000"
              data-count-suffix="×"
              data-i18n-key="pix.kpi_3_value"
              aria-label="106 mil vezes"
            >106.000×</span>
            <span class="pix-metric__label" data-i18n-key="pix.kpi_3_label">
              Crescimento desde nov/2020
            </span>
          </article>

          <!-- Card 4 -->
          <article
            class="pix-metric pix-metric--wide"
            role="listitem"
            data-metric="4"
            aria-label="R$ 17 de ticket médio por transação"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">04</span>
              <span class="pix-metric__spark pix-metric__spark--sm" aria-hidden="true">▂▅▇▅▂▅▇</span>
            </header>
            <span
              class="pix-metric__value"
              data-i18n-key="pix.kpi_4_value"
            >R$ 17</span>
            <span class="pix-metric__label" data-i18n-key="pix.kpi_4_label">
              Ticket médio por transação
            </span>
          </article>

          <!-- Card 5: Usuários cadastrados — dado real (PixUsuariosCadastradosDICT),
               atualizado em runtime via fetch de pix_usuarios.json. Valor abaixo é
               o fallback estático (snapshot no momento da build). -->
          <article
            class="pix-metric pix-metric--sm"
            role="listitem"
            data-metric="5"
            id="kpi-usuarios-card"
            aria-label="184 milhões de usuários cadastrados no DICT"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">05</span>
              <span class="pix-metric__spark pix-metric__spark--sm" aria-hidden="true">▁▃▅▆▇█</span>
            </header>
            <span
              class="pix-metric__value"
              id="kpi-usuarios-value"
              data-count-to="184"
              data-count-suffix="M+"
              aria-label="184 milhões e mais usuários"
            >184M+</span>
            <span class="pix-metric__label" id="kpi-usuarios-label">Usuários cadastrados (DICT)</span>
          </article>

          <!-- Card 6: Participantes -->
          <article
            class="pix-metric pix-metric--sm"
            role="listitem"
            data-metric="6"
            aria-label="800 instituições participantes"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">06</span>
            </header>
            <span
              class="pix-metric__value"
              data-count-to="800"
              data-count-suffix="+"
              aria-label="800 e mais instituições"
            >800+</span>
            <span class="pix-metric__label">Instituições participantes</span>
          </article>

          <!-- Card 7: Chaves DICT -->
          <article
            class="pix-metric pix-metric--sm"
            role="listitem"
            data-metric="7"
            aria-label="700 milhões de chaves cadastradas no DICT"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">07</span>
              <span class="pix-metric__spark pix-metric__spark--sm" aria-hidden="true">▂▄▆▇█</span>
            </header>
            <span
              class="pix-metric__value"
              data-count-to="700"
              data-count-suffix="M+"
              aria-label="700 milhões e mais chaves"
            >700M+</span>
            <span class="pix-metric__label">Chaves DICT cadastradas</span>
          </article>

          <!-- Card 8: Uptime SLA -->
          <article
            class="pix-metric pix-metric--sm"
            role="listitem"
            data-metric="8"
            aria-label="99,9% de disponibilidade histórica"
          >
            <header class="pix-metric__head">
              <span class="pix-metric__index mono-label" aria-hidden="true">08</span>
            </header>
            <span class="pix-metric__value">99,9%</span>
            <span class="pix-metric__label">Disponibilidade SLA histórico</span>
          </article>

          <!-- Card 9: Pipeline strip (full width) -->
          <div
            class="pix-pipeline-strip crop"
            role="listitem"
            aria-label="Pipeline Bronze Silver Gold"
          >
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <p class="pix-pipeline-strip__label mono-label" aria-hidden="true">pipeline</p>
            <div class="pix-pipeline-strip__flow" role="list" aria-label="Etapas do pipeline">
              <div class="pix-pipeline-strip__step" role="listitem">
                <span class="pix-pipeline-strip__badge pix-pipeline-strip__badge--bronze mono-label">Bronze</span>
                <span class="pix-pipeline-strip__desc">BACEN API → Parquet raw</span>
              </div>
              <span class="pix-pipeline-strip__arrow" aria-hidden="true">→</span>
              <div class="pix-pipeline-strip__step" role="listitem">
                <span class="pix-pipeline-strip__badge pix-pipeline-strip__badge--silver mono-label">Silver</span>
                <span class="pix-pipeline-strip__desc">DuckDB clean + tipagem</span>
              </div>
              <span class="pix-pipeline-strip__arrow" aria-hidden="true">→</span>
              <div class="pix-pipeline-strip__step" role="listitem">
                <span class="pix-pipeline-strip__badge pix-pipeline-strip__badge--gold mono-label">Gold</span>
                <span class="pix-pipeline-strip__desc">Agregações + KPIs JSON</span>
              </div>
              <span class="pix-pipeline-strip__arrow" aria-hidden="true">→</span>
              <div class="pix-pipeline-strip__step" role="listitem">
                <span class="pix-pipeline-strip__badge pix-pipeline-strip__badge--gh mono-label">AI</span>
                <span class="pix-pipeline-strip__desc">Chat demo local</span>
              </div>
            </div>
          </div>

        </div>

        <!-- Segunda linha: gráfico ASCII de crescimento mensal -->
        <div class="pix-growth-chart card crop" aria-labelledby="growth-chart-title">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <header class="pix-growth-chart__head">
            <span class="mono-label" id="growth-chart-title">crescimento mensal · nov/2020 → jun/2025</span>
            <span class="pix-growth-chart__unit mono-label" aria-hidden="true">tx/dia · M</span>
          </header>
          <div class="pix-growth-chart__body" aria-hidden="true">
            <pre class="pix-growth-chart__bars">2020 ▏█▌
2021 ▏███████████████▌
2022 ▏███████████████████████████▌
2023 ▏████████████████████████████████████████▌
2024 ▏████████████████████████████████████████████████████████▌
2025 ▏███████████████████████████████████████████████████████████████▌ 258M/dia</pre>
          </div>
          <div class="pix-growth-chart__legend">
            <span class="pix-growth-chart__note">
              Cada bloco █ representa ~4M transações/dia · dados: BACEN/SPI
            </span>
            <div class="pix-growth-chart__milestones">
              <span class="tag">Nov/2020: 2.345/dia</span>
              <span class="tag">Dez/2021: 47M/dia</span>
              <span class="tag">2023: PIX Parcelado</span>
              <span class="tag">2025: 258M/dia pico</span>
            </div>
          </div>
        </div>

        <!-- Widget de notícias recentes do PIX -->
        <div class="pix-news card crop" aria-labelledby="pix-news-title">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <header class="pix-news__head">
            <div class="pix-news__title-wrap">
              <span class="pix-news__live-dot" aria-hidden="true"></span>
              <span class="mono-label" id="pix-news-title">PIX no noticiário</span>
            </div>
            <span class="pix-news__feed mono-label" aria-hidden="true" data-news-updated>
              Google News · RSS
            </span>
          </header>

          <ol class="pix-news__list" id="pix-news-list" role="list" aria-live="polite">
            <!-- Preenchido em runtime via fetch de pix_news.json -->
            <li class="pix-news__loading mono-label" data-news-loading>carregando feed…</li>
          </ol>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 3: PIPELINE ARCHITECTURE
         ══════════════════════════════════════════════════════ -->
    <section id="pipeline" class="section pix-architecture" aria-labelledby="pix-arch-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">02</span>
          <h2 id="pix-arch-title" class="pix-display" data-i18n-key="pix.arch.title">
            Arquitetura do Pipeline
          </h2>
          <p class="pix-lead" data-i18n-key="pix.arch.subtitle">
            Medallion architecture sobre dados abertos do Banco Central do Brasil.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="arch-grid">

          <!-- Bronze layer -->
          <article
            class="card arch-card"
            style="border-top: 3px solid var(--medallion-bronze);"
            aria-labelledby="arch-bronze-title"
          >
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--bronze">Bronze</span>
              <span class="arch-card__layer" aria-hidden="true">[ L1 ]</span>
            </header>
            <h3 id="arch-bronze-title" class="arch-card__title" data-i18n-key="pix.arch.bronze.title">
              BACEN API → Parquet Raw
            </h3>
            <p class="arch-card__desc" data-i18n-key="pix.arch.bronze.desc">
              Coleta diária via python-bcb. Dados brutos preservados em Parquet
              particionado por data — imutável, auditável, versionado.
            </p>
            <div class="arch-card__tags">
              <span class="tag">Python</span>
              <span class="tag">python-bcb</span>
              <span class="tag">Parquet</span>
            </div>
          </article>

          <!-- Silver layer -->
          <article
            class="card arch-card"
            style="border-top: 3px solid var(--medallion-silver);"
            aria-labelledby="arch-silver-title"
          >
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--silver">Silver</span>
              <span class="arch-card__layer" aria-hidden="true">[ L2 ]</span>
            </header>
            <h3 id="arch-silver-title" class="arch-card__title" data-i18n-key="pix.arch.silver.title">
              Limpeza e Tipagem
            </h3>
            <p class="arch-card__desc" data-i18n-key="pix.arch.silver.desc">
              Normalização de nomes, inferência de tipos, deduplicação e
              enriquecimento de datas. Schema enforced via DuckDB.
            </p>
            <div class="arch-card__tags">
              <span class="tag">DuckDB</span>
              <span class="tag">Pandas</span>
              <span class="tag">Parquet</span>
            </div>
          </article>

          <!-- Gold layer -->
          <article
            class="card arch-card"
            style="border-top: 3px solid var(--medallion-gold);"
            aria-labelledby="arch-gold-title"
          >
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--gold">Gold</span>
              <span class="arch-card__layer" aria-hidden="true">[ L3 ]</span>
            </header>
            <h3 id="arch-gold-title" class="arch-card__title" data-i18n-key="pix.arch.gold.title">
              Agregações Analíticas
            </h3>
            <p class="arch-card__desc" data-i18n-key="pix.arch.gold.desc">
              Visões pré-computadas para dashboards: série temporal diária,
              crescimento acumulado, ticket médio por período.
            </p>
            <div class="arch-card__tags">
              <span class="tag">DuckDB WASM</span>
              <span class="tag">D3.js</span>
              <span class="tag">Chat demo</span>
            </div>
          </article>

        </div>

        <!-- GitHub Actions automation card -->
        <div class="arch-automation card crop" aria-labelledby="arch-automation-title">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <div class="arch-automation__inner">
            <div class="arch-automation__left">
              <span class="mono-label arch-automation__badge" data-i18n-key="pix.arch.automation.label">
                GitHub Actions
              </span>
              <h3 id="arch-automation-title" class="arch-automation__title" data-i18n-key="pix.arch.automation.title">
                Orquestração automatizada
              </h3>
              <p class="arch-automation__desc" data-i18n-key="pix.arch.automation.desc">
                Pipeline executado diariamente via GitHub Actions: coleta → transforma
                → publica. Zero infraestrutura — serverless completo no GitHub.
                Retry automático em falha, alertas por issue e histórico rastreável.
              </p>
            </div>
            <div class="arch-automation__right" aria-hidden="true">
              <pre class="arch-automation__code">schedule: cron
  │
  ├── fetch_bacen.py
  │     └── Bronze Parquet
  │
  ├── transform.py
  │     └── Silver DuckDB
  │
  └── aggregate.py
        └── Gold JSON</pre>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 4: DATA INSIGHTS
         ══════════════════════════════════════════════════════ -->
    <section id="insights" class="section pix-insights" aria-labelledby="pix-insights-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">03</span>
          <h2 id="pix-insights-title" class="pix-display" data-i18n-key="pix.insights.title">
            Insights dos Dados
          </h2>
          <p class="pix-lead" data-i18n-key="pix.insights.subtitle">
            Padrões descobertos ao analisar 4+ anos de histórico do PIX.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="insights-grid">

          <article class="card insight-card" aria-labelledby="insight-1-title">
            <header class="insight-card__header">
              <span class="tag tag--accent" aria-label="Data de referência">Nov/2020</span>
              <span class="insight-card__num mono-label" aria-hidden="true">01</span>
            </header>
            <h3 id="insight-1-title" class="insight-card__title" data-i18n-key="pix.insights.card1.title">
              Crescimento histórico
            </h3>
            <p class="insight-card__body" data-i18n-key="pix.insights.card1.body">
              Dia 1 do PIX: 2.345 transações. Hoje: 258M+/dia.
              Um crescimento de 106.000× em menos de 5 anos — o mais rápido
              da história dos sistemas de pagamento.
            </p>
            <div class="insight-card__stat" aria-hidden="true">
              <span class="insight-card__stat-value">2.345</span>
              <span class="insight-card__stat-arrow">→</span>
              <span class="insight-card__stat-value insight-card__stat-value--accent">258M+</span>
            </div>
          </article>

          <article class="card insight-card" aria-labelledby="insight-2-title">
            <header class="insight-card__header">
              <span class="tag tag--accent" aria-label="Categoria de insight">B2B</span>
              <span class="insight-card__num mono-label" aria-hidden="true">02</span>
            </header>
            <h3 id="insight-2-title" class="insight-card__title" data-i18n-key="pix.insights.card2.title">
              Evolução do ticket médio
            </h3>
            <p class="insight-card__body" data-i18n-key="pix.insights.card2.body">
              Ticket médio saiu de R$90 para R$700+ nos picos.
              O PIX virou instrumento B2B — empresas movem boladas fora
              do horário bancário, algo impensável antes de novembro/2020.
            </p>
            <div class="insight-card__stat" aria-hidden="true">
              <span class="insight-card__stat-value">R$ 90</span>
              <span class="insight-card__stat-arrow">→</span>
              <span class="insight-card__stat-value insight-card__stat-value--accent">R$ 700+</span>
            </div>
          </article>

