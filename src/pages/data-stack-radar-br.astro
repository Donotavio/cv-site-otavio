---
/**
 * data-stack-radar-br.astro — Data Stack Radar BR
 * Direção: Blueprint (DESIGN.md)
 *
 * Segunda página de projeto do portfólio (irmã de pix-observatory.astro,
 * mesmo padrão estrutural). Radar de adoção de 16 ferramentas de dados no
 * mercado brasileiro — cruza vagas reais (Gupy + carreiras diretas via
 * Greenhouse), repositórios novos no GitHub e downloads no PyPI num score
 * único (Adopt/Trial/Assess/Hold).
 *
 * Seções (mono-labels [ 01 ]…[ 07 ]):
 *  0. Hero — sem número
 *  1. [01] Radar — scatter chart SVG nativo (job_score × github_score,
 *         raio = pypi_score, cor = quadrant) + legenda de tiers
 *  2. [02] Ranking Adopt → Hold — as 16 ferramentas, segmentadas por tier
 *  3. [03] Breakdown de sinais — os 3 sinais brutos por ferramenta
 *  4. [04] Análise de vagas — remoto, senioridade, cidade, skills (301
 *         vagas, 2 fontes: Gupy scraping + Greenhouse Jobs API)
 *  5. [05] Pipeline Bronze → Silver → Gold
 *  6. [06] Stack do pipeline (meta — o que constrói o radar)
 *  7. [07] Vagas em destaque & insights — tabela de vagas recentes (com
 *         link para a vaga original), ranking de empresas que mais
 *         contratam, combinações de skills mais pedidas juntas e um
 *         callout de transparência salarial
 *  8. Metodologia & limitações — sem número, transparência total
 *
 * Dado real, sem mock: fetch runtime de assets/data/radar_scores.json,
 * radar_trending.json, radar_jobs_analysis.json e radar_insights.json
 * (gerados semanalmente/mensalmente via GitHub Actions —
 * radar-jobs-pipeline.yml e radar-signals-pipeline.yml). Mesmo padrão de
 * pix-observatory.astro: loading skeleton estático → hidratação via fetch.
 *
 * Tokens: src/styles/tokens.css (--radar-adopt/-trial/-assess/-hold, zero
 * hex hardcoded fora de tokens.css). Motion: revealUp + hairlineDraw +
 * countUp — os mesmos 5 padrões do resto do site.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectRecommendations from '../components/ProjectRecommendations.astro';

// ── Geometria do scatter — estática (a grade de fundo não depende do
// dado; só os dots dependem do fetch). viewBox 640×640, plot 56–616 × 24–584.
const PLOT = { x0: 56, x1: 616, y0: 24, y1: 584 };
const GRID_FRACTIONS = [0, 25, 50, 75, 100];
const gridX = GRID_FRACTIONS.map((f) => PLOT.x0 + (f / 100) * (PLOT.x1 - PLOT.x0));
const gridY = GRID_FRACTIONS.map((f) => PLOT.y1 - (f / 100) * (PLOT.y1 - PLOT.y0));
---

<BaseLayout
  title="Data Stack Radar BR — Otávio Ribeiro"
  description="Radar de adoção de ferramentas de dados no mercado brasileiro: vagas, GitHub e PyPI cruzados num score único — Adopt, Trial, Assess ou Hold."
>
  <Header />

  <!-- Índice de capítulos (rail lateral) — só aparece em telas largas,
       no gutter à esquerda do container. Scroll-spy marca o capítulo ativo. -->
  <nav class="radar-toc" aria-label="Índice de capítulos" id="radar-toc">
    <ol class="radar-toc__list">
      <li><a class="radar-toc__link" href="#radar" data-toc="radar"><span class="radar-toc__num" aria-hidden="true">01</span><span class="radar-toc__label">Radar</span></a></li>
      <li><a class="radar-toc__link" href="#ranking-tools" data-toc="ranking-tools"><span class="radar-toc__num" aria-hidden="true">02</span><span class="radar-toc__label">Ranking</span></a></li>
      <li><a class="radar-toc__link" href="#breakdown" data-toc="breakdown"><span class="radar-toc__num" aria-hidden="true">03</span><span class="radar-toc__label">Sinais</span></a></li>
      <li><a class="radar-toc__link" href="#jobs-analysis" data-toc="jobs-analysis"><span class="radar-toc__num" aria-hidden="true">04</span><span class="radar-toc__label">Análise</span></a></li>
      <li><a class="radar-toc__link" href="#pipeline" data-toc="pipeline"><span class="radar-toc__num" aria-hidden="true">05</span><span class="radar-toc__label">Pipeline</span></a></li>
      <li><a class="radar-toc__link" href="#meta-stack" data-toc="meta-stack"><span class="radar-toc__num" aria-hidden="true">06</span><span class="radar-toc__label">Stack</span></a></li>
      <li><a class="radar-toc__link" href="#jobs-highlights" data-toc="jobs-highlights"><span class="radar-toc__num" aria-hidden="true">07</span><span class="radar-toc__label">Destaques</span></a></li>
      <li><a class="radar-toc__link" href="#cobertura" data-toc="cobertura"><span class="radar-toc__num" aria-hidden="true">08</span><span class="radar-toc__label">Cobertura</span></a></li>
      <li><a class="radar-toc__link" href="#tendencia" data-toc="tendencia"><span class="radar-toc__num" aria-hidden="true">09</span><span class="radar-toc__label">Tendência</span></a></li>
      <li><a class="radar-toc__link" href="#contexto" data-toc="contexto"><span class="radar-toc__num" aria-hidden="true">10</span><span class="radar-toc__label">Contexto</span></a></li>
      <li><a class="radar-toc__link" href="#metodologia" data-toc="metodologia"><span class="radar-toc__num" aria-hidden="true">—</span><span class="radar-toc__label">Método</span></a></li>
    </ol>
  </nav>

  <main id="main-content">

    <!-- ══════════════════════════════════════════════════════
         HERO
         ══════════════════════════════════════════════════════ -->
    <section id="radar-hero" class="section radar-hero" aria-labelledby="radar-hero-title">
      <div class="container">
        <div class="hero-card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="hero-card__header">
            <span class="mono-label">Data Stack Radar BR</span>
            <span class="mono-label radar-hero__badge" id="radar-hero-badge">
              atualizado · semana <span id="radar-hero-week">atual</span>
            </span>
          </header>

          <h1 id="radar-hero-title" class="hero-display">
            Adotar, testar ou esperar? O mercado de dados brasileiro em 16 ferramentas.
          </h1>

          <p class="hero-lead">
            Cruzamos menções em vagas reais (Gupy + carreiras diretas via
            Greenhouse), repositórios novos no GitHub e downloads no PyPI
            para descobrir o que o mercado brasileiro de dados está de fato
            adotando — e o que ainda é aposta. Score único, sem achismo.
          </p>

          <div class="hero-actions">
            <a href="#radar" class="btn-primary">Ver Radar →</a>
            <a href="#metodologia" class="btn-secondary">Metodologia</a>
            <a
              href="https://github.com/Donotavio/cv-site-otavio/tree/main/ingestion_radar"
              class="btn-secondary"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Ver código-fonte do pipeline no GitHub (abre em nova aba)"
            >GitHub</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 1: RADAR (scatter chart)
         ══════════════════════════════════════════════════════ -->
    <section id="radar" class="section radar-scatter-section" aria-labelledby="radar-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">01</span>
          <h2 id="radar-title" class="radar-display">O Radar</h2>
          <p class="radar-lead">
            Cada ponto é uma ferramenta. Posição = sinais brutos de mercado e
            comunidade. Cor = score ponderado. Tamanho = adoção no PyPI.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="radar-chart-block card crop" id="radar-chart-block" role="group" aria-labelledby="radar-chart-title">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="radar-chart-block__head">
            <span class="mono-label" id="radar-chart-title">radar de adoção · vagas × github × pypi</span>
            <ul class="radar-tier-legend" id="radar-tier-legend" role="list" aria-label="Contagem de ferramentas por tier de adoção">
              <li class="radar-tier-chip" data-tier="adopt">Adopt · ···</li>
              <li class="radar-tier-chip" data-tier="trial">Trial · ···</li>
              <li class="radar-tier-chip" data-tier="assess">Assess · ···</li>
              <li class="radar-tier-chip" data-tier="hold">Hold · ···</li>
            </ul>
          </header>

          <div class="radar-chart-layout">
            <div class="radar-axis-y-wrap" aria-hidden="true">
              <span class="radar-axis-label mono-label">
                <span class="radar-axis-label__short">eixo y · github_score</span>
                <span class="radar-axis-label__full">eixo y · github_score — repos novos no ano</span>
              </span>
            </div>

            <div class="radar-chart-wrap">
              <span class="radar-corner-label radar-corner-label--tl mono-label" aria-hidden="true">comunidade &gt; mercado</span>
              <span class="radar-corner-label radar-corner-label--tr mono-label" aria-hidden="true">mercado + comunidade</span>
              <span class="radar-corner-label radar-corner-label--bl mono-label" aria-hidden="true">sinal fraco em ambos</span>
              <span class="radar-corner-label radar-corner-label--br mono-label" aria-hidden="true">mercado &gt; comunidade</span>

              <svg
                class="radar-svg"
                viewBox="0 0 640 640"
                width="640"
                height="640"
                role="img"
                aria-hidden="true"
              >
                {gridX.map((x) => (
                  <line class="radar-grid-line" x1={x} y1={PLOT.y0} x2={x} y2={PLOT.y1} />
                ))}
                {gridY.map((y) => (
                  <line class="radar-grid-line" x1={PLOT.x0} y1={y} x2={PLOT.x1} y2={y} />
                ))}
                <line
                  class="radar-crosshair"
                  x1={gridX[2]} y1={PLOT.y0} x2={gridX[2]} y2={PLOT.y1}
                />
                <line
                  class="radar-crosshair"
                  x1={PLOT.x0} y1={gridY[2]} x2={PLOT.x1} y2={gridY[2]}
                />
                <rect
                  class="radar-plot-border"
                  x={PLOT.x0} y={PLOT.y0}
                  width={PLOT.x1 - PLOT.x0} height={PLOT.y1 - PLOT.y0}
                />
                <g id="radar-dots"></g>
              </svg>
            </div>
          </div>

          <p class="radar-axis-label radar-axis-label--x mono-label" aria-hidden="true">
            eixo x · job_score — menções em vagas BR
          </p>

          <p class="radar-chart-note mono-label">
            posição = sinais brutos (job_score × github_score) · cor = score ponderado
            (job 50% + github 25% + pypi 25%) · tamanho = pypi_score — o quadrante é um
            score composto, não um corte geométrico 50/50 dos eixos
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 2: RANKING ADOPT → HOLD
         ══════════════════════════════════════════════════════ -->
    <section id="ranking-tools" class="section radar-ranking-section" aria-labelledby="ranking-tools-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">02</span>
          <h2 id="ranking-tools-title" class="radar-display">Ranking Adopt → Hold</h2>
          <p class="radar-lead">
            As 16 ferramentas ordenadas por score total — da adoção plena ao
            momento de esperar e observar.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="ranking-tools-list" id="ranking-tools-list" aria-live="polite">
          <p class="ranking-loading mono-label">carregando ranking…</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 3: BREAKDOWN DE SINAIS
         ══════════════════════════════════════════════════════ -->
    <section id="breakdown" class="section radar-breakdown-section" aria-labelledby="breakdown-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">03</span>
          <h2 id="breakdown-title" class="radar-display">Breakdown de sinais</h2>
          <p class="radar-lead">
            Os 3 sinais brutos por ferramenta — vagas, repositórios novos e
            downloads — antes de virarem um score único.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="radar-breakdown-grid" id="radar-breakdown-grid" aria-live="polite">
          <p class="ranking-loading mono-label">carregando breakdown…</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 4: ANÁLISE DE VAGAS
         ══════════════════════════════════════════════════════ -->
    <section id="jobs-analysis" class="section radar-jobs-section" aria-labelledby="jobs-analysis-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">04</span>
          <h2 id="jobs-analysis-title" class="radar-display">Análise de vagas</h2>
          <p class="radar-lead">
            <!-- Sem aria-label estático aqui de propósito: o valor é
                 preenchido em runtime via fetch (loadJobsAnalysis) e o
                 count-up só atualiza o textContent — um aria-label fixo
                 tipo "vagas coletadas" (sem o número) sobrescreveria o
                 nome acessível do elemento e o leitor de tela nunca
                 anunciaria o número real. Mesmo padrão sem aria-label
                 usado em GitHubStats.astro para contadores hidratados. -->
            <span
              class="radar-jobs-total"
              id="jobs-total-vagas"
              data-count-to="0"
            >0</span> vagas coletadas via 6 fontes — remoto, senioridade, vínculo, cidade e skills.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <p class="ranking-methodology mono-label">
          amostra de vagas coletadas via Gupy (scraping) + carreiras diretas
          (Greenhouse, Lever, Ashby, InHire) + comunidade dev BR (API BR) ·
          não é um censo do mercado brasileiro de dados, é um recorte
          agregado de várias fontes —
          <span id="jobs-fonte-badge" aria-live="polite">carregando fontes…</span>
        </p>

        <div class="radar-jobs-grid">

          <div class="card radar-jobs-block jobs-block" role="group" aria-labelledby="jobs-remoto-title">
            <header class="radar-jobs-block__head">
              <span class="mono-label" id="jobs-remoto-title">remoto vs. presencial</span>
            </header>
            <ul class="jobs-meter-list" id="jobs-remoto" aria-label="Distribuição remoto vs presencial" aria-live="polite">
              <li class="ranking-loading mono-label">carregando…</li>
            </ul>
          </div>

          <div class="card radar-jobs-block jobs-block" role="group" aria-labelledby="jobs-senioridade-title">
            <header class="radar-jobs-block__head">
              <span class="mono-label" id="jobs-senioridade-title">por senioridade</span>
            </header>
            <ul class="jobs-meter-list" id="jobs-senioridade" aria-label="Distribuição por senioridade" aria-live="polite">
              <li class="ranking-loading mono-label">carregando…</li>
            </ul>
          </div>

          <div class="card radar-jobs-block jobs-block" role="group" aria-labelledby="jobs-contrato-title">
            <header class="radar-jobs-block__head">
              <span class="mono-label" id="jobs-contrato-title">vínculo (contrato)</span>
            </header>
            <ul class="jobs-meter-list" id="jobs-contrato" aria-label="Distribuição por tipo de contrato (CLT, PJ, estágio)" aria-live="polite">
              <li class="ranking-loading mono-label">carregando…</li>
            </ul>
          </div>

          <div class="card radar-jobs-block jobs-block" role="group" aria-labelledby="jobs-cidades-title">
            <header class="radar-jobs-block__head">
              <span class="mono-label" id="jobs-cidades-title">por cidade</span>
            </header>
            <ol class="radar-city-list" id="jobs-cidades" aria-label="Ranking de cidades por número de vagas" aria-live="polite">
              <li class="ranking-loading mono-label">carregando…</li>
            </ol>
          </div>

          <div class="card radar-jobs-block jobs-block" role="group" aria-labelledby="jobs-skills-title">
            <header class="radar-jobs-block__head">
              <span class="mono-label" id="jobs-skills-title">skills mais mencionadas</span>
            </header>
            <ul class="jobs-meter-list" id="jobs-skills" aria-label="Skills mais mencionadas nas vagas" aria-live="polite">
              <li class="ranking-loading mono-label">carregando…</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 5: PIPELINE BRONZE → SILVER → GOLD
         ══════════════════════════════════════════════════════ -->
    <section id="pipeline" class="section radar-pipeline-section" aria-labelledby="pipeline-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">05</span>
          <h2 id="pipeline-title" class="radar-display">Pipeline do Radar</h2>
          <p class="radar-lead">
            Medallion architecture sobre 3 fontes independentes — vagas,
            GitHub e PyPI — reconciliadas num score comparável.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="arch-grid">

          <article class="card arch-card" style="border-top: 3px solid var(--medallion-bronze);" aria-labelledby="radar-bronze-title">
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--bronze">Bronze</span>
              <span class="arch-card__layer" aria-hidden="true">[ L1 ]</span>
            </header>
            <h3 id="radar-bronze-title" class="arch-card__title">Gupy + Greenhouse + GitHub + PyPI → Parquet</h3>
            <p class="arch-card__desc">
              Scraping de vagas na Gupy (API do portal de empregos) e
              coleta via Greenhouse Jobs API (11 empresas curadas
              manualmente), busca de repositórios via GitHub Search API e
              estatísticas de download via PyPI Stats — cada fonte
              preservada em Parquet, particionada por data de coleta.
            </p>
            <div class="arch-card__tags">
              <span class="tag">Python</span>
              <span class="tag">Gupy API</span>
              <span class="tag">Greenhouse Jobs API</span>
              <span class="tag">GitHub Search API</span>
              <span class="tag">PyPI Stats</span>
            </div>
          </article>

          <article class="card arch-card" style="border-top: 3px solid var(--medallion-silver);" aria-labelledby="radar-silver-title">
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--silver">Silver</span>
              <span class="arch-card__layer" aria-hidden="true">[ L2 ]</span>
            </header>
            <h3 id="radar-silver-title" class="arch-card__title">Skills extraídas + ranking percentual</h3>
            <p class="arch-card__desc">
              Regex sobre a descrição das vagas extrai menções de skills.
              PERCENT_RANK() do DuckDB normaliza as 3 métricas brutas (vagas,
              repositórios, downloads) numa escala 0–100 comparável entre si.
            </p>
            <div class="arch-card__tags">
              <span class="tag">DuckDB</span>
              <span class="tag">Regex</span>
              <span class="tag">PERCENT_RANK()</span>
            </div>
          </article>

          <article class="card arch-card" style="border-top: 3px solid var(--medallion-gold);" aria-labelledby="radar-gold-title">
            <header class="arch-card__header">
              <span class="arch-card__badge mono-label arch-card__badge--gold">Gold</span>
              <span class="arch-card__layer" aria-hidden="true">[ L3 ]</span>
            </header>
            <h3 id="radar-gold-title" class="arch-card__title">Score ponderado + quadrante</h3>
            <p class="arch-card__desc">
              job_score×50% + github_score×25% + pypi_score×25% = score total.
              Quadrante (Adopt/Trial/Assess/Hold) e ranking exportados como
              JSON, consumidos direto pelo site em runtime.
            </p>
            <div class="arch-card__tags">
              <span class="tag">DuckDB</span>
              <span class="tag">JSON</span>
              <span class="tag">GitHub Pages</span>
            </div>
          </article>

        </div>

        <div class="arch-automation card crop" role="group" aria-labelledby="radar-automation-title">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <div class="arch-automation__inner">
            <div class="arch-automation__left">
              <span class="mono-label arch-automation__badge">GitHub Actions</span>
              <h3 id="radar-automation-title" class="arch-automation__title">Dois cron jobs independentes</h3>
              <p class="arch-automation__desc">
                Vagas: semanal, toda segunda-feira às 02h UTC
                (<code>radar-jobs-pipeline.yml</code>). GitHub + PyPI: mensal,
                dia 1 às 03h UTC (<code>radar-signals-pipeline.yml</code>).
                Cada pipeline recalcula o gold e dispara o deploy do site
                automaticamente — zero infraestrutura, serverless completo.
              </p>
            </div>
            <div class="arch-automation__right" aria-hidden="true">
              <pre class="arch-automation__code">radar-jobs-pipeline.yml
  cron: seg 02h UTC
  ├── collect_gupy.py
  ├── collect_jobs_greenhouse.py
  │     └── Bronze Parquet
  └── gold_jobs_analysis.py
        └── Gold JSON

radar-signals-pipeline.yml
  cron: dia 1 · 03h UTC
  ├── collect_github.py
  ├── collect_pypi.py
  │     └── Bronze Parquet
  ├── silver_signals.py
  │     └── Silver DuckDB
  └── gold_radar.py
        └── Gold JSON</pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 6: STACK DO PIPELINE (meta)
         ══════════════════════════════════════════════════════ -->
    <section id="meta-stack" class="section radar-meta-section" aria-labelledby="meta-stack-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">06</span>
          <h2 id="meta-stack-title" class="radar-display">Stack do Pipeline</h2>
          <p class="radar-lead">
            O que constrói o radar — não o que o radar mede.
          </p>
        </div>

        <hr class="section-line" aria-hidden="true" />

        <div class="radar-meta-grid" role="list" aria-label="Tecnologias do pipeline do radar">
          <div class="card radar-meta-item" role="listitem">
            <span class="mono-label radar-meta-item__name">Python</span>
            <p class="radar-meta-item__role">Scripts de coleta e transformação (ingestion_radar/, transform_radar/)</p>
          </div>
          <div class="card radar-meta-item" role="listitem">
            <span class="mono-label radar-meta-item__name">Gupy API</span>
            <p class="radar-meta-item__role">employability-portal.gupy.io — scraping de vagas por termo de busca</p>
          </div>
          <div class="card radar-meta-item" role="listitem">
            <span class="mono-label radar-meta-item__name">Greenhouse Jobs API</span>
