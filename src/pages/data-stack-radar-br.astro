<!-- ════════════════════════════════════════════════════════════
     SCRIPTS — motion + fetch runtime dos dados reais
     ════════════════════════════════════════════════════════════ -->
<script>
  import { revealUp }     from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  // ── Reveal animations para o conteúdo estático (mesmo padrão de
  // pix-observatory.astro) — conteúdo hidratado via fetch recebe seu
  // próprio revealUp dentro das funções de render abaixo. ──────────
  // astro:page-load (não DOMContentLoaded): dispara no 1º load E após cada
  // navegação SPA do <ClientRouter />. O guard #radar-hero garante que só
  // roda nesta página (o listener no document persiste entre navegações).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('radar-hero')) return;

    const heroCard = document.querySelector('.hero-card');
    if (heroCard && motionOk) revealUp([heroCard], heroCard, 0);

    const radarSection = document.getElementById('radar');
    if (radarSection) {
      const head  = radarSection.querySelector('.section-head');
      const line  = radarSection.querySelector('.section-line');
      const block = radarSection.querySelector('.radar-chart-block');
      if (line) hairlineDraw(line, radarSection);
      if (motionOk && head) revealUp([head], radarSection, 0);
      if (motionOk && block) revealUp([block], radarSection, STAGGER.tight);
    }

    const rankingSection = document.getElementById('ranking-tools');
    if (rankingSection) {
      const head = rankingSection.querySelector('.section-head');
      const line = rankingSection.querySelector('.section-line');
      if (line) hairlineDraw(line, rankingSection);
      if (motionOk && head) revealUp([head], rankingSection, 0);
    }

    const breakdownSection = document.getElementById('breakdown');
    if (breakdownSection) {
      const head = breakdownSection.querySelector('.section-head');
      const line = breakdownSection.querySelector('.section-line');
      if (line) hairlineDraw(line, breakdownSection);
      if (motionOk && head) revealUp([head], breakdownSection, 0);
    }

    const jobsSection = document.getElementById('jobs-analysis');
    if (jobsSection) {
      const head = jobsSection.querySelector('.section-head');
      const line = jobsSection.querySelector('.section-line');
      const blocks = jobsSection.querySelectorAll('.radar-jobs-block');
      if (line) hairlineDraw(line, jobsSection);
      if (motionOk && head) revealUp([head], jobsSection, 0);
      if (motionOk && blocks.length) revealUp(blocks, jobsSection, STAGGER.tight);
    }

    const pipelineSection = document.getElementById('pipeline');
    if (pipelineSection) {
      const head  = pipelineSection.querySelector('.section-head');
      const line  = pipelineSection.querySelector('.section-line');
      const cards = pipelineSection.querySelectorAll('.arch-card, .arch-automation');
      if (line) hairlineDraw(line, pipelineSection);
      if (motionOk && head) revealUp([head], pipelineSection, 0);
      if (motionOk && cards.length) revealUp(cards, pipelineSection, STAGGER.tight);
    }

    const metaSection = document.getElementById('meta-stack');
    if (metaSection) {
      const head  = metaSection.querySelector('.section-head');
      const line  = metaSection.querySelector('.section-line');
      const items = metaSection.querySelectorAll('.radar-meta-item');
      if (line) hairlineDraw(line, metaSection);
      if (motionOk && head) revealUp([head], metaSection, 0);
      if (motionOk && items.length) revealUp(items, metaSection, STAGGER.tight);
    }

    const jobsHighlightsSection = document.getElementById('jobs-highlights');
    if (jobsHighlightsSection) {
      const head = jobsHighlightsSection.querySelector('.section-head');
      const line = jobsHighlightsSection.querySelector('.section-line');
      const blocks = jobsHighlightsSection.querySelectorAll(
        '.radar-jobs-table-block, .radar-highlights-block, .radar-salary-callout, .radar-benchmark-card',
      );
      if (line) hairlineDraw(line, jobsHighlightsSection);
      if (motionOk && head) revealUp([head], jobsHighlightsSection, 0);
      if (motionOk && blocks.length) revealUp(blocks, jobsHighlightsSection, STAGGER.tight);
    }

    const coberturaSection = document.getElementById('cobertura');
    if (coberturaSection) {
      const head  = coberturaSection.querySelector('.section-head');
      const line  = coberturaSection.querySelector('.section-line');
      const block = coberturaSection.querySelector('.radar-coverage-block');
      if (line) hairlineDraw(line, coberturaSection);
      if (motionOk && head) revealUp([head], coberturaSection, 0);
      if (motionOk && block) revealUp([block], coberturaSection, STAGGER.tight);
    }

    const tendenciaSection = document.getElementById('tendencia');
    if (tendenciaSection) {
      const head   = tendenciaSection.querySelector('.section-head');
      const line   = tendenciaSection.querySelector('.section-line');
      const blocks = tendenciaSection.querySelectorAll('.radar-trend-block');
      if (line) hairlineDraw(line, tendenciaSection);
      if (motionOk && head) revealUp([head], tendenciaSection, 0);
      if (motionOk && blocks.length) revealUp(blocks, tendenciaSection, STAGGER.tight);
    }

    const contextoSection = document.getElementById('contexto');
    if (contextoSection) {
      const head  = contextoSection.querySelector('.section-head');
      const line  = contextoSection.querySelector('.section-line');
      const cards = contextoSection.querySelectorAll('.radar-context-card');
      if (line) hairlineDraw(line, contextoSection);
      if (motionOk && head) revealUp([head], contextoSection, 0);
      if (motionOk && cards.length) revealUp(cards, contextoSection, STAGGER.tight);
    }

    const methodologySection = document.getElementById('metodologia');
    if (methodologySection) {
      const head  = methodologySection.querySelector('.section-head');
      const line  = methodologySection.querySelector('.section-line');
      const items = methodologySection.querySelectorAll('.radar-methodology-item');
      if (line) hairlineDraw(line, methodologySection);
      if (motionOk && head) revealUp([head], methodologySection, 0);
      if (motionOk && items.length) revealUp(items, methodologySection, STAGGER.tight);
    }
  });
</script>

<script>
  /**
   * radar_scores.json — 16 ferramentas com job/github/pypi score + quadrant.
   * Alimenta: badge da semana no hero, scatter chart (dots + labels),
   * legenda de tiers, ranking Adopt→Hold e breakdown de sinais.
   * Um único fetch, reaproveitado pelas 5 renderizações — evita 5 requests
   * para o mesmo arquivo.
   */
  import { revealUp } from '../scripts/motion/reveal-up';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  interface RadarTool {
    tool: string;
    category: string;
    job_mentions: number;
    new_repos_ytd: number;
    downloads_last_month: number;
    job_score: number;
    github_score: number;
    pypi_score: number;
    total_score: number;
    quadrant: string;
  }

  interface RadarScoresPayload {
    gerado_em?: string;
    janelas?: { jobs_semana?: string; github_mes?: string; pypi_mes?: string };
    tools?: RadarTool[];
  }

  const QUADRANT_ORDER = ['Adopt', 'Trial', 'Assess', 'Hold'] as const;
  const QUADRANT_VAR: Record<string, string> = {
    Adopt: 'var(--radar-adopt)',
    Trial: 'var(--radar-trial)',
    Assess: 'var(--radar-assess)',
    Hold: 'var(--radar-hold)',
  };

  function meter(pct: number): string {
    const p = Math.max(0, Math.min(100, pct));
    return `<span class="ui-bar"><span class="ui-bar__fill" style="inline-size:${p}%"></span></span>`;
  }

  function fmtScore(n: number): string {
    return n.toFixed(1).replace('.', ',');
  }
  function fmtInt(n: number): string {
    return Math.round(n).toLocaleString('pt-BR');
  }
  function fmtDownloads(n: number): string {
    if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.', ',')}M`;
    if (n >= 1_000) return `${(n / 1_000).toFixed(1).replace('.', ',')}mil`;
    return String(n);
  }
  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function renderHeroBadge(data: RadarScoresPayload): void {
    const weekEl = document.getElementById('radar-hero-week');
    if (weekEl && data.janelas?.jobs_semana) {
      weekEl.textContent = data.janelas.jobs_semana;
    }
  }

  function renderScatter(tools: RadarTool[]): void {
    const g = document.getElementById('radar-dots');
    if (!g) return;
    const NS = 'http://www.w3.org/2000/svg';
    const X0 = 56, X1 = 616, Y0 = 24, Y1 = 584;
    const created: Element[] = [];

    tools.forEach((tool) => {
      const cx = X0 + (tool.job_score / 100) * (X1 - X0);
      const cy = Y1 - (tool.github_score / 100) * (Y1 - Y0);
      const r = 4 + (tool.pypi_score / 100) * 10;
      const fill = QUADRANT_VAR[tool.quadrant] ?? 'var(--ink-faint)';

      const circle = document.createElementNS(NS, 'circle');
      circle.setAttribute('cx', cx.toFixed(1));
      circle.setAttribute('cy', cy.toFixed(1));
      circle.setAttribute('r', r.toFixed(1));
      circle.setAttribute('data-tool', tool.tool);
      circle.style.fill = fill;
      circle.style.stroke = 'var(--paper-card)';
      circle.style.strokeWidth = '1.5';
      g.appendChild(circle);
      created.push(circle);

      if (tool.total_score > 60) {
        const text = document.createElementNS(NS, 'text');
        text.setAttribute('x', (cx + 8).toFixed(1));
        text.setAttribute('y', (cy - 6).toFixed(1));
        text.setAttribute('class', 'radar-dot-label');
        text.textContent = tool.tool;
        g.appendChild(text);
        created.push(text);
      }
    });

    if (motionOk && created.length) {
      const block = document.getElementById('radar-chart-block');
      revealUp(created, block ?? g, STAGGER.tight);
    }
  }

  function renderTierLegend(tools: RadarTool[]): void {
    const legend = document.getElementById('radar-tier-legend');
    if (!legend) return;

    const counts: Record<string, number> = { Adopt: 0, Trial: 0, Assess: 0, Hold: 0 };
    tools.forEach((t) => {
      if (t.quadrant in counts) counts[t.quadrant] += 1;
    });

    legend.innerHTML = QUADRANT_ORDER.map(
      (q) => `<li class="radar-tier-chip" data-tier="${q.toLowerCase()}">${q} · ${counts[q]}</li>`,
    ).join('');
  }

  function renderRanking(tools: RadarTool[]): void {
    const list = document.getElementById('ranking-tools-list');
    if (!list) return;

    const sorted = [...tools].sort((a, b) => b.total_score - a.total_score);

    const blocks = QUADRANT_ORDER.map((q) => {
      const items = sorted.filter((t) => t.quadrant === q);
      if (!items.length) return '';

      const rows = items
        .map((tool, i) => `
          <li class="radar-tool-row" data-tier="${q.toLowerCase()}">
            <div class="radar-tool-row__top">
              <span class="radar-tool-row__rank mono-label" aria-hidden="true">${String(i + 1).padStart(2, '0')}</span>
              <span class="radar-tool-row__name">${escapeHtml(tool.tool)}</span>
              <span class="tag radar-tool-row__category">${escapeHtml(tool.category)}</span>
              <span class="tag radar-tool-row__tier-badge" data-tier="${q.toLowerCase()}">${q}</span>
            </div>
            <div class="radar-tool-row__meter-row">
              <span class="radar-tool-row__meter" data-tier="${q.toLowerCase()}" aria-hidden="true">${meter(tool.total_score)}</span>
              <span
                class="radar-tool-row__score"
                role="meter"
                aria-valuenow="${tool.total_score}"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-label="${escapeHtml(tool.tool)}: score total ${fmtScore(tool.total_score)} de 100, quadrante ${q}, categoria ${escapeHtml(tool.category)}"
              >${fmtScore(tool.total_score)}</span>
            </div>
          </li>`)
        .join('');

      return `
        <div class="radar-tier-block" data-tier="${q.toLowerCase()}">
          <h3 class="radar-tier-block__head mono-label" data-tier="${q.toLowerCase()}">${q} · ${items.length}</h3>
          <ol class="radar-tool-list" role="list">${rows}</ol>
        </div>`;
    }).join('');

    list.innerHTML = blocks;

    if (motionOk) {
      const tierBlocks = list.querySelectorAll('.radar-tier-block');
      if (tierBlocks.length) revealUp(tierBlocks, list, STAGGER.tight);
    }
  }

  function renderBreakdown(tools: RadarTool[]): void {
    const grid = document.getElementById('radar-breakdown-grid');
    if (!grid) return;

    const sorted = [...tools].sort((a, b) => b.total_score - a.total_score);

    grid.innerHTML = sorted.map((tool) => {
      const tier = tool.quadrant.toLowerCase();
      return `
        <article class="card radar-breakdown-card" data-tier="${tier}">
          <header class="radar-breakdown-card__head">
            <span class="radar-breakdown-card__name">${escapeHtml(tool.tool)}</span>
            <span class="tag radar-breakdown-card__tier" data-tier="${tier}">${tool.quadrant}</span>
          </header>
          <ul class="radar-breakdown-card__meters">
            <li class="radar-breakdown-meter">
              <span class="radar-breakdown-meter__label mono-label">vagas</span>
              <span class="radar-breakdown-meter__bar" data-tier="${tier}" aria-hidden="true">${meter(tool.job_score)}</span>
              <span class="radar-breakdown-meter__value">${fmtScore(tool.job_score)} <span class="radar-breakdown-meter__raw">(${fmtScore(tool.job_mentions)} menções/semana)</span></span>
            </li>
            <li class="radar-breakdown-meter">
              <span class="radar-breakdown-meter__label mono-label">github</span>
              <span class="radar-breakdown-meter__bar" data-tier="${tier}" aria-hidden="true">${meter(tool.github_score)}</span>
              <span class="radar-breakdown-meter__value">${fmtScore(tool.github_score)} <span class="radar-breakdown-meter__raw">(${fmtInt(tool.new_repos_ytd)} repos novos/ano)</span></span>
            </li>
            <li class="radar-breakdown-meter">
              <span class="radar-breakdown-meter__label mono-label">pypi</span>
              <span class="radar-breakdown-meter__bar" data-tier="${tier}" aria-hidden="true">${meter(tool.pypi_score)}</span>
              <span class="radar-breakdown-meter__value">${fmtScore(tool.pypi_score)} <span class="radar-breakdown-meter__raw">(${fmtDownloads(tool.downloads_last_month)} downloads/mês)</span></span>
            </li>
          </ul>
        </article>`;
    }).join('');

    if (motionOk) {
      const cards = grid.querySelectorAll('.radar-breakdown-card');
      if (cards.length) revealUp(cards, grid, STAGGER.tight);
    }
  }

  async function loadRadarScores(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const res = await fetch(`${base}assets/data/radar_scores.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: RadarScoresPayload = await res.json();
      const tools = data.tools ?? [];
      if (!tools.length) throw new Error('empty payload');

      renderHeroBadge(data);
      renderScatter(tools);
      renderTierLegend(tools);
      renderRanking(tools);
      renderBreakdown(tools);
    } catch {
      clearTimeout(timeoutId);
      const rankingList = document.getElementById('ranking-tools-list');
      if (rankingList) {
        rankingList.innerHTML = '<p class="ranking-error mono-label">ranking indisponível — tente recarregar</p>';
      }
      const breakdownGrid = document.getElementById('radar-breakdown-grid');
      if (breakdownGrid) {
        breakdownGrid.innerHTML = '<p class="ranking-error mono-label">breakdown indisponível — tente recarregar</p>';
      }
      const legend = document.getElementById('radar-tier-legend');
      if (legend) {
        legend.innerHTML = '<li class="ranking-error mono-label">indisponível</li>';
      }
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-hero')) loadRadarScores();
  });
</script>

<script>
  /**
   * radar_jobs_analysis.json — 301 vagas coletadas via 2 fontes: Gupy
   * (scraping) + Greenhouse Jobs API (11 empresas curadas manualmente,
   * filtradas por título de vaga de dados — a Greenhouse não tem busca
   * por termo, então baixamos todas as vagas da empresa e filtramos
   * client-side, ver ingestion_radar/collect_jobs_greenhouse.py).
   * Alimenta os 4 sub-blocos da seção [04]: remoto, senioridade, cidade,
   * skills — e o badge de por_fonte. Contador de vagas (count-up) dispara
   * após o fetch resolver.
   */
  import { revealUp } from '../scripts/motion/reveal-up';
  import { countUp } from '../scripts/motion/count-up';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  interface SeniorityItem { seniority: string; n: number; pct: number; }
  interface ContratoItem { contrato: string; n: number; pct: number; }
  interface CityItem { city: string; state: string; n: number; }
  interface SkillItem { skill: string; n_jobs: number; pct_of_jobs: number; }
  interface FonteItem { fonte: string; n: number; pct: number; }

  interface JobsAnalysisPayload {
    total_vagas?: number;
    remoto_pct?: number;
    por_fonte?: FonteItem[];
    por_senioridade?: SeniorityItem[];
    por_contrato?: ContratoItem[];
    por_cidade?: CityItem[];
    skills_mais_mencionadas?: SkillItem[];
  }

  function meter(pct: number): string {
    const p = Math.max(0, Math.min(100, pct));
    return `<span class="ui-bar"><span class="ui-bar__fill" style="inline-size:${p}%"></span></span>`;
  }
  function fmtPct(n: number): string {
    return n.toFixed(1).replace('.', ',');
  }
  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function capitalize(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function renderFontes(items: FonteItem[]): void {
    const el = document.getElementById('jobs-fonte-badge');
    if (!el) return;
    if (!items.length) {
      el.textContent = 'fontes indisponíveis';
      return;
    }
    el.textContent = items
      .map((item) => `${capitalize(item.fonte)} ${fmtPct(item.pct)}%`)
      .join(' · ');
  }

  function renderRemoto(remotoPct: number): void {
    const el = document.getElementById('jobs-remoto');
    if (!el) return;
    const presencial = 100 - remotoPct;
    el.innerHTML = `
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">Remoto</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(remotoPct)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${remotoPct}" aria-valuemin="0" aria-valuemax="100" aria-label="Remoto: ${fmtPct(remotoPct)}% das vagas">${fmtPct(remotoPct)}%</span>
      </li>
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">Presencial/híbrido</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(presencial)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${presencial}" aria-valuemin="0" aria-valuemax="100" aria-label="Presencial ou híbrido: ${fmtPct(presencial)}% das vagas">${fmtPct(presencial)}%</span>
      </li>`;
  }

  function renderSenioridade(items: SeniorityItem[]): void {
    const el = document.getElementById('jobs-senioridade');
    if (!el) return;
    el.innerHTML = items.map((item) => `
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">${escapeHtml(item.seniority)}</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(item.pct)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${item.pct}" aria-valuemin="0" aria-valuemax="100" aria-label="${escapeHtml(item.seniority)}: ${fmtPct(item.pct)}% das vagas, ${item.n} vagas">${fmtPct(item.pct)}%</span>
      </li>`).join('');
  }

  function renderContrato(items: ContratoItem[]): void {
    const el = document.getElementById('jobs-contrato');
    if (!el) return;
    if (!items.length) {
      el.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      return;
    }
    el.innerHTML = items.map((item) => `
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">${escapeHtml(item.contrato)}</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(item.pct)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${item.pct}" aria-valuemin="0" aria-valuemax="100" aria-label="${escapeHtml(item.contrato)}: ${fmtPct(item.pct)}% das vagas, ${item.n} vagas">${fmtPct(item.pct)}%</span>
      </li>`).join('');
  }

  function renderCidades(items: CityItem[]): void {
    const el = document.getElementById('jobs-cidades');
    if (!el) return;
    el.innerHTML = items.map((item, i) => `
      <li class="radar-city-row">
        <span class="radar-city-row__rank" aria-hidden="true">${i + 1}</span>
        <span class="radar-city-row__name" title="${escapeHtml(item.city)}, ${escapeHtml(item.state)}">${escapeHtml(item.city)}</span>
        <span class="radar-city-row__state">${escapeHtml(item.state)}</span>
        <span class="radar-city-row__n">${item.n}</span>
      </li>`).join('');
  }

  function renderSkills(items: SkillItem[]): void {
    const el = document.getElementById('jobs-skills');
    if (!el) return;
    const top = items.slice(0, 15);
    el.innerHTML = top.map((item) => `
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">${escapeHtml(item.skill)}</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(item.pct_of_jobs)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${item.pct_of_jobs}" aria-valuemin="0" aria-valuemax="100" aria-label="${escapeHtml(item.skill)}: ${fmtPct(item.pct_of_jobs)}% das vagas, ${item.n_jobs} vagas">${fmtPct(item.pct_of_jobs)}%</span>
      </li>`).join('');
  }

  async function loadJobsAnalysis(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const totalEl = document.getElementById('jobs-total-vagas');

    try {
      const res = await fetch(`${base}assets/data/radar_jobs_analysis.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: JobsAnalysisPayload = await res.json();

      renderRemoto(data.remoto_pct ?? 0);
      renderFontes(data.por_fonte ?? []);
      renderSenioridade(data.por_senioridade ?? []);
      renderContrato(data.por_contrato ?? []);
      renderCidades(data.por_cidade ?? []);
      renderSkills(data.skills_mais_mencionadas ?? []);

      if (totalEl && data.total_vagas) {
        totalEl.dataset.countTo = String(data.total_vagas);
        countUp(totalEl, document.getElementById('jobs-analysis') ?? totalEl);
      }

      if (motionOk) {
        const jobsSection = document.getElementById('jobs-analysis');
        const meterRows = document.querySelectorAll('.jobs-meter-row, .radar-city-row');
        if (jobsSection && meterRows.length) revealUp(meterRows, jobsSection, STAGGER.tight);
      }
    } catch {
      clearTimeout(timeoutId);
      ['jobs-remoto', 'jobs-senioridade', 'jobs-contrato', 'jobs-cidades', 'jobs-skills'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      });
      const fonteEl = document.getElementById('jobs-fonte-badge');
      if (fonteEl) fonteEl.textContent = 'fontes indisponíveis';
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-hero')) loadJobsAnalysis();
  });
</script>

<script>
  /**
   * radar_trending.json — [09] Tendência de demanda. Variação da SHARE (%)
   * de cada ferramenta nas menções de vaga, entre a janela recente e a
   * anterior (medalhão real, atualizado no CI). Renderiza dois blocos —
   * em alta / em baixa — ordenados pelo maior movimento (delta em pontos
   * percentuais). Enquanto não houver 2 semanas, mostra estado honesto.
   */
  interface TrendTool {
    tool: string;
    mentions_recent: number | null;
    mentions_prior: number | null;
    share_recent_pct: number | null;
    share_prior_pct: number | null;
    delta_pp: number | null;
    direction: string;
  }
  interface TrendingPayload {
    insufficient_history?: boolean;
    mode?: string;
    window_label?: string;
    nota?: string;
    weeks_available?: number;
    tools?: TrendTool[];
  }

  const TREND_MAX = 6;
  const TOOL_LABELS: Record<string, string> = {
    'apache-airflow': 'Airflow', 'apache-spark': 'Spark', 'apache-kafka': 'Kafka',
    'apache-iceberg': 'Iceberg', 'delta-lake': 'Delta Lake', 'great-expectations': 'Great Expectations',
    dbt: 'dbt', duckdb: 'DuckDB', polars: 'Polars', dagster: 'Dagster', prefect: 'Prefect',
    kestra: 'Kestra', databricks: 'Databricks', airbyte: 'Airbyte', dlt: 'dlt', mlflow: 'MLflow',
  };
  function toolLabel(t: string): string {
    return TOOL_LABELS[t] ?? t;
  }
  function fmtDelta(pp: number): string {
    const s = Math.abs(pp).toFixed(1).replace('.', ',');
    return `${pp > 0 ? '+' : pp < 0 ? '−' : ''}${s} pp`;
  }
  function escT(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function renderTrendList(id: string, items: TrendTool[], emptyMsg: string): void {
    const el = document.getElementById(id);
    if (!el) return;
    if (!items.length) {
      el.innerHTML = `<li class="radar-trend-empty mono-label">${escT(emptyMsg)}</li>`;
      return;
    }
    const maxAbs = Math.max(...items.map((t) => Math.abs(t.delta_pp ?? 0)), 0.1);
    el.innerHTML = items.map((t) => {
      const delta = t.delta_pp ?? 0;
      const barPct = Math.min(100, (Math.abs(delta) / maxAbs) * 100);
      const dir = t.direction === 'up' ? 'up' : 'down';
      const shareNow = (t.share_recent_pct ?? 0).toFixed(1).replace('.', ',');
      return `
        <li class="radar-trend-row radar-trend-row--${dir}">
          <span class="radar-trend-row__name">${escT(toolLabel(t.tool))}</span>
          <span class="radar-trend-row__track" aria-hidden="true">
            <span class="radar-trend-row__fill radar-trend-row__fill--${dir}" style="inline-size:${barPct}%"></span>
          </span>
          <span class="radar-trend-row__delta radar-trend-row__delta--${dir}"
                role="meter" aria-valuenow="${delta}"
                aria-label="${escT(toolLabel(t.tool))}: ${fmtDelta(delta)} de fatia, agora ${shareNow}% das menções">${fmtDelta(delta)}</span>
        </li>`;
    }).join('');
    // Reveal fica a cargo do card estático (§09) — reveal por-linha aqui
    // grudava em opacity:0 quando o conteúdo é injetado após o page-load.
  }

  async function loadTrending(): Promise<void> {
    const windowEl = document.getElementById('radar-trend-window');
    const noteEl = document.getElementById('radar-trend-note');
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const res = await fetch(`${base}assets/data/radar_trending.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: TrendingPayload = await res.json();

      if (windowEl) {
        windowEl.textContent = data.insufficient_history
          ? 'acumulando histórico — a tendência aparece a partir de 2 semanas de coleta'
          : `janela: ${data.window_label ?? '—'} · ${data.weeks_available ?? 0} semanas coletadas`;
      }
      if (noteEl) noteEl.textContent = data.nota ?? '';

      const tools = (data.tools ?? []).filter((t) => t.delta_pp != null);
      const up = tools.filter((t) => t.direction === 'up').slice(0, TREND_MAX);
      const down = tools.filter((t) => t.direction === 'down')
        .sort((a, b) => (a.delta_pp ?? 0) - (b.delta_pp ?? 0)).slice(0, TREND_MAX);

      renderTrendList('radar-trend-up', up,
        data.insufficient_history ? 'aguardando histórico' : 'nenhuma ferramenta ganhou fatia nesta janela');
      renderTrendList('radar-trend-down', down,
        data.insufficient_history ? 'aguardando histórico' : 'nenhuma ferramenta perdeu fatia nesta janela');
    } catch {
      clearTimeout(timeoutId);
      if (windowEl) windowEl.textContent = 'tendência indisponível';
      ['radar-trend-up', 'radar-trend-down'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-hero')) loadTrending();
  });
</script>

<script>
  /**
   * radar_insights.json — vagas mais recentes (com link para a vaga
   * original), ranking de empresas que mais contratam, combinações de
   * skills que aparecem juntas na mesma vaga e % de vagas com faixa
   * salarial informada. Um único fetch, reaproveitado pelos 4 sub-blocos
   * da seção [07] — mesmo padrão de radar_scores.json / radar_jobs_analysis.json.
   */
  import { revealUp } from '../scripts/motion/reveal-up';
  import { countUp } from '../scripts/motion/count-up';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  interface VagaRecente {
    title: string;
    company: string;
    city: string;
    is_remote: boolean;
    seniority: string;
    skills: string[];
    url: string;
    source: string;
    publishedDate: string;
  }
  interface EmpresaItem { company: string; n_vagas: number; n_remoto: number; source: string; }
  interface CoberturaItem { fonte: string; n_vagas: number; pct: number; n_empresas: number; }
  interface SkillCombo { skill_a: string; skill_b: string; n_vagas: number; pct_of_jobs: number; }
  interface VagaSalarioReal {
    title: string;
    company: string;
    seniority: string;
    contract_type?: string;
    salary_min: number;
    salary_max: number;
    salary_currency?: string;
    salary_source?: string;
    url: string;
    source: string;
  }
  interface BenchmarkExterno {
    fonte: string;
    amostra: string;
    salario_crescimento_2023_2024_pct: number;
    inflacao_2024_pct: number;
    pct_preferem_100_remoto: number;
    pct_preferem_hibrido_flexivel: number;
    url: string;
    nota: string;
  }

  interface InsightsPayload {
    gerado_em?: string;
    vagas_recentes?: VagaRecente[];
    por_empresa?: EmpresaItem[];
    cobertura_por_fonte?: CoberturaItem[];
    skill_combos?: SkillCombo[];
    salario_transparencia_pct?: number;
    n_vagas_com_salario_real?: number;
    n_vagas_total?: number;
    vagas_com_salario_real?: VagaSalarioReal[];
    benchmark_externo?: BenchmarkExterno;
    notas?: Record<string, string>;
  }

  const FONTE_LABELS: Record<string, string> = {
    gupy: 'Gupy', greenhouse: 'Greenhouse', lever: 'Lever', ashby: 'Ashby',
    inhire: 'InHire', apibr: 'API BR',
  };
  function fmtFonte(f: string): string {
    return FONTE_LABELS[f.toLowerCase()] ?? f.charAt(0).toUpperCase() + f.slice(1);
  }

  const TABLE_ROWS_MAX = 18;
  const COMPANIES_MAX = 10;
  const COMBOS_MAX = 10;

  const SKILL_LABELS: Record<string, string> = {
    python: 'Python', sql: 'SQL', 'power bi': 'Power BI', aws: 'AWS',
    azure: 'Azure', gcp: 'GCP', databricks: 'Databricks', spark: 'Spark',
    airflow: 'Airflow', bigquery: 'BigQuery', kafka: 'Kafka', dbt: 'dbt',
    docker: 'Docker',
  };

  function meter(pct: number): string {
    const p = Math.max(0, Math.min(100, pct));
    return `<span class="ui-bar"><span class="ui-bar__fill" style="inline-size:${p}%"></span></span>`;
  }
  function fmtPct(n: number): string {
    return n.toFixed(1).replace('.', ',');
  }
  /** Preserva a precisão exata do JSON (sem arredondar) — só troca '.' por ','. */
  function fmtDecimal(n: number): string {
    return String(n).replace('.', ',');
  }
  const currencyFmt = new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency: 'BRL',
    maximumFractionDigits: 0,
  });
  function formatSalary(min: number, max: number): string {
    if (min === max) return currencyFmt.format(min);
    return `${currencyFmt.format(min)} – ${currencyFmt.format(max)}`;
  }
  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }
  function capitalize(s: string): string {
    return s.length ? s.charAt(0).toUpperCase() + s.slice(1) : s;
  }
  function formatSkill(skill: string): string {
    return SKILL_LABELS[skill.toLowerCase()] ?? capitalize(skill);
  }

  /** Tempo relativo calculado client-side — nunca hardcoded no JSON. */
  function relativeTime(iso: string): string {
    const then = new Date(iso).getTime();
    if (Number.isNaN(then)) return '';
    const diffMs = Math.max(0, Date.now() - then);
    const minutes = Math.floor(diffMs / 60000);
    if (minutes < 1) return 'agora mesmo';
    if (minutes < 60) return `há ${minutes} min`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return hours === 1 ? 'há 1 hora' : `há ${hours} horas`;
    const days = Math.floor(hours / 24);
    if (days < 30) return days === 1 ? 'há 1 dia' : `há ${days} dias`;
    const months = Math.floor(days / 30);
    if (months < 12) return months === 1 ? 'há 1 mês' : `há ${months} meses`;
    const years = Math.floor(months / 12);
    return years === 1 ? 'há 1 ano' : `há ${years} anos`;
  }

  function renderSkillsChips(skills: string[]): string {
    if (!skills.length) return '<span class="radar-jobs-table__no-skills">—</span>';
    const shown = skills.slice(0, 4);
    const rest = skills.length - shown.length;
    const chips = shown
      .map((s) => `<span class="tag radar-jobs-table__skill-tag">${escapeHtml(formatSkill(s))}</span>`)
      .join('');
    const more = rest > 0
      ? `<span class="tag radar-jobs-table__skill-tag radar-jobs-table__skill-tag--more">+${rest}</span>`
      : '';
    return chips + more;
  }

  function renderJobRow(v: VagaRecente): string {
    const title = (v.title ?? '').trim() || 'sem título';
    const company = (v.company ?? '').trim() || 'confidencial';
    const cityTrim = (v.city ?? '').trim();
    const localLabel = cityTrim || (v.is_remote ? 'Remoto' : 'não informado');
    const showRemoteBadge = v.is_remote && Boolean(cityTrim);
    const remoteBadge = showRemoteBadge
      ? '<span class="tag tag--accent radar-jobs-table__remote-badge">remoto</span>'
      : '';
    const timeLabel = relativeTime(v.publishedDate) || '—';

    return `
      <tr>
        <td class="radar-jobs-table__title">${escapeHtml(title)}</td>
        <td class="radar-jobs-table__company">${escapeHtml(company)}</td>
        <td class="radar-jobs-table__local">
          <span class="radar-jobs-table__city">${escapeHtml(localLabel)}</span>
          ${remoteBadge}
        </td>
        <td class="radar-jobs-table__skills">${renderSkillsChips(v.skills ?? [])}</td>
        <td class="radar-jobs-table__time"><time datetime="${escapeHtml(v.publishedDate ?? '')}">${escapeHtml(timeLabel)}</time></td>
        <td class="radar-jobs-table__action">
          <a
            class="link-underline radar-jobs-table__link"
            href="${escapeHtml(v.url ?? '#')}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver vaga: ${escapeHtml(title)} — ${escapeHtml(company)} (abre em nova aba)"
          >Ver vaga ↗</a>
        </td>
      </tr>`;
  }

  function renderJobsTable(vagas: VagaRecente[]): void {
    const tbody = document.getElementById('radar-jobs-table-body');
    if (!tbody) return;
    const top = vagas.slice(0, TABLE_ROWS_MAX);

    if (!top.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="ranking-error mono-label">nenhuma vaga disponível</td></tr>';
      return;
    }

    tbody.innerHTML = top.map(renderJobRow).join('');

    if (motionOk) {
      const rows = tbody.querySelectorAll('tr');
      if (rows.length) revealUp(rows, tbody, STAGGER.tight);
    }
  }

  function renderCompanies(empresas: EmpresaItem[]): void {
    const list = document.getElementById('radar-company-list');
    if (!list) return;
    const top = empresas.slice(0, COMPANIES_MAX);

    if (!top.length) {
      list.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      return;
    }

    const max = Math.max(...top.map((e) => e.n_vagas));

    list.innerHTML = top.map((e, i) => {
      const pct = max ? (e.n_vagas / max) * 100 : 0;
      const remotoShare = e.n_vagas ? (e.n_remoto / e.n_vagas) * 100 : 0;
      const majority = remotoShare >= 50;
      const company = (e.company ?? '').trim() || 'confidencial';

      return `
        <li class="radar-company-row">
          <span class="radar-company-row__rank mono-label" aria-hidden="true">${String(i + 1).padStart(2, '0')}</span>
          <span class="radar-company-row__name" title="${escapeHtml(company)}">${escapeHtml(company)}</span>
          <span class="radar-company-row__bar" aria-hidden="true">${meter(pct)}</span>
          <span
            class="radar-company-row__n"
            role="meter"
            aria-valuenow="${e.n_vagas}"
            aria-valuemin="0"
            aria-valuemax="${max}"
            aria-label="${escapeHtml(company)}: ${e.n_vagas} vagas, ${Math.round(remotoShare)}% remoto"
          >${e.n_vagas} vagas</span>
          <span class="tag ${majority ? 'tag--accent' : ''} radar-company-row__remote">${Math.round(remotoShare)}% remoto</span>
        </li>`;
    }).join('');

    if (motionOk) {
      const rows = list.querySelectorAll('.radar-company-row');
      if (rows.length) revealUp(rows, list, STAGGER.tight);
    }
  }

  function renderCombos(combos: SkillCombo[]): void {
    const list = document.getElementById('radar-combo-list');
    if (!list) return;
    const top = combos.slice(0, COMBOS_MAX);

    if (!top.length) {
      list.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      return;
    }

    list.innerHTML = top.map((c) => {
      const a = formatSkill(c.skill_a);
      const b = formatSkill(c.skill_b);

      return `
        <li class="radar-combo-row">
          <div class="radar-combo-row__top">
            <span class="radar-combo-row__pair">
              <span class="tag">${escapeHtml(a)}</span>
              <span class="radar-combo-row__plus" aria-hidden="true">+</span>
              <span class="tag">${escapeHtml(b)}</span>
            </span>
            <span
              class="radar-combo-row__pct"
              role="meter"
              aria-valuenow="${c.pct_of_jobs}"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-label="${escapeHtml(a)} e ${escapeHtml(b)} aparecem juntas em ${fmtPct(c.pct_of_jobs)}% das vagas, ${c.n_vagas} vagas"
            >${fmtPct(c.pct_of_jobs)}%</span>
          </div>
          <span class="radar-combo-row__bar" aria-hidden="true">${meter(c.pct_of_jobs)}</span>
          <span class="radar-combo-row__note">${c.n_vagas} vagas com as duas skills juntas</span>
        </li>`;
    }).join('');

    if (motionOk) {
      const rows = list.querySelectorAll('.radar-combo-row');
      if (rows.length) revealUp(rows, list, STAGGER.tight);
    }
  }

  /** A) Número principal + framing honesto (N real é baixíssimo — 2 de 301). */
  function renderSalary(pct: number, nReal: number, nTotal: number): void {
    const el = document.getElementById('radar-salary-value');
    if (el) {
      el.dataset.countTo = String(pct);
      el.setAttribute('aria-valuenow', String(pct));
      countUp(el, document.getElementById('radar-salary-callout') ?? el);
    }

    const textEl = document.getElementById('radar-salary-text');
    if (textEl) {
      textEl.textContent = `Praticamente nenhuma vaga coletada informa quanto paga. De `
        + `${nTotal} vagas, só ${nReal} trazem um valor real de remuneração — o resto, `
        + `quando menciona "R$", é benefício (vale-refeição, auxílio home office), não salário.`;
    }
  }

  /** B) As poucas vagas com salário real — amostra individual, não estatística. */
  function renderSalarySample(vagas: VagaSalarioReal[]): void {
    const list = document.getElementById('radar-salary-sample-list');
    if (!list) return;

    const label = document.getElementById('radar-salary-sample-label');
    if (label) {
      label.textContent = vagas.length === 1
        ? 'o único valor real que encontramos'
        : `os ${vagas.length} valores reais que encontramos`;
    }

    if (!vagas.length) {
      list.innerHTML = '<li class="ranking-error mono-label">nenhuma vaga com valor real informado</li>';
      return;
    }

    list.innerHTML = vagas.map((v) => {
      const title = (v.title ?? '').trim() || 'sem título';
      const company = (v.company ?? '').trim() || 'confidencial';
      const seniority = capitalize((v.seniority ?? '').trim() || 'não especificado');
      const value = formatSalary(v.salary_min, v.salary_max);
      const origem = v.salary_source === 'estruturado' ? 'faixa do ATS' : 'extraído da descrição';
      const contrato = (v.contract_type ?? '').trim();
      const metaChips = [seniority, (contrato && contrato !== 'não especificado' ? contrato : null)]
        .filter(Boolean)
        .map((t) => `<span class="tag">${escapeHtml(t as string)}</span>`)
        .join('');

      return `
        <li class="radar-salary-sample__item">
          <div class="radar-salary-sample__item-head">
            <span class="radar-salary-sample__item-title">${escapeHtml(title)}</span>
            <span class="radar-salary-sample__item-value">${escapeHtml(value)}</span>
          </div>
          <p class="radar-salary-sample__item-meta">
            <span class="radar-salary-sample__item-company">${escapeHtml(company)}</span>
            ${metaChips}
            <span class="radar-salary-sample__item-origem">${escapeHtml(origem)}</span>
          </p>
          <a
            class="link-underline radar-salary-sample__item-link"
            href="${escapeHtml(v.url ?? '#')}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver vaga original: ${escapeHtml(title)} — ${escapeHtml(company)} (abre em nova aba)"
          >Ver vaga original ↗</a>
        </li>`;
    }).join('');

    if (motionOk) {
      const rows = list.querySelectorAll('.radar-salary-sample__item');
      if (rows.length) revealUp(rows, list, STAGGER.tight);
    }
  }

  /** C) Benchmark externo — citação de pesquisa de mercado, não dado do pipeline. */
  function renderBenchmark(benchmark: BenchmarkExterno | undefined): void {
    const body = document.getElementById('radar-benchmark-body');
    if (!body) return;

    if (!benchmark) {
      body.innerHTML = '<p class="ranking-error mono-label">dados indisponíveis</p>';
      return;
    }

    const growth = fmtDecimal(benchmark.salario_crescimento_2023_2024_pct);
    const inflation = fmtDecimal(benchmark.inflacao_2024_pct);
    const remote = fmtDecimal(benchmark.pct_preferem_100_remoto);
    const hybrid = fmtDecimal(benchmark.pct_preferem_hibrido_flexivel);

    body.innerHTML = `
      <p class="radar-benchmark-card__source">
        ${escapeHtml(benchmark.fonte ?? '')}
        <span class="radar-benchmark-card__sample">${escapeHtml(benchmark.amostra ?? '')}</span>
      </p>
      <ul class="radar-benchmark-card__stats">
        <li class="radar-benchmark-card__stat">
          <strong>+${growth}%</strong> de crescimento salarial entre 2023 e 2024 —
          acima da inflação do período (<strong>${inflation}%</strong>)
        </li>
        <li class="radar-benchmark-card__stat">
          <strong>${remote}%</strong> preferem trabalho 100% remoto
        </li>
        <li class="radar-benchmark-card__stat">
          <strong>${hybrid}%</strong> preferem híbrido flexível
        </li>
      </ul>
      <p class="radar-benchmark-card__note">${escapeHtml(benchmark.nota ?? '')}</p>
      <a
        class="radar-benchmark-card__link"
        href="${escapeHtml(benchmark.url ?? '#')}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver pesquisa completa: ${escapeHtml(benchmark.fonte ?? 'fonte externa')} (abre em nova aba)"
      >Ver pesquisa completa ↗</a>`;
  }

  /** [08] Cobertura de fontes — quantas vagas cada fonte contribui + nº de empresas. */
  function renderCobertura(items: CoberturaItem[]): void {
    const el = document.getElementById('radar-cobertura-list');
    if (!el) return;
    if (!items.length) {
      el.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      return;
    }
    el.innerHTML = items.map((item) => {
      const empresasLabel = item.n_empresas > 0
        ? `${item.n_empresas} ${item.n_empresas === 1 ? 'empresa' : 'empresas'}`
        : 'comunidade';
      return `
      <li class="jobs-meter-row">
        <span class="jobs-meter-row__label">${escapeHtml(fmtFonte(item.fonte))}</span>
        <span class="jobs-meter-row__bar" aria-hidden="true">${meter(item.pct)}</span>
        <span class="jobs-meter-row__val" role="meter" aria-valuenow="${item.pct}" aria-valuemin="0" aria-valuemax="100" aria-label="${escapeHtml(fmtFonte(item.fonte))}: ${item.n_vagas} vagas (${fmtPct(item.pct)}%), ${empresasLabel}">${item.n_vagas} · ${fmtPct(item.pct)}% · ${empresasLabel}</span>
      </li>`;
    }).join('');
    // Reveal fica a cargo do card estático (§08) — evita o bug de opacity:0
    // preso em conteúdo injetado após o page-load (card aparecia vazio).
  }

  async function loadInsights(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    try {
      const res = await fetch(`${base}assets/data/radar_insights.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: InsightsPayload = await res.json();

      renderJobsTable(data.vagas_recentes ?? []);
      renderCompanies(data.por_empresa ?? []);
      renderCobertura(data.cobertura_por_fonte ?? []);
      renderCombos(data.skill_combos ?? []);
      renderSalary(
        data.salario_transparencia_pct ?? 0,
        data.n_vagas_com_salario_real ?? 0,
        data.n_vagas_total ?? 0,
      );
      renderSalarySample(data.vagas_com_salario_real ?? []);
      renderBenchmark(data.benchmark_externo);
    } catch {
      clearTimeout(timeoutId);
      const tbody = document.getElementById('radar-jobs-table-body');
      if (tbody) {
        tbody.innerHTML = '<tr><td colspan="6" class="ranking-error mono-label">vagas indisponíveis — tente recarregar</td></tr>';
      }
      const companyList = document.getElementById('radar-company-list');
      if (companyList) {
        companyList.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      }
      const coberturaList = document.getElementById('radar-cobertura-list');
      if (coberturaList) {
        coberturaList.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      }
      const comboList = document.getElementById('radar-combo-list');
      if (comboList) {
        comboList.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      }
      const salaryEl = document.getElementById('radar-salary-value');
      if (salaryEl) salaryEl.textContent = '—';
      const salaryText = document.getElementById('radar-salary-text');
      if (salaryText) salaryText.textContent = 'dados indisponíveis — tente recarregar';
      const sampleList = document.getElementById('radar-salary-sample-list');
      if (sampleList) {
        sampleList.innerHTML = '<li class="ranking-error mono-label">dados indisponíveis</li>';
      }
      const benchmarkBody = document.getElementById('radar-benchmark-body');
      if (benchmarkBody) {
        benchmarkBody.innerHTML = '<p class="ranking-error mono-label">dados indisponíveis</p>';
      }
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-hero')) loadInsights();
  });
</script>

<script>
  /**
   * radar_contexto.json — bloco curado à mão (NÃO é do pipeline) com a
   * escala macro do mercado de tecnologia BR (Brasscom + CAGED). Alimenta a
   * seção [09] Contexto de mercado: cards de indicadores + listas de
   * profissões demandadas e competências estratégicas, cada um com fonte.
   */
  interface ContextoBloco {
    id?: string; titulo: string; valor: string; periodo?: string;
    descricao: string; fonte: string; fonte_url: string;
  }
  interface ContextoLista {
    titulo?: string; itens?: string[]; agora?: string[]; futuro?: string[];
    fonte: string; fonte_url: string;
  }
  interface ContextoPayload {
    disclaimer?: string;
    blocos?: ContextoBloco[];
    profissoes_mais_demandadas?: ContextoLista;
    competencias_estrategicas?: ContextoLista;
  }

  function esc(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function renderContextGrid(blocos: ContextoBloco[]): void {
    const grid = document.getElementById('radar-context-grid');
    if (!grid) return;
    if (!blocos.length) {
      grid.innerHTML = '<p class="ranking-error mono-label">contexto indisponível</p>';
      return;
    }
    grid.innerHTML = blocos.map((b) => `
      <div class="card radar-context-item" role="listitem">
        <span class="mono-label radar-context-item__eyebrow">${esc(b.titulo)}${b.periodo ? ` · ${esc(b.periodo)}` : ''}</span>
        <span class="radar-context-item__value">${esc(b.valor)}</span>
        <p class="radar-context-item__desc">${esc(b.descricao)}</p>
        <a class="link-underline radar-context-item__source" href="${esc(b.fonte_url)}" target="_blank" rel="noopener noreferrer"
           aria-label="Fonte: ${esc(b.fonte)} (abre em nova aba)">${esc(b.fonte)} ↗</a>
      </div>`).join('');
    // Sem reveal por-item (conteúdo injetado grudava em opacity:0);
    // aparece junto com o fetch. O header da seção anima via script estático.
  }

  function renderTags(el: HTMLElement | null, tags: string[]): string {
    if (!el) return '';
    return tags.map((t) => `<span class="tag">${esc(t)}</span>`).join('');
  }

  function renderProfissoes(lista: ContextoLista | undefined): void {
    const el = document.getElementById('radar-context-profissoes');
    if (!el) return;
    if (!lista) { el.innerHTML = '<p class="ranking-error mono-label">indisponível</p>'; return; }
    const agora = lista.agora ?? [];
    const futuro = lista.futuro ?? [];
    el.innerHTML = `
      <p class="radar-context-card__sub mono-label">agora</p>
      <div class="radar-context-card__tags">${renderTags(el, agora)}</div>
      <p class="radar-context-card__sub mono-label">estratégicas para o futuro</p>
      <div class="radar-context-card__tags">${renderTags(el, futuro)}</div>
      <a class="link-underline radar-context-item__source" href="${esc(lista.fonte_url)}" target="_blank" rel="noopener noreferrer"
         aria-label="Fonte: ${esc(lista.fonte)} (abre em nova aba)">${esc(lista.fonte)} ↗</a>`;
  }

  function renderCompetencias(lista: ContextoLista | undefined): void {
    const el = document.getElementById('radar-context-competencias');
    if (!el) return;
    if (!lista) { el.innerHTML = '<p class="ranking-error mono-label">indisponível</p>'; return; }
    el.innerHTML = `
      <div class="radar-context-card__tags">${renderTags(el, lista.itens ?? [])}</div>
      <a class="link-underline radar-context-item__source" href="${esc(lista.fonte_url)}" target="_blank" rel="noopener noreferrer"
         aria-label="Fonte: ${esc(lista.fonte)} (abre em nova aba)">${esc(lista.fonte)} ↗</a>`;
  }

  async function loadContexto(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    try {
      const res = await fetch(`${base}assets/data/radar_contexto.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: ContextoPayload = await res.json();
      renderContextGrid(data.blocos ?? []);
      renderProfissoes(data.profissoes_mais_demandadas);
      renderCompetencias(data.competencias_estrategicas);
    } catch {
      clearTimeout(timeoutId);
      const grid = document.getElementById('radar-context-grid');
      if (grid) grid.innerHTML = '<p class="ranking-error mono-label">contexto indisponível</p>';
      ['radar-context-profissoes', 'radar-context-competencias'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<p class="ranking-error mono-label">indisponível</p>';
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-hero')) loadContexto();
  });
</script>

<script>
  /**
   * Índice de capítulos (§ rail lateral) — scroll-spy via IntersectionObserver
   * + scroll suave ao clicar. Marca o capítulo ativo conforme a seção entra
   * numa faixa perto do topo do viewport. Registrado em astro:page-load
   * (navegação SPA do ClientRouter) com guard da própria página.
   */
  function initToc(): void {
    const toc = document.getElementById('radar-toc');
    if (!toc) return;
    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('.radar-toc__link'));
    const sections = links
      .map((l) => document.getElementById(l.dataset.toc ?? ''))
      .filter((s): s is HTMLElement => !!s);

    const smooth = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    links.forEach((l) => {
      l.addEventListener('click', (e) => {
        const target = document.getElementById(l.dataset.toc ?? '');
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: smooth ? 'smooth' : 'auto', block: 'start' });
        history.replaceState(null, '', `#${l.dataset.toc}`);
      });
    });

    let active = '';
    function setActive(id: string): void {
      if (id === active) return;
      active = id;
      links.forEach((l) => {
        const on = l.dataset.toc === id;
        l.classList.toggle('is-active', on);
        if (on) l.setAttribute('aria-current', 'true');
        else l.removeAttribute('aria-current');
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((en) => en.isIntersecting);
        if (!visible.length) return;
        visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        setActive((visible[0].target as HTMLElement).id);
      },
      { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
    );

    sections.forEach((s) => observer.observe(s));
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('radar-toc')) initToc();
  });
</script>
