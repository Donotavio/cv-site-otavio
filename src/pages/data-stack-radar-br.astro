<!-- ════════════════════════════════════════════════════════════
     ESTILOS GLOBAIS — elementos criados via innerHTML/createElement
     ════════════════════════════════════════════════════════════
     Mesmo racional de pix-observatory.astro: CSS "scoped" do Astro só
     atinge elementos presentes no HTML gerado em build. Tudo abaixo é
     conteúdo montado em runtime pelos widgets desta página (legenda de
     tiers, dots/labels do scatter, ranking, breakdown, análise de vagas).
     ════════════════════════════════════════════════════════════ -->
<style is:global>
  /* ── Legenda de tiers (scatter) ──────────────────────────── */
  .radar-tier-chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--paper-card);
    color: var(--ink-soft);
  }

  .radar-tier-chip[data-tier='adopt'] {
    color: var(--radar-adopt-ink);
    border-color: var(--radar-adopt-line);
    background: var(--radar-adopt-dim);
  }
  .radar-tier-chip[data-tier='trial'] {
    color: var(--radar-trial-ink);
    border-color: var(--radar-trial-line);
    background: var(--radar-trial-dim);
  }
  .radar-tier-chip[data-tier='assess'] {
    color: var(--radar-assess-ink);
    border-color: var(--radar-assess-line);
    background: var(--radar-assess-dim);
  }
  .radar-tier-chip[data-tier='hold'] {
    color: var(--radar-hold-ink);
    border-color: var(--radar-hold-line);
    background: var(--radar-hold-dim);
  }

  /* ── Labels inline nos dots (total_score > 60) ──────────── */
  .radar-dot-label {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink);
  }

  /* ── Barra de dados unificada (substitui as barras ASCII) ──────
     No bloco is:global porque é injetada via innerHTML (meter()) — CSS
     scoped do Astro não alcança nós criados em runtime. O preenchimento
     herda a cor do contexto (currentColor): as regras de tier/acento já
     existentes tingem a barra sem duplicar cor. Marca fina + data-end
     arredondado + trilho recessivo (skill dataviz). */
  .ui-bar {
    display: block;
    inline-size: 100%;
    block-size: 7px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .ui-bar__fill {
    display: block;
    block-size: 100%;
    background: currentColor;
    border-radius: var(--radius-full);
    transition: inline-size 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ui-bar__fill { transition: none; }
  }

  /* Tabela §07 — linhas injetadas via JS, então no bloco global. */
  .radar-jobs-table tbody tr {
    border-bottom: 1px solid var(--line);
    transition: background 0.15s ease;
  }

  .radar-jobs-table tbody tr:last-child { border-bottom: none; }

  .radar-jobs-table tbody tr:hover { background: var(--paper-soft); }

  .radar-jobs-table tbody td {
    padding: var(--space-4) var(--space-3);
    color: var(--ink-soft);
    vertical-align: middle;
  }

  /* ── §07 amostra salarial — item injetado ─────────────────── */
  .radar-salary-sample__item-origem {
    color: var(--ink-faint);
  }

  /* ── §09 Tendência — linhas injetadas via renderTrendList ─── */
  .radar-trend-row {
    display: grid;
    grid-template-columns: minmax(6.5rem, 8rem) 1fr auto;
    align-items: center;
    gap: var(--space-3);
  }

  .radar-trend-row__name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .radar-trend-row__track {
    position: relative;
    block-size: 7px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .radar-trend-row__fill {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    border-radius: var(--radius-full);
