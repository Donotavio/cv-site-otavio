<style>
  /* ── Alterna fundos para dar profundidade (WC pattern) ── */
  .el-alt { background: var(--paper-soft); }

  .el-badge { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--wc-gold-ink); }
  .el-badge__dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--wc-gold-ink); flex-shrink: 0; animation: el-badge-pulse 2.6s ease-out infinite; }
  @keyframes el-badge-pulse {
    0%   { box-shadow: 0 0 0 0 var(--wc-gold-dim); }
    70%  { box-shadow: 0 0 0 5px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @media (prefers-reduced-motion: reduce) { .el-badge__dot { animation: none; } }

  /* ── Hero ──────────────────────────────────────────────────
     Mesma assinatura tipográfica das páginas-irmãs (brasil-cockpit,
     pix-observatory, data-stack-radar-br): título em --font-display (serif),
     card blueprint com borda + crop marks. Antes o h1.hero-display não tinha
     regra scoped aqui e caía no default (sans bold), destoando do resto. */
  .el-hero { background: var(--paper); }

  .hero-card {
    position: relative;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-8) var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .hero-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-display {
    font-family: var(--font-display);
    font-size: var(--display-1);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 20ch;
  }
  .hero-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 62ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }
  /* Governança de cor: acento da página é --wc-gold* (líder/destaque),
     ecoado só no hover do CTA secundário. Primary segue o --ink global. */
  .hero-actions .btn-secondary:hover {
    border-color: var(--wc-gold-ink);
    color: var(--wc-gold-ink);
  }

  .el-h2 { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; line-height: 1.02; letter-spacing: var(--tracking-tight); margin: 0; color: var(--ink); }
  .el-lead { color: var(--ink-soft); font-size: var(--text-base); max-width: 60ch; margin-top: var(--space-3); line-height: var(--leading-normal); }

  /* ── Faixa de progresso ── */
  .el-progress { margin: var(--space-6) 0 var(--space-2); padding: var(--space-4) var(--space-5); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-progress__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-3); gap: var(--space-3); }
  .el-progress__phase { color: var(--ink-soft); }
  .el-progress__pct { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 600; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-progress__bar { height: 8px; background: var(--line); border-radius: var(--radius-full); overflow: hidden; }
  .el-progress__fill { height: 100%; background: linear-gradient(90deg, var(--ink-soft), var(--ink)); border-radius: var(--radius-full); transition: width 1.2s cubic-bezier(.16, 1, .3, 1); }
  .el-progress__meta { display: flex; gap: var(--space-2); margin-top: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); flex-wrap: wrap; align-items: baseline; }
  .el-progress__sep { opacity: .4; }
  @media (prefers-reduced-motion: reduce) { .el-progress__fill { transition: none; } }

  /* ── Bento de KPIs ── */
  .el-bento { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  .el-kpi { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; justify-content: space-between; gap: var(--space-6); min-height: 148px; transition: border-color var(--transition-normal); }
  .el-kpi:hover { border-color: var(--line-strong); }
  .el-kpi--hero { padding: var(--space-8); }
  .el-kpi--star { border-color: var(--wc-gold-line); background: linear-gradient(180deg, var(--paper-card) 0%, var(--wc-gold-dim) 100%); }
  .el-kpi__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .el-kpi__spark { font-family: var(--font-mono); font-size: var(--text-base); color: var(--ink-faint); line-height: 1; letter-spacing: .08em; }
  .el-kpi__badge { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--wc-gold-ink); background: var(--wc-gold-dim); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-sm); }
  .el-kpi__value { display: block; font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--ink); line-height: .95; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  .el-kpi__value--hero { font-size: var(--display-1); line-height: .88; }
  .el-kpi__value--star { font-size: var(--text-2xl); color: var(--wc-gold-ink); }
  .el-kpi__label { display: block; font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink-soft); margin-top: var(--space-2); line-height: var(--leading-normal); }
  .el-kpi__star { display: flex; flex-direction: column; }

  @media (min-width: 640px) {
    .el-bento { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
    .el-kpi--hero { grid-column: span 2; }
    .el-kpi--star { grid-column: span 2; }
  }
  @media (min-width: 1024px) {
    .el-bento { grid-template-columns: repeat(12, 1fr); grid-auto-rows: minmax(150px, auto); gap: var(--space-5); }
    .el-kpi--hero { grid-column: 1 / 8; grid-row: 1 / 3; }
    .el-bento > .el-kpi:nth-child(2) { grid-column: 8 / 13; grid-row: 1 / 2; }
    .el-bento > .el-kpi:nth-child(3) { grid-column: 8 / 13; grid-row: 2 / 3; }
    .el-kpi--star { grid-column: 1 / 13; grid-row: 3 / 4; }
  }

  /* ── Mini-stats ── */
  .el-ministats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: var(--space-5); background: var(--line); border: 1px solid var(--line); border-radius: var(--radius-md); overflow: hidden; }
  .el-ministat { background: var(--paper-card); padding: var(--space-5) var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .el-ministat__label { color: var(--ink-faint); }
  .el-ministat__value { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  @media (min-width: 640px)  { .el-ministats { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .el-ministats { grid-template-columns: repeat(6, 1fr); } }

  /* ── Cards de gráfico ── */
  .el-chartcard, .el-rank-wrap, .el-ufchart, .el-panel { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-chartcard { padding: var(--space-6) var(--space-6) var(--space-5); margin-top: var(--space-8); }
  .el-chartcard__head { margin-bottom: var(--space-5); }
  .el-chartcard__head .mono-label { color: var(--ink-faint); }
  /* Conteúdo injetado via JS → :global() sob ancestral estático (padrão pix/radar) */
  .el-barchart__svg :global(svg) { width: 100%; height: auto; display: block; }
  .el-barchart__svg :global(.el-axis) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-faint); }
  .el-barchart__svg :global(.el-barval) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-soft); }

  /* ── Elementos SVG de gráfico com eixo (bar chart [05] + série [02]) ──
     Espelha a família .ck-band-* do brasil-cockpit. Classes (não var() em
     atributo) garantem render consistente; linhas com non-scaling-stroke. */
  .el-band__svg :global(svg) { width: 100%; height: auto; display: block; }
  .el-band__svg :global(.el-band-tickline) { stroke: var(--line); stroke-width: 1; }
  .el-band__svg :global(.el-band-axisline) { stroke: var(--line-strong); stroke-width: 1; }
  .el-band__svg :global(.el-band-ticklabel),
  .el-band__svg :global(.el-band-axislabel) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-faint); }
  .el-band__svg :global(.el-band-val) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-soft); font-variant-numeric: var(--num-tabular); }
  .el-band__svg :global(.el-band-line) { fill: none; stroke: var(--ink); stroke-width: 1.5; stroke-linejoin: round; stroke-linecap: round; vector-effect: non-scaling-stroke; }
  .el-band__svg :global(.el-band-line--soft) { stroke: var(--ink-soft); stroke-width: 1.25; }
  .el-band__svg :global(.el-band-line--faint) { stroke: var(--ink-faint); stroke-width: 1.25; }
  .el-band__svg :global(.el-band-line--gold) { stroke: var(--wc-gold-ink); stroke-width: 2; }
  .el-band__svg :global(.el-band-marker) { stroke: var(--paper-card); stroke-width: 1.5; }
  .el-band__svg :global(.el-band-markerval) { font-family: var(--font-mono); font-size: 10px; font-weight: 500; fill: var(--ink); font-variant-numeric: var(--num-tabular); }
  /* Rótulo de nome no fim da linha — halo de papel garante leitura sobre as linhas */
  .el-band__svg :global(.el-band-endlabel) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-soft); paint-order: stroke; stroke: var(--paper-card); stroke-width: 3px; stroke-linejoin: round; }
  .el-band__svg :global(.el-band-endlabel.is-leader) { fill: var(--wc-gold-ink); font-weight: 600; }
  /* Camada de hover (guia vertical + pontos) e área de captura transparente */
  .el-band__svg :global(.el-band-capture) { fill: transparent; }
  .el-band__svg :global(.el-band-guide) { stroke: var(--line-strong); stroke-width: 1; stroke-dasharray: 3 3; pointer-events: none; }
  .el-band__svg :global(.el-band-hoverdot) { stroke: var(--paper-card); stroke-width: 1.5; pointer-events: none; }

  /* Tooltip de gráfico — segue o cartão de papel; nunca depende só de cor */
  .el-chart-tip { position: absolute; z-index: 6; pointer-events: none; min-width: 132px; max-width: 260px; padding: var(--space-3) var(--space-4); background: var(--paper-card); border: 1px solid var(--line-strong); border-radius: var(--radius-sm); box-shadow: var(--shadow-md); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink); line-height: 1.5; }
  .el-chart-tip[hidden] { display: none; }
  .el-chart-tip :global(.el-tip-head) { color: var(--ink-faint); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin-bottom: var(--space-2); }
  .el-chart-tip :global(.el-tip-row) { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); }
  .el-chart-tip :global(.el-tip-row + .el-tip-row) { margin-top: 2px; }
  .el-chart-tip :global(.el-tip-name) { color: var(--ink-soft); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .el-chart-tip :global(.el-tip-row.is-leader .el-tip-name), .el-chart-tip :global(.el-tip-row.is-leader .el-tip-val) { color: var(--wc-gold-ink); }
  .el-chart-tip :global(.el-tip-name .mono-label) { color: var(--ink-faint); }
  .el-chart-tip :global(.el-tip-val) { color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-chart-tip--float { position: fixed; }
  /* Barras com tooltip: cursor de ajuda + realce sutil no hover */
  :global([data-tip]) { cursor: help; }
  .el-vote-bars :global(.el-vote-row[data-tip]:hover .el-vote-track), .el-bars :global(.el-bar-row[data-tip]:hover .el-bar-track), .el-ufchart :global(.el-uf-row[data-tip]:hover .el-uf-track) { box-shadow: 0 0 0 2px var(--wc-gold-dim); }

  /* ── [02] Série temporal — card + legenda ── */
  .el-seriecard { margin-top: var(--space-6); }
  .el-serie__head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); flex-wrap: wrap; }
  .el-serie__legend { display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-4); }
  .el-serie__legend :global(.el-serie__lg) { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); }
  .el-serie__legend :global(.el-serie__sw) { width: 14px; height: 0; border-top: 2px solid var(--ink-soft); flex-shrink: 0; }
  .el-serie__legend :global(.el-serie__lg.is-leader) { color: var(--wc-gold-ink); }
  .el-serie__legend :global(.el-serie__lg.is-leader .el-serie__sw) { border-top-color: var(--wc-gold-ink); border-top-width: 2px; }
  .el-serie__legend :global(.el-serie__lg .mono-label) { color: var(--ink-faint); }

  /* ── Tabela ranqueada ── */
  .el-rank-wrap { overflow-x: auto; padding: var(--space-2) var(--space-3); margin-top: var(--space-8); }
  .el-rank-table { width: 100%; min-width: 480px; border-collapse: collapse; font-family: var(--font-sans); font-size: var(--text-sm); }
  .el-rank-table thead th { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--ink-faint); text-align: left; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--line); }
  .el-rank-table__rank { width: 68px; text-align: right !important; }
  .el-rank-table__num { text-align: right !important; }
  .el-rank-table :global(tbody td) { padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--line); color: var(--ink); vertical-align: middle; }
  .el-rank-table :global(tbody tr:last-child td) { border-bottom: none; }
  .el-rank-table :global(tbody tr) { transition: background var(--transition-fast); }
  .el-rank-table :global(tbody tr:hover) { background: var(--paper-soft); }
  .el-rank-table :global(.el-rk-rank) { font-family: var(--font-mono); font-weight: 500; text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-rank-table :global(.el-rk-name) { font-weight: 500; color: var(--ink); }
  .el-rank-table :global(.el-rk-n) { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 500; text-align: right; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-rank-table :global(.el-rk-rs) { font-family: var(--font-mono); font-size: var(--text-xs); text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-rank-table :global(tr.is-leader td) { background: var(--wc-gold-dim); border-bottom-color: var(--wc-gold-line); }
  .el-rank-table :global(tr.is-leader .el-rk-rank), .el-rank-table :global(tr.is-leader .el-rk-n) { color: var(--wc-gold-ink); }
  .el-rank-table :global(.el-medal) { display: inline-block; margin-left: var(--space-2); padding: 1px var(--space-2); font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wide); color: var(--wc-gold-ink); background: var(--paper-card); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-sm); white-space: nowrap; }
  .el-rank-table :global(.el-medal--eff) { color: var(--paper); background: var(--wc-gold-ink); border-color: var(--wc-gold-ink); }
  .el-rank-table :global(tr.is-efficient td) { background: var(--wc-gold-dim); }
  .el-rank-table :global(tr.is-efficient.is-leader td) { background: var(--wc-gold-dim); }
  #el-inst-nota { color: var(--ink-faint); }
  #el-inst-nota :global(strong) { color: var(--wc-gold-ink); font-weight: 600; }

  /* ── Como medem ── */
  .el-como-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  .el-panel { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); }
  .el-panel__title { color: var(--ink-faint); }
  @media (min-width: 1024px) { .el-como-grid { grid-template-columns: repeat(3, 1fr); } }

  .el-donut-wrap { display: flex; align-items: center; gap: var(--space-5); }
  .el-donut-wrap :global(.el-donut) { width: 132px; height: 132px; flex-shrink: 0; }
  .el-donut-wrap :global(.el-donut-num) { font-family: var(--font-display); font-size: 30px; fill: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-donut-wrap :global(.el-donut-lbl) { font-family: var(--font-mono); font-size: 9px; fill: var(--ink-faint); text-transform: uppercase; letter-spacing: .05em; }
  .el-donut-wrap :global(.el-legend) { display: flex; flex-direction: column; gap: var(--space-2); font-size: var(--text-sm); }
  .el-donut-wrap :global(.el-legend__row) { display: flex; align-items: center; gap: var(--space-2); color: var(--ink-soft); }
  .el-donut-wrap :global(.el-legend__sw) { width: 10px; height: 10px; border-radius: var(--radius-sm); flex-shrink: 0; }
  .el-donut-wrap :global(.el-legend__n) { margin-left: auto; font-family: var(--font-mono); color: var(--ink); font-variant-numeric: var(--num-tabular); }

  .el-split { display: flex; flex-direction: column; gap: var(--space-4); }
  .el-split :global(.el-split-row) { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-2); }
  .el-split :global(.el-split-row span:first-child) { color: var(--ink); font-size: var(--text-sm); }
  .el-split :global(.el-split-row span:last-child) { font-family: var(--font-mono); color: var(--ink-soft); font-size: var(--text-sm); font-variant-numeric: var(--num-tabular); }
  .el-split :global(.el-split-track) { height: 8px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; margin-top: var(--space-2); }
  .el-split :global(.el-split-fill) { display: block; height: 100%; background: var(--ink); }
  .el-split :global(.el-split-fill--alt) { background: var(--ink-faint); }

  .el-bars { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-bars :global(.el-bar-row) { display: grid; grid-template-columns: 5.5rem 1fr 2.5rem; gap: var(--space-2); align-items: center; }
  .el-bars :global(.el-bar-lbl) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-bars :global(.el-bar-track) { height: 8px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-bars :global(.el-bar-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-bars :global(.el-bar-n) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; font-variant-numeric: var(--num-tabular); }

  /* ── Cobertura UF (ranking horizontal com eixo) ── */
  .el-ufchart { padding: var(--space-6) var(--space-6) var(--space-5); margin-top: var(--space-8); }
  .el-ufchart :global(.el-uf-grid) { display: grid; grid-template-columns: 1fr; gap: var(--space-2) var(--space-10); }
  @media (min-width: 640px) { .el-ufchart :global(.el-uf-grid) { grid-template-columns: 1fr 1fr; } }
  .el-ufchart :global(.el-uf-row) { display: grid; grid-template-columns: 2.5rem 1fr 2.5rem; gap: var(--space-2); align-items: center; padding: var(--space-1) 0; }
  .el-ufchart :global(.el-uf-uf) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-ufchart :global(.el-uf-track) { height: 10px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-ufchart :global(.el-uf-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-ufchart :global(.el-uf-row.is-leader .el-uf-fill) { background: var(--wc-gold-ink); }
  .el-ufchart :global(.el-uf-row.is-leader .el-uf-uf) { color: var(--wc-gold-ink); }
  .el-ufchart :global(.el-uf-n) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; font-variant-numeric: var(--num-tabular); }

  /* ── [02] Intenção de voto (pré-candidatos) ── */
  .el-vote-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 860px) { .el-vote-grid { grid-template-columns: 1fr 1fr; } }
  .el-vote-ref { color: var(--ink-faint); font-size: var(--text-xs); margin-top: var(--space-2); }
  /* 1º turno — barras horizontais */
  .el-vote-bars { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-vote-bars :global(.el-vote-row) { display: grid; grid-template-columns: minmax(6rem, 9rem) minmax(0, 1fr) auto; gap: var(--space-3); align-items: center; }
  .el-vote-bars :global(.el-vote-row--spark) { grid-template-columns: minmax(6rem, 9rem) minmax(0, 1fr) 64px auto; }
  .el-vote-bars :global(.el-vote-spark) { display: inline-flex; align-items: center; justify-content: center; }
  .el-vote-bars :global(.el-spark) { display: block; width: 60px; height: 18px; }
  .el-vote-bars :global(.el-spark-line) { fill: none; stroke: var(--ink-faint); stroke-width: 1.25; stroke-linejoin: round; stroke-linecap: round; vector-effect: non-scaling-stroke; }
  .el-vote-bars :global(.el-spark-line--gold) { stroke: var(--wc-gold-ink); stroke-width: 1.5; }
  .el-vote-bars :global(.el-vote-name) { font-size: var(--text-sm); color: var(--ink); }
  .el-vote-bars :global(.el-vote-party) { color: var(--ink-faint); margin-left: var(--space-1); }
  .el-vote-bars :global(.el-vote-track) { height: 10px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-vote-bars :global(.el-vote-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-vote-bars :global(.el-vote-row.is-leader .el-vote-fill) { background: var(--wc-gold-ink); }
  .el-vote-bars :global(.el-vote-row.is-leader .el-vote-name) { color: var(--wc-gold-ink); font-weight: 600; }
  .el-vote-bars :global(.el-vote-pct) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink); text-align: right; font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-vote-bars :global(.el-vote-delta) { color: var(--ink-faint); margin-left: var(--space-2); font-variant-numeric: var(--num-tabular); }
  .el-vote-bars :global(.el-vote-delta.is-up) { color: var(--ink); }
  @media (max-width: 640px) {
    .el-vote-bars :global(.el-vote-row--spark) { grid-template-columns: minmax(5rem, 8rem) minmax(0, 1fr) auto; }
    .el-vote-bars :global(.el-vote-row--spark .el-vote-spark) { display: none; }
  }
  /* 2º turno — confrontos */
  .el-vote-duels { display: flex; flex-direction: column; gap: var(--space-4); }
  .el-vote-duels :global(.el-vote-duel) { display: flex; flex-direction: column; gap: var(--space-1); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); }
  .el-vote-duels :global(.el-vote-duel:last-child) { border-bottom: 0; padding-bottom: 0; }
  .el-vote-duels :global(.el-vote-duel__row) { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); }
  .el-vote-duels :global(.el-vote-duel__name) { font-size: var(--text-sm); color: var(--ink); }
  .el-vote-duels :global(.el-vote-duel__name .mono-label) { color: var(--ink-faint); }
  .el-vote-duels :global(.el-vote-duel__pct) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); font-variant-numeric: var(--num-tabular); }
  .el-vote-duels :global(.el-vote-duel__pct.is-leader) { color: var(--wc-gold-ink); font-weight: 600; }
  .el-vote-duels :global(.el-vote-duel__bar) { display: flex; height: 8px; gap: 2px; margin: var(--space-1) 0; }
  .el-vote-duels :global(.el-vote-duel__bar span) { display: block; height: 100%; background: var(--line); border-radius: var(--radius-sm); }
  .el-vote-duels :global(.el-vote-duel__bar span.is-leader) { background: var(--wc-gold-ink); }
  .el-vote-duels :global(.el-vote-duel__src) { color: var(--ink-faint); }
  /* panorama de pré-candidatos */
  .el-vote-panorama { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-4); }
  .el-vote-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .el-vote-chips :global(.el-chip) { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-full); }
  .el-vote-chips :global(.el-chip .mono-label) { color: var(--ink-faint); }

  /* ── [03] Intenção estadual — controle no topo + painéis em largura total ── */
  .el-est-wrap { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .el-est-ctl { max-width: 340px; }
  .el-est-panels { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  @media (min-width: 720px) { .el-est-panels { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .el-est-panels { grid-template-columns: 1fr 1fr 1fr; } }

  .el-nota { color: var(--ink-faint); font-size: var(--text-xs); margin-top: var(--space-8); max-width: 72ch; line-height: 1.5; }
  .el-loading { color: var(--ink-faint); }
  :global(.el-error) { color: var(--ink-faint); font-family: var(--font-mono); font-size: var(--text-sm); }

  /* ── [08] Explorar por estado ── */
  .el-explorar { display: grid; grid-template-columns: 1fr; gap: var(--space-6); margin-top: var(--space-8); align-items: start; }
  @media (min-width: 1024px) { .el-explorar { grid-template-columns: 300px 1fr; gap: var(--space-8); } }
  .el-explorar__control { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-explorar__caption { color: var(--ink-faint); }
  .el-explorar__panel { padding: var(--space-6); min-height: 220px; }
  .el-explorar__panel :global(.el-ufd-head) { display: flex; align-items: baseline; gap: var(--space-3); margin-bottom: var(--space-5); }
  .el-explorar__panel :global(.el-ufd-uf) { color: var(--wc-gold-ink); }
  .el-explorar__panel :global(.el-ufd-title) { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 400; color: var(--ink); margin: 0; }
  .el-explorar__panel :global(.el-ufd-kpis) { display: flex; gap: var(--space-8); margin-bottom: var(--space-5); padding-bottom: var(--space-5); border-bottom: 1px solid var(--line); }
  .el-explorar__panel :global(.el-ufd-kv) { display: block; font-family: var(--font-display); font-size: var(--text-2xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  .el-explorar__panel :global(.el-ufd-kl) { display: block; color: var(--ink-faint); margin-top: var(--space-1); }
  .el-explorar__panel :global(.el-ufd-list) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .el-explorar__panel :global(.el-ufd-row) { display: grid; grid-template-columns: 1.8rem 1fr auto; align-items: baseline; gap: var(--space-3); padding: var(--space-3) 0; border-top: 1px solid var(--line); }
  .el-explorar__panel :global(.el-ufd-row:first-child) { border-top: 0; }
  .el-explorar__panel :global(.el-ufd-rank) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-explorar__panel :global(.el-ufd-name) { color: var(--ink); font-size: var(--text-sm); }
  .el-explorar__panel :global(.el-ufd-n) { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink-soft); font-variant-numeric: var(--num-tabular); }

  /* ── Combobox acessível ── */
  .el-combobox { position: relative; display: inline-flex; align-items: stretch; min-width: 280px; max-width: 100%; }
  .el-combobox__input { flex: 1; min-width: 0; padding: var(--space-2) var(--space-3); padding-right: 36px; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-sm); outline-offset: 2px; transition: border-color .15s ease-out, box-shadow .15s ease-out; }
  .el-combobox__input:focus { border-color: var(--ink); box-shadow: 0 0 0 3px var(--wc-gold-dim); }
  .el-combobox__input::placeholder { color: var(--ink-faint); opacity: .7; }
  .el-combobox__btn { position: absolute; right: 4px; top: 50%; transform: translateY(-50%); width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: 0; color: var(--ink-soft); cursor: pointer; border-radius: var(--radius-sm); font-size: .8em; }
  .el-combobox__btn:hover { background: var(--paper-soft); color: var(--ink); }
  .el-combobox :global(.el-combobox__list) { position: absolute; top: calc(100% + 4px); left: 0; right: 0; max-height: 320px; overflow-y: auto; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-sm); box-shadow: 0 8px 24px rgba(10,10,10,.12), 0 2px 6px rgba(10,10,10,.04); margin: 0; padding: var(--space-1); list-style: none; z-index: 50; overscroll-behavior: contain; }
  .el-combobox :global(.el-combobox__option) { padding: var(--space-2) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink); cursor: pointer; border-radius: var(--radius-sm); transition: background .08s ease-out; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .el-combobox :global(.el-combobox__option.is-highlighted), .el-combobox :global(.el-combobox__option:hover) { background: var(--paper-soft); }
  .el-combobox :global(.el-combobox__option.is-selected) { background: var(--wc-gold-dim); color: var(--wc-gold-ink); font-weight: 600; }
  .el-combobox :global(.el-combobox__empty) { padding: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); text-align: center; }
  @media (max-width: 640px) { .el-combobox { min-width: 0; width: 100%; } .el-combobox :global(.el-combobox__list) { max-height: 260px; } }
  @media (prefers-reduced-motion: reduce) { .el-combobox__input, .el-combobox :global(.el-combobox__option) { transition: none !important; } }

  /* ── Mapa tile-cartograma (§03 e §10) ── */
  .el-mapwrap { margin-top: var(--space-5); }
  .el-mapwrap :global(.el-map) { display: grid; grid-template-columns: repeat(6, 1fr); gap: 3px; max-width: 288px; }
  .el-mapwrap :global(.el-map-tile) {
    aspect-ratio: 1; display: flex; align-items: center; justify-content: center; padding: 0;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .01em; color: var(--ink-soft);
    background: var(--paper-card);
    background: color-mix(in srgb, var(--ink) calc(var(--tile-shade, 0) * 100%), var(--paper-card));
    border: 1px solid var(--line); border-radius: var(--radius-sm); cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
  }
  .el-mapwrap :global(.el-map-tile:hover) { border-color: var(--wc-gold-line); color: var(--ink); }
  .el-mapwrap :global(.el-map-tile.is-selected) { background: var(--wc-gold-ink); border-color: var(--wc-gold-ink); color: var(--paper); font-weight: 600; }
  .el-mapwrap :global(.el-map-tile.is-off) { background: var(--paper-soft); color: var(--ink-faint); opacity: .5; cursor: default; border-style: dashed; }
  .el-mapwrap :global(.el-map-tile.is-off:hover) { border-color: var(--line); color: var(--ink-faint); }
  .el-mapwrap :global(.el-map-tile:focus-visible) { outline: 2px solid var(--wc-gold-ink); outline-offset: 1px; }
  @media (prefers-reduced-motion: reduce) { .el-mapwrap :global(.el-map-tile) { transition: none; } }

  /* Mapa de calor geográfico (choropleth) — corrida a governador por UF.
     Cor = margem do líder (gold, sem cor partidária); tooltip traz o resto. */
  .el-geowrap :global(.el-geo__svg) { display: block; width: 100%; max-width: 360px; height: auto; }
  .el-geowrap :global(.br-state) { fill: var(--paper-soft); stroke: var(--paper); stroke-width: 1; transition: stroke var(--transition-fast), fill var(--transition-fast); }
  .el-geowrap :global(.br-state.is-off) { fill: var(--paper-soft); opacity: .4; }
  .el-geowrap :global(.br-state.is-avail) { cursor: help; }
  #el-est-map :global(.br-state.is-avail) { cursor: pointer; }
  .el-geowrap :global(.br-state.is-avail:hover), .el-geowrap :global(.br-state.is-avail:focus-visible) { stroke: var(--wc-gold-ink); stroke-width: 1.8; outline: none; }
  .el-geowrap :global(.br-state.is-selected) { stroke: var(--ink); stroke-width: 2.2; }
  @media (prefers-reduced-motion: reduce) { .el-geowrap :global(.br-state) { transition: none; } }
  .el-geo-legend { display: flex; flex-direction: column; gap: var(--space-1); max-width: 360px; margin-top: var(--space-3); }
  .el-geo-legend__grad { height: 8px; border-radius: var(--radius-sm); background: linear-gradient(90deg, color-mix(in oklab, var(--wc-gold-ink) 12%, var(--paper-soft)), var(--wc-gold-ink)); }
  .el-geo-legend__ends { display: flex; justify-content: space-between; color: var(--ink-faint); }
  .el-est-mapnote, .el-reg-mapnote { margin-top: var(--space-3); color: var(--ink-faint); max-width: 360px; }
  .el-reg-disclaimer { margin-top: var(--space-2); color: var(--ink-faint); max-width: 52ch; }
  .el-reg-map__wrap { margin-top: var(--space-6); }
  .el-reg-map__meta { color: var(--ink-soft); margin-bottom: var(--space-2); }

  /* ── Jump-nav (rail desktop + FAB/sheet mobile) ── */
  :global(.el-jumpnav), :global(.el-jumpnav-fab) {
    --jn-bullet: 10px; --jn-bullet-active: 28px;
    --jn-rail-color: var(--line); --jn-ink: var(--ink-faint);
    --jn-ink-active: var(--wc-gold-ink); --jn-fill: var(--wc-gold);
  }
  :global(.el-jumpnav-fab) { position: fixed; bottom: var(--space-4); right: var(--space-4); display: none; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4); background: var(--paper-card); color: var(--ink); border: 1px solid var(--line); border-radius: 999px; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: .04em; text-transform: uppercase; cursor: pointer; box-shadow: 0 4px 12px rgba(10,10,10,.08), 0 1px 3px rgba(10,10,10,.04); z-index: 40; transition: transform .2s ease-out, box-shadow .2s ease-out; }
  :global(.el-jumpnav-fab:hover) { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(10,10,10,.12), 0 2px 4px rgba(10,10,10,.06); }
  :global(.el-jumpnav-fab:active) { transform: translateY(0); }
