<style>
  /* ── Alterna fundos para dar profundidade (WC pattern) ── */
  .el-alt { background: var(--paper-soft); }

  .el-badge { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--wc-gold-ink); }
  .el-badge__dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--wc-gold-ink); flex-shrink: 0; }

  /* ── Hero ──────────────────────────────────────────────────
     Mesma assinatura tipográfica das páginas-irmãs (brasil-cockpit,
     pix-observatory, data-stack-radar-br): título em --font-display (serif),
     card blueprint com borda + crop marks. Antes o h1.hero-display não tinha
     regra scoped aqui e caía no default (sans bold), destoando do resto. */
  .el-hero { background: var(--paper); }

  .hero-card {
    position: relative;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-8) var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .hero-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-display {
    font-family: var(--font-display);
    font-size: var(--display-1);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 20ch;
  }
  .hero-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 62ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }
  /* Governança de cor: acento da página é --wc-gold* (líder/destaque),
     ecoado só no hover do CTA secundário. Primary segue o --ink global. */
  .hero-actions .btn-secondary:hover {
    border-color: var(--wc-gold-ink);
    color: var(--wc-gold-ink);
  }

  .el-h2 { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; line-height: 1.02; letter-spacing: var(--tracking-tight); margin: 0; color: var(--ink); }
  .el-lead { color: var(--ink-soft); font-size: var(--text-base); max-width: 60ch; margin-top: var(--space-3); line-height: var(--leading-normal); }

  /* ── Faixa de progresso ── */
  .el-progress { margin: var(--space-6) 0 var(--space-2); padding: var(--space-4) var(--space-5); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-progress__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-3); gap: var(--space-3); }
  .el-progress__phase { color: var(--ink-soft); }
  .el-progress__pct { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 600; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-progress__bar { height: 8px; background: var(--line); border-radius: var(--radius-full); overflow: hidden; }
  .el-progress__fill { height: 100%; background: linear-gradient(90deg, var(--ink-soft), var(--ink)); border-radius: var(--radius-full); transition: width 1.2s cubic-bezier(.16, 1, .3, 1); }
  .el-progress__meta { display: flex; gap: var(--space-2); margin-top: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); flex-wrap: wrap; align-items: baseline; }
  .el-progress__sep { opacity: .4; }
  @media (prefers-reduced-motion: reduce) { .el-progress__fill { transition: none; } }

  /* ── Bento de KPIs ── */
  .el-bento { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  .el-kpi { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; justify-content: space-between; gap: var(--space-6); min-height: 148px; transition: border-color var(--transition-normal); }
  .el-kpi:hover { border-color: var(--line-strong); }
  .el-kpi--hero { padding: var(--space-8); }
  .el-kpi--star { border-color: var(--wc-gold-line); background: linear-gradient(180deg, var(--paper-card) 0%, var(--wc-gold-dim) 100%); }
  .el-kpi__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .el-kpi__spark { font-family: var(--font-mono); font-size: var(--text-base); color: var(--ink-faint); line-height: 1; letter-spacing: .08em; }
  .el-kpi__badge { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--wc-gold-ink); background: var(--wc-gold-dim); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-sm); }
  .el-kpi__value { display: block; font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--ink); line-height: .95; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  .el-kpi__value--hero { font-size: var(--display-1); line-height: .88; }
  .el-kpi__value--star { font-size: var(--text-2xl); color: var(--wc-gold-ink); }
  .el-kpi__label { display: block; font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink-soft); margin-top: var(--space-2); line-height: var(--leading-normal); }
  .el-kpi__star { display: flex; flex-direction: column; }

  @media (min-width: 640px) {
    .el-bento { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
    .el-kpi--hero { grid-column: span 2; }
    .el-kpi--star { grid-column: span 2; }
  }
  @media (min-width: 1024px) {
    .el-bento { grid-template-columns: repeat(12, 1fr); grid-auto-rows: minmax(150px, auto); gap: var(--space-5); }
    .el-kpi--hero { grid-column: 1 / 8; grid-row: 1 / 3; }
    .el-bento > .el-kpi:nth-child(2) { grid-column: 8 / 13; grid-row: 1 / 2; }
    .el-bento > .el-kpi:nth-child(3) { grid-column: 8 / 13; grid-row: 2 / 3; }
    .el-kpi--star { grid-column: 1 / 13; grid-row: 3 / 4; }
  }

  /* ── Mini-stats ── */
  .el-ministats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: var(--space-5); background: var(--line); border: 1px solid var(--line); border-radius: var(--radius-md); overflow: hidden; }
  .el-ministat { background: var(--paper-card); padding: var(--space-5) var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .el-ministat__label { color: var(--ink-faint); }
  .el-ministat__value { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  @media (min-width: 640px)  { .el-ministats { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .el-ministats { grid-template-columns: repeat(6, 1fr); } }

  /* ── Cards de gráfico ── */
  .el-chartcard, .el-rank-wrap, .el-ufchart, .el-panel { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-chartcard { padding: var(--space-6) var(--space-6) var(--space-5); margin-top: var(--space-8); }
  .el-chartcard__head { margin-bottom: var(--space-5); }
  .el-chartcard__head .mono-label { color: var(--ink-faint); }
  /* Conteúdo injetado via JS → :global() sob ancestral estático (padrão pix/radar) */
  .el-barchart__svg :global(svg) { width: 100%; height: auto; display: block; }
  .el-barchart__svg :global(.el-axis) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-faint); }
  .el-barchart__svg :global(.el-barval) { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-soft); }

  /* ── Tabela ranqueada ── */
  .el-rank-wrap { overflow-x: auto; padding: var(--space-2) var(--space-3); margin-top: var(--space-8); }
  .el-rank-table { width: 100%; min-width: 480px; border-collapse: collapse; font-family: var(--font-sans); font-size: var(--text-sm); }
  .el-rank-table thead th { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--ink-faint); text-align: left; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--line); }
  .el-rank-table__rank { width: 68px; text-align: right !important; }
  .el-rank-table__num { text-align: right !important; }
  .el-rank-table :global(tbody td) { padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--line); color: var(--ink); vertical-align: middle; }
  .el-rank-table :global(tbody tr:last-child td) { border-bottom: none; }
  .el-rank-table :global(tbody tr) { transition: background var(--transition-fast); }
  .el-rank-table :global(tbody tr:hover) { background: var(--paper-soft); }
  .el-rank-table :global(.el-rk-rank) { font-family: var(--font-mono); font-weight: 500; text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-rank-table :global(.el-rk-name) { font-weight: 500; color: var(--ink); }
  .el-rank-table :global(.el-rk-n) { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 500; text-align: right; color: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-rank-table :global(.el-rk-rs) { font-family: var(--font-mono); font-size: var(--text-xs); text-align: right; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-rank-table :global(tr.is-leader td) { background: var(--wc-gold-dim); border-bottom-color: var(--wc-gold-line); }
  .el-rank-table :global(tr.is-leader .el-rk-rank), .el-rank-table :global(tr.is-leader .el-rk-n) { color: var(--wc-gold-ink); }
  .el-rank-table :global(.el-medal) { display: inline-block; margin-left: var(--space-2); padding: 1px var(--space-2); font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wide); color: var(--wc-gold-ink); background: var(--paper-card); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-sm); }

  /* ── Como medem ── */
  .el-como-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  .el-panel { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); }
  .el-panel__title { color: var(--ink-faint); }
  @media (min-width: 1024px) { .el-como-grid { grid-template-columns: repeat(3, 1fr); } }

  .el-donut-wrap { display: flex; align-items: center; gap: var(--space-5); }
  .el-donut-wrap :global(.el-donut) { width: 132px; height: 132px; flex-shrink: 0; }
  .el-donut-wrap :global(.el-donut-num) { font-family: var(--font-display); font-size: 30px; fill: var(--ink); font-variant-numeric: var(--num-tabular); }
  .el-donut-wrap :global(.el-donut-lbl) { font-family: var(--font-mono); font-size: 9px; fill: var(--ink-faint); text-transform: uppercase; letter-spacing: .05em; }
  .el-donut-wrap :global(.el-legend) { display: flex; flex-direction: column; gap: var(--space-2); font-size: var(--text-sm); }
  .el-donut-wrap :global(.el-legend__row) { display: flex; align-items: center; gap: var(--space-2); color: var(--ink-soft); }
  .el-donut-wrap :global(.el-legend__sw) { width: 10px; height: 10px; border-radius: var(--radius-sm); flex-shrink: 0; }
  .el-donut-wrap :global(.el-legend__n) { margin-left: auto; font-family: var(--font-mono); color: var(--ink); font-variant-numeric: var(--num-tabular); }

  .el-split { display: flex; flex-direction: column; gap: var(--space-4); }
  .el-split :global(.el-split-row) { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-2); }
  .el-split :global(.el-split-row span:first-child) { color: var(--ink); font-size: var(--text-sm); }
  .el-split :global(.el-split-row span:last-child) { font-family: var(--font-mono); color: var(--ink-soft); font-size: var(--text-sm); font-variant-numeric: var(--num-tabular); }
  .el-split :global(.el-split-track) { height: 8px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; margin-top: var(--space-2); }
  .el-split :global(.el-split-fill) { display: block; height: 100%; background: var(--ink); }
  .el-split :global(.el-split-fill--alt) { background: var(--ink-faint); }

  .el-bars { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-bars :global(.el-bar-row) { display: grid; grid-template-columns: 5.5rem 1fr 2.5rem; gap: var(--space-2); align-items: center; }
  .el-bars :global(.el-bar-lbl) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-bars :global(.el-bar-track) { height: 8px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-bars :global(.el-bar-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-bars :global(.el-bar-n) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; font-variant-numeric: var(--num-tabular); }

  /* ── Cobertura UF (ranking horizontal com eixo) ── */
  .el-ufchart { padding: var(--space-6) var(--space-6) var(--space-5); margin-top: var(--space-8); }
  .el-ufchart :global(.el-uf-grid) { display: grid; grid-template-columns: 1fr; gap: var(--space-2) var(--space-10); }
  @media (min-width: 640px) { .el-ufchart :global(.el-uf-grid) { grid-template-columns: 1fr 1fr; } }
  .el-ufchart :global(.el-uf-row) { display: grid; grid-template-columns: 2.5rem 1fr 2.5rem; gap: var(--space-2); align-items: center; padding: var(--space-1) 0; }
  .el-ufchart :global(.el-uf-uf) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-ufchart :global(.el-uf-track) { height: 10px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-ufchart :global(.el-uf-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-ufchart :global(.el-uf-row.is-leader .el-uf-fill) { background: var(--wc-gold-ink); }
  .el-ufchart :global(.el-uf-row.is-leader .el-uf-uf) { color: var(--wc-gold-ink); }
  .el-ufchart :global(.el-uf-n) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; font-variant-numeric: var(--num-tabular); }

  /* ── [02] Intenção de voto (pré-candidatos) ── */
  .el-vote-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 860px) { .el-vote-grid { grid-template-columns: 1fr 1fr; } }
  .el-vote-ref { color: var(--ink-faint); font-size: var(--text-xs); margin-top: var(--space-2); }
  /* 1º turno — barras horizontais */
  .el-vote-bars { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-vote-bars :global(.el-vote-row) { display: grid; grid-template-columns: minmax(6rem, 9rem) minmax(0, 1fr) auto; gap: var(--space-3); align-items: center; }
  .el-vote-bars :global(.el-vote-name) { font-size: var(--text-sm); color: var(--ink); }
  .el-vote-bars :global(.el-vote-party) { color: var(--ink-faint); margin-left: var(--space-1); }
  .el-vote-bars :global(.el-vote-track) { height: 10px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  .el-vote-bars :global(.el-vote-fill) { display: block; height: 100%; background: var(--ink-soft); }
  .el-vote-bars :global(.el-vote-row.is-leader .el-vote-fill) { background: var(--wc-gold-ink); }
  .el-vote-bars :global(.el-vote-row.is-leader .el-vote-name) { color: var(--wc-gold-ink); font-weight: 600; }
  .el-vote-bars :global(.el-vote-pct) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink); text-align: right; font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  .el-vote-bars :global(.el-vote-delta) { color: var(--ink-faint); margin-left: var(--space-2); }
  /* 2º turno — confrontos */
  .el-vote-duels { display: flex; flex-direction: column; gap: var(--space-4); }
  .el-vote-duels :global(.el-vote-duel) { display: flex; flex-direction: column; gap: var(--space-1); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); }
  .el-vote-duels :global(.el-vote-duel:last-child) { border-bottom: 0; padding-bottom: 0; }
  .el-vote-duels :global(.el-vote-duel__row) { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); }
  .el-vote-duels :global(.el-vote-duel__name) { font-size: var(--text-sm); color: var(--ink); }
  .el-vote-duels :global(.el-vote-duel__name .mono-label) { color: var(--ink-faint); }
  .el-vote-duels :global(.el-vote-duel__pct) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); font-variant-numeric: var(--num-tabular); }
  .el-vote-duels :global(.el-vote-duel__pct.is-leader) { color: var(--wc-gold-ink); font-weight: 600; }
  .el-vote-duels :global(.el-vote-duel__bar) { display: flex; height: 8px; gap: 2px; margin: var(--space-1) 0; }
  .el-vote-duels :global(.el-vote-duel__bar span) { display: block; height: 100%; background: var(--line); border-radius: var(--radius-sm); }
  .el-vote-duels :global(.el-vote-duel__bar span.is-leader) { background: var(--wc-gold-ink); }
  .el-vote-duels :global(.el-vote-duel__src) { color: var(--ink-faint); }
  /* panorama de pré-candidatos */
  .el-vote-panorama { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-4); }
  .el-vote-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .el-vote-chips :global(.el-chip) { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-full); }
  .el-vote-chips :global(.el-chip .mono-label) { color: var(--ink-faint); }

  /* ── [03] Intenção estadual — controle no topo + painéis em largura total ── */
  .el-est-wrap { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .el-est-ctl { max-width: 340px; }
  .el-est-panels { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  @media (min-width: 720px) { .el-est-panels { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .el-est-panels { grid-template-columns: 1fr 1fr 1fr; } }

  .el-nota { color: var(--ink-faint); font-size: var(--text-xs); margin-top: var(--space-8); max-width: 72ch; line-height: 1.5; }
  .el-loading { color: var(--ink-faint); }
  :global(.el-error) { color: var(--ink-faint); font-family: var(--font-mono); font-size: var(--text-sm); }

  /* ── [08] Explorar por estado ── */
  .el-explorar { display: grid; grid-template-columns: 1fr; gap: var(--space-6); margin-top: var(--space-8); align-items: start; }
  @media (min-width: 1024px) { .el-explorar { grid-template-columns: 300px 1fr; gap: var(--space-8); } }
  .el-explorar__control { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-explorar__caption { color: var(--ink-faint); }
  .el-explorar__panel { padding: var(--space-6); min-height: 220px; }
  .el-explorar__panel :global(.el-ufd-head) { display: flex; align-items: baseline; gap: var(--space-3); margin-bottom: var(--space-5); }
  .el-explorar__panel :global(.el-ufd-uf) { color: var(--wc-gold-ink); }
  .el-explorar__panel :global(.el-ufd-title) { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 400; color: var(--ink); margin: 0; }
  .el-explorar__panel :global(.el-ufd-kpis) { display: flex; gap: var(--space-8); margin-bottom: var(--space-5); padding-bottom: var(--space-5); border-bottom: 1px solid var(--line); }
  .el-explorar__panel :global(.el-ufd-kv) { display: block; font-family: var(--font-display); font-size: var(--text-2xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  .el-explorar__panel :global(.el-ufd-kl) { display: block; color: var(--ink-faint); margin-top: var(--space-1); }
  .el-explorar__panel :global(.el-ufd-list) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .el-explorar__panel :global(.el-ufd-row) { display: grid; grid-template-columns: 1.8rem 1fr auto; align-items: baseline; gap: var(--space-3); padding: var(--space-3) 0; border-top: 1px solid var(--line); }
  .el-explorar__panel :global(.el-ufd-row:first-child) { border-top: 0; }
  .el-explorar__panel :global(.el-ufd-rank) { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-explorar__panel :global(.el-ufd-name) { color: var(--ink); font-size: var(--text-sm); }
  .el-explorar__panel :global(.el-ufd-n) { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink-soft); font-variant-numeric: var(--num-tabular); }

  /* ── Combobox acessível ── */
  .el-combobox { position: relative; display: inline-flex; align-items: stretch; min-width: 280px; max-width: 100%; }
  .el-combobox__input { flex: 1; min-width: 0; padding: var(--space-2) var(--space-3); padding-right: 36px; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-sm); outline-offset: 2px; transition: border-color .15s ease-out, box-shadow .15s ease-out; }
  .el-combobox__input:focus { border-color: var(--ink); box-shadow: 0 0 0 3px var(--wc-gold-dim); }
  .el-combobox__input::placeholder { color: var(--ink-faint); opacity: .7; }
  .el-combobox__btn { position: absolute; right: 4px; top: 50%; transform: translateY(-50%); width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: 0; color: var(--ink-soft); cursor: pointer; border-radius: var(--radius-sm); font-size: .8em; }
  .el-combobox__btn:hover { background: var(--paper-soft); color: var(--ink); }
  .el-combobox :global(.el-combobox__list) { position: absolute; top: calc(100% + 4px); left: 0; right: 0; max-height: 320px; overflow-y: auto; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-sm); box-shadow: 0 8px 24px rgba(10,10,10,.12), 0 2px 6px rgba(10,10,10,.04); margin: 0; padding: var(--space-1); list-style: none; z-index: 50; overscroll-behavior: contain; }
  .el-combobox :global(.el-combobox__option) { padding: var(--space-2) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink); cursor: pointer; border-radius: var(--radius-sm); transition: background .08s ease-out; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .el-combobox :global(.el-combobox__option.is-highlighted), .el-combobox :global(.el-combobox__option:hover) { background: var(--paper-soft); }
  .el-combobox :global(.el-combobox__option.is-selected) { background: var(--wc-gold-dim); color: var(--wc-gold-ink); font-weight: 600; }
  .el-combobox :global(.el-combobox__empty) { padding: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); text-align: center; }
  @media (max-width: 640px) { .el-combobox { min-width: 0; width: 100%; } .el-combobox :global(.el-combobox__list) { max-height: 260px; } }
  @media (prefers-reduced-motion: reduce) { .el-combobox__input, .el-combobox :global(.el-combobox__option) { transition: none !important; } }

  /* ── Jump-nav (rail desktop + FAB/sheet mobile) ── */
  :global(.el-jumpnav), :global(.el-jumpnav-fab) {
    --jn-bullet: 10px; --jn-bullet-active: 28px;
    --jn-rail-color: var(--line); --jn-ink: var(--ink-faint);
    --jn-ink-active: var(--wc-gold-ink); --jn-fill: var(--wc-gold);
  }
  :global(.el-jumpnav-fab) { position: fixed; bottom: var(--space-4); right: var(--space-4); display: none; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4); background: var(--paper-card); color: var(--ink); border: 1px solid var(--line); border-radius: 999px; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: .04em; text-transform: uppercase; cursor: pointer; box-shadow: 0 4px 12px rgba(10,10,10,.08), 0 1px 3px rgba(10,10,10,.04); z-index: 40; transition: transform .2s ease-out, box-shadow .2s ease-out; }
  :global(.el-jumpnav-fab:hover) { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(10,10,10,.12), 0 2px 4px rgba(10,10,10,.06); }
  :global(.el-jumpnav-fab:active) { transform: translateY(0); }
  :global(.el-jumpnav-fab__icon) { display: inline-flex; flex-direction: column; gap: 3px; width: 14px; }
  :global(.el-jumpnav-fab__icon span) { display: block; height: 2px; background: currentColor; border-radius: 1px; }
  :global(.el-jumpnav-fab__icon span:nth-child(2)) { width: 70%; align-self: flex-end; }
  :global(.el-jumpnav-fab[aria-expanded="true"]) { border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(1)) { transform: translateY(5px) rotate(45deg); transition: transform .2s ease-out; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(2)) { opacity: 0; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(3)) { transform: translateY(-5px) rotate(-45deg); transition: transform .2s ease-out; }
  :global(.el-jumpnav) { position: fixed; right: var(--space-5); top: 50%; transform: translateY(-50%); display: none; z-index: 35; }
  :global(.el-jumpnav__list) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; position: relative; }
  :global(.el-jumpnav__list::before) { content: ""; position: absolute; left: 50%; top: 5px; bottom: 5px; width: 1px; background: var(--jn-rail-color); transform: translateX(-50%); z-index: 0; }
  :global(.el-jumpnav__item) { position: relative; display: flex; align-items: center; justify-content: flex-end; gap: var(--space-3); margin: var(--space-2) 0; z-index: 1; }
  :global(.el-jumpnav__link) { display: flex; align-items: center; gap: var(--space-3); text-decoration: none; color: var(--jn-ink); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: .02em; padding: 4px 0; cursor: pointer; background: transparent; border: 0; outline-offset: 4px; transition: color .2s ease-out; }
  :global(.el-jumpnav__label) { display: inline-block; opacity: 0; transform: translateX(8px); transition: opacity .2s ease-out, transform .2s ease-out; pointer-events: none; padding: 2px var(--space-2); background: var(--paper-card); border-radius: var(--radius-sm); white-space: nowrap; box-shadow: 0 1px 2px rgba(10,10,10,.04); }
  :global(.el-jumpnav__bullet) { display: block; width: var(--jn-bullet); height: var(--jn-bullet); border-radius: 50%; background: var(--paper-card); border: 1.5px solid var(--jn-ink); flex-shrink: 0; transition: all .25s cubic-bezier(.16,1,.3,1); }
  :global(.el-jumpnav__link:hover .el-jumpnav__label), :global(.el-jumpnav__link:focus-visible .el-jumpnav__label) { opacity: 1; transform: translateX(0); }
  :global(.el-jumpnav__link:hover .el-jumpnav__bullet) { border-color: var(--jn-fill); background: var(--jn-fill); transform: scale(1.2); }
  :global(.el-jumpnav__link[aria-current="true"]) { color: var(--jn-ink-active); }
  :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__bullet) { width: var(--jn-bullet-active); height: 8px; border-radius: 999px; border-color: var(--jn-fill); background: var(--jn-fill); }
  :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__label) { opacity: 1; transform: translateX(0); font-weight: 600; }
  :global(.el-jumpnav__num) { display: none; font-variant-numeric: tabular-nums; opacity: .5; min-width: 1.5em; }
  @media (min-width: 1024px) { :global(.el-jumpnav) { display: block; } :global(.el-jumpnav-fab) { display: none; } }
  @media (max-width: 1023px) {
    :global(.el-jumpnav-fab) { display: inline-flex; }
    :global(.el-jumpnav) { position: fixed; inset: auto 0 0 0; top: auto; transform: none; background: var(--paper-card); border-top: 1px solid var(--line); border-radius: var(--radius-lg) var(--radius-lg) 0 0; padding: var(--space-4) var(--space-4) var(--space-6); box-shadow: 0 -8px 32px rgba(10,10,10,.12); max-height: 70vh; overflow-y: auto; z-index: 39; }
    :global(.el-jumpnav[hidden]) { display: none; }
    :global(.el-jumpnav__list::before) { display: none; }
    :global(.el-jumpnav__item) { justify-content: flex-start; border-bottom: 1px solid var(--line); }
    :global(.el-jumpnav__item:last-child) { border-bottom: 0; }
    :global(.el-jumpnav__link) { width: 100%; padding: var(--space-3) var(--space-2); font-size: var(--text-sm); }
    :global(.el-jumpnav__label) { opacity: 1; transform: none; box-shadow: none; background: transparent; padding: 0; flex: 1; text-align: left; }
    :global(.el-jumpnav__num) { display: inline-block; font-family: var(--font-mono); color: var(--jn-ink); margin-right: var(--space-3); }
    :global(.el-jumpnav__bullet) { display: none; }
    :global(.el-jumpnav__link[aria-current="true"]) { background: var(--wc-gold-dim); color: var(--jn-ink-active); border-radius: var(--radius-sm); }
    :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__num) { color: var(--jn-fill); opacity: 1; font-weight: 700; }
  }
  :global(.el-jumpnav-backdrop) { position: fixed; inset: 0; background: rgba(10,10,10,.32); z-index: 38; opacity: 0; pointer-events: none; transition: opacity .25s ease-out; }
  :global(.el-jumpnav-backdrop.is-visible) { opacity: 1; pointer-events: auto; }
  @media (prefers-reduced-motion: reduce) {
    :global(.el-jumpnav__bullet), :global(.el-jumpnav__label), :global(.el-jumpnav-fab), :global(.el-jumpnav-fab__icon span), :global(.el-jumpnav-backdrop) { transition: none !important; }
  }

  /* ── [02] O eleitorado ── */
  .el-elt-bento { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 640px)  { .el-elt-bento { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); } }
  @media (min-width: 1024px) { .el-elt-bento { grid-template-columns: repeat(3, 1fr); grid-auto-rows: minmax(150px, auto); } .el-elt-hero { grid-column: 1 / 2; grid-row: 1 / 3; } }
  .el-elt-hero { position: relative; background: linear-gradient(180deg, var(--paper-card) 0%, var(--wc-gold-dim) 100%); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-md); padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-3); }
  .el-elt-total { font-family: var(--font-display); font-size: var(--display-2); font-weight: 400; color: var(--wc-gold-ink); line-height: .9; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  .el-elt-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .el-chip { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-full); }

  /* ── [09] O que está em jogo ── */
  .el-jogo-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 1024px) { .el-jogo-grid { grid-template-columns: repeat(4, 1fr); } }
  .el-jogo-card { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-1); transition: border-color var(--transition-normal); }
  .el-jogo-card:hover { border-color: var(--line-strong); }
  .el-jogo-num { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--ink); line-height: .95; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  .el-jogo-label { font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink-soft); }
  .el-jogo-sub { color: var(--wc-gold-ink); margin-top: var(--space-1); }
  .el-fundo { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-8); margin-top: var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 768px) { .el-fundo { grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr); align-items: center; } }
  .el-fundo__main { display: flex; flex-direction: column; gap: var(--space-2); }
  .el-fundo__val { color: var(--wc-gold-ink); font-size: var(--display-2); line-height: .9; }
  .el-fundo__stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5) var(--space-6); }
  @media (min-width: 1024px) { .el-fundo__stats { grid-template-columns: repeat(4, 1fr); } }
  .el-fundo__sv { display: block; font-family: var(--font-display); font-size: var(--text-2xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  .el-fundo__sl { display: block; color: var(--ink-faint); margin-top: var(--space-2); }

  /* ── [10] Relógio (timeline vertical) ── */
  .el-timeline { position: relative; margin: var(--space-8) 0 0; padding: var(--space-8) var(--space-6); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-timeline__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .el-tl-item { position: relative; display: grid; grid-template-columns: 1.2rem 6.5rem 1fr; align-items: baseline; gap: var(--space-3); padding: var(--space-4) 0; padding-left: var(--space-2); border-left: 2px solid var(--line); margin-left: 5px; }
  .el-tl-item:first-of-type { padding-top: 0; }
  .el-tl-item:last-of-type { padding-bottom: 0; }
  .el-tl-dot { position: absolute; left: -7px; top: var(--space-4); width: 10px; height: 10px; border-radius: var(--radius-full); background: var(--paper-card); border: 2px solid var(--ink-faint); }
  .el-tl-item:first-of-type .el-tl-dot { top: 2px; }
  .el-tl-item.is-past { border-left-color: var(--wc-gold-line); }
  .el-tl-item.is-past .el-tl-dot { background: var(--wc-gold-ink); border-color: var(--wc-gold-ink); }
  .el-tl-date { color: var(--ink-faint); font-variant-numeric: var(--num-tabular); grid-column: 2; }
  .el-tl-marco { color: var(--ink); font-size: var(--text-sm); grid-column: 3; }
  .el-tl-item.is-past .el-tl-marco { color: var(--ink-soft); }

  /* ── [11] Transparência & fontes ── */
  .el-tr-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 768px) { .el-tr-grid { grid-template-columns: repeat(2, 1fr); } }
  .el-tr-text { color: var(--ink-soft); font-size: var(--text-base); line-height: var(--leading-normal); margin: 0; }
  .el-sources { list-style: none; margin: var(--space-8) 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .el-source-link { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-full); text-decoration: none; transition: border-color var(--transition-fast), color var(--transition-fast); }
  .el-source-link:hover { border-color: var(--wc-gold-line); color: var(--wc-gold-ink); }
  .el-source-link:focus-visible { outline: var(--focus-ring-width) solid var(--focus-ring-color); outline-offset: 2px; }
</style>

<script>
  // Observatório Eleições 2026 — hidrata as seções a partir de
  // assets/data/eleicoes_pesquisas.json. Fetch runtime (base do body,
  // cache no-cache, AbortController, fail-soft). i18n dinâmico via
  // window.i18n.t() + re-render em `languageChanged`.
  interface Records { maior_amostra?: number | null; pesquisa_mais_cara_rs?: number | null; instituto_mais_ativo?: { empresa: string; n: number; investimento_rs: number } | null; mes_pico?: { mes: string; n: number } | null; }
  interface ElPayload {
    janela?: { primeira_divulgacao?: string; ultima_divulgacao?: string };
    kpis?: { total_pesquisas?: number; n_institutos?: number; investimento_total_rs?: number; mediana_entrevistados?: number; custo_medio_rs?: number | null };
    concentracao?: { top1_share_pct?: number; top5_share_pct?: number; hhi?: number };
    por_mes?: { mes: string; n: number }[];
    por_nivel?: { presidencial?: number; estadual?: number };
    top_institutos?: { empresa: string; n: number; investimento_rs: number }[];
    por_uf?: { uf: string; n: number }[];
    por_uf_detalhe?: Record<string, { n: number; mediana_amostra: number | null; top_institutos: { empresa: string; n: number }[] }>;
    propria_vs_contratada?: { propria?: number; contratada?: number };
    amostragem?: { faixa: string; n: number }[];
    records?: Records;
  }

  interface Dist { label: string; n: number; pct: number }
  interface EleitoradoPayload {
    total_eleitores?: number;
    biometria?: { n: number; pct: number };
    genero?: Dist[];
    faixa_etaria?: Dist[];
    escolaridade?: Dist[];
    obrigatoriedade?: Dist[];
    por_uf?: { uf: string; eleitores: number; pct: number }[];
    exterior?: { eleitores: number };
    destaques?: {
      feminino_pct?: number; jovens_16_17?: number; idosos_70mais?: number;
      analfabetos?: { n: number; pct: number }; facultativo_pct?: number;
    };
  }
  interface VoteCand { nome: string; partido: string; media_recente: number; pct_ultima: number; instituto_ultima: string; data_ultima: string; n_pesquisas: number; delta: number | null; lider: boolean }
  interface VoteDuelSide { nome: string; partido: string; pct: number }
  interface VoteDuel { instituto: string; data: string; a: VoteDuelSide; b: VoteDuelSide }
  interface PrecandPayload {
    fonte_url?: string;
    janela?: { primeira?: string; ultima?: string };
    n_medicoes?: number;
    n_institutos?: number;
    panorama?: { nome: string; partido: string; n_pesquisas: number; ultima: string }[];
    primeiro_turno?: { data_ref?: string; janela_dias?: number; n_pesquisas?: number; candidatos: VoteCand[] } | null;
    segundo_turno?: VoteDuel[];
  }
  interface VoteSnapshot { data_ref?: string; janela_dias?: number; n_pesquisas?: number; candidatos: VoteCand[] }
  interface EstadoIntencao { governador_1t: VoteSnapshot | null; governador_2t: VoteDuel[]; senador: VoteSnapshot | null }
  interface EstaduaisPayload {
    fonte_url_fmt?: string;
    ufs_disponiveis?: string[];
    estados?: Record<string, EstadoIntencao>;
  }
  interface ContextoPayload {
    cargos?: { presidente?: number; governadores?: number; senadores?: number; senado_total?: number; deputados_federais?: number; nota_senado?: string };
    fundo_eleitoral?: { valor_rs?: number; ref_2018_rs?: number; multiplo_vs_2018?: number; top5_partidos_share_pct?: number; cota_mulheres_pct?: number; cota_negros_pct?: number; nota_dobro?: string };
    calendario?: { data: string; marco: string }[];
    calendario_fonte_url?: string;
  }

  const nf = new Intl.NumberFormat('pt-BR');
  const el = (id: string) => document.getElementById(id);
  const t = (key: string, fallback: string): string => {
    const v = (window as unknown as { i18n?: { t?: (k: string) => string } }).i18n?.t?.(key);
    return typeof v === 'string' && v ? v : fallback;
  };
  function fmtRS(v: number): string {
    if (v >= 1_000_000) return `R$ ${(v / 1_000_000).toLocaleString('pt-BR', { maximumFractionDigits: 1 })} mi`;
    if (v >= 1_000) return `R$ ${(v / 1_000).toLocaleString('pt-BR', { maximumFractionDigits: 0 })} mil`;
    return `R$ ${nf.format(Math.round(v))}`;
  }
  const MESES = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
  const fmtMes = (m: string): string => { const [y, mm] = m.split('-'); return `${MESES[parseInt(mm, 10) - 1]}/${y.slice(2)}`; };
  const fmtMesLong = (m: string): string => { const [y, mm] = m.split('-'); return `${MESES[parseInt(mm, 10) - 1]} ${y}`; };
  function fmtDate(iso?: string): string { if (!iso) return '—'; const [y, m, d] = iso.split('-'); return `${d}/${m}/${y}`; }
  function esc(s: string): string { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // ── Faixa de progresso: contagem para o 1º turno (4/out/2026) ──
  function renderProgress(p: ElPayload): void {
    const ELECTION = Date.parse('2026-10-04T00:00:00-03:00');
    const startISO = p.janela?.primeira_divulgacao ?? '2026-01-01';
    const start = Date.parse(startISO + 'T00:00:00-03:00');
    const now = Date.now();
    const total = ELECTION - start;
    const pct = Math.max(0, Math.min(100, Math.round(((now - start) / total) * 100)));
    const days = Math.max(0, Math.ceil((ELECTION - now) / 86_400_000));
    const fill = el('el-prog-fill'); if (fill) fill.style.width = pct + '%';
    const bar = fill?.parentElement; if (bar) bar.setAttribute('aria-valuenow', String(pct));
    if (el('el-prog-pct')) el('el-prog-pct')!.textContent = pct + '%';
    if (el('el-prog-remaining')) el('el-prog-remaining')!.textContent = `${nf.format(days)} ${t('portfolio.eleicoes.prog_days', 'dias até o 1º turno')}`;
    if (el('el-prog-next')) el('el-prog-next')!.textContent = t('portfolio.eleicoes.prog_date', '4 de outubro de 2026');
  }

  function renderBento(p: ElPayload): void {
    const k = p.kpis ?? {};
    if (el('kpi-total')) el('kpi-total')!.textContent = nf.format(k.total_pesquisas ?? 0);
    if (el('kpi-institutos')) el('kpi-institutos')!.textContent = nf.format(k.n_institutos ?? 0);
    if (el('kpi-investimento')) el('kpi-investimento')!.textContent = fmtRS(k.investimento_total_rs ?? 0);
    const star = p.records?.instituto_mais_ativo;
    if (el('kpi-star-name')) el('kpi-star-name')!.textContent = star?.empresa ?? '—';
    if (el('kpi-star-meta') && star) el('kpi-star-meta')!.textContent =
      `${nf.format(star.n)} ${t('portfolio.eleicoes.rk_pesq', 'pesq')} · ${fmtRS(star.investimento_rs)}`;
    if (el('el-updated-date')) el('el-updated-date')!.textContent = fmtDate(p.janela?.ultima_divulgacao);
  }

  function renderMiniStats(p: ElPayload): void {
    const r = p.records ?? {};
    if (el('mini-amostra')) el('mini-amostra')!.textContent = r.maior_amostra ? nf.format(r.maior_amostra) : '—';
    if (el('mini-mediana')) el('mini-mediana')!.textContent = p.kpis?.mediana_entrevistados ? nf.format(p.kpis.mediana_entrevistados) : '—';
    if (el('mini-cara')) el('mini-cara')!.textContent = r.pesquisa_mais_cara_rs ? fmtRS(r.pesquisa_mais_cara_rs) : '—';
    if (el('mini-pico')) el('mini-pico')!.textContent = r.mes_pico ? `${fmtMesLong(r.mes_pico.mes)}` : '—';
    if (el('mini-custo')) el('mini-custo')!.textContent = p.kpis?.custo_medio_rs ? fmtRS(p.kpis.custo_medio_rs) : '—';
    if (el('mini-conc')) el('mini-conc')!.textContent = p.concentracao?.top5_share_pct != null ? `${p.concentracao.top5_share_pct}%` : '—';
    const inline = el('el-conc-inline');
    if (inline) inline.textContent = p.concentracao?.top1_share_pct != null ? `${p.concentracao.top1_share_pct}%` : '—';
  }

  // ── Gráfico de barras vertical (SVG) ──
  function renderBarChart(p: ElPayload): void {
    const box = el('el-barchart-svg'); if (!box) return;
    const data = p.por_mes ?? [];
    if (!data.length) { box.innerHTML = '<p class="el-error">série indisponível</p>'; return; }
    const peak = p.records?.mes_pico?.mes;
    const W = 720, H = 240, padT = 22, padB = 30, padX = 6;
    const maxN = Math.max(...data.map((d) => d.n), 1);
    const cw = (W - padX * 2) / data.length;
    const bw = Math.min(cw * 0.6, 64);
    const bars = data.map((d) => {
      const i = data.indexOf(d);
      const h = (d.n / maxN) * (H - padT - padB);
      const x = padX + i * cw + (cw - bw) / 2;
      const y = H - padB - h;
      const isPeak = d.mes === peak;
      return `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${bw.toFixed(1)}" height="${h.toFixed(1)}" rx="2" fill="var(${isPeak ? '--wc-gold-ink' : '--ink-soft'})"></rect>
        <text x="${(x + bw / 2).toFixed(1)}" y="${(y - 6).toFixed(1)}" text-anchor="middle" class="el-barval">${nf.format(d.n)}</text>
        <text x="${(x + bw / 2).toFixed(1)}" y="${H - padB + 16}" text-anchor="middle" class="el-axis">${esc(fmtMes(d.mes))}</text>`;
    }).join('');
    const baseline = `<line x1="${padX}" y1="${H - padB}" x2="${W - padX}" y2="${H - padB}" stroke="var(--line)" stroke-width="1"></line>`;
    box.innerHTML = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Pesquisas por mês">${baseline}${bars}</svg>`;
  }

  // ── Tabela ranqueada ──
  function renderRankTable(p: ElPayload): void {
    const body = el('el-rank-body'); if (!body) return;
    const data = p.top_institutos ?? [];
    if (!data.length) { body.innerHTML = '<tr><td colspan="4"><p class="el-error">ranking indisponível</p></td></tr>'; return; }
    body.innerHTML = data.map((d, i) => {
      const rank = i + 1, leader = rank === 1;
      const medal = leader ? ` <span class="el-medal">🏆 ${esc(t('portfolio.eleicoes.leader', 'líder'))}</span>` : '';
      return `<tr class="${leader ? 'is-leader' : ''}">
        <td class="el-rk-rank">${String(rank).padStart(2, '0')}${medal}</td>
        <td><span class="el-rk-name">${esc(d.empresa)}</span></td>
        <td class="el-rk-n">${nf.format(d.n)}</td>
        <td class="el-rk-rs">${esc(fmtRS(d.investimento_rs))}</td>
      </tr>`;
    }).join('');
  }

  // ── Donut (própria × contratada) ──
  function renderOrigem(p: ElPayload): void {
    const box = el('el-origem'); if (!box) return;
    const o = p.propria_vs_contratada ?? {};
    const contr = o.contratada ?? 0, prop = o.propria ?? 0, total = contr + prop;
    if (!total) { box.innerHTML = '<p class="el-error">indisponível</p>'; return; }
    const r = 52, cx = 66, cy = 66, circ = 2 * Math.PI * r;
    const fracC = contr / total;
    const dash = `${(fracC * circ).toFixed(1)} ${circ.toFixed(1)}`;
    const svg = `<svg viewBox="0 0 132 132" class="el-donut" role="img" aria-label="Origem das pesquisas">
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--line)" stroke-width="16"></circle>
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--ink)" stroke-width="16" stroke-dasharray="${dash}" transform="rotate(-90 ${cx} ${cy})"></circle>
      <text x="${cx}" y="${cy - 2}" text-anchor="middle" class="el-donut-num">${Math.round(fracC * 100)}%</text>
      <text x="${cx}" y="${cy + 16}" text-anchor="middle" class="el-donut-lbl">${esc(t('portfolio.eleicoes.origem_contratada', 'contratada'))}</text>
    </svg>`;
    const legend = `<div class="el-legend">
      <div class="el-legend__row"><span class="el-legend__sw" style="background:var(--ink)"></span>${esc(t('portfolio.eleicoes.origem_contratada', 'Contratada'))}<span class="el-legend__n">${nf.format(contr)}</span></div>
      <div class="el-legend__row"><span class="el-legend__sw" style="background:var(--line-strong)"></span>${esc(t('portfolio.eleicoes.origem_propria', 'Própria (do instituto)'))}<span class="el-legend__n">${nf.format(prop)}</span></div>
    </div>`;
    box.innerHTML = svg + legend;
  }

  function splitRow(label: string, n: number, total: number, alt = false): string {
    const pct = total ? (n / total) * 100 : 0;
    return `<div>
      <div class="el-split-row"><span>${esc(label)}</span><span>${nf.format(n)} · ${pct.toFixed(0)}%</span></div>
      <div class="el-split-track"><span class="el-split-fill${alt ? ' el-split-fill--alt' : ''}" style="width:${pct}%"></span></div>
    </div>`;
  }
  function renderNivel(p: ElPayload): void {
    const box = el('el-nivel'); if (!box) return;
    const niv = p.por_nivel ?? {};
    const total = (niv.presidencial ?? 0) + (niv.estadual ?? 0);
    box.innerHTML =
      splitRow(t('portfolio.eleicoes.nivel_presidencial', 'Presidencial / nacional'), niv.presidencial ?? 0, total) +
      splitRow(t('portfolio.eleicoes.nivel_estadual', 'Estadual'), niv.estadual ?? 0, total, true);
  }
  function renderAmostragem(p: ElPayload): void {
    const box = el('el-amostragem'); if (!box) return;
    const am = p.amostragem ?? [];
    if (!am.length) { box.innerHTML = '<p class="el-error">indisponível</p>'; return; }
    const max = Math.max(...am.map((a) => a.n), 1);
    box.innerHTML = am.map((a) => `<div class="el-bar-row">
      <span class="el-bar-lbl">${esc(a.faixa)}</span>
      <span class="el-bar-track"><span class="el-bar-fill" style="width:${(a.n / max) * 100}%"></span></span>
      <span class="el-bar-n">${nf.format(a.n)}</span>
    </div>`).join('');
  }

  // ── Cobertura por UF (ranking horizontal, #1 destacado) ──
  function renderUF(p: ElPayload): void {
    const box = el('el-uf'); if (!box) return;
    const data = (p.por_uf ?? []).filter((d) => d.uf && d.uf !== 'BR').slice(0, 14);
    if (!data.length) { box.innerHTML = '<p class="el-error">cobertura indisponível</p>'; return; }
    const max = Math.max(...data.map((d) => d.n), 1);
    const rows = data.map((d, i) => `<div class="el-uf-row${i === 0 ? ' is-leader' : ''}">
      <span class="el-uf-uf">${esc(d.uf)}</span>
      <span class="el-uf-track"><span class="el-uf-fill" style="width:${(d.n / max) * 100}%"></span></span>
      <span class="el-uf-n">${nf.format(d.n)}</span>
    </div>`).join('');
    box.innerHTML =
      '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>' +
      `<div class="el-uf-grid">${rows}</div>`;
  }

  // ── [08] Explorar por estado ──
  const UF_NAME: Record<string, string> = {
    AC: 'Acre', AL: 'Alagoas', AP: 'Amapá', AM: 'Amazonas', BA: 'Bahia', CE: 'Ceará',
    DF: 'Distrito Federal', ES: 'Espírito Santo', GO: 'Goiás', MA: 'Maranhão',
    MT: 'Mato Grosso', MS: 'Mato Grosso do Sul', MG: 'Minas Gerais', PA: 'Pará',
    PB: 'Paraíba', PR: 'Paraná', PE: 'Pernambuco', PI: 'Piauí', RJ: 'Rio de Janeiro',
    RN: 'Rio Grande do Norte', RS: 'Rio Grande do Sul', RO: 'Rondônia', RR: 'Roraima',
    SC: 'Santa Catarina', SP: 'São Paulo', SE: 'Sergipe', TO: 'Tocantins',
  };
  let currentUf = '';

  function renderUFDetail(uf: string): void {
    const box = el('el-uf-detail'); if (!box) return;
    currentUf = uf;
    const crop = '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>';
    const d = payload?.por_uf_detalhe?.[uf];
    const name = UF_NAME[uf] ?? uf;
    if (!d) { box.innerHTML = crop + `<p class="el-error">${esc(t('portfolio.eleicoes.explorar_empty', 'Sem dados para este estado.'))}</p>`; return; }
    const rows = (d.top_institutos ?? []).map((it, i) => `
      <li class="el-ufd-row">
        <span class="el-ufd-rank">${String(i + 1).padStart(2, '0')}</span>
        <span class="el-ufd-name">${esc(it.empresa)}</span>
        <span class="el-ufd-n">${nf.format(it.n)} ${esc(t('portfolio.eleicoes.rk_pesq', 'pesq'))}</span>
      </li>`).join('');
    box.innerHTML = crop + `
      <header class="el-ufd-head">
        <span class="el-ufd-uf mono-label">${esc(uf)}</span>
        <h3 class="el-ufd-title">${esc(name)}</h3>
      </header>
      <div class="el-ufd-kpis">
        <div><span class="el-ufd-kv">${nf.format(d.n)}</span><span class="el-ufd-kl mono-label">${esc(t('portfolio.eleicoes.kpi_total', 'pesquisas'))}</span></div>
        <div><span class="el-ufd-kv">${d.mediana_amostra ? nf.format(d.mediana_amostra) : '—'}</span><span class="el-ufd-kl mono-label">${esc(t('portfolio.eleicoes.mini_amostra_med', 'amostra mediana'))}</span></div>
      </div>
      <ol class="el-ufd-list" aria-label="${esc(name)}">${rows}</ol>`;
  }

  interface CBItem { value: string; label: string; }
  function buildCombobox(rootId: string, items: CBItem[], onSelect: (v: string) => void) {
    const root = document.getElementById(rootId); if (!root) return null;
    const input = root.querySelector('.el-combobox__input') as HTMLInputElement;
    const btn = root.querySelector('.el-combobox__btn') as HTMLButtonElement;
    const listbox = root.querySelector('.el-combobox__list') as HTMLElement;
    let filtered: CBItem[] = items.slice(), hi = -1, open = false, current = '';
    const norm = (s: string) => s.normalize('NFKD').replace(/[̀-ͯ]/g, '').toLowerCase();
    function render(): void {
      if (!filtered.length) { listbox.innerHTML = `<li class="el-combobox__empty" role="status">${esc(t('portfolio.eleicoes.uf_none', 'Nenhum estado'))}</li>`; return; }
      listbox.innerHTML = filtered.map((it, i) => {
        const sel = it.value === current, hl = i === hi;
        return `<li role="option" id="el-opt-${i}" data-value="${esc(it.value)}" aria-selected="${sel}" class="el-combobox__option${sel ? ' is-selected' : ''}${hl ? ' is-highlighted' : ''}">${esc(it.label)}</li>`;
      }).join('');
    }
    function filter(q: string): void { const qn = norm(q.trim()); filtered = qn ? items.filter((it) => norm(it.label).includes(qn)) : items.slice(); hi = qn && filtered.length ? 0 : -1; render(); }
    function openList(): void { if (open) return; open = true; listbox.hidden = false; input.setAttribute('aria-expanded', 'true'); filter(''); }
    function closeList(): void { if (!open) return; open = false; listbox.hidden = true; input.setAttribute('aria-expanded', 'false'); input.removeAttribute('aria-activedescendant'); const it = items.find((i) => i.value === current); input.value = it ? it.label : ''; }
    function setHi(i: number): void { hi = Math.max(-1, Math.min(i, filtered.length - 1)); Array.from(listbox.querySelectorAll('[role=option]')).forEach((li, j) => li.classList.toggle('is-highlighted', j === hi)); const elx = listbox.querySelector('.is-highlighted') as HTMLElement | null; if (elx) { elx.scrollIntoView({ block: 'nearest' }); input.setAttribute('aria-activedescendant', elx.id); } }
    function choose(v: string): void { current = v; const it = items.find((i) => i.value === v); input.value = it ? it.label : ''; onSelect(v); closeList(); }
    input.addEventListener('focus', openList);
    input.addEventListener('input', () => { if (!open) openList(); filter(input.value); });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); if (!open) { openList(); return; } setHi(hi + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setHi(hi - 1); }
      else if (e.key === 'Home' && open) { e.preventDefault(); setHi(0); }
      else if (e.key === 'End' && open) { e.preventDefault(); setHi(filtered.length - 1); }
      else if (e.key === 'Enter') { e.preventDefault(); if (hi >= 0 && filtered[hi]) choose(filtered[hi].value); }
      else if (e.key === 'Escape') { e.preventDefault(); closeList(); }
      else if (e.key === 'Tab') { if (open) closeList(); }
    });
    btn.addEventListener('click', (e) => { e.preventDefault(); if (open) closeList(); else { input.focus(); openList(); } });
    listbox.addEventListener('mousedown', (e) => e.preventDefault());
    listbox.addEventListener('click', (e) => { const li = (e.target as HTMLElement).closest('[role=option]') as HTMLElement | null; if (li?.dataset.value) choose(li.dataset.value); });
    document.addEventListener('mousedown', (e) => { if (!root.contains(e.target as Node) && open) closeList(); });
    return { setValue(v: string) { current = v; const it = items.find((i) => i.value === v); if (it) input.value = it.label; } };
  }

  let explorarBuilt = false;
  function initExplorar(data: ElPayload): void {
    const det = data.por_uf_detalhe ?? {};
    const ufs = Object.keys(det).filter((u) => u !== 'BR').sort((a, b) => (det[b]?.n ?? 0) - (det[a]?.n ?? 0));
    if (!ufs.length) return;
    if (!explorarBuilt) {
      const items = ufs.map((u) => ({ value: u, label: `${UF_NAME[u] ?? u} (${u})` }));
      const cb = buildCombobox('el-uf-combobox', items, renderUFDetail);
      cb?.setValue(ufs[0]);
      renderUFDetail(ufs[0]);
      explorarBuilt = true;
    } else if (currentUf) {
      renderUFDetail(currentUf);
    }
  }

  // ── [02] intenção de voto + [03] eleitorado + [05] intensidade/UF + [10][11][12] ──
  let eleitorado: EleitoradoPayload | null = null;
  let contexto: ContextoPayload | null = null;
  let precand: PrecandPayload | null = null;

  function fmtNum(v: number): string {
    if (v >= 1_000_000) return `${(v / 1_000_000).toLocaleString('pt-BR', { maximumFractionDigits: 1 })} mi`;
    if (v >= 1_000) return `${(v / 1_000).toLocaleString('pt-BR', { maximumFractionDigits: 0 })} mil`;
    return nf.format(v);
  }
  function distBars(boxId: string, raw: Dist[]): void {
    const box = el(boxId); if (!box) return;
    const items = (raw ?? []).filter((d) => d.n > 0);
    if (!items.length) { box.innerHTML = '<p class="el-error">indisponível</p>'; return; }
    const max = Math.max(...items.map((d) => d.pct), 1);
    box.innerHTML = items.map((d) => `<div class="el-bar-row">
      <span class="el-bar-lbl">${esc(d.label)}</span>
      <span class="el-bar-track"><span class="el-bar-fill" style="width:${(d.pct / max) * 100}%"></span></span>
      <span class="el-bar-n">${d.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
    </div>`).join('');
  }

  // ── Helpers de intenção (reusados por presidencial [02] e estadual [03]) ──
  function voteBarsHTML(cands: VoteCand[]): string {
    const max = Math.max(...cands.map((c) => c.media_recente), 1);
    return cands.map((c) => {
      const d = c.delta;
      const deltaHtml = d == null ? '' :
        `<span class="el-vote-delta ${d > 0 ? 'is-up' : d < 0 ? 'is-down' : ''}">${d > 0 ? '▲' : d < 0 ? '▼' : '–'} ${Math.abs(d).toLocaleString('pt-BR', { maximumFractionDigits: 1 })}</span>`;
      return `<div class="el-vote-row${c.lider ? ' is-leader' : ''}">
        <span class="el-vote-name">${esc(c.nome)} <span class="el-vote-party mono-label">${esc(c.partido)}</span></span>
        <span class="el-vote-track"><span class="el-vote-fill" style="width:${(c.media_recente / max) * 100}%"></span></span>
        <span class="el-vote-pct">${c.media_recente.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%${deltaHtml}</span>
      </div>`;
    }).join('');
  }
  function voteDuelsHTML(duels: VoteDuel[]): string {
    return duels.map((d) => {
      const aWin = d.a.pct >= d.b.pct;
      return `<div class="el-vote-duel">
        <div class="el-vote-duel__row">
          <span class="el-vote-duel__name">${esc(d.a.nome)} <span class="mono-label">${esc(d.a.partido)}</span></span>
          <span class="el-vote-duel__pct${aWin ? ' is-leader' : ''}">${d.a.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
        </div>
        <div class="el-vote-duel__bar"><span style="width:${d.a.pct}%" class="${aWin ? 'is-leader' : ''}"></span><span style="width:${d.b.pct}%" class="${!aWin ? 'is-leader' : ''}"></span></div>
        <div class="el-vote-duel__row">
          <span class="el-vote-duel__name">${esc(d.b.nome)} <span class="mono-label">${esc(d.b.partido)}</span></span>
          <span class="el-vote-duel__pct${!aWin ? ' is-leader' : ''}">${d.b.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
        </div>
        <span class="el-vote-duel__src mono-label">${esc(d.instituto)} · ${esc(fmtDate(d.data))}</span>
      </div>`;
    }).join('');
  }
  function voteRefText(s: { janela_dias?: number; data_ref?: string; n_pesquisas?: number }): string {
    return `${t('portfolio.eleicoes.vote_ref', 'média dos últimos')} ${s.janela_dias ?? 90} ${t('portfolio.eleicoes.vote_ref_dias', 'dias · até')} ${fmtDate(s.data_ref)} · ${nf.format(s.n_pesquisas ?? 0)} ${t('portfolio.eleicoes.vote_ref_pesq', 'pesquisas')}`;
  }

  // ── [02] Intenção de voto presidencial (pré-candidatos) ──
  function voteFail(): void {
    ['el-vote-1t', 'el-vote-2t'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">intenção indisponível — tente recarregar</p>'; });
    const chips = el('el-vote-chips'); if (chips) chips.innerHTML = '';
    const ref = el('el-vote-1t-ref'); if (ref) ref.textContent = '';
  }
  function renderPrecandidatos(pc: PrecandPayload | null): void {
    if (!pc || !pc.primeiro_turno || !pc.primeiro_turno.candidatos?.length) { voteFail(); return; }
    const pt = pc.primeiro_turno;
    const box1 = el('el-vote-1t');
    if (box1) box1.innerHTML = voteBarsHTML(pt.candidatos);
    const ref = el('el-vote-1t-ref');
    if (ref) ref.textContent = voteRefText(pt);
    const box2 = el('el-vote-2t');
    if (box2) {
      const duels = (pc.segundo_turno ?? []).slice(0, 5);
      box2.innerHTML = duels.length ? voteDuelsHTML(duels) : '<p class="el-error">sem confrontos medidos</p>';
    }
    const chips = el('el-vote-chips');
    if (chips) chips.innerHTML = (pc.panorama ?? []).slice(0, 16)
      .map((p) => `<span class="el-chip">${esc(p.nome)} <span class="mono-label">${esc(p.partido)}</span></span>`).join('');
  }

  // ── [03] Intenção de voto estadual (governador + senador) ──
  let estaduais: EstaduaisPayload | null = null;
  let estBuilt = false;
  let currentEstUf = '';
  function renderEstadoDetail(uf: string): void {
    currentEstUf = uf;
    const est = estaduais?.estados?.[uf];
    const gov1 = el('el-est-gov1'), gov1ref = el('el-est-gov1-ref');
    const gov2 = el('el-est-gov2'), sen = el('el-est-sen'), senref = el('el-est-sen-ref');
    const semDados = t('portfolio.eleicoes.est_empty', 'sem pesquisas para este cargo');
    if (gov1) gov1.innerHTML = est?.governador_1t?.candidatos?.length ? voteBarsHTML(est.governador_1t.candidatos) : `<p class="el-error">${esc(semDados)}</p>`;
    if (gov1ref) gov1ref.textContent = est?.governador_1t ? voteRefText(est.governador_1t) : '';
    if (gov2) gov2.innerHTML = est?.governador_2t?.length ? voteDuelsHTML(est.governador_2t.slice(0, 4)) : `<p class="el-error">${esc(semDados)}</p>`;
    if (sen) sen.innerHTML = est?.senador?.candidatos?.length ? voteBarsHTML(est.senador.candidatos) : `<p class="el-error">${esc(semDados)}</p>`;
    if (senref) senref.textContent = est?.senador ? voteRefText(est.senador) : '';
  }
  function renderEstaduais(pc: EstaduaisPayload | null): void {
    const fail = (msg: string) => ['el-est-gov1', 'el-est-gov2', 'el-est-sen'].forEach((id) => { const b = el(id); if (b) b.innerHTML = `<p class="el-error">${esc(msg)}</p>`; });
    const ufs = pc?.ufs_disponiveis ?? [];
    if (!ufs.length) { fail(t('portfolio.eleicoes.est_unavailable', 'intenção estadual indisponível — tente recarregar')); return; }
    if (!estBuilt) {
      const items = ufs.map((u) => ({ value: u, label: `${UF_NAME[u] ?? u} (${u})` }));
      const cb = buildCombobox('el-est-combobox', items, renderEstadoDetail);
      cb?.setValue(ufs[0]);
      renderEstadoDetail(ufs[0]);
      estBuilt = true;
    } else if (currentEstUf) {
      renderEstadoDetail(currentEstUf);
    }
  }

  function renderEleitorado(e: EleitoradoPayload | null): void {
    if (!e) {
      if (el('el-elt-total')) el('el-elt-total')!.textContent = '—';
      ['el-elt-genero', 'el-elt-faixa', 'el-elt-escol'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">perfil indisponível</p>'; });
      return;
    }
    if (el('el-elt-total')) el('el-elt-total')!.textContent = e.total_eleitores ? fmtNum(e.total_eleitores) : '—';
    const d = e.destaques ?? {};
    const chips: string[] = [];
    if (d.feminino_pct != null) chips.push(`${d.feminino_pct}% ${t('portfolio.eleicoes.elt_chip_mulheres', 'mulheres')}`);
    if (e.biometria?.pct != null) chips.push(`${e.biometria.pct}% ${t('portfolio.eleicoes.elt_chip_bio', 'com biometria')}`);
    if (d.jovens_16_17) chips.push(`${fmtNum(d.jovens_16_17)} ${t('portfolio.eleicoes.elt_chip_jovens', 'jovens 16–17')}`);
    if (d.idosos_70mais) chips.push(`${fmtNum(d.idosos_70mais)} ${t('portfolio.eleicoes.elt_chip_idosos', 'com 70+')}`);
    if (d.analfabetos?.pct != null) chips.push(`${d.analfabetos.pct}% ${t('portfolio.eleicoes.elt_chip_analf', 'analfabetos')}`);
    if (e.exterior?.eleitores) chips.push(`${fmtNum(e.exterior.eleitores)} ${t('portfolio.eleicoes.elt_chip_exterior', 'no exterior')}`);
    const chipsBox = el('el-elt-chips');
    if (chipsBox) chipsBox.innerHTML = chips.map((c) => `<span class="el-chip">${esc(c)}</span>`).join('');
    // sexo → split (feminino vs masculino)
    const gbox = el('el-elt-genero');
    if (gbox && e.genero?.length) {
      const total = e.genero.reduce((s, x) => s + x.n, 0);
      gbox.innerHTML = e.genero.filter((g) => g.n > 0)
        .map((g, i) => splitRow(g.label, g.n, total, i > 0)).join('');
    }
    distBars('el-elt-faixa', e.faixa_etaria ?? []);
    distBars('el-elt-escol', e.escolaridade ?? []);
  }

  // ── [04] Índice de intensidade por UF (pesquisas ÷ eleitores em milhões) ──
  function renderIntensidadeUF(p: ElPayload, e: EleitoradoPayload | null): void {
    const box = el('el-iuf-body'); if (!box) return;
    const elt = e?.por_uf ?? [];
    if (!elt.length || !(p.por_uf ?? []).length) { box.innerHTML = '<p class="el-error">índice indisponível</p>'; return; }
    const pop: Record<string, number> = {};
    elt.forEach((u) => { pop[u.uf] = u.eleitores; });
    const rows = (p.por_uf ?? [])
      .filter((d) => d.uf && d.uf !== 'BR' && pop[d.uf])
      .map((d) => ({ uf: d.uf, idx: d.n / (pop[d.uf] / 1_000_000) }))
      .sort((a, b) => b.idx - a.idx)
      .slice(0, 14);
    if (!rows.length) { box.innerHTML = '<p class="el-error">índice indisponível</p>'; return; }
    const max = Math.max(...rows.map((r) => r.idx), 1);
    box.innerHTML = `<div class="el-uf-grid">` + rows.map((r, i) => `<div class="el-uf-row${i === 0 ? ' is-leader' : ''}">
      <span class="el-uf-uf">${esc(r.uf)}</span>
      <span class="el-uf-track"><span class="el-uf-fill" style="width:${(r.idx / max) * 100}%"></span></span>
      <span class="el-uf-n">${r.idx.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}</span>
    </div>`).join('') + `</div>`;
  }

  // ── [09] O que está em jogo ──
  function renderJogo(c: ContextoPayload | null): void {
    const grid = el('el-jogo-cargos');
    if (grid && !c?.cargos) grid.innerHTML = '<p class="el-error">cargos indisponíveis</p>';
    const fb = el('el-fundo');
    if (fb && !c?.fundo_eleitoral) fb.innerHTML = '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span><p class="el-error">Fundo Eleitoral indisponível</p>';
    if (grid && c?.cargos) {
      const g = c.cargos;
      const cards: [number | undefined, string, string][] = [
        [g.presidente, t('portfolio.eleicoes.jogo_presidente', 'presidente'), ''],
        [g.governadores, t('portfolio.eleicoes.jogo_governadores', 'governadores'), ''],
        [g.senadores, t('portfolio.eleicoes.jogo_senadores', 'senadores'), `${t('portfolio.eleicoes.jogo_de', 'de')} ${g.senado_total ?? 81} · 2/3`],
        [g.deputados_federais, t('portfolio.eleicoes.jogo_deputados', 'deputados federais'), ''],
      ];
      grid.innerHTML = cards.map(([n, label, sub]) => `<article class="el-jogo-card crop">
        <span class="crop-mark-br" aria-hidden="true"></span>
        <span class="el-jogo-num">${n != null ? nf.format(n) : '—'}</span>
        <span class="el-jogo-label">${esc(label)}</span>
        ${sub ? `<span class="el-jogo-sub mono-label">${esc(sub)}</span>` : ''}
      </article>`).join('');
    }
    const fbox = el('el-fundo');
    if (fbox && c?.fundo_eleitoral) {
      const f = c.fundo_eleitoral;
      const val = f.valor_rs ? fmtRS(f.valor_rs) : '—';
      const mult = f.multiplo_vs_2018 ? `${f.multiplo_vs_2018.toLocaleString('pt-BR')}×` : '—';
      fbox.innerHTML = `<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>
        <div class="el-fundo__main">
          <span class="el-jogo-num el-fundo__val">${esc(val)}</span>
          <span class="el-jogo-label">${esc(t('portfolio.eleicoes.jogo_fundo', 'Fundo Eleitoral (público) para campanhas'))}</span>
        </div>
        <div class="el-fundo__stats">
          <div><span class="el-fundo__sv">${esc(mult)}</span><span class="el-fundo__sl mono-label">${esc(t('portfolio.eleicoes.jogo_vs2018', 'vs. 2018'))}</span></div>
          <div><span class="el-fundo__sv">${f.top5_partidos_share_pct != null ? f.top5_partidos_share_pct + '%' : '—'}</span><span class="el-fundo__sl mono-label">${esc(t('portfolio.eleicoes.jogo_top5', 'nos 5 maiores partidos'))}</span></div>
          <div><span class="el-fundo__sv">${f.cota_mulheres_pct != null ? f.cota_mulheres_pct + '%' : '—'}</span><span class="el-fundo__sl mono-label">${esc(t('portfolio.eleicoes.jogo_cotam', 'mín. mulheres'))}</span></div>
          <div><span class="el-fundo__sv">${f.cota_negros_pct != null ? f.cota_negros_pct + '%' : '—'}</span><span class="el-fundo__sl mono-label">${esc(t('portfolio.eleicoes.jogo_cotan', 'mín. negros'))}</span></div>
        </div>`;
    }
  }

  // ── [10] Relógio da democracia (calendário) ──
  function renderRelogio(c: ContextoPayload | null): void {
    const box = el('el-timeline'); if (!box) return;
    const cal = c?.calendario ?? [];
    if (!cal.length) { box.innerHTML = '<li class="el-error">calendário indisponível</li>'; return; }
    const now = Date.now();
    box.innerHTML = cal.map((m) => {
      const ts = Date.parse(m.data + 'T00:00:00-03:00');
      const past = ts < now;
      return `<li class="el-tl-item${past ? ' is-past' : ''}">
        <span class="el-tl-dot" aria-hidden="true"></span>
        <time class="el-tl-date mono-label" datetime="${esc(m.data)}">${esc(fmtDate(m.data))}</time>
        <span class="el-tl-marco">${esc(m.marco)}</span>
      </li>`;
    }).join('');
  }

  // ── [11] Fontes ──
  function renderSources(): void {
    const box = el('el-sources'); if (!box) return;
    const srcs: [string, string][] = [
      [t('portfolio.eleicoes.src_pesquisas', 'Pesquisas Eleitorais 2026 — TSE Dados Abertos'), 'https://dadosabertos.tse.jus.br/dataset/pesquisas-eleitorais-2026'],
      [t('portfolio.eleicoes.src_eleitorado', 'Estatísticas de Eleitorado — TSE'), 'https://dadosabertos.tse.jus.br/dataset/eleitorado-atual'],
    ];
    if (precand?.fonte_url) srcs.push([t('portfolio.eleicoes.src_precand', 'Pesquisas presidenciais 2026 — Wikipedia (agrega TSE)'), precand.fonte_url]);
    if (estaduais?.ufs_disponiveis?.length) srcs.push([t('portfolio.eleicoes.src_estaduais', 'Pesquisas estaduais 2026 — Wikipedia (agrega TSE)'), 'https://pt.wikipedia.org/wiki/Categoria:Pesquisas_eleitorais_para_as_elei%C3%A7%C3%B5es_estaduais_no_Brasil_em_2026']);
    if (contexto?.calendario_fonte_url) srcs.push([t('portfolio.eleicoes.src_calendario', 'Calendário Eleitoral 2026 — TSE'), contexto.calendario_fonte_url]);
    box.innerHTML = srcs.map(([label, url]) =>
      `<li><a href="${esc(url)}" target="_blank" rel="noopener noreferrer" class="el-source-link">${esc(label)} <span aria-hidden="true">↗</span></a></li>`
    ).join('');
  }

  let payload: ElPayload | null = null;
  function renderAll(data: ElPayload): void {
    renderProgress(data);
    renderBento(data);
    renderMiniStats(data);
    renderBarChart(data);
    renderRankTable(data);
    renderOrigem(data);
    renderNivel(data);
    renderAmostragem(data);
    renderUF(data);
    initExplorar(data);
    renderPrecandidatos(precand);
    renderEstaduais(estaduais);
    renderEleitorado(eleitorado);
    renderIntensidadeUF(data, eleitorado);
    renderJogo(contexto);
    renderRelogio(contexto);
    renderSources();
  }

  async function fetchJSON<T>(base: string, file: string, ms = 8000): Promise<T | null> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), ms);
    try {
      const res = await fetch(`${base}assets/data/${file}`, { cache: 'no-cache', signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) return null;
      return (await res.json()) as T;
    } catch { clearTimeout(timeoutId); return null; }
  }

  async function loadEleicoes(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const [pdata, edata, cdata, prdata, estdata] = await Promise.all([
      fetchJSON<ElPayload>(base, 'eleicoes_pesquisas.json'),
      fetchJSON<EleitoradoPayload>(base, 'eleicoes_eleitorado.json'),
      fetchJSON<ContextoPayload>(base, 'eleicoes_contexto.json'),
      fetchJSON<PrecandPayload>(base, 'eleicoes_precandidatos.json'),
      fetchJSON<EstaduaisPayload>(base, 'eleicoes_estaduais.json'),
    ]);
    eleitorado = edata;
    contexto = cdata;
    precand = prdata;
    estaduais = estdata;
    if (pdata && pdata.kpis) {
      payload = pdata;
      renderAll(pdata);
    } else {
      ['el-barchart-svg', 'el-uf', 'el-iuf-body'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">dados indisponíveis — tente recarregar</p>'; });
      const body = el('el-rank-body'); if (body) body.innerHTML = '<tr><td colspan="4"><p class="el-error">dados indisponíveis — tente recarregar</p></td></tr>';
      // seções independentes ainda renderizam se vieram
      renderPrecandidatos(precand); renderEstaduais(estaduais); renderEleitorado(eleitorado); renderJogo(contexto); renderRelogio(contexto); renderSources();
    }
  }

  document.addEventListener('DOMContentLoaded', loadEleicoes);
  window.addEventListener('languageChanged', () => { if (payload) renderAll(payload); });
</script>

<script>
  // Motion — padrão nomeado `reveal-up` (GSAP + ScrollTrigger), guardado por
  // motionOk (respeita prefers-reduced-motion). Hero + por seção (head + cards).
  import { revealUp } from '../scripts/motion/reveal-up';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  function animateEleicoes(): void {
    if (!motionOk) return;
    const heroCard = document.querySelector('#eleicoes-hero .hero-card') as HTMLElement | null;
    if (heroCard) revealUp([heroCard], heroCard, 0);
    document.querySelectorAll<HTMLElement>('main section[id^="el-"]').forEach((sec) => {
      const head = sec.querySelector('.section-head') as HTMLElement | null;
      if (head) revealUp([head], sec, 0);
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.el-kpi, .el-ministat, .el-chartcard, .el-rank-wrap, .el-panel, .el-ufchart, .el-elt-hero, .el-jogo-card, .el-fundo, .el-timeline'));
      if (cards.length) revealUp(cards, sec, STAGGER.tight);
    });
  }
  document.addEventListener('DOMContentLoaded', animateEleicoes);
</script>

<script>
  // Jump-nav — rail de pontos (desktop) + FAB/bottom-sheet (mobile). Lê as
  // seções desta página; labels vêm do i18n (re-render em `languageChanged`).
  // Active via IntersectionObserver. Portado do world-cup-dashboard/jumpnav.js.
  const NAV = [
    { id: 'eleicoes-hero',     key: 'portfolio.eleicoes.nav_hero',          fb: 'Início' },
    { id: 'el-panorama',       key: 'portfolio.eleicoes.nav_panorama',      fb: 'Panorama' },
    { id: 'el-intencao',       key: 'portfolio.eleicoes.nav_intencao',      fb: 'Intenção de voto' },
    { id: 'el-estadual',       key: 'portfolio.eleicoes.nav_estadual',      fb: 'Intenção estadual' },
    { id: 'el-eleitorado',     key: 'portfolio.eleicoes.nav_eleitorado',    fb: 'Eleitorado' },
    { id: 'el-intensidade',    key: 'portfolio.eleicoes.nav_intensidade',   fb: 'Intensidade' },
    { id: 'el-intensidade-uf', key: 'portfolio.eleicoes.nav_intensidade_uf', fb: 'Por estado' },
    { id: 'el-institutos',     key: 'portfolio.eleicoes.nav_institutos',    fb: 'Quem mede' },
    { id: 'el-como',           key: 'portfolio.eleicoes.nav_como',          fb: 'Como medem' },
    { id: 'el-cobertura',      key: 'portfolio.eleicoes.nav_cobertura',     fb: 'Cobertura' },
    { id: 'el-explorar',       key: 'portfolio.eleicoes.nav_explorar',      fb: 'Explorar' },
    { id: 'el-jogo',           key: 'portfolio.eleicoes.nav_jogo',          fb: 'Em jogo' },
    { id: 'el-relogio',        key: 'portfolio.eleicoes.nav_relogio',       fb: 'Calendário' },
    { id: 'el-transparencia',  key: 'portfolio.eleicoes.nav_transparencia', fb: 'Transparência' },
  ];
  const jt = (k: string, fb: string): string => {
    const v = (window as unknown as { i18n?: { t?: (k: string) => string } }).i18n?.t?.(k);
    return typeof v === 'string' && v ? v : fb;
  };
  const jesc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
  const jReduce = (): boolean => matchMedia('(prefers-reduced-motion: reduce)').matches;
  const jMobile = (): boolean => matchMedia('(max-width: 1023px)').matches;
  let backdrop: HTMLElement | null = null;

  function jRenderList(): void {
    const list = document.getElementById('el-jumpnav-list'); if (!list) return;
    const items = NAV.filter((n) => document.getElementById(n.id));
    list.innerHTML = items.map((n, i) => `
      <li class="el-jumpnav__item">
        <a href="#${n.id}" class="el-jumpnav__link" data-target="${n.id}" aria-current="false">
          <span class="el-jumpnav__label">${jesc(jt(n.key, n.fb))}</span>
          <span class="el-jumpnav__bullet" aria-hidden="true"></span>
          <span class="el-jumpnav__num">${String(i + 1).padStart(2, '0')}</span>
        </a>
      </li>`).join('');
  }
  function jSetActive(id: string): void {
    document.querySelectorAll('.el-jumpnav__link').forEach((l) => {
      const on = (l as HTMLElement).dataset.target === id;
      if (l.getAttribute('aria-current') !== String(on)) l.setAttribute('aria-current', String(on));
    });
  }
  function jEnsureBackdrop(): HTMLElement {
    if (backdrop) return backdrop;
    backdrop = document.createElement('div');
    backdrop.className = 'el-jumpnav-backdrop';
    backdrop.setAttribute('aria-hidden', 'true');
    backdrop.addEventListener('click', jCloseSheet);
    document.body.appendChild(backdrop);
    return backdrop;
  }
  function jOpenSheet(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => jEnsureBackdrop().classList.add('is-visible'));
    document.body.style.overflow = 'hidden';
  }
  function jCloseSheet(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    fab.setAttribute('aria-expanded', 'false');
    backdrop?.classList.remove('is-visible');
    setTimeout(() => { if (fab.getAttribute('aria-expanded') === 'false') (nav as HTMLElement).hidden = true; }, 250);
    document.body.style.overflow = '';
  }
  function initJumpnav(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    jRenderList();
    document.getElementById('el-jumpnav-list')!.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.el-jumpnav__link') as HTMLElement | null;
      if (!link) return;
      e.preventDefault();
      const id = link.dataset.target!; const target = document.getElementById(id); if (!target) return;
      const go = () => { target.scrollIntoView({ behavior: jReduce() ? 'auto' : 'smooth', block: 'start' }); history.replaceState(null, '', '#' + id); };
      if (jMobile() && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); setTimeout(go, jReduce() ? 0 : 260); } else go();
      jSetActive(id);
    });
    fab.addEventListener('click', () => (fab.getAttribute('aria-expanded') === 'true' ? jCloseSheet() : jOpenSheet()));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); fab.focus(); } });
    matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) { (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'false'); backdrop?.classList.remove('is-visible'); document.body.style.overflow = ''; }
      else { fab.setAttribute('aria-expanded', 'false'); (nav as HTMLElement).hidden = true; }
    });
    const els = NAV.map((n) => document.getElementById(n.id)).filter(Boolean) as HTMLElement[];
    if (els[0]) jSetActive(els[0].id);
    const obs = new IntersectionObserver((ents) => {
      const vis = ents.filter((x) => x.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (vis[0]) jSetActive(vis[0].target.id);
    }, { rootMargin: '-30% 0px -50% 0px', threshold: [0, 0.1, 0.3, 0.5, 1] });
    els.forEach((el) => obs.observe(el));
    if (jMobile()) { (fab as HTMLElement).hidden = false; (nav as HTMLElement).hidden = true; }
    else { (nav as HTMLElement).hidden = false; (fab as HTMLElement).hidden = true; }
    window.addEventListener('languageChanged', jRenderList);
  }
  document.addEventListener('DOMContentLoaded', initJumpnav);
</script>
