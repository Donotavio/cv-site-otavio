    box.innerHTML = srcs.map(([label, url]) =>
      `<li><a href="${esc(url)}" target="_blank" rel="noopener noreferrer" class="el-source-link">${esc(label)} <span aria-hidden="true">↗</span></a></li>`
    ).join('');
  }

  let payload: ElPayload | null = null;
  // Isola cada passo de render: uma seção com dado parcial/malformado não pode
  // derrubar as seguintes. Sem isso, uma exceção antes de initExplorar/
  // renderEstaduais/renderPresRegioes deixava o mapa e os filtros sem montar.
  function safe(label: string, fn: () => void): void {
    try { fn(); } catch (e) { console.error(`[eleicoes] render "${label}" falhou:`, e); }
  }
  function renderAll(data: ElPayload): void {
    safe('progress', () => renderProgress(data));
    safe('bento', () => renderBento(data));
    safe('ministats', () => renderMiniStats(data));
    safe('barchart', () => renderBarChart(data));
    safe('ranktable', () => renderRankTable(data));
    safe('origem', () => renderOrigem(data));
    safe('nivel', () => renderNivel(data));
    safe('amostragem', () => renderAmostragem(data));
    safe('uf', () => renderUF(data));
    safe('explorar', () => initExplorar(data));
    safe('precandidatos', () => renderPrecandidatos(precand));
    safe('presregioes', () => renderPresRegioes(presReg));
    safe('estaduais', () => renderEstaduais(estaduais));
    safe('eleitorado', () => renderEleitorado(eleitorado));
    safe('intensidadeuf', () => renderIntensidadeUF(data, eleitorado));
    safe('jogo', () => renderJogo(contexto));
    safe('relogio', () => renderRelogio(contexto));
    safe('integridade', () => renderIntegridade());
    safe('sources', () => renderSources());
  }

  async function fetchJSON<T>(base: string, file: string, ms = 8000): Promise<T | null> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), ms);
    try {
      const res = await fetch(`${base}assets/data/${file}`, { cache: 'no-cache', signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) return null;
      return (await res.json()) as T;
    } catch { clearTimeout(timeoutId); return null; }
  }

  async function loadEleicoes(): Promise<void> {
    // Reset dos guards one-time: astro:page-load recria o DOM a cada navegação
    // SPA (<ClientRouter/>), mas estas flags/refs são de escopo de módulo e
    // sobreviviam entre navegações — ao re-entrar na página, os widgets (mapas
    // de calor + comboboxes) não eram reconstruídos e ficavam vazios. Resetar
    // aqui (só no page-load, não no languageChanged) garante DOM novo → widget
    // novo, sem reconstruir à toa na troca de idioma.
    explorarBuilt = false; ufCb = null; ufMap = null; currentUf = '';
    estBuilt = false; estCb = null; estMap = null; currentEstUf = '';
    presRegBuilt = false; integBuilt = false;
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const [pdata, edata, cdata, prdata, estdata, intdata, fipca, fregdata] = await Promise.all([
      fetchJSON<ElPayload>(base, 'eleicoes_pesquisas.json'),
      fetchJSON<EleitoradoPayload>(base, 'eleicoes_eleitorado.json'),
      fetchJSON<ContextoPayload>(base, 'eleicoes_contexto.json'),
      fetchJSON<PrecandPayload>(base, 'eleicoes_precandidatos.json'),
      fetchJSON<EstaduaisPayload>(base, 'eleicoes_estaduais.json'),
      fetchJSON<IntegridadePayload>(base, 'eleicoes_integridade.json'),
      fetchJSON<FundoIpcaPayload>(base, 'eleicoes_fundo_ipca.json'),
      fetchJSON<PresRegioesPayload>(base, 'eleicoes_presidencial_regioes.json'),
    ]);
    eleitorado = edata;
    contexto = cdata;
    // Companion do deflator IPCA (pipeline reprodutível, fonte BACEN) — funde a
    // correção real no bloco curado do fundo. Ausente → card fica só no nominal.
    if (cdata?.fundo_eleitoral && fipca) {
      Object.assign(cdata.fundo_eleitoral, {
        ref_2018_corrigido_rs: fipca.ref_2018_corrigido_rs,
        multiplo_real: fipca.multiplo_real,
        ipca_acumulado_pct: fipca.ipca_acumulado_pct,
        ipca_ref_ano: fipca.ref_ano,
        ipca_acima_pct: fipca.acima_inflacao_pct,
        ipca_fonte_url: fipca.fonte_url,
      });
    }
    precand = prdata;
    estaduais = estdata;
    integridade = intdata;
    presReg = fregdata;
    if (pdata && pdata.kpis) {
      payload = pdata;
      renderAll(pdata);
    } else {
      ['el-barchart-svg', 'el-uf', 'el-iuf-body'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">dados indisponíveis — tente recarregar</p>'; });
      const body = el('el-rank-body'); if (body) body.innerHTML = '<tr><td colspan="4"><p class="el-error">dados indisponíveis — tente recarregar</p></td></tr>';
      // seções independentes ainda renderizam se vieram (isoladas: uma falha
      // não pode derrubar as demais — sobretudo o mapa/filtro estadual)
      safe('precandidatos', () => renderPrecandidatos(precand));
      safe('presregioes', () => renderPresRegioes(presReg));
      safe('estaduais', () => renderEstaduais(estaduais));
      safe('eleitorado', () => renderEleitorado(eleitorado));
      safe('jogo', () => renderJogo(contexto));
      safe('relogio', () => renderRelogio(contexto));
      safe('integridade', () => renderIntegridade());
      safe('sources', () => renderSources());
    }
  }

  // astro:page-load (não DOMContentLoaded): dispara no 1º load E após cada
  // navegação SPA do <ClientRouter />. O guard #eleicoes-hero evita fetch em
  // outras páginas (o listener no document persiste entre navegações).
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('eleicoes-hero')) return;
    loadEleicoes();
  });
  document.addEventListener('astro:page-load', initBarTips);
  window.addEventListener('languageChanged', () => { if (payload) renderAll(payload); });
</script>

<script>
  // Motion — padrões nomeados (GSAP + ScrollTrigger), guardados por motionOk
  // (respeita prefers-reduced-motion): `resolve` no herói, `reveal-up` por seção
  // (head + cards), `hairline-draw` nas divisórias de seção.
  import { revealUp } from '../scripts/motion/reveal-up';
  import { resolveHero } from '../scripts/motion/resolve';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  function animateEleicoes(): void {
    if (!motionOk) return;
    const heroCard = document.querySelector('#eleicoes-hero .hero-card') as HTMLElement | null;
    if (heroCard) resolveHero(heroCard);
    document.querySelectorAll<HTMLElement>('main section[id^="el-"]').forEach((sec) => {
      const head = sec.querySelector('.section-head') as HTMLElement | null;
      if (head) revealUp([head], sec, 0);
      const line = sec.querySelector('.section-line') as HTMLElement | null;
      if (line && head) hairlineDraw(line, head);
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.el-kpi, .el-ministat, .el-chartcard, .el-rank-wrap, .el-panel, .el-ufchart, .el-elt-hero, .el-jogo-card, .el-fundo, .el-timeline'));
      if (cards.length) revealUp(cards, sec, STAGGER.tight);
    });
  }
  document.addEventListener('astro:page-load', animateEleicoes);
</script>

<script>
  // Jump-nav — rail de pontos (desktop) + FAB/bottom-sheet (mobile). Lê as
  // seções desta página; labels vêm do i18n (re-render em `languageChanged`).
  // Active via IntersectionObserver. Portado do world-cup-dashboard/jumpnav.js.
  const NAV = [
    { id: 'eleicoes-hero',     key: 'portfolio.eleicoes.nav_hero',          fb: 'Início' },
    { id: 'el-panorama',       key: 'portfolio.eleicoes.nav_panorama',      fb: 'Panorama' },
    { id: 'el-intencao',       key: 'portfolio.eleicoes.nav_intencao',      fb: 'Intenção de voto' },
    { id: 'el-estadual',       key: 'portfolio.eleicoes.nav_estadual',      fb: 'Intenção estadual' },
    { id: 'el-eleitorado',     key: 'portfolio.eleicoes.nav_eleitorado',    fb: 'Eleitorado' },
    { id: 'el-intensidade',    key: 'portfolio.eleicoes.nav_intensidade',   fb: 'Intensidade' },
    { id: 'el-intensidade-uf', key: 'portfolio.eleicoes.nav_intensidade_uf', fb: 'Por estado' },
    { id: 'el-institutos',     key: 'portfolio.eleicoes.nav_institutos',    fb: 'Quem mede' },
    { id: 'el-como',           key: 'portfolio.eleicoes.nav_como',          fb: 'Como medem' },
    { id: 'el-cobertura',      key: 'portfolio.eleicoes.nav_cobertura',     fb: 'Cobertura' },
    { id: 'el-explorar',       key: 'portfolio.eleicoes.nav_explorar',      fb: 'Explorar' },
    { id: 'el-jogo',           key: 'portfolio.eleicoes.nav_jogo',          fb: 'Em jogo' },
    { id: 'el-relogio',        key: 'portfolio.eleicoes.nav_relogio',       fb: 'Calendário' },
    { id: 'el-integridade',    key: 'portfolio.eleicoes.nav_integridade',   fb: 'Situação jurídica' },
    { id: 'el-transparencia',  key: 'portfolio.eleicoes.nav_transparencia', fb: 'Transparência' },
  ];
  const jt = (k: string, fb: string): string => {
    const v = (window as unknown as { i18n?: { t?: (k: string) => string } }).i18n?.t?.(k);
    return typeof v === 'string' && v ? v : fb;
  };
  const jesc = (s: string): string => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
  const jReduce = (): boolean => matchMedia('(prefers-reduced-motion: reduce)').matches;
  const jMobile = (): boolean => matchMedia('(max-width: 1023px)').matches;
  let backdrop: HTMLElement | null = null;

  function jRenderList(): void {
    const list = document.getElementById('el-jumpnav-list'); if (!list) return;
    const items = NAV.filter((n) => document.getElementById(n.id));
    list.innerHTML = items.map((n, i) => `
      <li class="el-jumpnav__item">
        <a href="#${n.id}" class="el-jumpnav__link" data-target="${n.id}" aria-current="false">
          <span class="el-jumpnav__label">${jesc(jt(n.key, n.fb))}</span>
          <span class="el-jumpnav__bullet" aria-hidden="true"></span>
          <span class="el-jumpnav__num">${String(i + 1).padStart(2, '0')}</span>
        </a>
      </li>`).join('');
  }
  function jSetActive(id: string): void {
    document.querySelectorAll('.el-jumpnav__link').forEach((l) => {
      const on = (l as HTMLElement).dataset.target === id;
      if (l.getAttribute('aria-current') !== String(on)) l.setAttribute('aria-current', String(on));
    });
  }
  function jEnsureBackdrop(): HTMLElement {
    if (backdrop) return backdrop;
    backdrop = document.createElement('div');
    backdrop.className = 'el-jumpnav-backdrop';
    backdrop.setAttribute('aria-hidden', 'true');
    backdrop.addEventListener('click', jCloseSheet);
    document.body.appendChild(backdrop);
    return backdrop;
  }
  function jOpenSheet(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => jEnsureBackdrop().classList.add('is-visible'));
    document.body.style.overflow = 'hidden';
  }
  function jCloseSheet(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    fab.setAttribute('aria-expanded', 'false');
    backdrop?.classList.remove('is-visible');
    setTimeout(() => { if (fab.getAttribute('aria-expanded') === 'false') (nav as HTMLElement).hidden = true; }, 250);
    document.body.style.overflow = '';
  }
  function initJumpnav(): void {
    const nav = document.getElementById('el-jumpnav'), fab = document.getElementById('el-jumpnav-fab');
    if (!nav || !fab) return;
    jRenderList();
    document.getElementById('el-jumpnav-list')!.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.el-jumpnav__link') as HTMLElement | null;
      if (!link) return;
      e.preventDefault();
      const id = link.dataset.target!; const target = document.getElementById(id); if (!target) return;
      const go = () => { target.scrollIntoView({ behavior: jReduce() ? 'auto' : 'smooth', block: 'start' }); history.replaceState(null, '', '#' + id); };
      if (jMobile() && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); setTimeout(go, jReduce() ? 0 : 260); } else go();
      jSetActive(id);
    });
    fab.addEventListener('click', () => (fab.getAttribute('aria-expanded') === 'true' ? jCloseSheet() : jOpenSheet()));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && fab.getAttribute('aria-expanded') === 'true') { jCloseSheet(); fab.focus(); } });
    matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) { (nav as HTMLElement).hidden = false; fab.setAttribute('aria-expanded', 'false'); backdrop?.classList.remove('is-visible'); document.body.style.overflow = ''; }
      else { fab.setAttribute('aria-expanded', 'false'); (nav as HTMLElement).hidden = true; }
    });
    const els = NAV.map((n) => document.getElementById(n.id)).filter(Boolean) as HTMLElement[];
    if (els[0]) jSetActive(els[0].id);
    const obs = new IntersectionObserver((ents) => {
      const vis = ents.filter((x) => x.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (vis[0]) jSetActive(vis[0].target.id);
    }, { rootMargin: '-30% 0px -50% 0px', threshold: [0, 0.1, 0.3, 0.5, 1] });
    els.forEach((el) => obs.observe(el));
    if (jMobile()) { (fab as HTMLElement).hidden = false; (nav as HTMLElement).hidden = true; }
    else { (nav as HTMLElement).hidden = false; (fab as HTMLElement).hidden = true; }
    window.addEventListener('languageChanged', jRenderList);
  }
  document.addEventListener('astro:page-load', initJumpnav);
</script>
