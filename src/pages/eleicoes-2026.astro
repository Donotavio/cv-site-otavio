---
/**
 * eleicoes-2026.astro — Observatório Eleições 2026
 * Direção: Blueprint (DESIGN.md) — mesmo nível de apresentação de
 * pix-observatory.astro / data-stack-radar-br.astro / world-cup-dashboard.
 *
 * Ângulo: a *máquina de medição* da eleição. O dataset oficial do TSE
 * (Pesquisas Eleitorais 2026) é de REGISTRO — traz metadados (instituto,
 * cargo, UF, amostra, custo, datas), não os percentuais de intenção de voto.
 * Apartidário por construção: mede quem mede o eleitorado. Cor: monocromático
 * (--ink) para os dados + --wc-gold-* para líder/estrela (sem cor partidária).
 *
 * Seções (mono-labels [01]…[11]):
 *  0. Header + Hero + faixa de progresso (contagem para 4/out)
 *  1. [01] Panorama — bento de KPIs + mini-stats (inclui custo médio + concentração)
 *  2. [02] O eleitorado — perfil real do Cadastro (sexo/faixa/escolaridade/biometria)
 *  3. [03] Intensidade — barras: pesquisas por mês (rampa)
 *  4. [04] Intensidade real por UF — índice = pesquisas ÷ eleitores (por milhão)
 *  5. [05] Quem mede — tabela ranqueada de institutos (medalha no líder)
 *  6. [06] Como medem — donut (própria×contratada) + nível + amostra
 *  7. [07] Cobertura — ranking horizontal por UF (contagem bruta)
 *  8. [08] Explorar por estado — combobox acessível + recorte por UF
 *  9. [09] O que está em jogo — cargos em disputa + Fundo Eleitoral
 * 10. [10] Relógio da democracia — marcos do calendário eleitoral
 * 11. [11] Transparência & fontes — o que temos / o que não temos
 *
 * Dados reais (fetch runtime, zero LLM):
 *   assets/data/eleicoes_pesquisas.json   ← ingestion_eleicoes → gold_eleicoes.py
 *   assets/data/eleicoes_eleitorado.json  ← collect_eleitorado → gold_eleitorado.py
 *   assets/data/eleicoes_contexto.json    ← curadoria de fontes oficiais (cited)
 * i18n: data-i18n-key estático + window.i18n.t() nos rótulos dinâmicos.
 * Motion: padrão nomeado `reveal-up` (motionOk). Breakpoints mobile-first.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Observatório Eleições 2026 — Otávio Ribeiro"
  description="A máquina de medição da eleição de 2026: pipeline sobre o dataset oficial do TSE (Pesquisas Eleitorais), quem mede o eleitorado, onde, com que rigor amostral e a que custo."
>
  <Header />

  <main id="main-content">

    <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
    <section id="eleicoes-hero" class="section el-hero" aria-labelledby="el-hero-title">
      <div class="container">
        <div class="hero-card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="hero-card__header">
            <span class="mono-label" data-i18n-key="portfolio.eleicoes.hero_label">Observatório Eleições 2026</span>
            <span class="mono-label el-badge" id="el-updated" aria-live="polite">
              <span class="el-badge__dot" aria-hidden="true"></span>
              <span data-i18n-key="portfolio.eleicoes.updated_label">atualizado</span> · <span id="el-updated-date">···</span>
            </span>
          </header>

          <h1 id="el-hero-title" class="hero-display" data-i18n-key="portfolio.eleicoes.hero_title">
            Quem está medindo o Brasil antes de 4 de outubro?
          </h1>

          <p class="hero-lead" data-i18n-key="portfolio.eleicoes.hero_lead">
            Toda pesquisa eleitoral precisa ser registrada no TSE. Este observatório
            lê esse registro oficial e mostra a <em>máquina de medição</em> da eleição —
            quem mede, onde, com que rigor amostral e a que custo. Sem palpite de quem
            ganha: os percentuais não estão no registro, só os metadados.
          </p>

          <!-- Faixa de progresso — contagem para o 1º turno -->
          <div class="el-progress" role="region" aria-label="Contagem para a eleição">
            <div class="el-progress__head">
              <span class="el-progress__phase mono-label" id="el-prog-phase" data-i18n-key="portfolio.eleicoes.prog_phase">rumo ao 1º turno</span>
              <span class="el-progress__pct" id="el-prog-pct">···</span>
            </div>
            <div class="el-progress__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
                 aria-label="Progresso rumo ao 1º turno" data-i18n-aria="portfolio.eleicoes.prog_aria">
              <div class="el-progress__fill" id="el-prog-fill" style="width:0%"></div>
            </div>
            <div class="el-progress__meta">
              <span id="el-prog-remaining">···</span>
              <span class="el-progress__sep" aria-hidden="true">·</span>
              <span id="el-prog-next">04/10/2026</span>
            </div>
          </div>

          <div class="hero-actions">
            <a href="#el-panorama" class="btn-primary" data-i18n-key="portfolio.eleicoes.cta_dados">Ver os dados</a>
            <a
              href="https://dadosabertos.tse.jus.br/dataset/pesquisas-eleitorais-2026"
              class="btn-secondary" target="_blank" rel="noopener noreferrer"
              data-i18n-key="portfolio.eleicoes.cta_fonte"
            >Fonte (TSE)</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ [01] PANORAMA (bento) ═══════════════════════ -->
    <section id="el-panorama" class="section el-alt" aria-labelledby="el-kpis-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">01</span>
          <h2 id="el-kpis-title" class="el-h2" data-i18n-key="portfolio.eleicoes.kpis_title">O tamanho da operação</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.kpis_lead">
            Pesquisas registradas no TSE para o pleito de 2026 — Python · pandas · Parquet.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="el-bento" role="list" aria-label="Métricas das pesquisas">
          <article class="el-kpi el-kpi--hero crop" role="listitem">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="el-kpi__head">
              <span class="mono-label" aria-hidden="true">01</span>
              <span class="el-kpi__spark" aria-hidden="true">▁▂▃▅▆▇█</span>
            </header>
            <div>
              <span class="el-kpi__value el-kpi__value--hero" id="kpi-total">···</span>
              <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_total">pesquisas registradas</span>
            </div>
          </article>

          <article class="el-kpi crop" role="listitem">
            <header class="el-kpi__head"><span class="mono-label" aria-hidden="true">02</span></header>
            <div>
              <span class="el-kpi__value" id="kpi-institutos">···</span>
              <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_institutos">institutos distintos</span>
            </div>
          </article>

          <article class="el-kpi crop" role="listitem">
            <header class="el-kpi__head"><span class="mono-label" aria-hidden="true">03</span></header>
            <div>
              <span class="el-kpi__value" id="kpi-investimento">···</span>
              <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_investimento">investimento declarado</span>
            </div>
          </article>

          <article class="el-kpi el-kpi--star crop" role="listitem">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <header class="el-kpi__head">
              <span class="mono-label" aria-hidden="true">04</span>
              <span class="el-kpi__badge" data-i18n-key="portfolio.eleicoes.star_badge">instituto mais ativo</span>
            </header>
            <div class="el-kpi__star">
              <span class="el-kpi__value el-kpi__value--star" id="kpi-star-name">···</span>
              <span class="el-kpi__label" id="kpi-star-meta"></span>
            </div>
          </article>
        </div>

        <!-- mini-stats -->
        <div class="el-ministats" role="list">
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_amostra_max">maior amostra</span>
            <span class="el-ministat__value" id="mini-amostra">···</span>
          </div>
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_amostra_med">amostra mediana</span>
            <span class="el-ministat__value" id="mini-mediana">···</span>
          </div>
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_cara">pesquisa mais cara</span>
            <span class="el-ministat__value" id="mini-cara">···</span>
          </div>
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_pico">mês de pico</span>
            <span class="el-ministat__value" id="mini-pico">···</span>
          </div>
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_custo">custo médio / pesquisa</span>
            <span class="el-ministat__value" id="mini-custo">···</span>
          </div>
          <div class="el-ministat" role="listitem">
            <span class="el-ministat__label mono-label" data-i18n-key="portfolio.eleicoes.mini_conc">top-5 dos institutos</span>
            <span class="el-ministat__value" id="mini-conc">···</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ [02] INTENÇÃO DE VOTO (presidência) ═══════════════════════ -->
    <section id="el-intencao" class="section" aria-labelledby="el-vote-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">02</span>
          <h2 id="el-vote-title" class="el-h2" data-i18n-key="portfolio.eleicoes.vote_title">Intenção de voto — presidência</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.vote_lead">
            O que as pesquisas medem para o Planalto — agregado de institutos registrados no TSE (via Wikipedia). Cada número traz instituto, data e margem. É medição, não previsão.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="el-vote-grid">
          <article class="el-panel crop" aria-labelledby="el-vote-1t-t">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="el-panel__title mono-label" id="el-vote-1t-t" data-i18n-key="portfolio.eleicoes.vote_1t">1º turno · média recente</span>
            <div id="el-vote-1t" class="el-vote-bars"><p class="el-loading mono-label">···</p></div>
            <p class="el-vote-ref mono-label" id="el-vote-1t-ref"></p>
          </article>
          <article class="el-panel crop" aria-labelledby="el-vote-2t-t">
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="el-panel__title mono-label" id="el-vote-2t-t" data-i18n-key="portfolio.eleicoes.vote_2t">2º turno · confronto mais recente</span>
            <div id="el-vote-2t" class="el-vote-duels"><p class="el-loading mono-label">···</p></div>
          </article>
        </div>

        <div class="el-vote-panorama">
          <span class="el-panel__title mono-label" data-i18n-key="portfolio.eleicoes.vote_panorama">quem já se colocou</span>
          <div id="el-vote-chips" class="el-vote-chips"></div>
        </div>

        <p class="el-nota mono-label" data-i18n-key="portfolio.eleicoes.vote_nota">
          Fonte: Wikipedia — agregação de pesquisas registradas no TSE. O destaque do líder (em dourado) é só visual, sem cor partidária. Escopo v1: presidência.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════ [03] INTENÇÃO ESTADUAL (governador + senador) ═══════════════════════ -->
    <section id="el-estadual" class="section el-alt" aria-labelledby="el-est-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">03</span>
          <h2 id="el-est-title" class="el-h2" data-i18n-key="portfolio.eleicoes.est_title">Intenção de voto nos estados</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.est_lead">
            Governador e senador por UF — mesmo agregado de institutos (via Wikipedia), com instituto, data e margem à vista. Escolha um estado.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="el-est-wrap">
          <div class="el-explorar__control el-est-ctl">
            <label class="el-explorar__caption mono-label" for="el-est-input" data-i18n-key="portfolio.eleicoes.est_pick">estado</label>
            <div class="el-combobox" id="el-est-combobox">
              <input type="text" id="el-est-input" class="el-combobox__input" role="combobox"
                     aria-expanded="false" aria-autocomplete="list" aria-controls="el-est-listbox"
                     placeholder="Buscar estado…" data-i18n-attr="placeholder:portfolio.eleicoes.uf_search"
                     autocomplete="off" spellcheck="false" />
              <button type="button" class="el-combobox__btn" tabindex="-1" aria-label="Abrir lista de estados"
                      data-i18n-aria="portfolio.eleicoes.uf_open"><span aria-hidden="true">▾</span></button>
              <ul id="el-est-listbox" class="el-combobox__list" role="listbox" aria-label="Estados" hidden></ul>
            </div>
          </div>

          <div class="el-est-panels" id="el-est-panels" aria-live="polite">
            <article class="el-panel crop" aria-labelledby="el-est-gov-t">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="el-panel__title mono-label" id="el-est-gov-t" data-i18n-key="portfolio.eleicoes.est_gov_1t">governador · 1º turno</span>
              <div id="el-est-gov1" class="el-vote-bars"><p class="el-loading mono-label">selecione um estado…</p></div>
              <p class="el-vote-ref mono-label" id="el-est-gov1-ref"></p>
            </article>
            <article class="el-panel crop" aria-labelledby="el-est-gov2-t">
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="el-panel__title mono-label" id="el-est-gov2-t" data-i18n-key="portfolio.eleicoes.est_gov_2t">governador · 2º turno</span>
              <div id="el-est-gov2" class="el-vote-duels"><p class="el-loading mono-label">···</p></div>
            </article>
            <article class="el-panel crop" aria-labelledby="el-est-sen-t">
              <span class="crop-mark-bl" aria-hidden="true"></span>
              <span class="crop-mark-br" aria-hidden="true"></span>
              <span class="el-panel__title mono-label" id="el-est-sen-t" data-i18n-key="portfolio.eleicoes.est_sen">senador</span>
              <div id="el-est-sen" class="el-vote-bars"><p class="el-loading mono-label">···</p></div>
              <p class="el-vote-ref mono-label" id="el-est-sen-ref"></p>
            </article>
          </div>
        </div>

        <p class="el-nota mono-label" data-i18n-key="portfolio.eleicoes.est_nota">
          Fonte: Wikipedia — pesquisas estaduais registradas no TSE. Em 2026 cada estado renova 2 das 3 cadeiras do Senado. Sem cor partidária; líder é destaque visual. DF, MS e MT ainda sem artigo na fonte.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════ [04] O ELEITORADO ═══════════════════════ -->
    <section id="el-eleitorado" class="section" aria-labelledby="el-elt-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">04</span>
          <h2 id="el-elt-title" class="el-h2" data-i18n-key="portfolio.eleicoes.elt_title">Quem é o eleitorado</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.elt_lead">
            O corpo que os institutos tentam medir — perfil real do Cadastro Nacional de Eleitores (TSE), agregado de 11 milhões de linhas por seção.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="el-elt-bento">
          <article class="el-elt-hero crop" aria-labelledby="el-elt-total">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.elt_total_label">eleitores aptos a votar</span>
            <span class="el-elt-total" id="el-elt-total">···</span>
            <div class="el-elt-chips" id="el-elt-chips"></div>
          </article>
          <article class="el-panel crop" aria-labelledby="el-elt-genero-t">
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="el-panel__title mono-label" id="el-elt-genero-t" data-i18n-key="portfolio.eleicoes.elt_genero">por sexo</span>
            <div id="el-elt-genero" class="el-split"><p class="el-loading mono-label">···</p></div>
          </article>
          <article class="el-panel crop" aria-labelledby="el-elt-faixa-t">
            <span class="el-panel__title mono-label" id="el-elt-faixa-t" data-i18n-key="portfolio.eleicoes.elt_faixa">por faixa etária</span>
            <div id="el-elt-faixa" class="el-bars"><p class="el-loading mono-label">···</p></div>
          </article>
          <article class="el-panel crop" aria-labelledby="el-elt-escol-t">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="el-panel__title mono-label" id="el-elt-escol-t" data-i18n-key="portfolio.eleicoes.elt_escol">por escolaridade</span>
            <div id="el-elt-escol" class="el-bars"><p class="el-loading mono-label">···</p></div>
          </article>
        </div>
        <p class="el-nota mono-label" data-i18n-key="portfolio.eleicoes.elt_nota">
          Fonte: TSE — Estatísticas de Eleitorado (snapshot atual). Números facultativos: voto é opcional para 16–17 anos, 70+ e analfabetos.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════ [05] INTENSIDADE (bar chart) ═══════════════════════ -->
    <section id="el-intensidade" class="section el-alt" aria-labelledby="el-int-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">05</span>
          <h2 id="el-int-title" class="el-h2" data-i18n-key="portfolio.eleicoes.timeline_title">A rampa das pesquisas</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.timeline_lead">
            Pesquisas divulgadas por mês. A intensidade acelera conforme a eleição se aproxima.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <figure class="el-chartcard crop" id="el-barchart" aria-label="Pesquisas por mês">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <div class="el-chartcard__head">
            <span class="mono-label" data-i18n-key="portfolio.eleicoes.chart_mes">[ pesquisas por mês de divulgação ]</span>
          </div>
          <div class="el-barchart__svg" id="el-barchart-svg"><p class="el-loading mono-label">carregando série…</p></div>
        </figure>
      </div>
    </section>

    <!-- ═══════════════ [06] INTENSIDADE REAL POR UF (índice normalizado) ═══════════════ -->
    <section id="el-intensidade-uf" class="section" aria-labelledby="el-iuf-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">06</span>
          <h2 id="el-iuf-title" class="el-h2" data-i18n-key="portfolio.eleicoes.iuf_title">Onde a disputa está quente de verdade</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.iuf_lead">
            Contagem bruta favorece estados grandes. Aqui, pesquisas por milhão de eleitores — cruzando o registro do TSE com o Cadastro de Eleitores. Revela onde se mede com mais intensidade, independentemente do tamanho.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <figure class="el-ufchart crop" id="el-iuf" aria-label="Intensidade de pesquisas por milhão de eleitores, por estado">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <div class="el-chartcard__head">
            <span class="mono-label" data-i18n-key="portfolio.eleicoes.iuf_axis">[ pesquisas estaduais por milhão de eleitores ]</span>
          </div>
          <div id="el-iuf-body"><p class="el-loading mono-label">carregando índice…</p></div>
        </figure>
        <p class="el-nota mono-label" data-i18n-key="portfolio.eleicoes.iuf_nota">
          Índice = pesquisas estaduais registradas ÷ eleitores do estado (em milhões). Exclui a disputa nacional/presidencial.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════ [07] QUEM MEDE (tabela) ═══════════════════════ -->
    <section id="el-institutos" class="section el-alt" aria-labelledby="el-inst-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">07</span>
          <h2 id="el-inst-title" class="el-h2" data-i18n-key="portfolio.eleicoes.institutos_title">Quem mede o eleitorado</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.institutos_lead">
            Institutos por volume de pesquisas registradas e investimento declarado (R$). Mercado pulverizado — o líder detém <span id="el-conc-inline">···</span> do total.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <div class="el-rank-wrap crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <table class="el-rank-table" aria-labelledby="el-inst-title">
            <thead>
              <tr>
                <th class="el-rank-table__rank">#</th>
                <th data-i18n-key="portfolio.eleicoes.th_instituto">Instituto</th>
