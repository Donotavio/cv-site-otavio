  // ── [12] Relógio da democracia (calendário) — timeline com marcador "HOJE",
  //    contagem relativa por marco e destaque dos turnos. Spine dourado até hoje. ──
  function renderRelogio(c: ContextoPayload | null): void {
    const box = el('el-timeline'); if (!box) return;
    const cal = c?.calendario ?? [];
    if (!cal.length) { box.innerHTML = '<li class="el-error">calendário indisponível</li>'; return; }
    const now = Date.now(), DAY = 86_400_000;
    const items = cal.map((m) => ({ ...m, ts: Date.parse(m.data + 'T00:00:00-03:00') })).sort((a, b) => a.ts - b.ts);
    const rel = (ts: number): string => {
      const d = Math.round((ts - now) / DAY);
      if (d === 0) return t('portfolio.eleicoes.rel_hoje', 'hoje');
      if (d < 0) return t('portfolio.eleicoes.rel_done', 'concluído');
      return `${t('portfolio.eleicoes.rel_em', 'em')} ${d} ${d === 1 ? t('portfolio.eleicoes.rel_dia', 'dia') : t('portfolio.eleicoes.rel_dias', 'dias')}`;
    };
    const rows = items.map((it) => {
      const past = it.ts < now, isKey = /turno/i.test(it.marco);
      return `<li class="el-tl-item${past ? ' is-past' : ''}${isKey ? ' is-key' : ''}">
        <span class="el-tl-dot" aria-hidden="true"></span>
        <time class="el-tl-date mono-label" datetime="${esc(it.data)}">${esc(fmtDate(it.data))}</time>
        <span class="el-tl-marco">${esc(it.marco)}</span>
        <span class="el-tl-rel mono-label${past ? ' is-done' : ''}">${esc(rel(it.ts))}</span>
      </li>`;
    });
    const td = new Date(now);
    const nowISO = `${td.getFullYear()}-${String(td.getMonth() + 1).padStart(2, '0')}-${String(td.getDate()).padStart(2, '0')}`;
    const nowMarker = `<li class="el-tl-item el-tl-now" aria-current="date">
      <span class="el-tl-dot" aria-hidden="true"></span>
      <time class="el-tl-date mono-label" datetime="${esc(nowISO)}">${esc(fmtDate(nowISO))}</time>
      <span class="el-tl-marco">${esc(t('portfolio.eleicoes.rel_hoje', 'hoje').toUpperCase())}</span>
    </li>`;
    const idx = items.findIndex((it) => it.ts > now);
    box.innerHTML = (idx < 0 ? [...rows, nowMarker] : [...rows.slice(0, idx), nowMarker, ...rows.slice(idx)]).join('');
  }

  // ── [13] Situação jurídica dos pré-candidatos (integridade) ──
  let integridade: IntegridadePayload | null = null;
  let integBuilt = false;
  let integCb: { setValue(v: string): void } | null = null;
  let currentInteg = 'PR';
  function integCandidatos(scope: string): { nome: string; partido: string }[] {
    const src = scope === 'PR'
      ? (precand?.primeiro_turno?.candidatos ?? [])
      : (estaduais?.estados?.[scope]?.governador_1t?.candidatos ?? []);
    return src.map((c) => ({ nome: c.nome, partido: c.partido }));
  }
  function renderIntegCards(scope: string): void {
    currentInteg = scope;
    const box = el('el-integ-cards'); if (!box) return;
    const cands = integCandidatos(scope);
    if (!cands.length) { box.innerHTML = `<p class="el-error mono-label">${esc(t('portfolio.eleicoes.integ_empty_scope', 'sem pré-candidatos neste recorte'))}</p>`; return; }
    const itensMap = integridade?.itens_por_candidato ?? {};
    const estLabel = (id: string): string => (integridade?.estagios ?? []).find((e) => e.id === id)?.label ?? id;
    const consulta = (integridade?.fontes ?? []).map((f) => `<a class="el-integ-src" href="${esc(f.url)}" target="_blank" rel="noopener noreferrer">${esc(f.label)} <span aria-hidden="true">↗</span></a>`).join('');
    box.innerHTML = cands.map((c) => {
      const itens = itensMap[c.nome] ?? [];
      const body = itens.length
        ? `<ul class="el-integ-itens">${itens.map((it) => `<li class="el-integ-item"><span class="el-integ-stage" data-stage="${esc(it.estagio)}">${esc(estLabel(it.estagio))}</span><span class="el-integ-desc">${esc(it.descricao)}${it.orgao ? ` <span class="mono-label">${esc(it.orgao)}</span>` : ''}</span>${it.fonte_url ? `<a class="el-integ-srclink mono-label" href="${esc(it.fonte_url)}" target="_blank" rel="noopener noreferrer">${esc(it.fonte || t('portfolio.eleicoes.integ_fonte', 'fonte'))} ↗</a>` : ''}</li>`).join('')}</ul>`
        : `<p class="el-integ-none mono-label">${esc(t('portfolio.eleicoes.integ_none', 'sem registros nesta base — consulte as fontes oficiais'))}</p>`;
      return `<article class="el-integ-card crop">
        <span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>
        <header class="el-integ-head"><span class="el-integ-name">${esc(c.nome)}</span> <span class="el-integ-party mono-label">${esc(c.partido)}</span></header>
        ${body}
        <div class="el-integ-consulta">${consulta}</div>
      </article>`;
    }).join('');
  }
  function renderIntegridade(): void {
    const legend = el('el-integ-legend'); const nota = el('el-integ-nota');
    if (legend) legend.innerHTML = (integridade?.estagios ?? []).map((e) => `<span class="el-integ-lg" data-stage="${esc(e.id)}">${esc(e.label)}</span>`).join('');
    if (nota) nota.textContent = `${integridade?.metodologia ?? ''} ${integridade?.disclaimer ?? ''}`.trim();
    if (!integBuilt) {
      const ufs = estaduais?.ufs_disponiveis ?? [];
      const items = [{ value: 'PR', label: t('portfolio.eleicoes.integ_presidencia', 'Presidência (federal)') }, ...ufs.map((u) => ({ value: u, label: `${UF_NAME[u] ?? u} (${u})` }))];
      const selectInteg = (v: string): void => { renderIntegCards(v); integCb?.setValue(v); };
      integCb = buildCombobox('el-integ-combobox', items, selectInteg) ?? null;
      selectInteg('PR');
      integBuilt = true;
    } else {
      renderIntegCards(currentInteg);
    }
  }

  // ── [14] Fontes ──
  function renderSources(): void {
    const box = el('el-sources'); if (!box) return;
    const srcs: [string, string][] = [
      [t('portfolio.eleicoes.src_pesquisas', 'Pesquisas Eleitorais 2026 — TSE Dados Abertos'), 'https://dadosabertos.tse.jus.br/dataset/pesquisas-eleitorais-2026'],
      [t('portfolio.eleicoes.src_eleitorado', 'Estatísticas de Eleitorado — TSE'), 'https://dadosabertos.tse.jus.br/dataset/eleitorado-atual'],
    ];
    if (precand?.fonte_url) srcs.push([t('portfolio.eleicoes.src_precand', 'Pesquisas presidenciais 2026 — Wikipedia (agrega TSE)'), precand.fonte_url]);
    if (estaduais?.ufs_disponiveis?.length) srcs.push([t('portfolio.eleicoes.src_estaduais', 'Pesquisas estaduais 2026 — Wikipedia (agrega TSE)'), 'https://pt.wikipedia.org/wiki/Categoria:Pesquisas_eleitorais_para_as_elei%C3%A7%C3%B5es_estaduais_no_Brasil_em_2026']);
    if (contexto?.calendario_fonte_url) srcs.push([t('portfolio.eleicoes.src_calendario', 'Calendário Eleitoral 2026 — TSE'), contexto.calendario_fonte_url]);
    if (presReg?.fonte_url) srcs.push([presReg.fonte || t('portfolio.eleicoes.src_pres_reg', 'Presidencial por região — Genial/Quaest'), presReg.fonte_url]);
