      [t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), nf.format(a.n)],
      [t('portfolio.eleicoes.tip_percentual', 'percentual'), `${total ? ((a.n / total) * 100).toLocaleString('pt-BR', { maximumFractionDigits: 1 }) : '0'}%`],
    ])}>
      <span class="el-bar-lbl">${esc(a.faixa)}</span>
      <span class="el-bar-track"><span class="el-bar-fill" style="width:${(a.n / max) * 100}%"></span></span>
      <span class="el-bar-n">${nf.format(a.n)}</span>
    </div>`).join('');
