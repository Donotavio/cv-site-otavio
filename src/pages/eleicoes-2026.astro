  :global(.el-jumpnav__label) { display: inline-block; opacity: 0; transform: translateX(8px); transition: opacity .2s ease-out, transform .2s ease-out; pointer-events: none; padding: 2px var(--space-2); background: var(--paper-card); border-radius: var(--radius-sm); white-space: nowrap; box-shadow: 0 1px 2px rgba(10,10,10,.04); }
  :global(.el-jumpnav__bullet) { display: block; width: var(--jn-bullet); height: var(--jn-bullet); border-radius: 50%; background: var(--paper-card); border: 1.5px solid var(--jn-ink); flex-shrink: 0; transition: all .25s cubic-bezier(.16,1,.3,1); }
