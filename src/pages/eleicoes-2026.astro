  :global(.el-jumpnav-fab__icon span) { display: block; height: 2px; background: currentColor; border-radius: 1px; }
  :global(.el-jumpnav-fab__icon span:nth-child(2)) { width: 70%; align-self: flex-end; }
  :global(.el-jumpnav-fab[aria-expanded="true"]) { border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(1)) { transform: translateY(5px) rotate(45deg); transition: transform .2s ease-out; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(2)) { opacity: 0; }
  :global(.el-jumpnav-fab[aria-expanded="true"] .el-jumpnav-fab__icon span:nth-child(3)) { transform: translateY(-5px) rotate(-45deg); transition: transform .2s ease-out; }
  :global(.el-jumpnav) { position: fixed; right: var(--space-5); top: 50%; transform: translateY(-50%); display: none; z-index: 35; }
  :global(.el-jumpnav__list) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; position: relative; }
  :global(.el-jumpnav__list::before) { content: ""; position: absolute; left: 50%; top: 5px; bottom: 5px; width: 1px; background: var(--jn-rail-color); transform: translateX(-50%); z-index: 0; }
  :global(.el-jumpnav__item) { position: relative; display: flex; align-items: center; justify-content: flex-end; gap: var(--space-3); margin: var(--space-2) 0; z-index: 1; }
  :global(.el-jumpnav__link) { display: flex; align-items: center; gap: var(--space-3); text-decoration: none; color: var(--jn-ink); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: .02em; padding: 4px 0; cursor: pointer; background: transparent; border: 0; outline-offset: 4px; transition: color .2s ease-out; }
  :global(.el-jumpnav__label) { display: inline-block; opacity: 0; transform: translateX(8px); transition: opacity .2s ease-out, transform .2s ease-out; pointer-events: none; padding: 2px var(--space-2); background: var(--paper-card); border-radius: var(--radius-sm); white-space: nowrap; box-shadow: 0 1px 2px rgba(10,10,10,.04); }
  :global(.el-jumpnav__bullet) { display: block; width: var(--jn-bullet); height: var(--jn-bullet); border-radius: 50%; background: var(--paper-card); border: 1.5px solid var(--jn-ink); flex-shrink: 0; transition: all .25s cubic-bezier(.16,1,.3,1); }
  :global(.el-jumpnav__link:hover .el-jumpnav__label), :global(.el-jumpnav__link:focus-visible .el-jumpnav__label) { opacity: 1; transform: translateX(0); }
  :global(.el-jumpnav__link:hover .el-jumpnav__bullet) { border-color: var(--jn-fill); background: var(--jn-fill); transform: scale(1.2); }
  :global(.el-jumpnav__link[aria-current="true"]) { color: var(--jn-ink-active); }
  :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__bullet) { width: var(--jn-bullet-active); height: 8px; border-radius: 999px; border-color: var(--jn-fill); background: var(--jn-fill); }
  :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__label) { opacity: 1; transform: translateX(0); font-weight: 600; }
  :global(.el-jumpnav__num) { display: none; font-variant-numeric: tabular-nums; opacity: .5; min-width: 1.5em; }
  @media (min-width: 1024px) { :global(.el-jumpnav) { display: block; } :global(.el-jumpnav-fab) { display: none; } }
  @media (max-width: 1023px) {
    :global(.el-jumpnav-fab) { display: inline-flex; }
    :global(.el-jumpnav) { position: fixed; inset: auto 0 0 0; top: auto; transform: none; background: var(--paper-card); border-top: 1px solid var(--line); border-radius: var(--radius-lg) var(--radius-lg) 0 0; padding: var(--space-4) var(--space-4) var(--space-6); box-shadow: 0 -8px 32px rgba(10,10,10,.12); max-height: 70vh; overflow-y: auto; z-index: 39; }
    :global(.el-jumpnav[hidden]) { display: none; }
    :global(.el-jumpnav__list::before) { display: none; }
    :global(.el-jumpnav__item) { justify-content: flex-start; border-bottom: 1px solid var(--line); }
    :global(.el-jumpnav__item:last-child) { border-bottom: 0; }
    :global(.el-jumpnav__link) { width: 100%; padding: var(--space-3) var(--space-2); font-size: var(--text-sm); }
    :global(.el-jumpnav__label) { opacity: 1; transform: none; box-shadow: none; background: transparent; padding: 0; flex: 1; text-align: left; }
    :global(.el-jumpnav__num) { display: inline-block; font-family: var(--font-mono); color: var(--jn-ink); margin-right: var(--space-3); }
    :global(.el-jumpnav__bullet) { display: none; }
    :global(.el-jumpnav__link[aria-current="true"]) { background: var(--wc-gold-dim); color: var(--jn-ink-active); border-radius: var(--radius-sm); }
    :global(.el-jumpnav__link[aria-current="true"] .el-jumpnav__num) { color: var(--jn-fill); opacity: 1; font-weight: 700; }
  }
  :global(.el-jumpnav-backdrop) { position: fixed; inset: 0; background: rgba(10,10,10,.32); z-index: 38; opacity: 0; pointer-events: none; transition: opacity .25s ease-out; }
  :global(.el-jumpnav-backdrop.is-visible) { opacity: 1; pointer-events: auto; }
  @media (prefers-reduced-motion: reduce) {
    :global(.el-jumpnav__bullet), :global(.el-jumpnav__label), :global(.el-jumpnav-fab), :global(.el-jumpnav-fab__icon span), :global(.el-jumpnav-backdrop) { transition: none !important; }
  }

  /* ── [02] O eleitorado ── */
  .el-elt-bento { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 640px)  { .el-elt-bento { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); } }
  @media (min-width: 1024px) { .el-elt-bento { grid-template-columns: repeat(3, 1fr); grid-auto-rows: minmax(150px, auto); } .el-elt-hero { grid-column: 1 / 2; grid-row: 1 / 3; } }
  .el-elt-hero { position: relative; background: linear-gradient(180deg, var(--paper-card) 0%, var(--wc-gold-dim) 100%); border: 1px solid var(--wc-gold-line); border-radius: var(--radius-md); padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-3); }
  .el-elt-total { font-family: var(--font-display); font-size: var(--display-2); font-weight: 400; color: var(--wc-gold-ink); line-height: .9; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  .el-elt-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .el-chip { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-full); }

  /* ── [09] O que está em jogo ── */
  .el-jogo-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 1024px) { .el-jogo-grid { grid-template-columns: repeat(4, 1fr); } }
  /* Cards injetados via JS → :global() sob a section estática #el-jogo */
  #el-jogo :global(.el-jogo-card) { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; justify-content: flex-start; gap: var(--space-1); transition: border-color var(--transition-normal); }
  #el-jogo :global(.el-jogo-card:hover) { border-color: var(--line-strong); }
  #el-jogo :global(.el-jogo-card--partial) { border-color: var(--wc-gold-line); }
  #el-jogo :global(.el-jogo-num) { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 400; color: var(--ink); line-height: .95; letter-spacing: var(--tracking-tight); font-variant-numeric: var(--num-tabular); }
  #el-jogo :global(.el-jogo-label) { font-family: var(--font-sans); font-size: var(--text-sm); color: var(--ink-soft); }
  #el-jogo :global(.el-jogo-sub) { color: var(--ink-faint); margin-top: var(--space-1); }
  #el-jogo :global(.el-jogo-renov) { display: flex; flex-direction: column; gap: var(--space-2); margin-top: auto; padding-top: var(--space-4); }
  #el-jogo :global(.el-jogo-renov__track) { height: 6px; background: var(--line); border-radius: var(--radius-full); overflow: hidden; }
  #el-jogo :global(.el-jogo-renov__fill) { display: block; height: 100%; background: var(--ink-soft); border-radius: var(--radius-full); }
  #el-jogo :global(.el-jogo-renov__fill.is-partial) { background: var(--wc-gold-ink); }
  #el-jogo :global(.el-jogo-renov__pct) { color: var(--ink-faint); }

  .el-fundo { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-8); margin-top: var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-8); }
  @media (min-width: 768px) { .el-fundo { grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); align-items: start; } }
  #el-jogo :global(.el-fundo__main) { display: flex; flex-direction: column; gap: var(--space-3); }
  #el-jogo :global(.el-fundo__val) { color: var(--wc-gold-ink); font-size: var(--display-2); line-height: .9; }
  #el-jogo :global(.el-fundo__compare) { display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-4); }
  #el-jogo :global(.el-fundo__cmp) { display: grid; grid-template-columns: 3.5rem 1fr auto; align-items: center; gap: var(--space-3); }
  #el-jogo :global(.el-fundo__cmp-yr) { color: var(--ink-faint); }
  #el-jogo :global(.el-fundo__cmp-track) { height: 10px; background: var(--line); border-radius: var(--radius-sm); overflow: hidden; }
  #el-jogo :global(.el-fundo__cmp-fill) { display: block; height: 100%; background: var(--ink-faint); }
  #el-jogo :global(.el-fundo__cmp-fill.is-now) { background: var(--wc-gold-ink); }
  /* Barra do valor de 2018 corrigido pelo IPCA: hachura sutil = referência, não real */
  #el-jogo :global(.el-fundo__cmp-fill.is-infl) { background: repeating-linear-gradient(45deg, var(--ink-faint), var(--ink-faint) 3px, transparent 3px, transparent 6px); opacity: 0.8; }
  #el-jogo :global(.el-fundo__cmp-v) { color: var(--ink-soft); font-variant-numeric: var(--num-tabular); white-space: nowrap; }
  #el-jogo :global(.el-fundo__mult) { font-family: var(--font-display); font-size: var(--text-2xl); color: var(--wc-gold-ink); margin-top: var(--space-2); line-height: 1; }
  #el-jogo :global(.el-fundo__mult--real) { font-size: var(--text-xl); color: var(--ink-soft); margin-top: var(--space-1); }
  #el-jogo :global(.el-fundo__mult .mono-label) { color: var(--ink-faint); }
  #el-jogo :global(.el-fundo__ipca-note) { margin: var(--space-2) 0 0; color: var(--ink-faint); }
  #el-jogo :global(.el-fundo__stats) { display: flex; flex-direction: column; gap: var(--space-5); }
  #el-jogo :global(.el-fundo__meter) { display: flex; flex-direction: column; gap: var(--space-2); }
  #el-jogo :global(.el-fundo__meter-head) { display: flex; align-items: baseline; gap: var(--space-3); }
  #el-jogo :global(.el-fundo__sv) { font-family: var(--font-display); font-size: var(--text-2xl); color: var(--ink); font-variant-numeric: var(--num-tabular); line-height: 1; }
  #el-jogo :global(.el-fundo__sl) { color: var(--ink-faint); }
  #el-jogo :global(.el-fundo__meter-track) { height: 6px; background: var(--line); border-radius: var(--radius-full); overflow: hidden; }
  #el-jogo :global(.el-fundo__meter-fill) { display: block; height: 100%; background: var(--ink-soft); border-radius: var(--radius-full); }

  /* ── [10] Relógio (timeline vertical) ── */
  .el-timeline { position: relative; margin: var(--space-8) 0 0; padding: var(--space-8) var(--space-6); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .el-timeline__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  /* Itens injetados via JS → :global() sob a section estática #el-relogio */
  #el-relogio :global(.el-tl-item) { position: relative; display: grid; grid-template-columns: 1.2rem 6.5rem 1fr auto; align-items: baseline; gap: var(--space-2) var(--space-3); padding: var(--space-4) 0; padding-left: var(--space-2); border-left: 2px solid var(--line); margin-left: 5px; }
  #el-relogio :global(.el-tl-item:first-of-type) { padding-top: 0; }
  #el-relogio :global(.el-tl-item:last-of-type) { padding-bottom: 0; }
  #el-relogio :global(.el-tl-dot) { position: absolute; left: -7px; top: var(--space-4); width: 10px; height: 10px; border-radius: var(--radius-full); background: var(--paper-card); border: 2px solid var(--ink-faint); }
  #el-relogio :global(.el-tl-item:first-of-type .el-tl-dot) { top: 2px; }
  #el-relogio :global(.el-tl-item.is-past) { border-left-color: var(--wc-gold-line); }
  #el-relogio :global(.el-tl-item.is-past .el-tl-dot) { background: var(--wc-gold-ink); border-color: var(--wc-gold-ink); }
  #el-relogio :global(.el-tl-date) { color: var(--ink-faint); font-variant-numeric: var(--num-tabular); grid-column: 2; }
  #el-relogio :global(.el-tl-marco) { color: var(--ink); font-size: var(--text-sm); grid-column: 3; }
  #el-relogio :global(.el-tl-item.is-past .el-tl-marco) { color: var(--ink-soft); }
  #el-relogio :global(.el-tl-rel) { grid-column: 4; color: var(--ink-faint); font-variant-numeric: var(--num-tabular); white-space: nowrap; text-align: right; }
  #el-relogio :global(.el-tl-rel.is-done) { color: var(--wc-gold-ink); }
  #el-relogio :global(.el-tl-item.is-key .el-tl-marco) { font-weight: 600; color: var(--ink); }
  #el-relogio :global(.el-tl-item.is-key .el-tl-dot) { width: 12px; height: 12px; left: -8px; top: calc(var(--space-4) - 1px); }
  /* Marcador "HOJE" — ponto pulsante dourado, spine dourado até aqui */
  #el-relogio :global(.el-tl-now) { border-left-color: var(--wc-gold-line); }
  #el-relogio :global(.el-tl-now .el-tl-dot) { background: var(--wc-gold-ink); border-color: var(--wc-gold-ink); animation: el-badge-pulse 2.6s ease-out infinite; }
  #el-relogio :global(.el-tl-now .el-tl-date) { color: var(--wc-gold-ink); }
  #el-relogio :global(.el-tl-now .el-tl-marco) { grid-column: 3; color: var(--wc-gold-ink); font-family: var(--font-mono); font-weight: 700; letter-spacing: .08em; font-size: var(--text-xs); }
  @media (prefers-reduced-motion: reduce) { #el-relogio :global(.el-tl-now .el-tl-dot) { animation: none; } }

  /* ── [11] Transparência & fontes ── */
  .el-tr-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 768px) { .el-tr-grid { grid-template-columns: repeat(2, 1fr); } }
  .el-tr-text { color: var(--ink-soft); font-size: var(--text-base); line-height: var(--leading-normal); margin: 0; }
  .el-sources { list-style: none; margin: var(--space-8) 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  /* hover-glow (padrão CSS): halo suave --wc-gold-dim, mesmo idioma do foco do combobox. */
  .el-source-link { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-full); text-decoration: none; transition: border-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast); }
  .el-source-link:hover { border-color: var(--wc-gold-line); color: var(--wc-gold-ink); box-shadow: 0 0 0 3px var(--wc-gold-dim); }
  .el-source-link:focus-visible { outline: var(--focus-ring-width) solid var(--focus-ring-color); outline-offset: 2px; }
  @media (hover: none) { .el-source-link:hover { box-shadow: none; } }
  @media (prefers-reduced-motion: reduce) { .el-source-link { transition: none; } }

  /* ── [13] Situação jurídica (integridade) — cards/legend injetados via :global ── */
  .el-integ-wrap { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .el-integ-legend { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  #el-integridade :global(.el-integ-lg) { padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-full); }
  #el-integridade :global(.el-integ-lg[data-stage="ficha_limpa"]) { color: var(--wc-gold-ink); border-color: var(--wc-gold-line); }
  .el-integ-cards { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .el-integ-cards { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .el-integ-cards { grid-template-columns: repeat(3, 1fr); } }
  #el-integridade :global(.el-integ-card) { position: relative; background: var(--paper-card); border: 1px solid var(--line); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  #el-integridade :global(.el-integ-head) { display: flex; align-items: baseline; gap: var(--space-2); flex-wrap: wrap; }
  #el-integridade :global(.el-integ-name) { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); line-height: 1.05; }
  #el-integridade :global(.el-integ-party) { color: var(--ink-faint); }
  #el-integridade :global(.el-integ-none) { color: var(--ink-faint); }
  #el-integridade :global(.el-integ-itens) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-3); }
  #el-integridade :global(.el-integ-item) { display: flex; flex-direction: column; gap: var(--space-1); }
  #el-integridade :global(.el-integ-stage) { align-self: flex-start; padding: 1px var(--space-2); font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--ink-soft); background: var(--paper-soft); border: 1px solid var(--line); border-radius: var(--radius-sm); }
  #el-integridade :global(.el-integ-stage[data-stage="ficha_limpa"]) { color: var(--wc-gold-ink); border-color: var(--wc-gold-line); background: var(--wc-gold-dim); }
  #el-integridade :global(.el-integ-desc) { color: var(--ink); font-size: var(--text-sm); }
  #el-integridade :global(.el-integ-srclink) { color: var(--ink-faint); text-decoration: none; }
  #el-integridade :global(.el-integ-srclink:hover) { color: var(--wc-gold-ink); }
  #el-integridade :global(.el-integ-consulta) { margin-top: auto; display: flex; flex-wrap: wrap; gap: var(--space-3); padding-top: var(--space-2); }
  #el-integridade :global(.el-integ-src) { font-family: var(--font-mono); font-size: 10px; color: var(--ink-soft); text-decoration: none; border-bottom: 1px solid var(--line); }
  #el-integridade :global(.el-integ-src:hover) { color: var(--wc-gold-ink); border-color: var(--wc-gold-line); }
</style>

<script>
  // Observatório Eleições 2026 — hidrata as seções a partir de
  // assets/data/eleicoes_pesquisas.json. Fetch runtime (base do body,
  // cache no-cache, AbortController, fail-soft). i18n dinâmico via
  // window.i18n.t() + re-render em `languageChanged`.
  interface Records { maior_amostra?: number | null; pesquisa_mais_cara_rs?: number | null; instituto_mais_ativo?: { empresa: string; n: number; investimento_rs: number } | null; mes_pico?: { mes: string; n: number } | null; }
  interface ElPayload {
    janela?: { primeira_divulgacao?: string; ultima_divulgacao?: string };
    kpis?: { total_pesquisas?: number; n_institutos?: number; investimento_total_rs?: number; mediana_entrevistados?: number; custo_medio_rs?: number | null };
    concentracao?: { top1_share_pct?: number; top5_share_pct?: number; hhi?: number };
    por_mes?: { mes: string; n: number }[];
    por_nivel?: { presidencial?: number; estadual?: number };
    top_institutos?: { empresa: string; n: number; investimento_rs: number }[];
    por_uf?: { uf: string; n: number }[];
    por_uf_detalhe?: Record<string, { n: number; mediana_amostra: number | null; top_institutos: { empresa: string; n: number }[] }>;
    propria_vs_contratada?: { propria?: number; contratada?: number };
    amostragem?: { faixa: string; n: number }[];
    records?: Records;
  }

  interface Dist { label: string; n: number; pct: number }
  interface EleitoradoPayload {
    total_eleitores?: number;
    biometria?: { n: number; pct: number };
    genero?: Dist[];
    faixa_etaria?: Dist[];
    escolaridade?: Dist[];
    obrigatoriedade?: Dist[];
    por_uf?: { uf: string; eleitores: number; pct: number }[];
    exterior?: { eleitores: number };
    destaques?: {
      feminino_pct?: number; jovens_16_17?: number; idosos_70mais?: number;
      analfabetos?: { n: number; pct: number }; facultativo_pct?: number;
    };
  }
  interface VoteCand { nome: string; partido: string; media_recente: number; pct_ultima: number; instituto_ultima: string; data_ultima: string; n_pesquisas: number; delta: number | null; lider: boolean }
  interface VoteDuelSide { nome: string; partido: string; pct: number }
  interface VoteDuel { instituto: string; data: string; a: VoteDuelSide; b: VoteDuelSide }
  interface PrecandPayload {
    fonte_url?: string;
    janela?: { primeira?: string; ultima?: string };
    n_medicoes?: number;
    n_institutos?: number;
    panorama?: { nome: string; partido: string; n_pesquisas: number; ultima: string }[];
    primeiro_turno?: { data_ref?: string; janela_dias?: number; n_pesquisas?: number; candidatos: VoteCand[] } | null;
    segundo_turno?: VoteDuel[];
    serie_temporal?: SerieTemporal;
  }
  interface SerieTemporal { meses: string[]; candidatos: Record<string, (number | null)[]> }
  interface VoteSnapshot { data_ref?: string; janela_dias?: number; n_pesquisas?: number; candidatos: VoteCand[] }
  interface EstadoIntencao { governador_1t: VoteSnapshot | null; governador_2t: VoteDuel[]; senador: VoteSnapshot | null }
  interface EstaduaisPayload {
    fonte_url_fmt?: string;
    ufs_disponiveis?: string[];
    estados?: Record<string, EstadoIntencao>;
  }
  interface ContextoPayload {
    cargos?: { presidente?: number; governadores?: number; senadores?: number; senado_total?: number; deputados_federais?: number; nota_senado?: string };
    fundo_eleitoral?: { valor_rs?: number; ref_2018_rs?: number; multiplo_vs_2018?: number; top5_partidos_share_pct?: number; cota_mulheres_pct?: number; cota_negros_pct?: number; nota_dobro?: string;
      ref_2018_corrigido_rs?: number; multiplo_real?: number; ipca_acumulado_pct?: number; ipca_ref_ano?: number; ipca_acima_pct?: number; ipca_fonte_url?: string };
    calendario?: { data: string; marco: string }[];
    calendario_fonte_url?: string;
  }
  interface FundoIpcaPayload {
    ref_2018_corrigido_rs?: number; multiplo_real?: number; ipca_acumulado_pct?: number;
    ref_ano?: number; acima_inflacao_pct?: number; fonte_url?: string;
  }
  interface RegCand { nome: string; partido: string; pct: number }
  interface PresRegioesPayload {
    instituto?: string; contratante?: string; periodo?: string; data_ref?: string;
    amostra?: number; registro_tse?: string; cenario?: string; margem_erro_pp?: number;
    fonte?: string; fonte_url?: string; disclaimer?: string;
    ufs_por_regiao?: Record<string, string[]>;
    regioes?: Record<string, { nome: string; agrupada?: boolean; candidatos: RegCand[] }>;
  }
  interface IntegItem { estagio: string; tipo?: string; descricao: string; orgao?: string; fonte?: string; fonte_url?: string; data?: string }
  interface IntegridadePayload {
    metodologia?: string;
    disclaimer?: string;
    estagios?: { id: string; label: string }[];
    fontes?: { label: string; url: string }[];
    itens_por_candidato?: Record<string, IntegItem[]>;
  }

  const nf = new Intl.NumberFormat('pt-BR');
  const el = (id: string) => document.getElementById(id);
  const t = (key: string, fallback: string): string => {
    const v = (window as unknown as { i18n?: { t?: (k: string) => string } }).i18n?.t?.(key);
    return typeof v === 'string' && v ? v : fallback;
  };
  function fmtRS(v: number): string {
    if (v >= 1_000_000) return `R$ ${(v / 1_000_000).toLocaleString('pt-BR', { maximumFractionDigits: 1 })} mi`;
    if (v >= 1_000) return `R$ ${(v / 1_000).toLocaleString('pt-BR', { maximumFractionDigits: 0 })} mil`;
    return `R$ ${nf.format(Math.round(v))}`;
  }
  const MESES = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
  const fmtMes = (m: string): string => { const [y, mm] = m.split('-'); return `${MESES[parseInt(mm, 10) - 1]}/${y.slice(2)}`; };
  const fmtMesLong = (m: string): string => { const [y, mm] = m.split('-'); return `${MESES[parseInt(mm, 10) - 1]} ${y}`; };
  function fmtDate(iso?: string): string { if (!iso) return '—'; const [y, m, d] = iso.split('-'); return `${d}/${m}/${y}`; }
  function esc(s: string): string { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // ── Escala de eixo com ticks arredondados (Heckbert) — portado do
  //    brasil-cockpit (bandChart). Usado pelo bar chart mensal [05] e pela
  //    série temporal presidencial [02]. Fonte única: mesma lógica, sem lib. ──
  function niceNum(range: number, round: boolean): number {
    const exp = Math.floor(Math.log10(range));
    const frac = range / Math.pow(10, exp);
    let n: number;
    if (round) { if (frac < 1.5) n = 1; else if (frac < 3) n = 2; else if (frac < 7) n = 5; else n = 10; }
    else { if (frac <= 1) n = 1; else if (frac <= 2) n = 2; else if (frac <= 5) n = 5; else n = 10; }
    return n * Math.pow(10, exp);
  }
  function niceTicks(min: number, max: number, n = 5): { ticks: number[]; niceMax: number } {
    if (max <= min) max = min + 1;
    const step = niceNum((max - min) / (n - 1), true);
    const niceMax = Math.ceil(max / step) * step;
    const ticks: number[] = [];
    for (let v = 0; v <= niceMax + step * 0.5; v += step) ticks.push(Math.round(v * 100) / 100);
    return { ticks, niceMax };
  }

  // ── Tooltip para barras HTML: dados vão num atributo data-tip como JSON
  //    (escapado p/ atributo — sem HTML embutido, evita dupla-codificação).
  //    O HTML é montado no hover por initBarTips(). ──
  function escAttr(s: string): string { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
  function barTip(title: string, rows: [string, string][]): string {
    return ` data-tip="${escAttr(JSON.stringify({ t: title, r: rows }))}"`;
  }

  // ── Faixa de progresso: contagem para o 1º turno (4/out/2026) ──
  function renderProgress(p: ElPayload): void {
    const ELECTION = Date.parse('2026-10-04T00:00:00-03:00');
    const startISO = p.janela?.primeira_divulgacao ?? '2026-01-01';
    const start = Date.parse(startISO + 'T00:00:00-03:00');
    const now = Date.now();
    const total = ELECTION - start;
    const pct = Math.max(0, Math.min(100, Math.round(((now - start) / total) * 100)));
    const days = Math.max(0, Math.ceil((ELECTION - now) / 86_400_000));
    const fill = el('el-prog-fill'); if (fill) fill.style.width = pct + '%';
    const bar = fill?.parentElement; if (bar) bar.setAttribute('aria-valuenow', String(pct));
    if (el('el-prog-pct')) el('el-prog-pct')!.textContent = pct + '%';
    if (el('el-prog-remaining')) el('el-prog-remaining')!.textContent = `${nf.format(days)} ${t('portfolio.eleicoes.prog_days', 'dias até o 1º turno')}`;
    if (el('el-prog-next')) el('el-prog-next')!.textContent = t('portfolio.eleicoes.prog_date', '4 de outubro de 2026');
  }

  function renderBento(p: ElPayload): void {
    const k = p.kpis ?? {};
    if (el('kpi-total')) el('kpi-total')!.textContent = nf.format(k.total_pesquisas ?? 0);
    if (el('kpi-institutos')) el('kpi-institutos')!.textContent = nf.format(k.n_institutos ?? 0);
    if (el('kpi-investimento')) el('kpi-investimento')!.textContent = fmtRS(k.investimento_total_rs ?? 0);
    const star = p.records?.instituto_mais_ativo;
    if (el('kpi-star-name')) el('kpi-star-name')!.textContent = star?.empresa ?? '—';
    if (el('kpi-star-meta') && star) el('kpi-star-meta')!.textContent =
      `${nf.format(star.n)} ${t('portfolio.eleicoes.rk_pesq', 'pesq')} · ${fmtRS(star.investimento_rs)}`;
    if (el('el-updated-date')) el('el-updated-date')!.textContent = fmtDate(p.janela?.ultima_divulgacao);
  }

  function renderMiniStats(p: ElPayload): void {
    const r = p.records ?? {};
    if (el('mini-amostra')) el('mini-amostra')!.textContent = r.maior_amostra ? nf.format(r.maior_amostra) : '—';
    if (el('mini-mediana')) el('mini-mediana')!.textContent = p.kpis?.mediana_entrevistados ? nf.format(p.kpis.mediana_entrevistados) : '—';
    if (el('mini-cara')) el('mini-cara')!.textContent = r.pesquisa_mais_cara_rs ? fmtRS(r.pesquisa_mais_cara_rs) : '—';
    if (el('mini-pico')) el('mini-pico')!.textContent = r.mes_pico ? `${fmtMesLong(r.mes_pico.mes)}` : '—';
    if (el('mini-custo')) el('mini-custo')!.textContent = p.kpis?.custo_medio_rs ? fmtRS(p.kpis.custo_medio_rs) : '—';
    if (el('mini-conc')) el('mini-conc')!.textContent = p.concentracao?.top5_share_pct != null ? `${p.concentracao.top5_share_pct}%` : '—';
    const inline = el('el-conc-inline');
    if (inline) inline.textContent = p.concentracao?.top1_share_pct != null ? `${p.concentracao.top1_share_pct}%` : '—';
  }

  // ── Hover interativo (guia vertical + pontos no SVG + tooltip HTML) para os
  //    gráficos com eixo — série [02] e barras [05]. Pointer-only, sem libs. ──
  const SVG_NS = 'http://www.w3.org/2000/svg';
  interface HoverDot { x: number; y: number; color: string }
  interface HoverProbe { gx: number; dots: HoverDot[]; html: string }
  function attachChartHover(
    box: HTMLElement, fig: HTMLElement | null, tip: HTMLElement | null,
    W: number, yTop: number, yBot: number,
    xToIdx: (vx: number) => number, probe: (idx: number) => HoverProbe | null,
  ): void {
    const svg = box.querySelector('svg'); if (!svg || !fig || !tip) return;
    const guide = document.createElementNS(SVG_NS, 'g');
    const vline = document.createElementNS(SVG_NS, 'line');
    vline.setAttribute('class', 'el-band-guide');
    guide.appendChild(vline); guide.style.display = 'none';
    svg.appendChild(guide);
    const hide = (): void => { guide.style.display = 'none'; tip.hidden = true; };
    const move = (e: PointerEvent): void => {
      const r = svg.getBoundingClientRect(); if (!r.width) return;
      const res = probe(xToIdx(((e.clientX - r.left) / r.width) * W));
      if (!res || !res.dots.length) { hide(); return; }
      vline.setAttribute('x1', res.gx.toFixed(1)); vline.setAttribute('x2', res.gx.toFixed(1));
      vline.setAttribute('y1', String(yTop)); vline.setAttribute('y2', String(yBot));
      guide.querySelectorAll('circle').forEach((c) => c.remove());
      res.dots.forEach((d) => {
        const c = document.createElementNS(SVG_NS, 'circle');
        c.setAttribute('class', 'el-band-hoverdot');
        c.setAttribute('cx', d.x.toFixed(1)); c.setAttribute('cy', d.y.toFixed(1));
        c.setAttribute('r', '3.5'); c.setAttribute('fill', d.color);
        guide.appendChild(c);
      });
      guide.style.display = '';
      tip.innerHTML = res.html; tip.hidden = false;
      const fr = fig.getBoundingClientRect(), tw = tip.offsetWidth, th = tip.offsetHeight;
      let left = e.clientX - fr.left + 14, top = e.clientY - fr.top + 14;
      if (left + tw > fr.width) left = e.clientX - fr.left - tw - 14;
      if (top + th > fr.height) top = e.clientY - fr.top - th - 14;
      tip.style.left = Math.max(2, left) + 'px';
      tip.style.top = Math.max(2, top) + 'px';
    };
    svg.style.touchAction = 'pan-y';
    svg.addEventListener('pointermove', move);
    svg.addEventListener('pointerleave', hide);
  }

  // ── Tooltip flutuante para barras HTML: delegação única em [data-tip];
  //    monta o HTML no hover a partir do JSON e segue o cursor (fixed). ──
  function initBarTips(): void {
    const tip = el('el-float-tip'); if (!tip) return;
    let active: HTMLElement | null = null;
    const place = (e: PointerEvent): void => {
      const tw = tip.offsetWidth, th = tip.offsetHeight;
      let left = e.clientX + 14, top = e.clientY + 14;
      if (left + tw > window.innerWidth - 8) left = e.clientX - tw - 14;
      if (top + th > window.innerHeight - 8) top = e.clientY - th - 14;
      tip.style.left = Math.max(8, left) + 'px';
      tip.style.top = Math.max(8, top) + 'px';
    };
    document.addEventListener('pointermove', (e) => {
      const host = (e.target as HTMLElement).closest?.('[data-tip]') as HTMLElement | null;
      if (host?.dataset.tip) {
        if (host !== active) {
          active = host;
          try {
            const d = JSON.parse(host.dataset.tip) as { t: string; r: [string, string][] };
            tip.innerHTML = `<div class="el-tip-head">${esc(d.t)}</div>` +
              d.r.map(([k, v]) => `<div class="el-tip-row"><span class="el-tip-name">${esc(k)}</span><span class="el-tip-val">${esc(v)}</span></div>`).join('');
            tip.hidden = false;
          } catch { tip.hidden = true; active = null; return; }
        }
        place(e);
      } else if (active) { active = null; tip.hidden = true; }
    });
    window.addEventListener('scroll', () => { if (active) { active = null; tip.hidden = true; } }, { passive: true });
  }

  // ── Gráfico de barras vertical (SVG) — com eixo Y (niceTicks), grade e
  //    moldura, no padrão bandChart do brasil-cockpit. Pico em --wc-gold-ink. ──
  function renderBarChart(p: ElPayload): void {
    const box = el('el-barchart-svg'); if (!box) return;
    const data = p.por_mes ?? [];
    if (!data.length) { box.innerHTML = '<p class="el-error mono-label">série indisponível</p>'; return; }
    const peak = p.records?.mes_pico?.mes;
    const W = 720, H = 260, PAD = { l: 40, r: 12, t: 20, b: 34 };
    const plotW = W - PAD.l - PAD.r, plotH = H - PAD.t - PAD.b;
    const { ticks, niceMax } = niceTicks(0, Math.max(...data.map((d) => d.n), 1) * 1.08, 5);
    const yMax = niceMax || 1;
    const yAt = (v: number) => PAD.t + (1 - v / yMax) * plotH;
    const cw = plotW / data.length;
    const bw = Math.min(cw * 0.62, 60);

    const tickEls = ticks.map((v) => {
      const yy = yAt(v);
      return `<line class="el-band-tickline" x1="${PAD.l}" y1="${yy.toFixed(1)}" x2="${W - PAD.r}" y2="${yy.toFixed(1)}"></line>`
        + `<text class="el-band-ticklabel" x="${PAD.l - 6}" y="${(yy + 3).toFixed(1)}" text-anchor="end">${nf.format(v)}</text>`;
    }).join('');

    const bars = data.map((d, i) => {
      const y = yAt(d.n), h = (H - PAD.b) - y;
      const x = PAD.l + i * cw + (cw - bw) / 2;
      const isPeak = d.mes === peak;
      return `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.max(0, h).toFixed(1)}" rx="2" fill="var(${isPeak ? '--wc-gold-ink' : '--ink-soft'})"></rect>
        <text x="${(x + bw / 2).toFixed(1)}" y="${(y - 6).toFixed(1)}" text-anchor="middle" class="el-band-val">${nf.format(d.n)}</text>
        <text x="${(x + bw / 2).toFixed(1)}" y="${H - PAD.b + 15}" text-anchor="middle" class="el-band-axislabel">${esc(fmtMes(d.mes))}</text>`;
    }).join('');
    const baseline = `<line class="el-band-axisline" x1="${PAD.l}" y1="${(H - PAD.b).toFixed(1)}" x2="${W - PAD.r}" y2="${(H - PAD.b).toFixed(1)}"></line>`;
    const capture = `<rect class="el-band-capture" x="0" y="0" width="${W}" height="${H}"></rect>`;
    box.innerHTML = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="${esc(t('portfolio.eleicoes.chart_mes_aria', 'Pesquisas por mês de divulgação'))}">${tickEls}${bars}${baseline}${capture}</svg>`;

    attachChartHover(box, el('el-barchart'), el('el-barchart-tip'), W, PAD.t, H - PAD.b,
      (vx) => Math.max(0, Math.min(data.length - 1, Math.floor((vx - PAD.l) / cw))),
      (idx) => {
        const d = data[idx]; if (!d) return null;
        const gx = PAD.l + idx * cw + cw / 2, isPeak = d.mes === peak;
        const head = `<div class="el-tip-head">${esc(fmtMesLong(d.mes))}</div>`;
        const body = `<div class="el-tip-row${isPeak ? ' is-leader' : ''}"><span class="el-tip-name">${esc(t('portfolio.eleicoes.kpi_total', 'pesquisas'))}</span><span class="el-tip-val">${nf.format(d.n)}</span></div>`;
        return { gx, dots: [{ x: gx, y: yAt(d.n), color: isPeak ? 'var(--wc-gold-ink)' : 'var(--ink-soft)' }], html: head + body };
      });
  }

  // ── Tabela ranqueada ──
  function renderRankTable(p: ElPayload): void {
    const body = el('el-rank-body'); if (!body) return;
    const nota = el('el-inst-nota');
    const data = p.top_institutos ?? [];
    if (!data.length) { body.innerHTML = '<tr><td colspan="4"><p class="el-error">ranking indisponível</p></td></tr>'; if (nota) nota.textContent = ''; return; }
    // Instituto mais eficiente: mais pesquisas por real declarado (n ÷ investimento),
    // entre os que declararam investimento. Eficiência de volume, não de acurácia.
    let effIdx = -1, effBest = -1;
    data.forEach((d, i) => { if (d.investimento_rs > 0) { const e = d.n / d.investimento_rs; if (e > effBest) { effBest = e; effIdx = i; } } });
    const totalPesq = p.kpis?.total_pesquisas ?? data.reduce((s, x) => s + x.n, 0);
    body.innerHTML = data.map((d, i) => {
      const rank = i + 1, leader = rank === 1, efficient = i === effIdx;
      const medal = leader ? ` <span class="el-medal">🏆 ${esc(t('portfolio.eleicoes.leader', 'líder'))}</span>` : '';
      const star = efficient ? ` <span class="el-medal el-medal--eff">★ ${esc(t('portfolio.eleicoes.eff_badge', 'mais eficiente'))}</span>` : '';
      const rows: [string, string][] = [
        [t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), nf.format(d.n)],
        [t('portfolio.eleicoes.tip_percentual', 'percentual'), totalPesq ? `${((d.n / totalPesq) * 100).toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%` : '—'],
        [t('portfolio.eleicoes.tip_investimento', 'investimento'), fmtRS(d.investimento_rs)],
      ];
      if (d.investimento_rs > 0) rows.push([t('portfolio.eleicoes.tip_eficiencia', 'eficiência (pesq/R$ mi)'), (d.n / (d.investimento_rs / 1_000_000)).toLocaleString('pt-BR', { maximumFractionDigits: 0 })]);
      return `<tr class="${leader ? 'is-leader' : ''}${efficient ? ' is-efficient' : ''}"${barTip(d.empresa, rows)}>
        <td class="el-rk-rank">${String(rank).padStart(2, '0')}${medal}${star}</td>
        <td><span class="el-rk-name">${esc(d.empresa)}</span></td>
        <td class="el-rk-n">${nf.format(d.n)}</td>
        <td class="el-rk-rs">${esc(fmtRS(d.investimento_rs))}</td>
      </tr>`;
    }).join('');
    if (nota) {
      if (effIdx >= 0) {
        const d = data[effIdx];
        const perMi = d.n / (d.investimento_rs / 1_000_000);
        nota.innerHTML = `★ ${esc(t('portfolio.eleicoes.eff_note_a', 'Mais eficiente'))}: <strong>${esc(d.empresa)}</strong> — ${nf.format(d.n)} ${esc(t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'))} · ${perMi.toLocaleString('pt-BR', { maximumFractionDigits: 0 })} ${esc(t('portfolio.eleicoes.eff_per_mi', 'pesquisas por R$ mi declarado'))}. ${esc(t('portfolio.eleicoes.eff_note_b', 'Mede volume por real declarado ao TSE — não a acurácia nem o rigor das pesquisas.'))}`;
      } else { nota.textContent = ''; }
    }
  }

  // ── Donut (própria × contratada) ──
  function renderOrigem(p: ElPayload): void {
    const box = el('el-origem'); if (!box) return;
    const o = p.propria_vs_contratada ?? {};
    const contr = o.contratada ?? 0, prop = o.propria ?? 0, total = contr + prop;
    if (!total) { box.innerHTML = '<p class="el-error">indisponível</p>'; return; }
    const r = 52, cx = 66, cy = 66, circ = 2 * Math.PI * r;
    const fracC = contr / total;
    const dash = `${(fracC * circ).toFixed(1)} ${circ.toFixed(1)}`;
    const svg = `<svg viewBox="0 0 132 132" class="el-donut" role="img" aria-label="Origem das pesquisas">
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--line)" stroke-width="16"></circle>
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--ink)" stroke-width="16" stroke-dasharray="${dash}" transform="rotate(-90 ${cx} ${cy})"></circle>
      <text x="${cx}" y="${cy - 2}" text-anchor="middle" class="el-donut-num">${Math.round(fracC * 100)}%</text>
      <text x="${cx}" y="${cy + 16}" text-anchor="middle" class="el-donut-lbl">${esc(t('portfolio.eleicoes.origem_contratada', 'contratada'))}</text>
    </svg>`;
    const legend = `<div class="el-legend">
      <div class="el-legend__row"><span class="el-legend__sw" style="background:var(--ink)"></span>${esc(t('portfolio.eleicoes.origem_contratada', 'Contratada'))}<span class="el-legend__n">${nf.format(contr)}</span></div>
      <div class="el-legend__row"><span class="el-legend__sw" style="background:var(--line-strong)"></span>${esc(t('portfolio.eleicoes.origem_propria', 'Própria (do instituto)'))}<span class="el-legend__n">${nf.format(prop)}</span></div>
    </div>`;
    box.innerHTML = svg + legend;
  }

  function splitRow(label: string, n: number, total: number, alt = false): string {
    const pct = total ? (n / total) * 100 : 0;
    return `<div>
      <div class="el-split-row"><span>${esc(label)}</span><span>${nf.format(n)} · ${pct.toFixed(0)}%</span></div>
      <div class="el-split-track"><span class="el-split-fill${alt ? ' el-split-fill--alt' : ''}" style="width:${pct}%"></span></div>
    </div>`;
  }
  function renderNivel(p: ElPayload): void {
    const box = el('el-nivel'); if (!box) return;
    const niv = p.por_nivel ?? {};
    const total = (niv.presidencial ?? 0) + (niv.estadual ?? 0);
    box.innerHTML =
      splitRow(t('portfolio.eleicoes.nivel_presidencial', 'Presidencial / nacional'), niv.presidencial ?? 0, total) +
      splitRow(t('portfolio.eleicoes.nivel_estadual', 'Estadual'), niv.estadual ?? 0, total, true);
