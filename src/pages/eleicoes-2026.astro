          <div class="el-fundo__compare" role="img" aria-label="${esc(mult)} ${esc(t('portfolio.eleicoes.jogo_nominal', 'nominal'))}${realMult ? ` · ${esc(realMult)} ${esc(t('portfolio.eleicoes.jogo_real', 'real'))}` : ''} ${esc(t('portfolio.eleicoes.jogo_vs2018', 'vs. 2018'))}">
