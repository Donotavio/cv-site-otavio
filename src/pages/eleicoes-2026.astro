---
/**
 * eleicoes-2026.astro — Observatório Eleições 2026
 * Direção: Blueprint (DESIGN.md) — irmão de pix-observatory.astro e
 * data-stack-radar-br.astro.
 *
 * Ângulo: a *máquina de medição* da eleição. O dataset oficial do TSE
 * (Pesquisas Eleitorais 2026) é de REGISTRO — traz metadados (instituto,
 * cargo, UF, amostra, custo, datas), não os percentuais de intenção de voto.
 * Apartidário por construção: mede quem mede o eleitorado.
 *
 * Seções (mono-labels [01]…[04]):
 *  0. Header (reuse) + Hero — badge ATUALIZADO em runtime
 *  1. [01] KPIs — total de pesquisas, institutos, investimento, amostra mediana
 *  2. [02] Intensidade — pesquisas por mês (rampa rumo a 4/out)
 *  3. [03] Quem mede — ranking de institutos (nº + investimento declarado)
 *  4. [04] Como medem — nível da disputa, própria×contratada, tamanho de amostra
 *  5. Footer (reuse)
 *
 * Dado real via ingestion_eleicoes/collect_pesquisas.py → gold_eleicoes.py →
 * fetch runtime de assets/data/eleicoes_pesquisas.json. Zero LLM em runtime.
 * i18n: data-i18n-key nos textos estáticos (portfolio.eleicoes.*).
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Observatório Eleições 2026 — Otávio Ribeiro"
  description="A máquina de medição da eleição de 2026: pipeline sobre o dataset oficial do TSE (Pesquisas Eleitorais), quem mede o eleitorado, onde, com que rigor amostral e a que custo."
>
  <Header />

  <main id="main-content">

    <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
    <section id="eleicoes-hero" class="section el-hero" aria-labelledby="el-hero-title">
      <div class="container">
        <div class="hero-card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>

          <header class="hero-card__header">
            <span class="mono-label" data-i18n-key="portfolio.eleicoes.hero_label">Observatório Eleições 2026</span>
            <span class="mono-label el-badge" id="el-updated" aria-live="polite">
              <span data-i18n-key="portfolio.eleicoes.updated_label">atualizado</span> · <span id="el-updated-date">···</span>
            </span>
          </header>

          <h1 id="el-hero-title" class="hero-display" data-i18n-key="portfolio.eleicoes.hero_title">
            Quem está medindo o Brasil antes de 4 de outubro?
          </h1>

          <p class="hero-lead" data-i18n-key="portfolio.eleicoes.hero_lead">
            Toda pesquisa eleitoral precisa ser registrada no TSE. Este observatório
            lê esse registro oficial e mostra a <em>máquina de medição</em> da eleição —
            quem mede, onde, com que rigor amostral e a que custo. Sem palpite de quem
            ganha: os percentuais não estão no registro, só os metadados.
          </p>

          <div class="hero-actions">
            <a href="#el-kpis" class="btn-primary" data-i18n-key="portfolio.eleicoes.cta_dados">Ver os dados</a>
            <a
              href="https://dadosabertos.tse.jus.br/dataset/pesquisas-eleitorais-2026"
              class="btn-secondary" target="_blank" rel="noopener noreferrer"
              data-i18n-key="portfolio.eleicoes.cta_fonte"
            >Fonte (TSE)</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ [01] KPIs ═══════════════════════ -->
    <section id="el-kpis" class="section" aria-labelledby="el-kpis-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">01</span>
          <h2 id="el-kpis-title" class="el-h2" data-i18n-key="portfolio.eleicoes.kpis_title">O tamanho da operação</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.kpis_lead">
            Pesquisas registradas no TSE para o pleito de 2026 — Python · pandas · Parquet.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />

        <div class="el-kpis" role="list">
          <article class="el-kpi card crop" role="listitem">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="el-kpi__value" id="kpi-total">···</span>
            <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_total">pesquisas registradas</span>
          </article>
          <article class="el-kpi card crop" role="listitem">
            <span class="el-kpi__value" id="kpi-institutos">···</span>
            <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_institutos">institutos distintos</span>
          </article>
          <article class="el-kpi card crop" role="listitem">
            <span class="el-kpi__value" id="kpi-investimento">···</span>
            <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_investimento">investimento declarado</span>
          </article>
          <article class="el-kpi card crop" role="listitem">
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="el-kpi__value" id="kpi-amostra">···</span>
            <span class="el-kpi__label" data-i18n-key="portfolio.eleicoes.kpi_amostra">amostra mediana</span>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ [02] INTENSIDADE ═══════════════════════ -->
    <section id="el-intensidade" class="section" aria-labelledby="el-int-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">02</span>
          <h2 id="el-int-title" class="el-h2" data-i18n-key="portfolio.eleicoes.timeline_title">A rampa das pesquisas</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.timeline_lead">
            Pesquisas divulgadas por mês. A intensidade acelera conforme a eleição se aproxima.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <div class="el-timeline card crop" id="el-timeline" aria-label="Pesquisas por mês">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <p class="el-loading mono-label">carregando série…</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ [03] QUEM MEDE ═══════════════════════ -->
    <section id="el-institutos" class="section" aria-labelledby="el-inst-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">03</span>
          <h2 id="el-inst-title" class="el-h2" data-i18n-key="portfolio.eleicoes.institutos_title">Quem mede o eleitorado</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.institutos_lead">
            Institutos por volume de pesquisas registradas e investimento declarado (R$).
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <ol class="el-ranking card crop" id="el-ranking" aria-label="Ranking de institutos">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <li class="el-loading mono-label">carregando ranking…</li>
        </ol>
      </div>
    </section>

    <!-- ═══════════════════════ [04] COMO MEDEM ═══════════════════════ -->
    <section id="el-como" class="section" aria-labelledby="el-como-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">04</span>
          <h2 id="el-como-title" class="el-h2" data-i18n-key="portfolio.eleicoes.como_title">Como medem</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.como_lead">
            Nível da disputa, origem da encomenda e rigor amostral.
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <div class="el-grid3">
          <article class="card crop el-panel">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <h3 class="el-panel__title mono-label" data-i18n-key="portfolio.eleicoes.nivel_title">Nível da disputa</h3>
            <div id="el-nivel" class="el-split"><p class="el-loading mono-label">···</p></div>
          </article>
          <article class="card crop el-panel">
            <h3 class="el-panel__title mono-label" data-i18n-key="portfolio.eleicoes.origem_title">Origem</h3>
            <div id="el-origem" class="el-split"><p class="el-loading mono-label">···</p></div>
          </article>
          <article class="card crop el-panel">
            <span class="crop-mark-br" aria-hidden="true"></span>
            <h3 class="el-panel__title mono-label" data-i18n-key="portfolio.eleicoes.amostra_title">Tamanho de amostra</h3>
            <div id="el-amostragem" class="el-bars"><p class="el-loading mono-label">···</p></div>
          </article>
        </div>

        <p class="el-nota mono-label" id="el-nota" data-i18n-key="portfolio.eleicoes.nota">
          Escopo: dataset de registro do TSE — metadados das pesquisas, não os
          percentuais de intenção de voto (que constam nos questionários em PDF).
        </p>
      </div>
    </section>

    <!-- ═══════════════════════ [05] COBERTURA POR UF ═══════════════════════ -->
    <section id="el-cobertura" class="section" aria-labelledby="el-uf-title">
      <div class="container">
        <div class="section-head">
          <span class="mono-label">05</span>
          <h2 id="el-uf-title" class="el-h2" data-i18n-key="portfolio.eleicoes.uf_title">Onde se mede mais</h2>
          <p class="el-lead" data-i18n-key="portfolio.eleicoes.uf_lead">
            Pesquisas estaduais por UF (exclui a disputa presidencial/nacional).
          </p>
        </div>
        <hr class="section-line" aria-hidden="true" />
        <div class="el-uf card crop" id="el-uf" aria-label="Pesquisas por estado">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <p class="el-loading mono-label">carregando cobertura…</p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .el-badge { color: var(--accent); }

  .el-h2 { font-family: var(--font-display); font-size: var(--text-2xl); line-height: 1.05; margin: 0; }
  .el-lead { color: var(--ink-soft); font-size: var(--text-base); max-width: 60ch; margin-top: var(--space-2); }

  /* KPIs */
  .el-kpis {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .el-kpi { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-6); }
  .el-kpi__value {
    font-family: var(--font-display); font-size: var(--text-2xl); color: var(--ink);
    line-height: 1; font-variant-numeric: tabular-nums;
  }
  .el-kpi__label { font-size: var(--text-sm); color: var(--ink-faint); }

  /* Timeline */
  .el-timeline { padding: var(--space-8); margin-top: var(--space-8); }
  .el-tl-row { display: grid; grid-template-columns: 5.5rem 1fr 3rem; align-items: center; gap: var(--space-3); padding: var(--space-1) 0; }
  .el-tl-mes { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-tl-track { height: 12px; background: var(--line-faint); border-radius: var(--radius-sm); overflow: hidden; }
  .el-tl-fill { height: 100%; background: var(--accent); border-radius: var(--radius-sm); }
  .el-tl-n { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; font-variant-numeric: tabular-nums; }

  /* Ranking */
  .el-ranking { list-style: none; margin: var(--space-8) 0 0; padding: var(--space-6) var(--space-8); }
  .el-rk-row { display: grid; grid-template-columns: 1.6rem 1fr auto; align-items: baseline; gap: var(--space-3); padding: var(--space-3) 0; border-top: 1px solid var(--line-faint); }
  .el-ranking .el-rk-row:first-of-type { border-top: 0; }
  .el-rk-pos { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-rk-name { color: var(--ink); font-size: var(--text-sm); }
  .el-rk-meta { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); white-space: nowrap; font-variant-numeric: tabular-nums; }
  .el-rk-meta strong { color: var(--ink); }

  /* Como medem */
  .el-grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-top: var(--space-8); }
  .el-panel { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .el-panel__title { color: var(--ink-faint); }
  .el-split { display: flex; flex-direction: column; gap: var(--space-3); }
  .el-split-row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-2); }
  .el-split-row span:first-child { color: var(--ink); font-size: var(--text-sm); }
  .el-split-row span:last-child { font-family: var(--font-mono); color: var(--ink-soft); font-size: var(--text-sm); font-variant-numeric: tabular-nums; }
  .el-split-track { height: 8px; background: var(--line-faint); border-radius: var(--radius-sm); overflow: hidden; }
  .el-split-fill { height: 100%; background: var(--accent); }
  .el-split-fill--alt { background: var(--ink-soft); }
  .el-bars { display: flex; flex-direction: column; gap: var(--space-2); }
  .el-bar-row { display: grid; grid-template-columns: 5rem 1fr 2rem; gap: var(--space-2); align-items: center; }
  .el-bar-lbl { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); }
  .el-bar-track { height: 8px; background: var(--line-faint); border-radius: var(--radius-sm); overflow: hidden; }
  .el-bar-fill { height: 100%; background: var(--accent); }
  .el-bar-n { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); text-align: right; }

  .el-nota { color: var(--ink-faint); font-size: var(--text-xs); margin-top: var(--space-8); max-width: 70ch; line-height: 1.5; }
  .el-loading { color: var(--ink-faint); }
  .el-error { color: var(--ink-faint); font-family: var(--font-mono); font-size: var(--text-sm); }

  /* Cobertura por UF */
  .el-uf { padding: var(--space-8); margin-top: var(--space-8); display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2) var(--space-10); }

  @media (max-width: 720px) {
    .el-kpis { grid-template-columns: repeat(2, 1fr); }
    .el-grid3 { grid-template-columns: 1fr; }
    .el-uf { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Observatório Eleições 2026 — carrega assets/data/eleicoes_pesquisas.json e
  // hidrata as seções. Mesmo padrão de fetch das outras páginas (base do body,
  // cache no-cache, AbortController, fail-soft).
  interface ElPayload {
    gerado_em?: string;
    janela?: { primeira_divulgacao?: string; ultima_divulgacao?: string };
    kpis?: { total_pesquisas?: number; n_institutos?: number; investimento_total_rs?: number; mediana_entrevistados?: number; pct_presidencial?: number };
    por_mes?: { mes: string; n: number }[];
    por_nivel?: { presidencial?: number; estadual?: number };
    top_institutos?: { empresa: string; n: number; investimento_rs: number }[];
    por_uf?: { uf: string; n: number }[];
    propria_vs_contratada?: { propria?: number; contratada?: number };
    amostragem?: { faixa: string; n: number }[];
    notas?: { escopo?: string };
  }

  const nf = new Intl.NumberFormat('pt-BR');
  const el = (id: string) => document.getElementById(id);

  function fmtRS(v: number): string {
    if (v >= 1_000_000) return `R$ ${(v / 1_000_000).toLocaleString('pt-BR', { maximumFractionDigits: 1 })} mi`;
    if (v >= 1_000) return `R$ ${(v / 1_000).toLocaleString('pt-BR', { maximumFractionDigits: 0 })} mil`;
    return `R$ ${nf.format(Math.round(v))}`;
  }
  function fmtMes(m: string): string {
    const [y, mm] = m.split('-');
    const meses = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
    return `${meses[parseInt(mm, 10) - 1]}/${y.slice(2)}`;
  }
  function fmtDate(iso?: string): string {
    if (!iso) return '—';
    const [y, m, d] = iso.split('-');
    return `${d}/${m}/${y}`;
  }
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function renderKpis(p: ElPayload): void {
    const k = p.kpis ?? {};
    if (el('kpi-total')) el('kpi-total')!.textContent = nf.format(k.total_pesquisas ?? 0);
    if (el('kpi-institutos')) el('kpi-institutos')!.textContent = nf.format(k.n_institutos ?? 0);
    if (el('kpi-investimento')) el('kpi-investimento')!.textContent = fmtRS(k.investimento_total_rs ?? 0);
    if (el('kpi-amostra')) el('kpi-amostra')!.textContent = k.mediana_entrevistados ? nf.format(k.mediana_entrevistados) : '—';
    const dt = el('el-updated-date');
    if (dt) dt.textContent = fmtDate(p.janela?.ultima_divulgacao);
  }

  function renderTimeline(p: ElPayload): void {
    const box = el('el-timeline');
    if (!box) return;
    const data = p.por_mes ?? [];
    if (!data.length) { box.innerHTML = '<p class="el-error">série indisponível</p>'; return; }
    const max = Math.max(...data.map((d) => d.n), 1);
    const rows = data.map((d) => `
      <div class="el-tl-row">
        <span class="el-tl-mes">${esc(fmtMes(d.mes))}</span>
        <span class="el-tl-track"><span class="el-tl-fill" style="width:${(d.n / max) * 100}%"></span></span>
        <span class="el-tl-n">${nf.format(d.n)}</span>
      </div>`).join('');
    box.innerHTML =
      '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>' + rows;
  }

  function renderRanking(p: ElPayload): void {
    const box = el('el-ranking');
    if (!box) return;
    const data = p.top_institutos ?? [];
    if (!data.length) { box.innerHTML = '<li class="el-error">ranking indisponível</li>'; return; }
    const rows = data.map((d, i) => `
      <li class="el-rk-row">
        <span class="el-rk-pos">${String(i + 1).padStart(2, '0')}</span>
        <span class="el-rk-name">${esc(d.empresa)}</span>
        <span class="el-rk-meta"><strong>${nf.format(d.n)}</strong> pesq · ${esc(fmtRS(d.investimento_rs))}</span>
      </li>`).join('');
    box.innerHTML =
      '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>' + rows;
  }

  function splitRow(label: string, n: number, total: number, alt = false): string {
    const pct = total ? (n / total) * 100 : 0;
    return `
      <div>
        <div class="el-split-row"><span>${esc(label)}</span><span>${nf.format(n)} · ${pct.toFixed(0)}%</span></div>
        <div class="el-split-track"><span class="el-split-fill${alt ? ' el-split-fill--alt' : ''}" style="width:${pct}%"></span></div>
      </div>`;
  }

  function renderComo(p: ElPayload): void {
    const niv = p.por_nivel ?? {};
    const nivTotal = (niv.presidencial ?? 0) + (niv.estadual ?? 0);
    if (el('el-nivel')) el('el-nivel')!.innerHTML =
      splitRow('Presidencial / nacional', niv.presidencial ?? 0, nivTotal) +
      splitRow('Estadual', niv.estadual ?? 0, nivTotal, true);

    const org = p.propria_vs_contratada ?? {};
    const orgTotal = (org.propria ?? 0) + (org.contratada ?? 0);
    if (el('el-origem')) el('el-origem')!.innerHTML =
      splitRow('Contratada', org.contratada ?? 0, orgTotal) +
      splitRow('Própria (do instituto)', org.propria ?? 0, orgTotal, true);

    const am = p.amostragem ?? [];
    const amMax = Math.max(...am.map((a) => a.n), 1);
    if (el('el-amostragem')) el('el-amostragem')!.innerHTML = am.map((a) => `
      <div class="el-bar-row">
        <span class="el-bar-lbl">${esc(a.faixa)}</span>
        <span class="el-bar-track"><span class="el-bar-fill" style="width:${(a.n / amMax) * 100}%"></span></span>
        <span class="el-bar-n">${nf.format(a.n)}</span>
      </div>`).join('');

    if (p.notas?.escopo && el('el-nota')) {
      el('el-nota')!.textContent = 'Escopo: ' + p.notas.escopo;
      el('el-nota')!.removeAttribute('data-i18n-key');
    }
  }

  function renderUF(p: ElPayload): void {
    const box = el('el-uf');
    if (!box) return;
    // Exclui 'BR' (disputa presidencial/nacional) — foco na cobertura estadual.
    const data = (p.por_uf ?? []).filter((d) => d.uf && d.uf !== 'BR').slice(0, 14);
    if (!data.length) { box.innerHTML = '<p class="el-error">cobertura indisponível</p>'; return; }
    const max = Math.max(...data.map((d) => d.n), 1);
    const rows = data.map((d) => `
      <div class="el-bar-row">
        <span class="el-bar-lbl">${esc(d.uf)}</span>
        <span class="el-bar-track"><span class="el-bar-fill" style="width:${(d.n / max) * 100}%"></span></span>
        <span class="el-bar-n">${nf.format(d.n)}</span>
      </div>`).join('');
    box.innerHTML =
      '<span class="crop-mark-bl" aria-hidden="true"></span><span class="crop-mark-br" aria-hidden="true"></span>' + rows;
  }

  async function loadEleicoes(): Promise<void> {
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    try {
      const res = await fetch(`${base}assets/data/eleicoes_pesquisas.json`, {
        cache: 'no-cache',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('fetch failed');
      const data: ElPayload = await res.json();
      if (!data.kpis) throw new Error('empty payload');
      renderKpis(data);
      renderTimeline(data);
      renderRanking(data);
      renderComo(data);
      renderUF(data);
    } catch {
      clearTimeout(timeoutId);
      ['el-timeline', 'el-ranking', 'el-uf'].forEach((id) => {
        const box = el(id);
        if (box) box.innerHTML = '<p class="el-error">dados indisponíveis — tente recarregar</p>';
      });
    }
  }

  document.addEventListener('DOMContentLoaded', loadEleicoes);
</script>

<script>
  // Motion — padrão nomeado `reveal-up` do site (GSAP + ScrollTrigger),
  // guardado por motionOk (respeita prefers-reduced-motion). Revela o hero e,
  // por seção, o cabeçalho e os cards com stagger. Mesmo padrão da página do
  // Data Stack Radar. Só transform/opacity; sem layout thrash.
  import { revealUp } from '../scripts/motion/reveal-up';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  function animateEleicoes(): void {
    if (!motionOk) return;

    const heroCard = document.querySelector('#eleicoes-hero .hero-card') as HTMLElement | null;
    if (heroCard) revealUp([heroCard], heroCard, 0);

    document.querySelectorAll<HTMLElement>('main section[id^="el-"]').forEach((sec) => {
      const head = sec.querySelector('.section-head') as HTMLElement | null;
      if (head) revealUp([head], sec, 0);
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.card'));
      if (cards.length) revealUp(cards, sec, STAGGER.tight);
    });
  }

  document.addEventListener('DOMContentLoaded', animateEleicoes);
</script>
