  // ── Mapa tile-cartograma do Brasil (geofacet br_states_grid1: 8×6, 27 UFs).
  //    Reusado por [03] intenção estadual e [10] explorar. Cada UF é um <button>
  //    posicionado por grid-row/col; seleção sincroniza com o combobox. Tiles
  //    indisponíveis ficam esmaecidos e não-focáveis. Sombra opcional = volume. ──
  const BR_TILES: [number, number, string][] = [
    [1, 2, 'RR'], [1, 3, 'AP'], [2, 2, 'AM'], [2, 3, 'PA'], [2, 4, 'MA'], [2, 5, 'CE'],
    [3, 1, 'AC'], [3, 2, 'RO'], [3, 3, 'TO'], [3, 4, 'PI'], [3, 5, 'PB'], [3, 6, 'RN'],
    [4, 2, 'MT'], [4, 3, 'GO'], [4, 4, 'BA'], [4, 5, 'PE'], [4, 6, 'AL'],
    [5, 2, 'MS'], [5, 3, 'DF'], [5, 4, 'MG'], [5, 5, 'SE'],
    [6, 3, 'SP'], [6, 4, 'RJ'], [6, 5, 'ES'],
    [7, 3, 'PR'], [7, 4, 'SC'], [8, 3, 'RS'],
  ];
  interface UfMapOpts { available: Set<string>; values?: Record<string, number>; valueLabel?: string; onSelect: (uf: string) => void; ariaLabel: string }
  function buildUfMap(containerId: string, opts: UfMapOpts): { setValue(uf: string): void } | null {
    const root = el(containerId); if (!root) return null;
    const maxVal = opts.values ? Math.max(...Object.values(opts.values), 1) : 1;
    const tiles = BR_TILES.map(([r, c, code]) => {
      const avail = opts.available.has(code);
      const v = opts.values?.[code];
      const shade = (avail && v != null) ? (0.14 + 0.46 * (v / maxVal)) : 0;
      const tip = avail ? barTip(UF_NAME[code] ?? code, (v != null && opts.valueLabel) ? [[opts.valueLabel, nf.format(v)]] : []) : '';
      return `<button type="button" class="el-map-tile${avail ? '' : ' is-off'}" data-uf="${code}" style="grid-column:${c};grid-row:${r};--tile-shade:${shade.toFixed(3)}"${avail ? '' : ' aria-disabled="true" tabindex="-1"'} aria-pressed="false" aria-label="${esc(UF_NAME[code] ?? code)}"${tip}>${code}</button>`;
    }).join('');
    root.innerHTML = `<div class="el-map" role="group" aria-label="${esc(opts.ariaLabel)}">${tiles}</div>`;
    const map = root.querySelector('.el-map') as HTMLElement;
    const setValue = (uf: string): void => {
      map.querySelectorAll('.el-map-tile').forEach((tEl) => {
        const on = (tEl as HTMLElement).dataset.uf === uf;
        tEl.classList.toggle('is-selected', on);
        tEl.setAttribute('aria-pressed', String(on));
      });
    };
    map.addEventListener('click', (e) => {
      const b = (e.target as HTMLElement).closest('.el-map-tile') as HTMLButtonElement | null;
      if (!b || b.classList.contains('is-off') || !b.dataset.uf) return;
      setValue(b.dataset.uf);
      opts.onSelect(b.dataset.uf);
    });
    return { setValue };
  }

  // ── Mapa de calor geográfico (choropleth) do Brasil — corrida a governador.
  //    Busca o SVG (27 UF paths com data-uf), pinta cada UF por intensidade da
  //    margem do líder (gold, apartidário) e injeta data-tip (o tooltip flutuante
  //    global cuida do hover). Clique/Enter seleciona → sincroniza os painéis. ──
  interface GeoInfo { heat: number; tip: { t: string; r: [string, string][] }; aria: string }
  interface GeoMapOpts { info: Record<string, GeoInfo>; onSelect?: (uf: string) => void; ariaLabel: string; legendId?: string; selectable?: boolean }
  function buildGeoMap(containerId: string, opts: GeoMapOpts): { setValue(uf: string): void } | null {
    const selectable = opts.selectable !== false;
    const root = el(containerId); if (!root) return null;
    const base: string = (document.body as HTMLElement).dataset.baseurl ?? '';
    let svg: SVGSVGElement | null = null;
    let pending = '';
    const applySel = (uf: string): void => {
      if (!svg) return;
      svg.querySelectorAll<SVGPathElement>('.br-state').forEach((p) => {
        const on = p.getAttribute('data-uf') === uf;
        p.classList.toggle('is-selected', on);
        if (p.classList.contains('is-avail')) p.setAttribute('aria-pressed', String(on));
      });
    };
    fetch(`${base}assets/img/maps/brazil-states.svg`, { cache: 'force-cache' })
      .then((r) => (r.ok ? r.text() : Promise.reject(new Error('svg'))))
      .then((txt) => {
        root.innerHTML = txt;
        svg = root.querySelector('svg');
        if (svg) { svg.classList.add('el-geo__svg'); svg.setAttribute('role', 'group'); svg.setAttribute('aria-label', opts.ariaLabel); }
        root.querySelectorAll<SVGPathElement>('.br-state').forEach((p) => {
          const uf = p.getAttribute('data-uf'); if (!uf) return;
          const info = opts.info[uf];
          if (info) {
            p.classList.add('is-avail');
            p.style.fill = `color-mix(in oklab, var(--wc-gold-ink) ${Math.round(info.heat * 100)}%, var(--paper-soft))`;
            p.setAttribute('aria-label', info.aria);
            p.setAttribute('data-tip', JSON.stringify(info.tip));
            if (selectable) { p.setAttribute('tabindex', '0'); p.setAttribute('role', 'button'); p.setAttribute('aria-pressed', 'false'); }
          } else {
            p.classList.add('is-off');
          }
        });
        if (opts.legendId) { const legend = el(opts.legendId); if (legend) { legend.hidden = false; legend.removeAttribute('aria-hidden'); } }
        if (pending) applySel(pending);
      })
      .catch(() => { root.innerHTML = `<p class="el-error mono-label">${esc(t('portfolio.eleicoes.map_unavailable', 'mapa indisponível'))}</p>`; });
    if (selectable) {
      const pick = (target: EventTarget | null): void => {
        const p = (target as Element)?.closest?.('.br-state.is-avail') as SVGPathElement | null;
        const uf = p?.getAttribute('data-uf'); if (!uf) return;
        applySel(uf); opts.onSelect?.(uf);
      };
      root.addEventListener('click', (e) => pick(e.target));
      root.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        if (!(e.target as Element)?.closest?.('.br-state.is-avail')) return;
        e.preventDefault(); pick(e.target);
      });
    }
    return { setValue(uf: string) { pending = uf; applySel(uf); } };
  }

  interface CBItem { value: string; label: string; }
  function buildCombobox(rootId: string, items: CBItem[], onSelect: (v: string) => void) {
    const root = document.getElementById(rootId); if (!root) return null;
    const input = root.querySelector('.el-combobox__input') as HTMLInputElement;
    const btn = root.querySelector('.el-combobox__btn') as HTMLButtonElement;
    const listbox = root.querySelector('.el-combobox__list') as HTMLElement;
    let filtered: CBItem[] = items.slice(), hi = -1, open = false, current = '';
    const norm = (s: string) => s.normalize('NFKD').replace(/[̀-ͯ]/g, '').toLowerCase();
    function render(): void {
      if (!filtered.length) { listbox.innerHTML = `<li class="el-combobox__empty" role="status">${esc(t('portfolio.eleicoes.uf_none', 'Nenhum estado'))}</li>`; return; }
      listbox.innerHTML = filtered.map((it, i) => {
        const sel = it.value === current, hl = i === hi;
        return `<li role="option" id="el-opt-${i}" data-value="${esc(it.value)}" aria-selected="${sel}" class="el-combobox__option${sel ? ' is-selected' : ''}${hl ? ' is-highlighted' : ''}">${esc(it.label)}</li>`;
      }).join('');
    }
    function filter(q: string): void { const qn = norm(q.trim()); filtered = qn ? items.filter((it) => norm(it.label).includes(qn)) : items.slice(); hi = qn && filtered.length ? 0 : -1; render(); }
    function openList(): void { if (open) return; open = true; listbox.hidden = false; input.setAttribute('aria-expanded', 'true'); filter(''); }
    function closeList(): void { if (!open) return; open = false; listbox.hidden = true; input.setAttribute('aria-expanded', 'false'); input.removeAttribute('aria-activedescendant'); const it = items.find((i) => i.value === current); input.value = it ? it.label : ''; }
    function setHi(i: number): void { hi = Math.max(-1, Math.min(i, filtered.length - 1)); Array.from(listbox.querySelectorAll('[role=option]')).forEach((li, j) => li.classList.toggle('is-highlighted', j === hi)); const elx = listbox.querySelector('.is-highlighted') as HTMLElement | null; if (elx) { elx.scrollIntoView({ block: 'nearest' }); input.setAttribute('aria-activedescendant', elx.id); } }
    function choose(v: string): void { current = v; const it = items.find((i) => i.value === v); input.value = it ? it.label : ''; onSelect(v); closeList(); }
    input.addEventListener('focus', openList);
    input.addEventListener('input', () => { if (!open) openList(); filter(input.value); });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); if (!open) { openList(); return; } setHi(hi + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setHi(hi - 1); }
      else if (e.key === 'Home' && open) { e.preventDefault(); setHi(0); }
      else if (e.key === 'End' && open) { e.preventDefault(); setHi(filtered.length - 1); }
      else if (e.key === 'Enter') { e.preventDefault(); if (hi >= 0 && filtered[hi]) choose(filtered[hi].value); }
      else if (e.key === 'Escape') { e.preventDefault(); closeList(); }
      else if (e.key === 'Tab') { if (open) closeList(); }
    });
    btn.addEventListener('click', (e) => { e.preventDefault(); if (open) closeList(); else { input.focus(); openList(); } });
    listbox.addEventListener('mousedown', (e) => e.preventDefault());
    listbox.addEventListener('click', (e) => { const li = (e.target as HTMLElement).closest('[role=option]') as HTMLElement | null; if (li?.dataset.value) choose(li.dataset.value); });
    document.addEventListener('mousedown', (e) => { if (!root.contains(e.target as Node) && open) closeList(); });
    return { setValue(v: string) { current = v; const it = items.find((i) => i.value === v); if (it) input.value = it.label; } };
  }

  let explorarBuilt = false;
  let ufCb: { setValue(v: string): void } | null = null;
  let ufMap: { setValue(v: string): void } | null = null;
  function initExplorar(data: ElPayload): void {
    const det = data.por_uf_detalhe ?? {};
    const ufs = Object.keys(det).filter((u) => u !== 'BR').sort((a, b) => (det[b]?.n ?? 0) - (det[a]?.n ?? 0));
    if (!ufs.length) return;
    if (!explorarBuilt) {
      const items = ufs.map((u) => ({ value: u, label: `${UF_NAME[u] ?? u} (${u})` }));
      const values: Record<string, number> = {};
      ufs.forEach((u) => { values[u] = det[u]?.n ?? 0; });
      const selectUf = (uf: string): void => { renderUFDetail(uf); ufCb?.setValue(uf); ufMap?.setValue(uf); };
      ufCb = buildCombobox('el-uf-combobox', items, selectUf) ?? null;
      ufMap = buildUfMap('el-uf-map', { available: new Set(ufs), values, valueLabel: t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), onSelect: selectUf, ariaLabel: t('portfolio.eleicoes.map_aria', 'Mapa de estados — clique para selecionar') });
      selectUf(ufs[0]);
      explorarBuilt = true;
    } else if (currentUf) {
      renderUFDetail(currentUf);
    }
  }

  // ── [02] intenção de voto + [03] eleitorado + [05] intensidade/UF + [10][11][12] ──
  let eleitorado: EleitoradoPayload | null = null;
  let contexto: ContextoPayload | null = null;
  let precand: PrecandPayload | null = null;
  let presReg: PresRegioesPayload | null = null;

  function fmtNum(v: number): string {
    if (v >= 1_000_000) return `${(v / 1_000_000).toLocaleString('pt-BR', { maximumFractionDigits: 1 })} mi`;
    if (v >= 1_000) return `${(v / 1_000).toLocaleString('pt-BR', { maximumFractionDigits: 0 })} mil`;
    return nf.format(v);
  }
  function distBars(boxId: string, raw: Dist[]): void {
    const box = el(boxId); if (!box) return;
    const items = (raw ?? []).filter((d) => d.n > 0);
    if (!items.length) { box.innerHTML = '<p class="el-error">indisponível</p>'; return; }
    const max = Math.max(...items.map((d) => d.pct), 1);
    box.innerHTML = items.map((d) => `<div class="el-bar-row"${barTip(d.label, [
      [t('portfolio.eleicoes.tip_eleitores', 'eleitores'), nf.format(d.n)],
      [t('portfolio.eleicoes.tip_percentual', 'percentual'), `${d.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%`],
    ])}>
      <span class="el-bar-lbl">${esc(d.label)}</span>
      <span class="el-bar-track"><span class="el-bar-fill" style="width:${(d.pct / max) * 100}%"></span></span>
      <span class="el-bar-n">${d.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
    </div>`).join('');
  }

  // ── Sparkline compacta (trajetória) a partir da série temporal ──
  function sparkSVG(vals: (number | null)[] | undefined, leader: boolean): string {
    if (!vals) return '';
    const pts = vals.map((v, i) => ({ v, i })).filter((p): p is { v: number; i: number } => p.v != null);
    if (pts.length < 2) return '';
    const W = 60, H = 18, P = 2;
    const xs = pts.map((p) => p.i), vs = pts.map((p) => p.v);
    const minX = Math.min(...xs), rangeX = (Math.max(...xs) - minX) || 1;
    const minV = Math.min(...vs), rangeV = (Math.max(...vs) - minV) || 1;
    const coords = pts.map((p) =>
      `${(P + ((p.i - minX) / rangeX) * (W - 2 * P)).toFixed(1)},${(P + (1 - (p.v - minV) / rangeV) * (H - 2 * P)).toFixed(1)}`
    ).join(' ');
    return `<svg class="el-spark" viewBox="0 0 ${W} ${H}" aria-hidden="true"><polyline class="el-spark-line${leader ? ' el-spark-line--gold' : ''}" points="${coords}"></polyline></svg>`;
  }

  // ── Helpers de intenção (reusados por presidencial [02] e estadual [03]) ──
  // `series` só é passada no presidencial → habilita a coluna de sparkline.
  function voteBarsHTML(cands: VoteCand[], series?: SerieTemporal): string {
    const max = Math.max(...cands.map((c) => c.media_recente), 1);
    const withSpark = !!series;
    return cands.map((c) => {
      const d = c.delta;
      const deltaHtml = d == null ? '' :
        `<span class="el-vote-delta ${d > 0 ? 'is-up' : d < 0 ? 'is-down' : ''}">${d > 0 ? '▲' : d < 0 ? '▼' : '–'} ${Math.abs(d).toLocaleString('pt-BR', { maximumFractionDigits: 1 })}</span>`;
      const sparkHtml = withSpark ? `<span class="el-vote-spark">${sparkSVG(series!.candidatos?.[c.nome], c.lider)}</span>` : '';
      const tip = barTip(`${c.nome} · ${c.partido}`, [
        [t('portfolio.eleicoes.tip_media', 'média recente'), `${c.media_recente.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%`],
        [t('portfolio.eleicoes.tip_ultima', 'última medição'), `${c.pct_ultima.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}% · ${c.instituto_ultima}`],
        [t('portfolio.eleicoes.tip_data', 'data'), fmtDate(c.data_ultima)],
        [t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), nf.format(c.n_pesquisas)],
      ]);
      return `<div class="el-vote-row${withSpark ? ' el-vote-row--spark' : ''}${c.lider ? ' is-leader' : ''}"${tip}>
        <span class="el-vote-name">${esc(c.nome)} <span class="el-vote-party mono-label">${esc(c.partido)}</span></span>
        <span class="el-vote-track"><span class="el-vote-fill" style="width:${(c.media_recente / max) * 100}%"></span></span>
        ${sparkHtml}
        <span class="el-vote-pct">${c.media_recente.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%${deltaHtml}</span>
      </div>`;
    }).join('');
  }
  function voteDuelsHTML(duels: VoteDuel[]): string {
    return duels.map((d) => {
      const aWin = d.a.pct >= d.b.pct;
      return `<div class="el-vote-duel">
        <div class="el-vote-duel__row">
          <span class="el-vote-duel__name">${esc(d.a.nome)} <span class="mono-label">${esc(d.a.partido)}</span></span>
          <span class="el-vote-duel__pct${aWin ? ' is-leader' : ''}">${d.a.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
        </div>
        <div class="el-vote-duel__bar"><span style="width:${d.a.pct}%" class="${aWin ? 'is-leader' : ''}"></span><span style="width:${d.b.pct}%" class="${!aWin ? 'is-leader' : ''}"></span></div>
        <div class="el-vote-duel__row">
          <span class="el-vote-duel__name">${esc(d.b.nome)} <span class="mono-label">${esc(d.b.partido)}</span></span>
          <span class="el-vote-duel__pct${!aWin ? ' is-leader' : ''}">${d.b.pct.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span>
        </div>
        <span class="el-vote-duel__src mono-label">${esc(d.instituto)} · ${esc(fmtDate(d.data))}</span>
      </div>`;
    }).join('');
  }
  function voteRefText(s: { janela_dias?: number; data_ref?: string; n_pesquisas?: number }): string {
    return `${t('portfolio.eleicoes.vote_ref', 'média dos últimos')} ${s.janela_dias ?? 90} ${t('portfolio.eleicoes.vote_ref_dias', 'dias · até')} ${fmtDate(s.data_ref)} · ${nf.format(s.n_pesquisas ?? 0)} ${t('portfolio.eleicoes.vote_ref_pesq', 'pesquisas')}`;
  }

  // ── [02] Série temporal — evolução da média do 1º turno (multi-linha SVG) ──
  // Segue o scaffolding do bandChart (brasil-cockpit): niceTicks no eixo Y,
  // grade (ticks + virada de ano), linha de base, uma polyline por candidato
  // (quebrada onde o valor é null). Líder em --wc-gold-ink; o "campo" em ink.
  function renderSerie(pc: PrecandPayload | null): void {
    const box = el('el-serie-svg'); const legendBox = el('el-serie-legend');
    if (!box) return;
    const st = pc?.serie_temporal;
    const cands = pc?.primeiro_turno?.candidatos ?? [];
    const fail = () => {
      box.innerHTML = `<p class="el-error mono-label">${esc(t('portfolio.eleicoes.serie_unavailable', 'série indisponível'))}</p>`;
      if (legendBox) legendBox.innerHTML = '';
    };
    if (!st || !st.meses?.length || !st.candidatos || !cands.length) { fail(); return; }
    const meses = st.meses;
    // Ordena pelo ranking do leaderboard; mantém só quem tem série com algum ponto.
    const series = cands
      .map((c) => ({ cand: c, vals: st.candidatos[c.nome] }))
      .filter((s) => Array.isArray(s.vals) && s.vals.some((v) => v != null))
      .slice(0, 5);
    if (!series.length) { fail(); return; }

    const W = 720, H = 300, PAD = { l: 40, r: 84, t: 18, b: 40 };
    const plotW = W - PAD.l - PAD.r, plotH = H - PAD.t - PAD.b;
    const allVals = series.flatMap((s) => s.vals.filter((v): v is number => v != null));
    const { ticks, niceMax } = niceTicks(0, Math.max(...allVals, 1) * 1.1, 5);
    const yMax = niceMax || 1;
    const xAt = (i: number) => PAD.l + (meses.length <= 1 ? 0 : (i / (meses.length - 1)) * plotW);
    const yAt = (v: number) => PAD.t + (1 - v / yMax) * plotH;

    const tickEls = ticks.map((v) => {
      const yy = yAt(v);
      return `<line class="el-band-tickline" x1="${PAD.l}" y1="${yy.toFixed(1)}" x2="${W - PAD.r}" y2="${yy.toFixed(1)}"></line>`
        + `<text class="el-band-ticklabel" x="${PAD.l - 6}" y="${(yy + 3).toFixed(1)}" text-anchor="end">${v}%</text>`;
    }).join('');

    const yearMarks: { i: number; yr: string }[] = [];
    let lastYear = '';
    meses.forEach((m, i) => { const yr = m.slice(0, 4); if (yr !== lastYear) { yearMarks.push({ i, yr }); lastYear = yr; } });
    const yearEls = yearMarks.map(({ i, yr }) => {
      const xx = xAt(i);
      return `<line class="el-band-tickline" x1="${xx.toFixed(1)}" y1="${PAD.t}" x2="${xx.toFixed(1)}" y2="${(H - PAD.b).toFixed(1)}"></line>`
        + `<text class="el-band-axislabel" x="${xx.toFixed(1)}" y="${H - PAD.b + 16}" text-anchor="middle">${esc(yr)}</text>`;
    }).join('');
    const baseline = `<line class="el-band-axisline" x1="${PAD.l}" y1="${(H - PAD.b).toFixed(1)}" x2="${W - PAD.r}" y2="${(H - PAD.b).toFixed(1)}"></line>`;

    const lines = series.map((s) => {
      const cls = s.cand.lider ? 'el-band-line--gold' : 'el-band-line--soft';
      // Quebra a linha em segmentos contíguos onde há valor (null → interrompe).
      const segs: string[] = []; let cur: string[] = [];
      s.vals.forEach((v, i) => {
        if (v == null) { if (cur.length > 1) segs.push(cur.join(' ')); cur = []; }
        else cur.push(`${xAt(i).toFixed(1)},${yAt(v).toFixed(1)}`);
      });
      if (cur.length > 1) segs.push(cur.join(' '));
      const poly = segs.map((pts) => `<polyline class="el-band-line ${cls}" points="${pts}"></polyline>`).join('');
      let lastI = -1; for (let i = s.vals.length - 1; i >= 0; i--) if (s.vals[i] != null) { lastI = i; break; }
      let marker = '';
      if (lastI >= 0) {
        const v = s.vals[lastI] as number, mx = xAt(lastI), my = yAt(v);
        const fillc = s.cand.lider ? 'var(--wc-gold-ink)' : 'var(--ink-soft)';
        marker = `<circle class="el-band-marker" cx="${mx.toFixed(1)}" cy="${my.toFixed(1)}" r="3.5" fill="${fillc}"></circle>`;
        if (s.cand.lider) marker += `<text class="el-band-markerval" x="${(mx - 6).toFixed(1)}" y="${(my - 8).toFixed(1)}" text-anchor="end" fill="var(--wc-gold-ink)">${v.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</text>`;
      }
      return poly + marker;
    }).join('');

    // Rótulo de nome no fim de cada linha — desambigua o "campo" (líder em gold).
    // Nome curto = último token sem parênteses; anti-sobreposição por cluster de x.
    interface EndLabel { name: string; x: number; y: number; li: number; leader: boolean }
    const shortName = (n: string): string => { const parts = n.replace(/\(.*\)/, '').trim().split(/\s+/); return parts.length > 1 ? parts[parts.length - 1] : parts[0]; };
    const labels: EndLabel[] = [];
    series.forEach((s) => {
      let li = -1; for (let i = s.vals.length - 1; i >= 0; i--) if (s.vals[i] != null) { li = i; break; }
      if (li >= 0) labels.push({ name: shortName(s.cand.nome), x: xAt(li) + 8, y: yAt(s.vals[li] as number), li, leader: s.cand.lider });
    });
    const MINGAP = 12, botY = H - PAD.b;
    const groups = new Map<number, EndLabel[]>();
    labels.forEach((l) => { const g = groups.get(l.li) ?? []; g.push(l); groups.set(l.li, g); });
    groups.forEach((g) => {
      g.sort((a, b) => a.y - b.y);
      for (let i = 1; i < g.length; i++) if (g[i].y < g[i - 1].y + MINGAP) g[i].y = g[i - 1].y + MINGAP;
      for (let i = g.length - 1; i >= 0; i--) { if (g[i].y > botY) g[i].y = botY; if (i > 0 && g[i].y - g[i - 1].y < MINGAP) g[i - 1].y = g[i].y - MINGAP; }
    });
    const labelEls = labels.map((l) => `<text class="el-band-endlabel${l.leader ? ' is-leader' : ''}" x="${l.x.toFixed(1)}" y="${(l.y + 3).toFixed(1)}" text-anchor="start">${esc(l.name)}</text>`).join('');

    const capture = `<rect class="el-band-capture" x="0" y="0" width="${W}" height="${H}"></rect>`;
    box.innerHTML = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="${esc(t('portfolio.eleicoes.serie_aria', 'Evolução da intenção de voto no 1º turno'))}">${tickEls}${yearEls}${baseline}${lines}${labelEls}${capture}</svg>`;
    if (legendBox) legendBox.innerHTML = series.map((s) =>
      `<span class="el-serie__lg${s.cand.lider ? ' is-leader' : ''}"><span class="el-serie__sw" aria-hidden="true"></span>${esc(s.cand.nome)} <span class="mono-label">${esc(s.cand.partido)}</span></span>`
    ).join('');

    attachChartHover(box, el('el-serie'), el('el-serie-tip'), W, PAD.t, H - PAD.b,
      (vx) => Math.max(0, Math.min(meses.length - 1, Math.round(((vx - PAD.l) / plotW) * (meses.length - 1)))),
      (idx) => {
        const rows = series
          .map((s) => ({ cand: s.cand, v: s.vals[idx] }))
          .filter((r): r is { cand: VoteCand; v: number } => r.v != null)
          .sort((a, b) => b.v - a.v);
        if (!rows.length) return null;
        const dots: HoverDot[] = rows.map((r) => ({ x: xAt(idx), y: yAt(r.v), color: r.cand.lider ? 'var(--wc-gold-ink)' : 'var(--ink-soft)' }));
        const head = `<div class="el-tip-head">${esc(fmtMesLong(meses[idx]))}</div>`;
        const body = rows.map((r) => `<div class="el-tip-row${r.cand.lider ? ' is-leader' : ''}"><span class="el-tip-name">${esc(r.cand.nome)} <span class="mono-label">${esc(r.cand.partido)}</span></span><span class="el-tip-val">${r.v.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%</span></div>`).join('');
        return { gx: xAt(idx), dots, html: head + body };
      });
  }

  // ── [02] Intenção de voto presidencial (pré-candidatos) ──
  function voteFail(): void {
    ['el-vote-1t', 'el-vote-2t'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">intenção indisponível — tente recarregar</p>'; });
    const chips = el('el-vote-chips'); if (chips) chips.innerHTML = '';
    const ref = el('el-vote-1t-ref'); if (ref) ref.textContent = '';
    renderSerie(null);
  }
  // ── [02b] Mapa presidencial por REGIÃO (bloco curado — 1 pesquisa citável).
  //    Reusa o choropleth: cada UF é pintada pela margem do líder na SUA região
  //    (4 macrorregiões — Norte+CO agrupados pela fonte). Só hover, sem seleção. ──
  let presRegBuilt = false;
  function renderPresRegioes(d: PresRegioesPayload | null): void {
    const wrap = el('el-reg'); if (!wrap) return;
    if (presRegBuilt || !d?.regioes || !d.ufs_por_regiao) return; // sem dado → fica hidden
    const HEAT_SCALE = 30; // pts de margem p/ saturação máxima
    const info: Record<string, GeoInfo> = {};
    Object.entries(d.ufs_por_regiao).forEach(([rk, ufs]) => {
      const r = d.regioes![rk]; if (!r?.candidatos?.length) return;
      const sorted = [...r.candidatos].sort((a, b) => b.pct - a.pct);
      const L = sorted[0], second = sorted[1];
      const margin = second ? Math.max(0, L.pct - second.pct) : L.pct;
      const heat = 0.12 + 0.76 * Math.min(1, margin / HEAT_SCALE);
      const rows: [string, string][] = sorted.slice(0, 5)
        .map((c) => [`${c.nome}${c.partido && c.partido !== '—' ? ` · ${c.partido}` : ''}`, `${c.pct}%`]);
      const tipTitle = `${r.nome}${r.agrupada ? ' *' : ''}${d.cenario ? ` · ${d.cenario}` : ''}`;
      ufs.forEach((u) => {
        info[u] = {
          heat,
          aria: `${UF_NAME[u] ?? u} — ${r.nome}: ${L.nome} ${t('portfolio.eleicoes.map_lidera', 'lidera com')} ${L.pct}%`,
          tip: { t: tipTitle, r: rows },
        };
      });
    });
    if (!Object.keys(info).length) return;
    buildGeoMap('el-reg-map', { info, ariaLabel: t('portfolio.eleicoes.reg_aria', 'Mapa presidencial por região'), legendId: 'el-reg-legend', selectable: false });
    const meta = el('el-reg-meta');
    if (meta) meta.textContent = [d.instituto, d.periodo, d.amostra ? `n=${nf.format(d.amostra)}` : '', d.registro_tse ? `TSE ${d.registro_tse}` : '']
      .filter(Boolean).join('  ·  ');
    const note = el('el-reg-mapnote');
    if (note) note.textContent = Object.values(d.regioes).some((r) => r.agrupada)
      ? `* ${t('portfolio.eleicoes.reg_agrupada', 'Norte e Centro-Oeste agrupados pela fonte — 4 macrorregiões, não 5.')}` : '';
    const disc = el('el-reg-disclaimer');
    if (disc && d.disclaimer) disc.textContent = d.disclaimer;
    wrap.hidden = false;
    presRegBuilt = true;
  }

  function renderPrecandidatos(pc: PrecandPayload | null): void {
    if (!pc || !pc.primeiro_turno || !pc.primeiro_turno.candidatos?.length) { voteFail(); return; }
    const pt = pc.primeiro_turno;
    const box1 = el('el-vote-1t');
    if (box1) box1.innerHTML = voteBarsHTML(pt.candidatos, pc.serie_temporal);
    const ref = el('el-vote-1t-ref');
    if (ref) ref.textContent = voteRefText(pt);
    renderSerie(pc);
    const box2 = el('el-vote-2t');
    if (box2) {
      const duels = (pc.segundo_turno ?? []).slice(0, 5);
      box2.innerHTML = duels.length ? voteDuelsHTML(duels) : '<p class="el-error">sem confrontos medidos</p>';
    }
    const chips = el('el-vote-chips');
    if (chips) chips.innerHTML = (pc.panorama ?? []).slice(0, 16)
      .map((p) => `<span class="el-chip">${esc(p.nome)} <span class="mono-label">${esc(p.partido)}</span></span>`).join('');
  }

  // ── [03] Intenção de voto estadual (governador + senador) ──
  let estaduais: EstaduaisPayload | null = null;
  let estBuilt = false;
  let currentEstUf = '';
  let estCb: { setValue(v: string): void } | null = null;
  let estMap: { setValue(v: string): void } | null = null;
  function renderEstadoDetail(uf: string): void {
    currentEstUf = uf;
    const est = estaduais?.estados?.[uf];
    const gov1 = el('el-est-gov1'), gov1ref = el('el-est-gov1-ref');
    const gov2 = el('el-est-gov2'), sen = el('el-est-sen'), senref = el('el-est-sen-ref');
    const semDados = t('portfolio.eleicoes.est_empty', 'sem pesquisas para este cargo');
    if (gov1) gov1.innerHTML = est?.governador_1t?.candidatos?.length ? voteBarsHTML(est.governador_1t.candidatos) : `<p class="el-error">${esc(semDados)}</p>`;
    if (gov1ref) gov1ref.textContent = est?.governador_1t ? voteRefText(est.governador_1t) : '';
    if (gov2) gov2.innerHTML = est?.governador_2t?.length ? voteDuelsHTML(est.governador_2t.slice(0, 4)) : `<p class="el-error">${esc(semDados)}</p>`;
    if (sen) sen.innerHTML = est?.senador?.candidatos?.length ? voteBarsHTML(est.senador.candidatos) : `<p class="el-error">${esc(semDados)}</p>`;
    if (senref) senref.textContent = est?.senador ? voteRefText(est.senador) : '';
  }
  function renderEstaduais(pc: EstaduaisPayload | null): void {
    const fail = (msg: string) => ['el-est-gov1', 'el-est-gov2', 'el-est-sen'].forEach((id) => { const b = el(id); if (b) b.innerHTML = `<p class="el-error">${esc(msg)}</p>`; });
    const ufs = pc?.ufs_disponiveis ?? [];
    if (!ufs.length) { fail(t('portfolio.eleicoes.est_unavailable', 'intenção estadual indisponível — tente recarregar')); return; }
    if (!estBuilt) {
      const items = ufs.map((u) => ({ value: u, label: `${UF_NAME[u] ?? u} (${u})` }));
      // Calor por UF = margem do líder na corrida a governador (1º turno). Sem
      // cor partidária: intensidade em gold; o tooltip carrega quem/quanto/volume.
      const HEAT_SCALE = 25; // pts de margem p/ saturação máxima
      const info: Record<string, GeoInfo> = {};
      let maxVol = 0, maxVolUf = '', tight = Infinity, tightUf = '';
      ufs.forEach((u) => {
        const g = pc!.estados?.[u]?.governador_1t;
        const cands = g?.candidatos ?? [];
        if (!cands.length) return;
        const sorted = [...cands].sort((a, b) => (b.media_recente ?? 0) - (a.media_recente ?? 0));
        const L = sorted.find((c) => c.lider) ?? sorted[0];
        const second = sorted.find((c) => c !== L);
        const margin = second ? Math.max(0, L.media_recente - second.media_recente) : L.media_recente;
        const vol = g?.n_pesquisas ?? 0;
        const d = L.delta;
        const trend = d == null ? '—' : `${d > 0 ? '▲' : d < 0 ? '▼' : '–'} ${Math.abs(d).toLocaleString('pt-BR', { maximumFractionDigits: 1 })}`;
        const pct = L.media_recente.toLocaleString('pt-BR', { maximumFractionDigits: 1 });
        info[u] = {
          heat: 0.12 + 0.76 * Math.min(1, margin / HEAT_SCALE),
          aria: `${UF_NAME[u] ?? u}: ${L.nome} ${t('portfolio.eleicoes.map_lidera', 'lidera com')} ${pct}%`,
          tip: {
            t: `${UF_NAME[u] ?? u} · ${t('portfolio.eleicoes.est_gov_1t', 'governador · 1º turno')}`,
            r: [
              [t('portfolio.eleicoes.map_lider', 'líder'), `${L.nome} · ${L.partido}`],
              [t('portfolio.eleicoes.map_int', 'intenção'), `${pct}%`],
              [t('portfolio.eleicoes.map_margem', 'margem s/ 2º'), second ? `+${margin.toLocaleString('pt-BR', { maximumFractionDigits: 1 })} pts` : '—'],
              [t('portfolio.eleicoes.map_tend', 'tendência'), trend],
              [t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), nf.format(vol)],
            ],
          },
        };
        if (vol > maxVol) { maxVol = vol; maxVolUf = u; }
        if (second && margin < tight) { tight = margin; tightUf = u; }
      });
      const note = el('el-est-mapnote');
      if (note) {
        const parts: string[] = [];
        if (maxVolUf) parts.push(`${t('portfolio.eleicoes.map_mais_medido', 'mais medido')}: ${maxVolUf} (${nf.format(maxVol)} ${t('portfolio.eleicoes.tip_pesquisas', 'pesquisas')})`);
        if (tightUf) parts.push(`${t('portfolio.eleicoes.map_acirrada', 'disputa mais acirrada')}: ${tightUf} (+${tight.toLocaleString('pt-BR', { maximumFractionDigits: 1 })} pts)`);
        note.textContent = parts.join('  ·  ');
      }
      const selectEst = (uf: string): void => { renderEstadoDetail(uf); estCb?.setValue(uf); estMap?.setValue(uf); };
      estCb = buildCombobox('el-est-combobox', items, selectEst) ?? null;
      estMap = buildGeoMap('el-est-map', { info, onSelect: selectEst, legendId: 'el-est-legend', ariaLabel: t('portfolio.eleicoes.map_aria', 'Mapa de estados — clique para selecionar') });
      selectEst(ufs[0]);
      estBuilt = true;
    } else if (currentEstUf) {
      renderEstadoDetail(currentEstUf);
    }
  }

  function renderEleitorado(e: EleitoradoPayload | null): void {
    if (!e) {
      if (el('el-elt-total')) el('el-elt-total')!.textContent = '—';
      ['el-elt-genero', 'el-elt-faixa', 'el-elt-escol'].forEach((id) => { const b = el(id); if (b) b.innerHTML = '<p class="el-error">perfil indisponível</p>'; });
      return;
    }
    if (el('el-elt-total')) el('el-elt-total')!.textContent = e.total_eleitores ? fmtNum(e.total_eleitores) : '—';
    const d = e.destaques ?? {};
    const chips: string[] = [];
    if (d.feminino_pct != null) chips.push(`${d.feminino_pct}% ${t('portfolio.eleicoes.elt_chip_mulheres', 'mulheres')}`);
    if (e.biometria?.pct != null) chips.push(`${e.biometria.pct}% ${t('portfolio.eleicoes.elt_chip_bio', 'com biometria')}`);
    if (d.jovens_16_17) chips.push(`${fmtNum(d.jovens_16_17)} ${t('portfolio.eleicoes.elt_chip_jovens', 'jovens 16–17')}`);
    if (d.idosos_70mais) chips.push(`${fmtNum(d.idosos_70mais)} ${t('portfolio.eleicoes.elt_chip_idosos', 'com 70+')}`);
    if (d.analfabetos?.pct != null) chips.push(`${d.analfabetos.pct}% ${t('portfolio.eleicoes.elt_chip_analf', 'analfabetos')}`);
    if (e.exterior?.eleitores) chips.push(`${fmtNum(e.exterior.eleitores)} ${t('portfolio.eleicoes.elt_chip_exterior', 'no exterior')}`);
    const chipsBox = el('el-elt-chips');
    if (chipsBox) chipsBox.innerHTML = chips.map((c) => `<span class="el-chip">${esc(c)}</span>`).join('');
    // sexo → split (feminino vs masculino)
    const gbox = el('el-elt-genero');
    if (gbox && e.genero?.length) {
      const total = e.genero.reduce((s, x) => s + x.n, 0);
      gbox.innerHTML = e.genero.filter((g) => g.n > 0)
        .map((g, i) => splitRow(g.label, g.n, total, i > 0)).join('');
    }
    distBars('el-elt-faixa', e.faixa_etaria ?? []);
    distBars('el-elt-escol', e.escolaridade ?? []);
  }

  // ── [04] Índice de intensidade por UF (pesquisas ÷ eleitores em milhões) ──
  function renderIntensidadeUF(p: ElPayload, e: EleitoradoPayload | null): void {
    const box = el('el-iuf-body'); if (!box) return;
    const elt = e?.por_uf ?? [];
    if (!elt.length || !(p.por_uf ?? []).length) { box.innerHTML = '<p class="el-error">índice indisponível</p>'; return; }
    const pop: Record<string, number> = {};
    elt.forEach((u) => { pop[u.uf] = u.eleitores; });
    const rows = (p.por_uf ?? [])
      .filter((d) => d.uf && d.uf !== 'BR' && pop[d.uf])
      .map((d) => ({ uf: d.uf, idx: d.n / (pop[d.uf] / 1_000_000), n: d.n, elei: pop[d.uf] }))
      .sort((a, b) => b.idx - a.idx)
      .slice(0, 14);
    if (!rows.length) { box.innerHTML = '<p class="el-error">índice indisponível</p>'; return; }
    const max = Math.max(...rows.map((r) => r.idx), 1);
    box.innerHTML = `<div class="el-uf-grid">` + rows.map((r, i) => `<div class="el-uf-row${i === 0 ? ' is-leader' : ''}"${barTip(UF_NAME[r.uf] ?? r.uf, [
      [t('portfolio.eleicoes.tip_indice', 'índice (pesq/mi eleitores)'), r.idx.toLocaleString('pt-BR', { maximumFractionDigits: 1 })],
      [t('portfolio.eleicoes.tip_pesquisas', 'pesquisas'), nf.format(r.n)],
      [t('portfolio.eleicoes.tip_eleitores', 'eleitores'), fmtNum(r.elei)],
    ])}>
      <span class="el-uf-uf">${esc(r.uf)}</span>
      <span class="el-uf-track"><span class="el-uf-fill" style="width:${(r.idx / max) * 100}%"></span></span>
      <span class="el-uf-n">${r.idx.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}</span>
    </div>`).join('') + `</div>`;
  }

