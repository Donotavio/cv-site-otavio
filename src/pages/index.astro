---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Events from '../components/Events.astro';
import About from '../components/About.astro';
import ArchitectureFlow from '../components/ArchitectureFlow.astro';
import Impact from '../components/Impact.astro';
import AiDelivery from '../components/AiDelivery.astro';
import EnrichmentMachine from '../components/EnrichmentMachine.astro';
import Timeline from '../components/Timeline.astro';
import Skills from '../components/Skills.astro';
import TechStack from '../components/TechStack.astro';
import Projects from '../components/Projects.astro';
import PortfolioIndex from '../components/PortfolioIndex.astro';
import PixObservatoryPanel from '../components/PixObservatoryPanel.astro';
import DataStackRadarCard from '../components/DataStackRadarCard.astro';
import EleicoesCard from '../components/EleicoesCard.astro';
import BrasilCockpitCard from '../components/BrasilCockpitCard.astro';
import WorldCupCard from '../components/WorldCupCard.astro';
import EduInteligenciaCard from '../components/EduInteligenciaCard.astro';
import SaulGoodmanCard from '../components/SaulGoodmanCard.astro';
import GitHubStats from '../components/GitHubStats.astro';
import Blog from '../components/Blog.astro';
import Recommendations from '../components/Recommendations.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <Hero />
    <Events />
    <About />
    <ArchitectureFlow />
    <Impact />
    <AiDelivery />
    <EnrichmentMachine />
    <Timeline />
    <Skills />
    <TechStack />
    <Projects />
    <PortfolioIndex>
      <EleicoesCard slot="eleicoes" />
      <PixObservatoryPanel slot="pix" />
      <EduInteligenciaCard slot="edu" />
      <DataStackRadarCard slot="radar" />
      <BrasilCockpitCard slot="cockpit" />
      <WorldCupCard slot="worldcup" />
      <SaulGoodmanCard slot="saul" />
    </PortfolioIndex>
    <GitHubStats />
    <Blog />
    <Recommendations />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
