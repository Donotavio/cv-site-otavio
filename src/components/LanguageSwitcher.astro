---
/**
 * LanguageSwitcher.astro — frontend-builder + motion-engineer
 * Direção: Blueprint (DESIGN.md)
 *
 * Skills consultadas:
 *   src/styles/tokens.css            — tokens Blueprint, zero hex
 *   .opencode/skills/content-i18n.md — .lang-btn + data-lang exigidos por i18n.js
 *
 * Três botões PT | EN | ES em mono.
 * Classes .lang-btn e data-lang são obrigatórias para i18n.js funcionar.
 * Estado ativo (.active) é gerenciado pelo i18n.js em runtime — sem JS aqui.
 * Separadores · entre botões, em --ink-faint.
 */
---

<div class="lang-switcher" role="group" aria-label="Language / Idioma">
  <button class="lang-btn" data-lang="pt-BR" type="button">PT</button>
  <span class="lang-sep" aria-hidden="true">/</span>
  <button class="lang-btn" data-lang="en-US" type="button">EN</button>
  <span class="lang-sep" aria-hidden="true">/</span>
  <button class="lang-btn" data-lang="es-ES" type="button">ES</button>
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .lang-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    color: var(--ink-faint);
    background: transparent;
    border: none;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition-fast);
    line-height: var(--leading-tight);
  }

  .lang-btn:hover {
    color: var(--ink);
  }

  .lang-btn.active {
    color: var(--accent);
  }

  .lang-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Sem hover em touch */
  @media (hover: none) {
    .lang-btn:hover {
      color: var(--ink-faint);
    }
    .lang-btn.active:hover {
      color: var(--accent);
    }
  }

  .lang-sep {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--line-strong);
    user-select: none;
    line-height: var(--leading-tight);
  }
</style>
