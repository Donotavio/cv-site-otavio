---
/**
 * GitHubStats.astro — Seção [ ~/.git ] — Direção Blueprint
 *
 * Renderização 100% Astro/SSR (sem innerHTML/DOM): os dados vêm de
 * `assets/data/github_activity.json` importado em build-time (regenerado pelo
 * `fetch_github_data.py` no CI diário). Summary, seletor de ano, heatmap de
 * TODOS os anos (só o selecionado visível) e barras de linguagem nascem no
 * HTML — o JS só faz motion e a troca de ano (alterna visibilidade, não recria
 * DOM). Isso elimina a defasagem de cache do antigo fetch client-side.
 *
 * NÃO está no menu Navigation. Motion: hairlineDraw + revealUp + count-up +
 * varredura do heatmap + crescimento das barras (scaleX). Tudo gated por
 * motionOk; troca de idioma via data-i18n-key (labels).
 */
import { t } from '../lib/i18n';
import githubData from '../../assets/data/github_activity.json';

interface CalendarDay { date: string; count: number; weekday: number; }
interface CalendarYear { year: number; total: number; days: CalendarDay[]; }
interface Language { name: string; bytes: number; percentage: number; }

const gh = githubData as {
  summary?: { public_repos?: number; total_stars?: number; contributions_last_year?: number };
  top_languages?: Language[];
  contributions_calendar?: Record<string, CalendarYear>;
};

const summary = gh.summary ?? {};
const calendar = gh.contributions_calendar ?? {};
const years = Object.keys(calendar).sort();          // ['2022'…'2026']
const currentYear = years[years.length - 1] ?? '';
const totalContributions = Object.values(calendar).reduce((a, y) => a + (y.total ?? 0), 0);
const languages = (gh.top_languages ?? []).slice(0, 6);

const summaryCards = [
  { key: 'public_repos', value: summary.public_repos ?? 0, labelKey: 'stats.labels.repos' },
  { key: 'total_stars', value: summary.total_stars ?? 0, labelKey: 'stats.labels.stars' },
  { key: 'contributions', value: totalContributions, labelKey: 'stats.labels.contributions' },
];

/** Mapeia uma contagem de commits para um nível 0–4 de intensidade. */
const level = (c: number) => (c <= 0 ? 0 : c < 3 ? 1 : c < 6 ? 2 : c < 10 ? 3 : 4);

// Pré-computa o heatmap de cada ano (lead de alinhamento + células por dia).
const heatmaps = years.map((y) => {
  const days = calendar[y]?.days ?? [];
  return {
    year: y,
    total: calendar[y]?.total ?? 0,
    lead: days[0]?.weekday ?? 0,
    cells: days.map((d) => ({ lvl: level(d.count), title: `${d.date}: ${d.count}` })),
  };
});
---

<section id="stats" class="section stats" aria-labelledby="stats-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">~/.git</span>
      <h2 id="stats-title" class="stats-display" data-i18n-key="stats.title">{t('stats.title')}</h2>
      <p class="stats-lead" data-i18n-key="stats.subtitle">{t('stats.subtitle')}</p>
    </div>

    <hr class="section-line" aria-hidden="true" />

    <!-- Summary cards -->
    <ul class="stats-summary" aria-label="GitHub summary">
      {summaryCards.map((c) => (
        <li class="summary-card crop">
          <span class="crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark-br" aria-hidden="true"></span>
          <span class="summary-value" data-summary={c.key} data-count-to={c.value}>{c.value}</span>
          <span class="summary-label mono-label" data-i18n-key={c.labelKey}>{t(c.labelKey)}</span>
        </li>
      ))}
    </ul>

    <!-- Heatmap de contribuições -->
    <div class="stats-block crop">
      <span class="crop-mark-bl" aria-hidden="true"></span>
      <span class="crop-mark-br" aria-hidden="true"></span>
      <div class="block-head">
        <h3 class="block-title mono-label" data-i18n-key="stats.contributions_title">{t('stats.contributions_title')}</h3>
        <div class="year-tabs" role="tablist" aria-label="years">
          {years.map((y) => (
            <button
              class:list={['year-tab', { 'is-active': y === currentYear }]}
              role="tab"
              type="button"
              data-year={y}
              aria-selected={y === currentYear ? 'true' : 'false'}
            >{y}</button>
          ))}
        </div>
      </div>

      <!-- Total do ano selecionado -->
      <p class="heatmap-total" aria-live="polite">
        <span class="heatmap-total-num" data-year-total>{(calendar[currentYear]?.total ?? 0).toLocaleString('pt-BR')}</span>
        <span class="heatmap-total-label" data-i18n-key="stats.labels.contributions">{t('stats.labels.contributions')}</span>
        <span aria-hidden="true"> · </span>
        <span class="heatmap-total-year" data-year-label>{currentYear}</span>
      </p>

      <div class="heatmap-scroll">
        {heatmaps.map((h) => (
          <div class="heatmap" data-year={h.year} hidden={h.year !== currentYear} aria-hidden="true">
            {Array.from({ length: h.lead }).map(() => (
              <span class="heat-cell heat-cell--pad"></span>
            ))}
            {h.cells.map((cell) => (
              <span class="heat-cell" data-lvl={cell.lvl} title={cell.title}></span>
            ))}
          </div>
        ))}
      </div>

      <div class="heatmap-legend">
        <span class="mono-label" data-i18n-key="stats.less">{t('stats.less')}</span>
        <span class="legend-cells" aria-hidden="true">
          <i class="legend-cell" data-lvl="0"></i>
          <i class="legend-cell" data-lvl="1"></i>
          <i class="legend-cell" data-lvl="2"></i>
          <i class="legend-cell" data-lvl="3"></i>
          <i class="legend-cell" data-lvl="4"></i>
        </span>
        <span class="mono-label" data-i18n-key="stats.more">{t('stats.more')}</span>
      </div>
    </div>

    <!-- Top linguagens -->
    <div class="stats-block crop">
      <span class="crop-mark-bl" aria-hidden="true"></span>
      <span class="crop-mark-br" aria-hidden="true"></span>
      <h3 class="block-title mono-label" data-i18n-key="stats.labels.languages">{t('stats.labels.languages')}</h3>
      <ul class="lang-list">
        {languages.map((l) => (
          <li class="lang-row">
            <span class="lang-name">{l.name}</span>
            <span class="lang-pct">{l.percentage.toFixed(2)}%</span>
            <span class="lang-track"><span class="lang-fill" style={`width:${l.percentage}%`} data-pct={l.percentage}></span></span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .stats { background: var(--paper); }

  .stats-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .stats-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line { margin-block-end: var(--space-12); }

  /* ── Summary cards ───────────────────────────────────────── */
  .stats-summary {
    list-style: none;
    margin: 0 0 var(--space-8) 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .stats-summary { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }

  .summary-card {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition-normal);
  }
  .summary-card:hover { border-color: var(--line-strong); }

  .summary-value {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 500;
    color: var(--accent);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
  }

  .summary-label { margin: 0; }

  /* ── Blocks (heatmap + linguagens) ───────────────────────── */
  .stats-block {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    margin-block-end: var(--space-6);
  }
  .stats-block:last-child { margin-block-end: 0; }

  .block-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-block-end: var(--space-4);
  }

  .block-title { margin: 0; }

  /* ── Year tabs ───────────────────────────────────────────── */
  .year-tabs {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .year-tab {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background-color var(--transition-fast);
  }
  .year-tab:hover { border-color: var(--line-strong); color: var(--ink); }
  .year-tab.is-active,
  .year-tab[aria-selected='true'] {
    color: var(--accent);
    border-color: var(--line-accent);
    background: var(--accent-dim);
  }
  .year-tab:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* ── Total do ano ────────────────────────────────────────── */
  .heatmap-total {
    margin: 0 0 var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-faint);
  }
  .heatmap-total-num {
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    margin-inline-end: 0.4em;
  }
  .heatmap-total-year { font-family: var(--font-mono); color: var(--ink-soft); }

  /* ── Heatmap ─────────────────────────────────────────────── */
  .heatmap-scroll {
    overflow-x: auto;
    padding-block-end: var(--space-2);
  }
  .heatmap {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 1fr);
    gap: 3px;
    min-width: max-content;
  }
  .heatmap[hidden] { display: none; }

  .heat-cell {
    width: 11px;
    height: 11px;
    border-radius: var(--radius-sm);
    background: var(--line);
  }
  .heat-cell--pad { visibility: hidden; }
  /* tons crescentes de --accent por nível de intensidade */
  .heat-cell[data-lvl='1'] { background: rgba(26, 26, 255, 0.25); }
  .heat-cell[data-lvl='2'] { background: rgba(26, 26, 255, 0.45); }
  .heat-cell[data-lvl='3'] { background: rgba(26, 26, 255, 0.70); }
  .heat-cell[data-lvl='4'] { background: var(--accent); }

  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-block-start: var(--space-4);
  }
  .legend-cells { display: inline-flex; gap: 3px; }
  .legend-cell {
    width: 11px;
    height: 11px;
    border-radius: var(--radius-sm);
    background: var(--line);
    display: inline-block;
  }
  .legend-cell[data-lvl='1'] { background: rgba(26, 26, 255, 0.25); }
  .legend-cell[data-lvl='2'] { background: rgba(26, 26, 255, 0.45); }
  .legend-cell[data-lvl='3'] { background: rgba(26, 26, 255, 0.70); }
  .legend-cell[data-lvl='4'] { background: var(--accent); }

  /* ── Top linguagens ──────────────────────────────────────── */
  .lang-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .lang-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
  }
  .lang-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
  }
  .lang-pct {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .lang-track {
    grid-column: 1 / -1;
    height: 3px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .lang-fill {
    display: block;
    height: 100%;
    background: var(--accent);
    border-radius: var(--radius-full);
    transform-origin: left center;
  }
</style>

<script>
  import gsap from 'gsap';
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { countUp } from '../scripts/motion/count-up';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { DURATIONS, EASINGS, motionOk } from '../scripts/motion/constants';

  gsap.registerPlugin(ScrollTrigger);

  let contentMotionDone = false;

  /** Varredura dos quadradinhos do heatmap visível (opacity/scale, once). */
  function sweepHeatmap(section: HTMLElement) {
    if (!motionOk) return;
    const active = section.querySelector<HTMLElement>('.heatmap:not([hidden])');
    if (!active) return;
    const cells = active.querySelectorAll('.heat-cell:not(.heat-cell--pad)');
    if (!cells.length) return;
    gsap.from(cells, {
      opacity: 0,
      scale: 0.4,
      duration: DURATIONS.fast,
      ease: EASINGS.out,
      stagger: { each: 0.0015, from: 'start' },
    });
  }

  /** Motion de conteúdo (count-up + heatmap + barras), UMA vez, à vista. */
  function runContentMotion(section: HTMLElement) {
    if (contentMotionDone || !motionOk) return;
    contentMotionDone = true;

    section.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el) => {
      el.textContent = '0';
      countUp(el);
    });

    sweepHeatmap(section);

    section.querySelectorAll<HTMLElement>('.lang-fill').forEach((fill, i) => {
      gsap.fromTo(fill, { scaleX: 0 }, {
        scaleX: 1,
        duration: DURATIONS.slow,
        ease: EASINGS.outStrong,
        delay: i * 0.06,
      });
    });
  }

  /** Troca o ano exibido: alterna visibilidade (sem recriar DOM). */
  function activateYear(section: HTMLElement, year: string) {
    section.querySelectorAll<HTMLButtonElement>('.year-tab').forEach((tab) => {
      const on = tab.dataset.year === year;
      tab.setAttribute('aria-selected', String(on));
      tab.classList.toggle('is-active', on);
    });
    section.querySelectorAll<HTMLElement>('.heatmap').forEach((hm) => {
      hm.hidden = hm.dataset.year !== year;
    });
    // Atualiza o total do ano (soma real das contagens lidas dos títulos).
    const label = section.querySelector<HTMLElement>('[data-year-label]');
    if (label) label.textContent = year;
    const totalEl = section.querySelector<HTMLElement>('[data-year-total]');
    const active = section.querySelector<HTMLElement>('.heatmap:not([hidden])');
    if (totalEl && active) {
      // soma real das contagens via títulos das células "date: N"
      let sum = 0;
      active.querySelectorAll<HTMLElement>('.heat-cell:not(.heat-cell--pad)').forEach((c) => {
        const n = parseInt((c.title.split(':')[1] ?? '').trim(), 10);
        if (!Number.isNaN(n)) sum += n;
      });
      totalEl.textContent = sum.toLocaleString('pt-BR');
    }
    if (motionOk) sweepHeatmap(section);
  }

  document.addEventListener('astro:page-load', () => {
    const section = document.getElementById('stats');
    if (!section) return;

    const line = section.querySelector('.section-line') as Element | null;
    const head = section.querySelector('.section-head') as Element | null;

    if (line) hairlineDraw(line, section);
    if (motionOk && head) revealUp([head], section, 0);
    if (motionOk) {
      revealUp(section.querySelectorAll('.summary-card'), section, 0.08);
      revealUp(section.querySelectorAll('.stats-block'), section, 0.1);
    }

    // Troca de ano (delegação — sobrevive a re-render de idioma dos labels).
    const tabs = section.querySelector('.year-tabs');
    tabs?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.year-tab');
      if (btn?.dataset.year) activateYear(section as HTMLElement, btn.dataset.year);
    });

    // Motion de conteúdo quando a seção entra em cena (once). Sem motion /
    // sem JS, os valores/heatmap/barras já estão no HTML (SSR).
    if (motionOk) {
      ScrollTrigger.create({
        trigger: section,
        start: 'top 80%',
        once: true,
        onEnter: () => runContentMotion(section as HTMLElement),
      });
    }
  });
</script>
