---
/**
 * TechStack.astro — Seção [ 05 ] — Direção Blueprint (fundo --paper-soft)
 * Grid de tecnologias por categoria: logo + nome + nível como .tag.
 * Marquee horizontal de logos no topo (pausa no hover / reduced-motion).
 * Dados: fetch tech_stack.json. Motion: hairlineDraw + revealUp (categorias).
 */
---

<section id="tech-stack" class="section tech-stack" aria-labelledby="tech-stack-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">05</span>
      <h2 id="tech-stack-title" class="ts-display" data-i18n-key="tech_stack.title"></h2>
      <p class="ts-lead" data-i18n-key="tech_stack.subtitle"></p>
    </div>

    <hr class="section-line" aria-hidden="true" />
  </div>

  <!-- Marquee de logos (full-bleed) -->
  <div class="ts-marquee" aria-hidden="true">
    <div id="ts-marquee-track" class="ts-marquee__track"></div>
  </div>

  <div class="container">
    <div id="tech-stack-grid" class="ts-grid"></div>
  </div>
</section>

<style>
  .tech-stack {
    background: var(--paper-soft);
  }

  .ts-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .ts-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line {
    margin-block-end: var(--space-12);
  }

  /* ── Marquee ─────────────────────────────────────────────── */
  .ts-marquee {
    overflow: hidden;
    border-block: 1px solid var(--line);
    padding-block: var(--space-6);
    margin-block-end: var(--space-12);
    -webkit-mask-image: linear-gradient(90deg, transparent, var(--ink) 8%, var(--ink) 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, var(--ink) 8%, var(--ink) 92%, transparent);
  }

  .ts-marquee__track {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    width: max-content;
    animation: ts-scroll 32s linear infinite;
  }

  .ts-marquee:hover .ts-marquee__track {
    animation-play-state: paused;
  }

  .ts-marquee__logo {
    height: 28px;
    width: auto;
    object-fit: contain;
    opacity: 0.7;
    flex-shrink: 0;
  }

  @keyframes ts-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ts-marquee__track { animation: none; }
  }

  /* ── Grid de categorias ──────────────────────────────────── */
  .ts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .ts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .ts-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Categoria ───────────────────────────────────────────── */
  .ts-category {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    transition: border-color var(--transition-normal);
  }

  .ts-category:hover { border-color: var(--line-strong); }

  .ts-category__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--line);
  }
  .ts-category__name::before { content: '[ '; }
  .ts-category__name::after  { content: ' ]'; }

  .ts-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ts-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .ts-item__logo {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    object-fit: contain;
  }

  .ts-item__name {
    flex: 1;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk } from '../scripts/motion/constants';

  const baseUrl: string = (document.body as HTMLElement).dataset.baseurl ?? '';

  interface Technology {
    name: string;
    level: 'expert' | 'advanced' | 'intermediate';
    logo: string;
  }

  interface Category {
    name: string;
    icon: string;
    technologies: Technology[];
  }

  function levelTagClass(level: string): string {
    return level === 'expert' ? 'tag tag--accent' : 'tag';
  }

  function renderMarquee(categories: Category[]) {
    const track = document.getElementById('ts-marquee-track');
    if (!track) return;
    const logos = categories.flatMap((c) => c.technologies ?? []);
    // Duplicar a sequência para loop contínuo (-50% no keyframe)
    const seq = [...logos, ...logos];
    track.innerHTML = seq
      .map(
        (t) =>
          `<img class="ts-marquee__logo" src="${t.logo}" alt="" loading="lazy" onerror="this.style.display='none'">`
      )
      .join('');
  }

  async function renderTechStack() {
    const grid = document.getElementById('tech-stack-grid') as HTMLElement;
    if (!grid) return;

    let data: { categories?: Category[] } = {};
    try {
      const res = await fetch(`${baseUrl}assets/data/tech_stack.json`);
      if (!res.ok) throw new Error('fetch failed');
      data = await res.json();
    } catch {
      return;
    }

    const categories: Category[] = data.categories ?? [];
    grid.innerHTML = '';
    renderMarquee(categories);

    categories.forEach((cat) => {
      const div = document.createElement('div');
      div.className = 'ts-category';

      const itemsHtml = (cat.technologies ?? [])
        .map((tech) => {
          const levelLabel = window.i18n?.t(`tech_stack.level_${tech.level}`) ?? tech.level;
          const tagClass = levelTagClass(tech.level);
          return `
            <div class="ts-item">
              <img
                class="ts-item__logo"
                src="${tech.logo}"
                alt="${tech.name}"
                loading="lazy"
                onerror="this.style.display='none'"
              >
              <span class="ts-item__name">${tech.name}</span>
              <span class="${tagClass}">${levelLabel}</span>
            </div>
          `;
        })
        .join('');

      div.innerHTML = `
        <h3 class="ts-category__name">${cat.name}</h3>
        <div class="ts-items">${itemsHtml}</div>
      `;

      grid.appendChild(div);
    });

    const cards = grid.querySelectorAll<Element>('.ts-category');
    revealUp(cards, grid, 0.08);
  }

  // ─── Section line hairline + head reveal ─────────────────────
  const section = document.getElementById('tech-stack');
  if (section) {
    const line = section.querySelector('.section-line') as Element;
    const head = section.querySelector('.section-head') as Element;
    if (line) hairlineDraw(line, section);
    if (motionOk && head) revealUp([head], section, 0);
  }

  // ─── i18n ────────────────────────────────────────────────────
  window.addEventListener('languageChanged', () => renderTechStack());

  if (window.i18n) {
    renderTechStack();
  } else {
    window.addEventListener('languageChanged', () => renderTechStack(), { once: true });
  }
</script>
