---
/**
 * TechStack.astro
 * Grade de tecnologias — carrega tech_stack.json em runtime.
 *
 * Regras aplicadas:
 *  - design-system.md: zero hex, CSS scoped, tokens apenas, mobile-first
 *  - web-motion.md: revealUp com stagger 0.08 nas categorias, motionOk verificado
 *  - content-i18n.md: data-i18n-key para UI, fetch() para dados,
 *                     window.i18n.t() para nível em JS
 */
---

<section id="tech-stack" class="section section--soft">
  <div class="container">
    <div class="section-header">
      <h2 data-i18n-key="tech_stack.title"></h2>
      <p class="section-subtitle" data-i18n-key="tech_stack.subtitle"></p>
    </div>

    <div id="tech-stack-grid" class="ts-grid"></div>
  </div>
</section>

<style>
  /* ── Section ─────────────────────────────────────────────── */
  .section {
    padding-block: var(--space-20);
  }

  .section--soft {
    background: var(--bg-soft);
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    color: var(--text);
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--muted);
    line-height: var(--leading-normal);
  }

  /* ── Grid de categorias ──────────────────────────────────── */
  .ts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .ts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ts-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Categoria card ──────────────────────────────────────── */
  .ts-category {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .ts-category:hover {
    border-color: var(--line-accent);
    box-shadow: var(--shadow-glow);
  }

  .ts-category__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--line);
  }

  .ts-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ── Tech item ───────────────────────────────────────────── */
  .ts-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .ts-item__logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    object-fit: contain;
  }

  .ts-item__name {
    flex: 1;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';

  const baseUrl: string = (document.body as HTMLElement).dataset.baseurl ?? '';

  interface Technology {
    name: string;
    level: 'expert' | 'advanced' | 'intermediate';
    logo: string;
  }

  interface Category {
    name: string;
    icon: string;
    technologies: Technology[];
  }

  function levelTagClass(level: string): string {
    if (level === 'expert') return 'tag tag--accent';
    return 'tag';
  }

  async function renderTechStack() {
    const grid = document.getElementById('tech-stack-grid') as HTMLElement;
    if (!grid) return;

    let data: { categories?: Category[] } = {};
    try {
      const res = await fetch(`${baseUrl}assets/data/tech_stack.json`);
      if (!res.ok) throw new Error('fetch failed');
      data = await res.json();
    } catch {
      return;
    }

    const categories: Category[] = data.categories ?? [];
    grid.innerHTML = '';

    categories.forEach((cat) => {
      const div = document.createElement('div');
      div.className = 'ts-category';

      const itemsHtml = (cat.technologies ?? [])
        .map((tech) => {
          const levelLabel =
            window.i18n?.t(`tech_stack.level_${tech.level}`) ?? tech.level;
          const tagClass = levelTagClass(tech.level);
          return `
            <div class="ts-item">
              <img
                class="ts-item__logo"
                src="${tech.logo}"
                alt="${tech.name}"
                loading="lazy"
                onerror="this.style.display='none'"
              >
              <span class="ts-item__name">${tech.name}</span>
              <span class="${tagClass}">${levelLabel}</span>
            </div>
          `;
        })
        .join('');

      div.innerHTML = `
        <h3 class="ts-category__name">${cat.name}</h3>
        <div class="ts-items">${itemsHtml}</div>
      `;

      grid.appendChild(div);
    });

    // Motion: revealUp nas categorias
    const cards = grid.querySelectorAll<Element>('.ts-category');
    revealUp(cards, grid, 0.08);
  }

  // ─── i18n: renderizar ao carregar e ao trocar idioma ─────────
  window.addEventListener('languageChanged', () => renderTechStack());

  if (window.i18n) {
    renderTechStack();
  } else {
    window.addEventListener('languageChanged', () => renderTechStack(), { once: true });
  }
</script>
