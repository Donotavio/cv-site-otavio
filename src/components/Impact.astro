---
/**
 * Impact.astro — Seção [ 02 ] — Direção Blueprint
 * Bento grid assimétrico de métricas (inspiração StackGrid).
 * Números GIGANTES em mono com count-up quando o valor é numérico;
 * valores textuais (ex.: "Petabytes") exibidos direto.
 * Motion: countUpAll + revealUp + hairlineDraw.
 *
 * Fundo --paper-soft. Zero hex, CSS scoped, mobile-first, UI via data-i18n-key.
 */
import { t } from '../lib/i18n';
---

<section id="impact" class="section impact" aria-labelledby="impact-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">02</span>
      <h2 id="impact-title" class="impact-display" data-i18n-key="impact.title">{t('impact.title')}</h2>
      <p class="impact-lead" data-i18n-key="impact.subtitle">{t('impact.subtitle')}</p>
    </div>

    <hr class="section-line" aria-hidden="true" />

    <!-- Bento grid de métricas -->
    <div class="impact-bento" role="list" aria-label="impact metrics">
      <div class="metric metric--lg crop" role="listitem" data-metric="1">
        <span class="crop-mark-bl" aria-hidden="true"></span>
        <span class="crop-mark-br" aria-hidden="true"></span>
        <span class="metric-value" data-metric-value>{t('impact.metric_1_value')}</span>
        <span class="metric-label" data-i18n-key="impact.metric_1_label">{t('impact.metric_1_label')}</span>
      </div>

      <div class="metric" role="listitem" data-metric="2">
        <span class="metric-value" data-metric-value>{t('impact.metric_2_value')}</span>
        <span class="metric-label" data-i18n-key="impact.metric_2_label">{t('impact.metric_2_label')}</span>
      </div>

      <div class="metric" role="listitem" data-metric="3">
        <span class="metric-value" data-metric-value>{t('impact.metric_3_value')}</span>
        <span class="metric-label" data-i18n-key="impact.metric_3_label">{t('impact.metric_3_label')}</span>
      </div>

      <div class="metric metric--wide" role="listitem" data-metric="4">
        <span class="metric-value" data-metric-value>{t('impact.metric_4_value')}</span>
        <span class="metric-label" data-i18n-key="impact.metric_4_label">{t('impact.metric_4_label')}</span>
      </div>
    </div>

    <!-- Highlight strip -->
    <div class="impact-highlight crop" role="complementary" aria-label="tech stack highlight">
      <span class="crop-mark-bl" aria-hidden="true"></span>
      <span class="crop-mark-br" aria-hidden="true"></span>
      <p class="highlight-title mono-label" data-i18n-key="impact.highlight_title">{t('impact.highlight_title')}</p>
      <p class="highlight-items" data-i18n-key="impact.highlight_items">{t('impact.highlight_items')}</p>
    </div>
  </div>
</section>

<style>
  .impact {
    background: var(--paper-soft);
  }

  .impact-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .impact-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line {
    margin-block-end: var(--space-16);
  }

  /* ── Bento grid assimétrico ──────────────────────────────── */
  .impact-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-block-end: var(--space-12);
  }

  @media (min-width: 640px) {
    .impact-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .impact-bento {
      /* 3 colunas; métrica destaque ocupa 2 col + 2 linhas */
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(180px, auto);
    }
    .metric--lg {
      grid-column: span 2;
      grid-row: span 2;
    }
    .metric--wide {
      grid-column: span 2;
    }
  }

  /* ── Metric card ─────────────────────────────────────────── */
  .metric {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-3);
    transition: border-color var(--transition-normal);
  }

  .metric:hover {
    border-color: var(--line-strong);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 500;
    color: var(--accent);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .metric--lg .metric-value {
    font-size: var(--display-2);
  }

  .metric-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
  }

  /* ── Highlight strip ─────────────────────────────────────── */
  .impact-highlight {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .highlight-title {
    margin: 0;
  }

  .highlight-items {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    line-height: var(--leading-loose);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { countUp } from '../scripts/motion/count-up';
  import { motionOk } from '../scripts/motion/constants';

  const section = document.getElementById('impact');

  /**
   * Preenche as métricas a partir do i18n. Para valores que começam com
   * número (ex.: "10+", "3 Clouds") aplica count-up no número e preserva o
   * sufixo textual. Valores puramente textuais ("Petabytes") são exibidos direto.
   */
  function renderMetrics() {
    if (!section || !window.i18n) return;

    section.querySelectorAll<HTMLElement>('.metric').forEach((metric) => {
      const idx = metric.dataset.metric;
      const valueEl = metric.querySelector<HTMLElement>('[data-metric-value]');
      if (!idx || !valueEl) return;

      const raw = window.i18n?.t(`impact.metric_${idx}_value`) ?? '';
      const match = raw.match(/^(\d+(?:\.\d+)?)(.*)$/);

      if (match) {
        const num = match[1];
        const suffix = match[2] ?? '';
        valueEl.dataset.countTo = num;
        valueEl.dataset.countSuffix = suffix;
        valueEl.dataset.countDecimals = num.includes('.')
          ? String(num.split('.')[1].length)
          : '0';
        valueEl.textContent = `0${suffix}`;
        countUp(valueEl);
      } else {
        // Valor textual: exibe direto, sem count-up
        delete valueEl.dataset.countTo;
        valueEl.textContent = raw;
      }
    });
  }

  if (section) {
    const line = section.querySelector('.section-line') as Element;
    const head = section.querySelector('.section-head') as Element;
    const cards = section.querySelectorAll('.metric');
    const highlight = section.querySelector('.impact-highlight') as Element;

    if (line) hairlineDraw(line, section);

    if (motionOk) {
      revealUp([head], section, 0);
      revealUp(cards, section, 0.08);
      if (highlight) revealUp([highlight], section, 0);
    }

    // Render inicial + re-render ao trocar idioma (valores são localizados)
    if (window.i18n) {
      renderMetrics();
    } else {
      window.addEventListener('languageChanged', () => renderMetrics(), { once: true });
    }
    window.addEventListener('languageChanged', () => renderMetrics());
  }
</script>
