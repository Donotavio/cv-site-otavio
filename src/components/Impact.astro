---
/**
 * Impact.astro — Seção [ 02 ] — Direção Blueprint
 * Redesign "leituras de instrumento": números GIGANTES em Instrument Serif
 * (escala de cartaz), cada métrica como uma spec de blueprint:
 *   [ MÉTRICA 0N ] · número serif gigante · descrição.
 * Uma métrica dominante (01 — anos de experiência) ocupa destaque e as outras
 * três formam uma spec-list à direita, separadas por hairlines que crescem.
 * Crop marks emolduram o bloco dominante.
 *
 * Motion: countUp (números numéricos, preserva sufixo textual) + revealUp + hairlineDraw.
 * Fundo --paper-soft. Zero hex, CSS scoped, mobile-first, UI via data-i18n-key.
 */
import { t } from '../lib/i18n';

// idx: índice; spec: rótulo de instrumento mono fixo (independente de idioma)
const metrics = [
  { idx: 1, spec: 'METRIC 01' },
  { idx: 2, spec: 'METRIC 02' },
  { idx: 3, spec: 'METRIC 03' },
  { idx: 4, spec: 'METRIC 04' },
];
---

<section id="impact" class="section impact" aria-labelledby="impact-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">02</span>
      <h2 id="impact-title" class="impact-display" data-i18n-key="impact.title">{t('impact.title')}</h2>
      <p class="impact-lead" data-i18n-key="impact.subtitle">{t('impact.subtitle')}</p>
    </div>

    <hr class="section-line" aria-hidden="true" />

    <div class="impact-readout" role="list" aria-label="impact metrics">
      <!-- Métrica dominante (01) — leitura principal, emoldurada -->
      <article class="readout-hero crop" role="listitem" data-metric="1">
        <span class="crop-mark-bl" aria-hidden="true"></span>
        <span class="crop-mark-br" aria-hidden="true"></span>
        <p class="readout-spec mono-label">{metrics[0].spec}</p>
        <span class="readout-number" data-metric-value>{t('impact.metric_1_value')}</span>
        <p class="readout-desc" data-i18n-key="impact.metric_1_label">{t('impact.metric_1_label')}</p>
      </article>

      <!-- Spec-list: as três métricas secundárias, separadas por hairlines -->
      <div class="readout-specs">
        {metrics.slice(1).map((m) => (
          <article class="readout-row" role="listitem" data-metric={m.idx}>
            <hr class="readout-rule" aria-hidden="true" />
            <p class="readout-spec mono-label">{m.spec}</p>
            <span class="readout-number readout-number--sm" data-metric-value>
              {t(`impact.metric_${m.idx}_value`)}
            </span>
            <p class="readout-desc" data-i18n-key={`impact.metric_${m.idx}_label`}>
              {t(`impact.metric_${m.idx}_label`)}
            </p>
          </article>
        ))}
      </div>
    </div>

    <!-- Highlight strip — stack principal -->
    <div class="impact-highlight crop" role="complementary" aria-label="tech stack highlight">
      <span class="crop-mark-bl" aria-hidden="true"></span>
      <span class="crop-mark-br" aria-hidden="true"></span>
      <p class="highlight-title mono-label" data-i18n-key="impact.highlight_title">{t('impact.highlight_title')}</p>
      <p class="highlight-items" data-i18n-key="impact.highlight_items">{t('impact.highlight_items')}</p>
    </div>
  </div>
</section>

<style>
  .impact {
    background: var(--paper-soft);
  }

  .impact-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .impact-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line {
    margin-block-end: var(--space-16);
  }

  /* ── Readout layout: hero dominante + spec-list ───────────── */
  .impact-readout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-block-end: var(--space-12);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .impact-readout {
      /* hero domina a esquerda; spec-list ocupa a coluna direita */
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-20);
    }
  }

  /* ── Métrica dominante ────────────────────────────────────── */
  .readout-hero {
    padding: var(--space-10) var(--space-8) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .readout-spec {
    margin: 0;
    color: var(--ink-faint);
  }

  .readout-number {
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--accent);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
    /* escala de cartaz para a leitura principal */
    font-size: var(--display-1);
  }

  .readout-number--sm {
    color: var(--ink);
    font-size: var(--text-3xl);
  }

  .readout-desc {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    max-width: 32ch;
  }

  /* ── Spec-list (métricas secundárias) ─────────────────────── */
  .readout-specs {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .readout-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* hairline conectora — cresce via hairlineDraw */
  .readout-rule {
    width: 100%;
    height: 1px;
    border: 0;
    background: var(--line);
    margin: 0 0 var(--space-3);
    transform-origin: left center;
  }

  /* ── Highlight strip ─────────────────────────────────────── */
  .impact-highlight {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .highlight-title {
    margin: 0;
  }

  .highlight-items {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    line-height: var(--leading-loose);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { countUp } from '../scripts/motion/count-up';
  import { motionOk } from '../scripts/motion/constants';

  const section = document.getElementById('impact');

  /**
   * Preenche os números a partir do i18n. Valores que começam com número
   * (ex.: "10+", "3 Clouds") recebem count-up no número, preservando o sufixo
   * textual. Valores puramente textuais ("Petabytes") são exibidos direto.
   */
  function renderMetrics() {
    if (!section || !window.i18n) return;

    section.querySelectorAll<HTMLElement>('[data-metric]').forEach((metric) => {
      const idx = metric.dataset.metric;
      const valueEl = metric.querySelector<HTMLElement>('[data-metric-value]');
      if (!idx || !valueEl) return;

      const raw = window.i18n?.t(`impact.metric_${idx}_value`) ?? '';
      const match = raw.match(/^(\d+(?:\.\d+)?)(.*)$/);

      if (match) {
        const num = match[1];
        const suffix = match[2] ?? '';
        valueEl.dataset.countTo = num;
        valueEl.dataset.countSuffix = suffix;
        valueEl.dataset.countDecimals = num.includes('.')
          ? String(num.split('.')[1].length)
          : '0';
        valueEl.textContent = `0${suffix}`;
        countUp(valueEl);
      } else {
        // Valor textual: exibe direto, sem count-up
        delete valueEl.dataset.countTo;
        valueEl.textContent = raw;
      }
    });
  }

  if (section) {
    const line  = section.querySelector('.section-line') as Element;
    const head  = section.querySelector('.section-head') as Element;
    const hero  = section.querySelector('.readout-hero') as Element;
    const rows  = section.querySelectorAll('.readout-row');
    const rules = section.querySelectorAll('.readout-rule');
    const highlight = section.querySelector('.impact-highlight') as Element;

    if (line) hairlineDraw(line, section);
    // Hairlines conectoras das specs crescem ao entrar
    rules.forEach((rule) => hairlineDraw(rule, rule));

    if (motionOk) {
      revealUp([head], section, 0);
      if (hero) revealUp([hero], section, 0);
      revealUp(rows, section, 0.1);
      if (highlight) revealUp([highlight], section, 0);
    }

    // Render inicial + re-render ao trocar idioma (valores são localizados)
    if (window.i18n) {
      renderMetrics();
    } else {
      window.addEventListener('languageChanged', () => renderMetrics(), { once: true });
    }
    window.addEventListener('languageChanged', () => renderMetrics());
  }
</script>
