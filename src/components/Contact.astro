---
/**
 * Contact.astro
 * Seção de contato com 2 colunas — links à esquerda, card hire à direita.
 *
 * Regras aplicadas:
 *  - design-system.md: zero hex, CSS scoped, tokens apenas, mobile-first
 *  - web-motion.md: revealUp nos dois cards, motionOk verificado, once: true
 *  - content-i18n.md: todos os textos via data-i18n-key, sem strings hardcoded
 */
---

<section id="contact" class="section">
  <div class="container">
    <div class="section-header">
      <h2 data-i18n-key="contact.title"></h2>
      <p class="section-subtitle" data-i18n-key="contact.subtitle"></p>
    </div>

    <div class="contact-layout">
      <!-- Coluna esquerda: links de contato -->
      <div class="contact-links card" id="contact-links-card">
        <a
          class="contact-link hover-glow"
          href="mailto:ribeitemp@gmail.com"
          aria-label="Email"
        >
          <span class="contact-link__icon" aria-hidden="true">
            <!-- Email icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </span>
          <div class="contact-link__body">
            <span class="contact-link__label" data-i18n-key="contact.email_label"></span>
            <span class="contact-link__value">ribeitemp@gmail.com</span>
          </div>
          <span class="contact-link__arrow" aria-hidden="true">→</span>
        </a>

        <a
          class="contact-link hover-glow"
          href="https://linkedin.com/in/donotavio/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <span class="contact-link__icon" aria-hidden="true">
            <!-- LinkedIn icon -->
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </span>
          <div class="contact-link__body">
            <span class="contact-link__label" data-i18n-key="contact.linkedin_label"></span>
            <span class="contact-link__value">linkedin.com/in/donotavio</span>
          </div>
          <span class="contact-link__arrow" aria-hidden="true">→</span>
        </a>

        <a
          class="contact-link hover-glow"
          href="https://github.com/donotavio"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <span class="contact-link__icon" aria-hidden="true">
            <!-- GitHub icon -->
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </span>
          <div class="contact-link__body">
            <span class="contact-link__label" data-i18n-key="contact.github_label"></span>
            <span class="contact-link__value">github.com/donotavio</span>
          </div>
          <span class="contact-link__arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Coluna direita: card hire -->
      <div class="hire-card card" id="contact-hire-card">
        <h3 class="hire-card__title" data-i18n-key="contact.hire_title"></h3>
        <p class="hire-card__message" data-i18n-key="contact.hire_message"></p>
        <a
          class="btn-primary hire-card__cta"
          href="mailto:ribeitemp@gmail.com?subject=Oportunidade%20de%20Contrata%C3%A7%C3%A3o"
          data-i18n-key="contact.hire_cta"
        ></a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ─────────────────────────────────────────────── */
  .section {
    padding-block: var(--space-20);
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    color: var(--text);
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--muted);
    line-height: var(--leading-normal);
  }

  /* ── Layout 2 colunas ────────────────────────────────────── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* ── Links card ──────────────────────────────────────────── */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    text-decoration: none;
    color: var(--text);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .contact-link:hover {
    border-color: var(--line-accent);
    background: var(--primary-dim);
    color: var(--text);
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 3px;
  }

  .contact-link__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-soft);
    border-radius: var(--radius-md);
    color: var(--primary);
    border: 1px solid var(--line);
  }

  .contact-link__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-link__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .contact-link__value {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact-link__arrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    flex-shrink: 0;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .contact-link:hover .contact-link__arrow {
    color: var(--primary);
    transform: translateX(4px);
  }

  /* ── Hire card ───────────────────────────────────────────── */
  .hire-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hire-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
    line-height: var(--leading-snug);
  }

  .hire-card__message {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--muted);
    line-height: var(--leading-loose);
    flex: 1;
  }

  .hire-card__cta {
    align-self: flex-start;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';

  function initContactMotion() {
    const linksCard = document.getElementById('contact-links-card');
    const hireCard = document.getElementById('contact-hire-card');
    const section = document.getElementById('contact');
    if (!linksCard || !hireCard || !section) return;

    revealUp([linksCard, hireCard], section, 0.12);
  }

  // Executar após DOM pronto — sem dependência de i18n para motion
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactMotion);
  } else {
    initContactMotion();
  }
</script>
