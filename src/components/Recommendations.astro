---
/**
 * Recommendations.astro — Seção [ 11 ] — Direção Blueprint (fundo --paper-soft)
 *
 * Renderização 100% Astro/SSR (sem innerHTML/DOM): dados de `profile.json`
 * importado em build-time; texto/data/relação de `recommendations.items.<id>`
 * no i18n (default pt-BR via t() + data-i18n-key p/ troca de idioma).
 *
 * Cada card mostra uma PRÉVIA (citação recortada em N linhas → altura
 * uniforme) e abre um <dialog> nativo com a recomendação completa ao clicar
 * (acessível: focus-trap + Esc nativos, backdrop, botão fechar). O <dialog> de
 * cada card também é SSR — o JS só alterna open/close.
 *
 * Motion: hairlineDraw (linha) + revealUp (cabeçalho + cards).
 */
import { t } from '../lib/i18n';
import profileData from '../../assets/data/profile.json';

const base = import.meta.env.BASE_URL;

interface Rec {
  id: string;
  author: string;
  role?: string;
  company?: string;
  linkedin?: string;
  photo?: string;
}

const recs: Rec[] = (profileData as { recommendations?: Rec[] }).recommendations ?? [];

const joinUrl = (b: string, p: string) =>
  !p ? '' : b.replace(/\/+$/, '') + '/' + p.replace(/^\/+/, '');

const initialsOf = (name: string) => {
  const parts = (name ?? '').trim().split(/\s+/).filter(Boolean);
  if (!parts.length) return '·';
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
};

const readLabel = t('recommendations.read');

const cards = recs.map((r, i) => ({
  ...r,
  num: String(i + 1).padStart(2, '0'),
  initials: initialsOf(r.author),
  photoSrc: r.photo ? joinUrl(base, r.photo) : '',
  textKey: `recommendations.items.${r.id}.text`,
  dateKey: `recommendations.items.${r.id}.date`,
  relKey: `recommendations.items.${r.id}.relationship`,
  text: t(`recommendations.items.${r.id}.text`),
  date: t(`recommendations.items.${r.id}.date`),
  relationship: t(`recommendations.items.${r.id}.relationship`),
}));

const LINKEDIN_PATH =
  'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z';
---

<section id="recommendations" class="section recommendations" aria-labelledby="recommendations-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">11</span>
      <h2 id="recommendations-title" class="rec-display" data-i18n-key="recommendations.title">{t('recommendations.title')}</h2>
      <p class="rec-lead" data-i18n-key="recommendations.subtitle">{t('recommendations.subtitle')}</p>
    </div>

    <hr class="section-line" aria-hidden="true" />

    {cards.length > 0 ? (
      <div class="rec-grid">
        {cards.map((r) => (
          <article class="rec-card crop">
            <span class="crop-mark-bl" aria-hidden="true"></span>
            <span class="crop-mark-br" aria-hidden="true"></span>
            <span class="rec-card__index mono-label" aria-hidden="true">{r.num}</span>

            <!-- Botão-gatilho cobre o card inteiro (único elemento interativo
                 da prévia → sem interativos aninhados). -->
            <button
              type="button"
              class="rec-card__trigger"
              aria-haspopup="dialog"
              aria-controls={`rec-modal-${r.id}`}
              aria-label={`${readLabel}: ${r.author}`}
              data-modal={`rec-modal-${r.id}`}
            ></button>

            <div class="rec-card__quote">
              <p data-i18n-key={r.textKey}>{r.text}</p>
            </div>

            <div class="rec-card__author">
              <span class="rec-card__avatar" role="img" aria-label={r.author}>
                <span class="rec-card__initials" aria-hidden="true">{r.initials}</span>
                {r.photoSrc && (
                  <img class="rec-card__photo" src={r.photoSrc} alt={r.author} loading="lazy" decoding="async" onerror="this.remove()" />
                )}
              </span>
              <div class="rec-card__author-info">
                <span class="rec-card__name">{r.author}</span>
                <p class="rec-card__role">
                  {r.role}{r.role && r.date && <span aria-hidden="true"> · </span>}<span data-i18n-key={r.dateKey}>{r.date}</span>
                </p>
              </div>
              <span class="rec-card__more mono-label" aria-hidden="true">→</span>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-state" data-i18n-key="recommendations.empty">{t('recommendations.empty')}</p>
    )}
  </div>

  <!-- Modais (um <dialog> por recomendação, SSR) -->
  {cards.map((r) => (
    <dialog class="rec-modal" id={`rec-modal-${r.id}`} aria-labelledby={`rec-modal-name-${r.id}`}>
      <div class="rec-modal__inner">
        <button type="button" class="rec-modal__close" data-close aria-label={t('recommendations.close')} data-i18n-aria="recommendations.close">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        </button>

        <div class="rec-modal__quote">
          <p data-i18n-key={r.textKey}>{r.text}</p>
        </div>

        <div class="rec-modal__author">
          <span class="rec-modal__avatar" role="img" aria-label={r.author}>
            <span class="rec-card__initials" aria-hidden="true">{r.initials}</span>
            {r.photoSrc && (
              <img class="rec-card__photo" src={r.photoSrc} alt={r.author} loading="lazy" decoding="async" onerror="this.remove()" />
            )}
          </span>
          <div class="rec-modal__author-info">
            <div class="rec-modal__author-header">
              <span class="rec-modal__name" id={`rec-modal-name-${r.id}`}>{r.author}</span>
              {r.linkedin && (
                <a class="rec-card__linkedin" href={r.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`LinkedIn de ${r.author}`}>
                  <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d={LINKEDIN_PATH} /></svg>
                </a>
              )}
            </div>
            <p class="rec-modal__role">
              {r.role}{r.role && r.date && <span aria-hidden="true"> · </span>}<span data-i18n-key={r.dateKey}>{r.date}</span>
            </p>
            {r.relationship && (
              <p class="rec-modal__rel" data-i18n-key={r.relKey}>{r.relationship}</p>
            )}
          </div>
        </div>
      </div>
    </dialog>
  ))}
</section>

<style>
  .recommendations { background: var(--paper-soft); }

  .rec-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .rec-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line { margin-block-end: var(--space-16); }

  .rec-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .rec-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .rec-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card (prévia) ────────────────────────────────────────── */
  .rec-card {
    position: relative;
    min-width: 0; /* permite ao track 1fr encolher (corrige estouro à direita) */
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .rec-card:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .rec-card:focus-within { border-color: var(--line-accent); }

  .rec-card__index {
    position: absolute;
    top: var(--space-4);
    right: var(--space-5);
    color: var(--ink-faint);
    font-size: var(--text-xs);
  }

  /* gatilho invisível cobrindo o card */
  .rec-card__trigger {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
    cursor: pointer;
    border-radius: var(--radius-md);
  }
  .rec-card__trigger:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  /* ── Citação (prévia recortada) ──────────────────────────── */
  .rec-card__quote {
    flex: 1;
    position: relative;
    padding-top: var(--space-8);
    min-width: 0;
  }

  .rec-card__quote::before {
    content: '\201C';
    position: absolute;
    top: -0.15em;
    left: -0.02em;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--accent);
    line-height: 1;
  }

  .rec-card__quote p {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    margin: 0;
    /* prévia: colapsa parágrafos e recorta em 6 linhas (altura uniforme) */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    line-clamp: 6;
    overflow: hidden;
  }

  /* ── Autor ───────────────────────────────────────────────── */
  .rec-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--line);
    min-width: 0;
  }

  .rec-card__avatar {
    position: relative;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--accent-dim);
    border: 1px solid var(--line);
  }

  .rec-card__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    object-fit: cover;
    z-index: 1;
    filter: grayscale(0.99);
    transition: filter var(--transition-slow);
  }

  .rec-card:hover .rec-card__photo,
  .rec-card:focus-within .rec-card__photo { filter: grayscale(0); }

  .rec-card__initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    user-select: none;
    pointer-events: none;
  }

  .rec-card__author-info { flex: 1; min-width: 0; }

  .rec-card__name {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rec-card__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: var(--space-1) 0 0;
  }

  .rec-card__more {
    flex-shrink: 0;
    color: var(--ink-faint);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }
  .rec-card:hover .rec-card__more {
    color: var(--accent);
    transform: translateX(2px);
  }

  .rec-card__linkedin {
    display: inline-flex;
    align-items: center;
    color: var(--ink-faint);
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }
  .rec-card__linkedin:hover { color: var(--accent); }
  .rec-card__linkedin:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  /* ── Modal (<dialog>) ─────────────────────────────────────── */
  .rec-modal {
    /* Centraliza: o reset global zera o `margin:auto` que o navegador usa p/
       centrar um <dialog> modal → reforçamos posição/inset/margin aqui. */
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(92vw, 40rem);
    max-height: min(86vh, 44rem);
    padding: 0;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    background: var(--paper-card);
    color: var(--ink);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .rec-modal::backdrop {
    background: rgba(10, 10, 10, 0.55);
    backdrop-filter: blur(2px);
  }

  .rec-modal__inner {
    position: relative;
    padding: var(--space-10);
    max-height: min(86vh, 44rem);
    overflow-y: auto;
  }

  .rec-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    background: var(--paper);
    color: var(--ink-soft);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }
  .rec-modal__close:hover { border-color: var(--line-strong); color: var(--ink); }
  .rec-modal__close:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  .rec-modal__quote {
    position: relative;
    padding-top: var(--space-10);
    padding-right: var(--space-8);
  }
  .rec-modal__quote::before {
    content: '\201C';
    position: absolute;
    top: 0;
    left: -0.02em;
    font-family: var(--font-display);
    font-size: var(--display-2);
    color: var(--accent);
    line-height: 0.8;
  }
  .rec-modal__quote p {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--ink);
    line-height: var(--leading-loose);
    margin: 0;
    white-space: pre-line; /* preserva os parágrafos do depoimento */
  }

  .rec-modal__author {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
  }
  .rec-modal__avatar {
    position: relative;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--accent-dim);
    border: 1px solid var(--line);
  }
  .rec-modal__author-info { min-width: 0; }
  .rec-modal__author-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .rec-modal__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    letter-spacing: var(--tracking-tight);
  }
  .rec-modal__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wide);
    margin: var(--space-1) 0 0;
  }
  .rec-modal__rel {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: var(--space-2) 0 0;
  }

  /* entrada sutil do modal (composited) */
  .rec-modal[open] { animation: rec-modal-in 0.28s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes rec-modal-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rec-modal[open] { animation: none; }
    .rec-card { transition: none; }
  }

  /* ── Empty state ─────────────────────────────────────────── */
  .empty-state {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-faint);
    text-align: center;
    padding: var(--space-12) 0;
  }
</style>

<script>
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk, STAGGER } from '../scripts/motion/constants';

  document.addEventListener('astro:page-load', () => {
    const section = document.getElementById('recommendations');
    if (!section) return;

    const line = section.querySelector('.section-line') as Element | null;
    const head = section.querySelector('.section-head') as Element | null;
    const grid = section.querySelector('.rec-grid') as Element | null;

    if (line) hairlineDraw(line, section);
    if (motionOk && head) revealUp([head], section, 0);
    if (motionOk && grid) {
      const cards = grid.querySelectorAll('.rec-card');
      if (cards.length) revealUp(cards, grid, STAGGER.tight);
    }

    // ── Modais: abrir/fechar (<dialog> nativo: Esc + focus-trap grátis) ──
    section.querySelectorAll<HTMLButtonElement>('.rec-card__trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.dataset.modal;
        const dlg = id ? (document.getElementById(id) as HTMLDialogElement | null) : null;
        dlg?.showModal();
      });
    });

    section.querySelectorAll<HTMLDialogElement>('.rec-modal').forEach((dlg) => {
      // botão fechar
      dlg.querySelector<HTMLButtonElement>('[data-close]')?.addEventListener('click', () => dlg.close());
      // clique no backdrop (fora do conteúdo) fecha
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) dlg.close();
      });
    });
  });
</script>
