---
/**
 * Recommendations.astro — Seção [ 07 ] — Direção Blueprint (fundo --paper-soft)
 * Cards: foto, author, role, company, texto via i18n.
 * Foto path = baseUrl + rec.photo. Dados: fetch profile.json → recommendations[].
 * Motion: hairlineDraw + revealUp (cards).
 */
import { t } from '../lib/i18n';
---

<section id="recommendations" class="section recommendations" aria-labelledby="recommendations-title">
  <div class="container">
    <div class="section-head">
      <span class="mono-label">09</span>
      <h2 id="recommendations-title" class="rec-display" data-i18n-key="recommendations.title">{t('recommendations.title')}</h2>
      <p class="rec-lead" data-i18n-key="recommendations.subtitle">{t('recommendations.subtitle')}</p>
    </div>

    <hr class="section-line" aria-hidden="true" />

    <div id="recommendations-grid" class="rec-grid"></div>

    <p
      id="recommendations-empty"
      class="empty-state"
      data-i18n-key="recommendations.empty"
      hidden
    ></p>
  </div>
</section>

<style>
  .recommendations {
    background: var(--paper-soft);
  }

  .rec-display {
    font-family: var(--font-display);
    font-size: var(--display-2);
    font-weight: 400;
    color: var(--ink);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .rec-lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 56ch;
  }

  .section-line {
    margin-block-end: var(--space-16);
  }

  .rec-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .rec-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .rec-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card ─────────────────────────────────────────────────── */
  .rec-card {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: border-color var(--transition-normal);
  }

  .rec-card:hover { border-color: var(--line-strong); }

  .rec-card__quote {
    flex: 1;
    position: relative;
    padding-top: var(--space-8);
    --quote-scale: 1;
  }

  .rec-card__quote::before {
    content: '\201C';
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--accent);
    line-height: 1;
    transform: scale(var(--quote-scale));
    transform-origin: top left;
  }

  .rec-card__quote p {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: var(--leading-loose);
    margin: 0;
  }

  /* ── Author ──────────────────────────────────────────────── */
  .rec-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--line);
  }

  .rec-card__avatar {
    position: relative;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    overflow: hidden;
    /* placeholder blueprint visível ANTES da foto carregar */
    background: var(--accent-dim);
    border: 1px solid var(--line);
    /* máscara cinematográfica de entrada da foto */
    clip-path: inset(0 round var(--radius-full));
  }

  .rec-card__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 1px solid var(--line-strong);
    /* sobre o placeholder de iniciais */
    z-index: 1;
    transition: filter var(--transition-slow);
  }

  /* P&B → cor no hover. :global porque as fotos são injetadas via JS
     (innerHTML) e não recebem o atributo de scoping do Astro.
     grayscale(.99): o minificador transforma 1/100% em "" (inválido). */
  :global(.rec-card__photo) {
    filter: grayscale(0.99);
  }
  :global(.rec-card:hover .rec-card__photo),
  :global(.rec-card:focus-within .rec-card__photo) {
    filter: grayscale(0);
  }

  /* fallback iniciais — círculo blueprint, mono sobre accent-dim */
  .rec-card__initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    user-select: none;
    pointer-events: none;
  }

  .rec-card__author-info { flex: 1; min-width: 0; }

  .rec-card__author-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .rec-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rec-card__linkedin {
    display: inline-flex;
    align-items: center;
    color: var(--ink-faint);
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }

  .rec-card__linkedin:hover { color: var(--accent); }

  .rec-card__linkedin:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  .rec-card__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
  }

  /* ── Empty state ─────────────────────────────────────────── */
  .empty-state {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-faint);
    text-align: center;
    padding: var(--space-12) 0;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { revealUp } from '../scripts/motion/reveal-up';
  import { hairlineDraw } from '../scripts/motion/hairline-draw';
  import { motionOk, DURATIONS, EASINGS, STAGGER } from '../scripts/motion/constants';

  gsap.registerPlugin(ScrollTrigger);

  const baseUrl: string = (document.body as HTMLElement).dataset.baseurl ?? '';
  let entrancePlayed = false;

  interface Recommendation {
    id: string;
    author: string;
    role: string;
    company: string;
    linkedin: string;
    photo: string;
  }

  /**
   * Normaliza join de baseUrl (trailing slash) + path (leading slash)
   * evitando barra dupla (//) que quebra no serve estático do GitHub Pages.
   */
  function joinUrl(base: string, path: string): string {
    if (!path) return '';
    return base.replace(/\/+$/, '') + '/' + path.replace(/^\/+/, '');
  }

  /** Iniciais do autor para o placeholder blueprint (máx. 2). */
  function initialsOf(name: string): string {
    const parts = (name ?? '').trim().split(/\s+/).filter(Boolean);
    if (!parts.length) return '·';
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }

  const LINKEDIN_SVG = `
    <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
    </svg>
  `;

  async function renderRecommendations() {
    const grid = document.getElementById('recommendations-grid') as HTMLElement;
    const emptyEl = document.getElementById('recommendations-empty') as HTMLElement;
    if (!grid) return;

    let data: { recommendations?: Recommendation[] } = {};
    try {
      const res = await fetch(`${baseUrl}assets/data/profile.json`);
      if (!res.ok) throw new Error('fetch failed');
      data = await res.json();
    } catch {
      emptyEl.hidden = false;
      return;
    }

    const recs: Recommendation[] = data.recommendations ?? [];
    grid.innerHTML = '';

    if (!recs.length) {
      emptyEl.hidden = false;
      return;
    }
    emptyEl.hidden = true;

    recs.forEach((rec) => {
      const text = window.i18n?.t(`recommendations.items.${rec.id}.text`) ?? '';
      const date = window.i18n?.t(`recommendations.items.${rec.id}.date`) ?? '';

      const photoSrc = joinUrl(baseUrl, rec.photo);
      const initials = initialsOf(rec.author);
      // placeholder de iniciais sempre presente sob a foto;
      // se a foto falhar (404/erro), onerror remove a <img> e expõe o placeholder.
      const photoImg = photoSrc
        ? `<img class="rec-card__photo" src="${photoSrc}" alt="${rec.author}" loading="lazy" onerror="this.remove()">`
        : '';
      const photoHtml = `
        <span class="rec-card__avatar" role="img" aria-label="${rec.author}">
          <span class="rec-card__initials" aria-hidden="true">${initials}</span>
          ${photoImg}
        </span>`;

      const linkedinHtml = rec.linkedin
        ? `<a
             class="rec-card__linkedin"
             href="${rec.linkedin}"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="LinkedIn de ${rec.author}"
           >${LINKEDIN_SVG}</a>`
        : '';

      const roleDate = [rec.role, date].filter(Boolean).join(' · ');

      const article = document.createElement('article');
      article.className = 'rec-card';
      article.innerHTML = `
        <div class="rec-card__quote">
          <p>${text}</p>
        </div>
        <div class="rec-card__author">
          ${photoHtml}
          <div class="rec-card__author-info">
            <div class="rec-card__author-header">
              <span class="rec-card__name">${rec.author ?? ''}</span>
              ${linkedinHtml}
            </div>
            <p class="rec-card__role">${roleDate}</p>
          </div>
        </div>
      `;

      grid.appendChild(article);
    });

    // Entrada só na 1ª render. Em re-render (languageChanged) o conteúdo
    // aparece direto — evita cards/fotos presos no estado `from` (invisíveis)
    // quando a seção já foi vista e o ScrollTrigger once:true não re-dispara.
    if (!entrancePlayed) {
      entrancePlayed = true;
      const cards = grid.querySelectorAll<Element>('.rec-card');
      revealUp(cards, grid, STAGGER.tight);
      revealPortraits(grid);
    }
  }

  /**
   * Entrada cinematográfica dos retratos: a máscara circular (clip-path)
   * abre de baixo→cima enquanto a foto faz scale 1.08→1. Aspa serif cresce.
   * Só transform/opacity/clip-path. once:true. prefers-reduced-motion = direto.
   */
  function revealPortraits(grid: HTMLElement) {
    if (!motionOk) return;

    const trigger = { trigger: grid, start: 'top 88%', once: true } as const;

    const avatars = grid.querySelectorAll<Element>('.rec-card__avatar');
    gsap.from(avatars, {
      clipPath: 'inset(100% 0 0 0 round 50%)',
      duration: DURATIONS.slow,
      ease: EASINGS.out,
      stagger: STAGGER.tight,
      scrollTrigger: { ...trigger },
    });

    const photos = grid.querySelectorAll<Element>('.rec-card__photo');
    gsap.from(photos, {
      scale: 1.08,
      duration: DURATIONS.entrance,
      ease: EASINGS.out,
      stagger: STAGGER.tight,
      transformOrigin: 'center center',
      scrollTrigger: { ...trigger },
    });

    const quotes = grid.querySelectorAll<Element>('.rec-card__quote');
    gsap.from(quotes, {
      '--quote-scale': 0,
      opacity: 0,
      duration: DURATIONS.slow,
      ease: EASINGS.out,
      stagger: STAGGER.tight,
      scrollTrigger: { ...trigger },
    });
  }

  // ─── Section line hairline + head reveal ─────────────────────
  const section = document.getElementById('recommendations');
  if (section) {
    const line = section.querySelector('.section-line') as Element;
    const head = section.querySelector('.section-head') as Element;
    if (line) hairlineDraw(line, section);
    if (motionOk && head) revealUp([head], section, 0);
  }

  // ─── i18n ────────────────────────────────────────────────────
  window.addEventListener('languageChanged', () => renderRecommendations());

  if (window.i18n) {
    renderRecommendations();
  } else {
    window.addEventListener('languageChanged', () => renderRecommendations(), { once: true });
  }
</script>
