---
/**
 * Header.astro — frontend-builder + motion-engineer
 * Direção: Blueprint (DESIGN.md)
 *
 * Skills consultadas:
 *   src/styles/tokens.css            — tokens Blueprint, zero hex
 *   .opencode/skills/web-motion.md   — sem GSAP no header (só CSS transitions)
 *   .opencode/skills/content-i18n.md — i18n via componentes filhos
 *
 * Header sticky sobre papel claro (sólido, não transparente):
 *   - Logo: marca mono [ OR ] + nome "Otávio Ribeiro" em sans 600
 *   - Navigation + LanguageSwitcher
 *   - Borda inferior --line + leve sombra quando .scrolled (IntersectionObserver)
 */

import Navigation from './Navigation.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t } from '../lib/i18n';

// Fora da home (ex: /pix-observatory/) "#hero" seria um link morto —
// mesma lógica de resolução usada em Navigation.astro.
const base = import.meta.env.BASE_URL;
const normalize = (p: string) => (p.endsWith('/') ? p : `${p}/`);
const isHome = normalize(Astro.url.pathname) === normalize(base);
const logoHref = isHome ? '#hero' : `${base}#hero`;
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <!-- Logo: marca mono + nome -->
    <a
      href={logoHref}
      class="logo"
      aria-label={t('a11y.logo_home_label')}
      data-i18n-aria="a11y.logo_home_label"
    >
      <span class="logo-mark mono-label" aria-hidden="true">OR</span>
      <span class="logo-text">Otávio Ribeiro</span>
    </a>

    <!-- Navegação principal -->
    <Navigation />

    <!-- Seletor de idioma -->
    <div class="header-lang">
      <LanguageSwitcher />
    </div>
  </div>
</header>

<!-- Scroll observer: adiciona .scrolled ao header sem GSAP -->
<script>
  // astro:page-load (não top-level): dispara no 1º load E após cada navegação
  // SPA do <ClientRouter />. O #site-header e o sentinel são recriados no swap,
  // então recriamos o observer a cada navegação (desconectando o anterior e
  // removendo sentinels órfãos para não acumular).
  let headerObserver: IntersectionObserver | null = null;
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('site-header');
    if (!header) return;

    headerObserver?.disconnect();
    document.querySelectorAll('[data-header-sentinel]').forEach((el) => el.remove());

    headerObserver = new IntersectionObserver(
      ([entry]) => {
        // Quando o sentinel (topo da página) sai do viewport → scrollado
        header.classList.toggle('scrolled', !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: '0px' }
    );

    // Sentinel: elemento invisível no topo absoluto da página
    const sentinel = document.createElement('div');
    sentinel.setAttribute('aria-hidden', 'true');
    sentinel.setAttribute('data-header-sentinel', '');
    sentinel.style.cssText =
      'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
    document.body.prepend(sentinel);
    headerObserver.observe(sentinel);
  });
</script>

<style>
  /* ── Header shell — papel sólido (blueprint não usa dark/transparente) ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    width: 100%;
    background: var(--paper);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--transition-normal),
      box-shadow var(--transition-normal);
  }

  .site-header.scrolled {
    border-bottom-color: var(--line);
    box-shadow: var(--shadow-sm);
  }

  /* ── Inner layout ───────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    height: var(--space-16);
    /* Barra mais larga que o conteúdo (1280) para os 11 links do nav caberem
       inline em telas grandes sem cortar "CONTATO". O corpo segue centrado em
       --container-xl; só o header respira até --container-max. */
    max-width: var(--container-max);
  }

  /* ── Logo ───────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Marca [ OR ] — usa .mono-label (colchetes via ::before/::after) */
  .logo-mark {
    font-weight: 500;
    color: var(--ink);
    transition: color var(--transition-fast);
  }

  .logo:hover .logo-mark {
    color: var(--accent);
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-tight);

    /* Ocultar em telas muito pequenas para não comprimir o layout */
    display: none;
  }

  .logo:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  /* ── Language switcher wrapper ──────────────────────── */
  .header-lang {
    flex-shrink: 0;
  }

  /* ── Tablet: mostrar nome ───────────────────────────── */
  @media (min-width: 640px) {
    .logo-text {
      display: block;
    }
  }

  /* ── Desktop: mais espaço interno ──────────────────── */
  @media (min-width: 1024px) {
    .header-inner {
      gap: var(--space-8);
    }
  }
</style>
