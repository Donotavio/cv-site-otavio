---
/**
 * BaseLayout.astro — frontend-builder
 * Segue: design-system.md, web-motion.md, content-i18n.md
 *
 * Responsabilidades:
 * - <head> com fonts, meta tags, CSP
 * - data-baseurl no <body> para i18n.js (content-i18n.md)
 * - global.css (tokens → reset → layout → componentes)
 * - i18n.js runtime (portado sem alteração)
 * - motion-init.ts: Lenis + GSAP — uma única vez (web-motion.md)
 * - <ClientRouter />: View Transitions API habilitada site-wide.
 *   O motion-engineer já wireou cleanup em `astro:before-swap`
 *   (src/scripts/motion/cleanup.ts), então o teardown do Lenis/GSAP
 *   roda automaticamente entre navegações.
 */

import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Otávio Ribeiro — Data Engineering Manager',
  description = 'Portfolio profissional de Engenharia de Dados e Liderança',
} = Astro.props;

const base = import.meta.env.BASE_URL;

/**
 * JSON-LD: Person schema (SEO + rich results).
 * Identidade pública + sameAs (LinkedIn/GitHub). Dados estáticos
 * (não variam por idioma) — crawled por todos os search engines.
 */
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  'name': 'Otávio Henrique da Silva Ribeiro',
  'givenName': 'Otávio',
  'familyName': 'Ribeiro',
  'jobTitle': 'Data Engineering Manager',
  'description': description,
  'url': 'https://donotavio.github.io/cv-site-otavio/',
  'email': 'mailto:ribeitemp@gmail.com',
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': 'Curitiba',
    'addressRegion': 'PR',
    'addressCountry': 'BR',
  },
  'knowsAbout': [
    'Data Engineering',
    'Databricks',
    'Delta Lake',
    'Unity Catalog',
    'Apache Spark',
    'Machine Learning Platforms',
    'Cloud Architecture',
    'Data Governance',
  ],
  'sameAs': [
    'https://linkedin.com/in/donotavio/',
    'https://github.com/donotavio',
  ],
};
---

<!doctype html>
<html lang="pt-BR" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FDFDFD" />

    <!-- Segurança (GitHub Pages não permite headers HTTP → via meta) -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://abacus.jasoncameron.dev; base-uri 'self'; form-action 'self'; object-src 'none'" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- SEO — conteúdo atualizado em runtime por i18n.js -->
    <title id="page-title">{title}</title>
    <meta id="page-description" name="description" content={description} />
    <meta name="author" content="Otávio Ribeiro" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content="https://donotavio.github.io/cv-site-otavio/" />
    <meta property="og:site_name" content="Otávio Ribeiro — Portfolio" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href="https://donotavio.github.io/cv-site-otavio/" />

    <!-- Structured data: Person schema (JSON-LD) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!--
      View Transitions (Astro 7 ClientRouter).
      Habilita navegação SPA suave entre páginas (/, /brasil-cockpit,
      /pix-observatory, /data-stack-radar-br). O fallback `animate` mantém
      compatibilidade com browsers sem a View Transitions API nativa.
      O motion-engineer registrou listeners em `astro:before-swap` para
      teardown do Lenis/GSAP — ver src/scripts/motion/cleanup.ts.
    -->
    <ClientRouter fallback="animate" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}assets/img/favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}assets/img/favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}assets/img/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />

    <!-- Fonts self-hosted (Blueprint) — preload das críticas, zero render-block, zero request externo -->
    <link rel="preload" href={`${base}assets/fonts/instrumentserif-400.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}assets/fonts/inter-var.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}assets/fonts/ibmplexmono-400.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Global styles: tokens → reset → layout → componentes (importado no frontmatter) -->
  </head>

  <body data-baseurl={base}>
    <a href="#main-content" class="skip-link" data-i18n-key="a11y.skip_to_content">Ir para o conteúdo principal</a>
    <slot />

    <!--
      i18n runtime — portado sem alteração (content-i18n.md).
      Lê data-baseurl do body para prefixar fetch de traduções.
    -->
    <script src={`${base}assets/js/i18n.js`} is:inline defer></script>

    <!--
      Motion init — Lenis + GSAP ScrollTrigger (web-motion.md padrão 4) +
      page loader (terminal "código rodando") como TRANSIÇÃO DE PÁGINA.

      astro:page-load dispara no 1º carregamento E após cada navegação SPA
      (ClientRouter). O listener é registrado uma única vez (o `document`
      persiste entre navegações; guard __pageBootWired evita duplicar se o
      script for reavaliado numa view transition) e a cada page-load:
        1. initMotion() — idempotente; recria o Lenis após o teardown que o
           astro:before-swap dispara (destroyAllMotion).
        2. firePageLoader() — o terminal roda como intro da página.
      O loader NÃO dispara mais no scroll de seções (ficava cansativo).
    -->
    <script>
      import { initMotion } from '../scripts/motion-init';
      import { firePageLoader } from '../scripts/motion/query-loader';

      const w = window as Window & { __pageBootWired?: boolean };
      if (!w.__pageBootWired) {
        w.__pageBootWired = true;
        document.addEventListener('astro:page-load', () => {
          initMotion();
          firePageLoader();
        });
      }
    </script>
  </body>
</html>
